---
import Layout from "../layouts/Layout.astro";
import { t } from "../lib/i18n";

let error = "";
const lang = Astro.cookies.get("lang")?.value ?? "en";

if (Astro.cookies.has("access_token")) {
    return Astro.redirect("/dashboard");
}

const flashError = Astro.cookies.get("login_error")?.value;
if (flashError) {
    error = flashError;
    Astro.cookies.delete("login_error", { path: "/" });
}
---

<Layout title={`${t(lang, "login_submit")} - Family Task Manager`}>
    {/*
      CRITICAL ORDERING — Google Identity Services (GIS) scans the DOM for
      g_id_onload elements and validates their data-callback attribute at
      init time. If the named function isn't already a global when GIS
      runs, it logs "callback is not a function. Configuration ignored"
      and silently disables the button.

      In Astro dev mode the bundled <script> below was inlined early, so
      window.handleGoogleLogin was defined before the GIS async script
      finished parsing the DOM. In Astro prod SSR the bundled module is
      a separate deferred file that loads AFTER GIS — race lost, button
      broken.

      Fix: define window.handleGoogleLogin in a `is:inline` script that
      runs synchronously, BEFORE the GIS script tag. Astro `is:inline`
      emits the script verbatim into the HTML without bundling, so it
      executes in document order. The full submit handler (with all the
      check-methods / login_hint logic) still lives in the bundled
      module below; this inline stub only has to exist on window so GIS
      accepts the config.
    */}
    <script is:inline define:vars={{ API_URL: "/api/oauth/google" }}>
        window.handleGoogleLogin = async function (response) {
            try {
                const result = await fetch(API_URL, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        token: response.credential,
                        join_code: null,
                    }),
                });
                const data = await result.json();
                if (result.ok) {
                    window.location.href = "/dashboard";
                } else {
                    const msg = data.message || data.detail || "Login failed";
                    // Toast library is loaded by the module script below;
                    // if it hasn't arrived yet, fall back to alert.
                    if (window.__showToast) {
                        window.__showToast(msg, "error");
                    } else {
                        alert(msg);
                    }
                }
            } catch (err) {
                console.error("Google login error:", err);
                if (window.__showToast) {
                    window.__showToast("An error occurred during login", "error");
                } else {
                    alert("An error occurred during login");
                }
            }
        };
    </script>
    <script src="https://accounts.google.com/gsi/client" async></script>

    <main class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 flex items-center justify-center p-4">
        <div class="w-full max-w-5xl">
            <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
                    <!-- Left column: Hero / Value Proposition -->
                    <div class="hidden md:flex md:flex-col md:justify-center md:items-start p-12 lg:p-16 bg-gradient-to-br from-indigo-600 via-indigo-500 to-purple-600 text-white">
                        <div class="mb-8">
                            <h2 class="text-5xl font-black leading-tight mb-4">
                                {lang === "es" ? "Gestiona tu familia" : "Manage your family"}
                            </h2>
                            <p class="text-xl text-indigo-100 leading-relaxed">
                                {lang === "es" 
                                    ? "Tareas, recompensas y control parental en un solo lugar" 
                                    : "Tasks, rewards, and parental control in one place"}
                            </p>
                        </div>

                        <div class="space-y-6 mt-12">
                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0">
                                    <svg class="h-6 w-6 text-indigo-200" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="font-semibold">{lang === "es" ? "Asignación de tareas" : "Task assignment"}</p>
                                    <p class="text-sm text-indigo-100">{lang === "es" ? "Crea y asigna tareas con puntos" : "Create and assign tasks with points"}</p>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0">
                                    <svg class="h-6 w-6 text-indigo-200" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="font-semibold">{lang === "es" ? "Sistema de recompensas" : "Reward system"}</p>
                                    <p class="text-sm text-indigo-100">{lang === "es" ? "Motiva con recompensas atractivas" : "Motivate with attractive rewards"}</p>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0">
                                    <svg class="h-6 w-6 text-indigo-200" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="font-semibold">{lang === "es" ? "Finanzas familiares" : "Family finances"}</p>
                                    <p class="text-sm text-indigo-100">{lang === "es" ? "Presupuesto y control de gastos" : "Budget and expense tracking"}</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right column: Login form -->
                    <div class="p-8 lg:p-12 flex flex-col justify-center">
                        <div class="mb-8">
                            <h1 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-2">
                                {t(lang, "login_welcome")}
                            </h1>
                            <p class="text-slate-500 text-lg">
                                {t(lang, "login_subtitle")}
                            </p>
                        </div>

                        {
                            error && (
                                <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-700 text-sm font-medium">
                                    {error}
                                </div>
                            )
                        }

                        <!-- Google Sign-In Button -->
                        <div class="mb-6">
                            <div
                                id="g_id_onload"
                                data-client_id="436801934159-r2klrd5n7b4da2q806c58utd24h9f71v.apps.googleusercontent.com"
                                data-callback="handleGoogleLogin"
                                data-auto_prompt="false"
                                data-use_fedcm_for_prompt="true">
                            </div>
                            <!--
                              data-width must be a pixel number, not "100%".
                              GIS logs "Expected a number for 'width'. Configuration
                              ignored" otherwise. 360px fits the right-column
                              width comfortably; the button is centered by its
                              flex parent when the column is wider.
                            -->
                            <div
                                class="g_id_signin"
                                data-type="standard"
                                data-size="large"
                                data-theme="outline"
                                data-text="signin_with"
                                data-shape="rectangular"
                                data-logo_alignment="left"
                                data-width="360">
                            </div>
                        </div>

                        <!-- Divider -->
                        <div class="relative my-6">
                            <div class="absolute inset-0 flex items-center">
                                <div class="w-full border-t border-slate-300"></div>
                            </div>
                            <div class="relative flex justify-center text-sm">
                                <span class="px-3 bg-white text-slate-500 font-medium">
                                    {lang === "es" ? "O continúa con correo" : "Or continue with email"}
                                </span>
                            </div>
                        </div>

                        <!-- Email/Password Form -->
                        <form id="login-form" class="space-y-5">
                            <div>
                                <label for="email" class="block text-sm font-semibold text-slate-700 mb-2">
                                    {t(lang, "login_email")}
                                </label>
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    placeholder="parent@demo.com"
                                    class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition-all hover:border-slate-400"
                                />
                            </div>

                            <div>
                                <label for="password" class="block text-sm font-semibold text-slate-700 mb-2">
                                    {t(lang, "login_password")}
                                </label>
                                <input
                                    type="password"
                                    id="password"
                                    name="password"
                                    required
                                    placeholder="••••••••"
                                    class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition-all hover:border-slate-400"
                                />
                            </div>

                            <div class="flex items-center justify-between">
                                <a
                                    href="/forgot-password"
                                    class="text-sm font-medium text-indigo-600 hover:text-indigo-700 transition-colors"
                                >
                                    {lang === "es" ? "¿Olvidaste tu contraseña?" : "Forgot password?"}
                                </a>
                            </div>

                            <button
                                type="submit"
                                id="login-submit-btn"
                                class="w-full py-3 px-4 rounded-lg text-white font-bold bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all shadow-lg hover:shadow-xl active:scale-95"
                            >
                                {t(lang, "login_submit")}
                            </button>
                        </form>

                        <!-- Register Link -->
                        <p class="mt-8 text-center text-sm text-slate-600">
                            {lang === "es" ? "¿No tienes cuenta?" : "Don't have an account?"}
                            {" "}
                            <a href="/register" class="font-bold text-indigo-600 hover:text-indigo-700 transition-colors">
                                {lang === "es" ? "Crear cuenta" : "Create one"}
                            </a>
                        </p>

                        <!-- Language Toggle -->
                        <form method="POST" action="/api/lang" class="mt-6 flex justify-center">
                            <input type="hidden" name="lang" value={lang === "es" ? "en" : "es"} />
                            <button
                                type="submit"
                                class="text-xs text-slate-400 hover:text-indigo-600 font-medium flex items-center gap-1.5 transition-colors"
                            >
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
                                </svg>
                                {lang === "es" ? "English" : "Español"}
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Demo credentials hint (mobile) -->
            <div class="mt-6 text-center text-xs text-slate-500 md:hidden">
                <p>{lang === "es" ? "Demo: parent@demo.com / password123" : "Demo: parent@demo.com / password123"}</p>
            </div>
        </div>
    </main>

    <script>
        import { showToast } from '../lib/toast';

        const GOOGLE_CLIENT_ID =
            '436801934159-r2klrd5n7b4da2q806c58utd24h9f71v.apps.googleusercontent.com';

        // Expose showToast to the inline Google callback defined above.
        // The inline callback runs outside this module scope, so it can't
        // import directly — we stash a reference on window as a bridge.
        // Checked with `if (window.__showToast)` before calling, so if the
        // module hasn't finished loading yet (race with a click on the
        // Google button) the inline fallback is `alert`.
        (window as any).__showToast = showToast;

        /**
         * Trigger the GIS sign-in prompt with a login_hint so Google
         * pre-selects the account matching the email the user typed.
         * Returns true if the prompt was displayed, false otherwise.
         */
        async function triggerGoogleSignIn(loginHint: string): Promise<boolean> {
            // Wait up to 2s for the GIS client library to finish loading.
            for (let i = 0; i < 20; i++) {
                if ((window as any).google?.accounts?.id) break;
                await new Promise(r => setTimeout(r, 100));
            }
            const gid = (window as any).google?.accounts?.id;
            if (!gid) {
                showToast('Google Sign-In is not available', 'error');
                return false;
            }
            // Re-initialize with login_hint so the Google UI pre-selects
            // the matching account. This is a no-op if already initialized
            // with the same config, but cheap enough to always call.
            gid.initialize({
                client_id: GOOGLE_CLIENT_ID,
                callback: window.handleGoogleLogin,
                login_hint: loginHint,
                auto_select: false,
            });
            gid.prompt();
            return true;
        }

        document.addEventListener('astro:page-load', () => {
            const loginForm = document.getElementById('login-form');
            if (loginForm) {
                loginForm.addEventListener('submit', async function(e) {
                    e.preventDefault();

                    const email = (document.getElementById('email') as HTMLInputElement)?.value;
                    const password = (document.getElementById('password') as HTMLInputElement)?.value;
                    const submitBtn = document.getElementById('login-submit-btn') as HTMLButtonElement;
                    if (!submitBtn) return;
                    const originalHTML = submitBtn.innerHTML;

                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<svg class="animate-spin h-4 w-4 mx-auto" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>';

                    try {
                        // Step 1: ask the backend which auth methods exist
                        // for this email. If it's a Google-only account we
                        // redirect to Google sign-in instead of trying the
                        // password (which they don't have).
                        if (email) {
                            try {
                                const methodsRes = await fetch('/api/auth/check-methods', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ email }),
                                });
                                if (methodsRes.ok) {
                                    const methods = await methodsRes.json();
                                    if (methods.has_google && !methods.has_password) {
                                        showToast(
                                            'This account uses Google sign-in. Continuing with Google…',
                                            'info'
                                        );
                                        const prompted = await triggerGoogleSignIn(email);
                                        if (prompted) {
                                            // Leave the button spinning —
                                            // handleGoogleLogin will redirect
                                            // on success.
                                            return;
                                        }
                                    }
                                }
                            } catch {
                                // Non-fatal: if the methods check fails,
                                // fall through to the normal password flow.
                            }
                        }

                        // Step 2: normal email+password login
                        const response = await fetch('/api/auth/login', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ email, password }),
                        });

                        const data = await response.json();

                        if (data.success && data.redirect) {
                            window.location.href = data.redirect;
                        } else {
                            showToast(data.error || 'Login failed', 'error');
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = originalHTML;
                        }
                    } catch (error) {
                        console.error('Login error:', error);
                        showToast('An error occurred', 'error');
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = originalHTML;
                    }
                });
            }
        });
    </script>
</Layout>
