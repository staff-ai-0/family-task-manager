---
/**
 * Guía de usuario pública — Español. Renderiza docs/USER_GUIDE_ES.md dentro del
 * GuideShell compartido (hero + búsqueda + TOC automática + estilos). Enlazada
 * desde el welcome email y en el allowlist publicRoutes del middleware. La
 * versión en inglés está en /help.
 */
import GuideShell from "../components/GuideShell.astro";
// docs/ está montado read-only en /app/docs dentro del container del frontend.
import { Content as GuideContent } from "../../docs/USER_GUIDE_ES.md";
---

<GuideShell
    title="Guía de usuario — Family Task Manager"
    backHref="/"
    backLabel="← Volver al inicio"
    toggleHref="/help"
    toggleLabel="English"
    heroTitle="Centro de Ayuda"
    heroSub="Guías para cada parte de Family Task Manager"
    searchPlaceholder="Buscar temas…"
    searchAria="Buscar en la guía del usuario"
    contentsLabel="Contenido"
    noResultsText="Ningún tema coincide con tu búsqueda."
    tocAria="Tabla de contenidos"
>
    <GuideContent />
</GuideShell>
