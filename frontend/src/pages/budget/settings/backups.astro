---
/**
 * Budget Backups Management Page
 * 
 * Export and manage budget data backups.
 */

import Layout from "@layouts/Layout.astro";
import BudgetNav from "@components/BudgetNav.astro";
import BottomNav from "@components/BottomNav.astro";
import { t } from "@lib/i18n";
import { apiFetch } from "@lib/api";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = Astro.cookies.get("lang")?.value ?? "en";

const { data: user, ok } = await apiFetch<any>("/api/auth/me", { token });
if (!ok) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}

if (user.role !== "parent") {
    return Astro.redirect("/dashboard");
}
---

<Layout title={`${t(lang, 'fin_settings_backups')} - Budget`}>
    <div class="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto bg-slate-50 min-h-screen flex flex-col">
        <header class="bg-slate-700 text-white pt-12 pb-6 px-6 rounded-b-3xl shadow-md">
            <div class="flex items-center justify-between mb-4">
                <a href="/budget/settings" class="text-white hover:text-slate-200 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <h1 class="text-2xl font-bold">{t(lang, 'fin_settings_backups')}</h1>
                <div class="w-6"></div>
            </div>
            <p class="text-slate-100 text-sm">{t(lang, 'fin_settings_backups_body')}</p>
        </header>

        <BudgetNav active="settings" />

        <main class="px-6 py-6 flex-1 space-y-6">
            <!-- Quick Export Section -->
            <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6 space-y-4">
                <div>
                    <h2 class="text-lg font-bold text-slate-900">{lang === "es" ? "Exportar Datos" : "Export Budget Data"}</h2>
                    <p class="text-sm text-slate-600">{lang === "es" ? "Descargar una copia de tu presupuesto" : "Download a copy of your budget data"}</p>
                </div>

                <div class="grid md:grid-cols-2 gap-4">
                    <!-- CSV Export -->
                    <div class="border border-slate-200 rounded-lg p-4 space-y-3">
                        <div class="flex items-start gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 7v10m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V17a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                            </svg>
                            <div class="flex-1">
                                <p class="font-semibold text-slate-900">{lang === "es" ? "CSV" : "CSV Format"}</p>
                                <p class="text-sm text-slate-600">{lang === "es" ? "Transacciones, cuentas y categorías" : "Transactions, accounts, categories"}</p>
                            </div>
                        </div>
                        <button 
                            onclick="exportAsCSV()"
                            class="w-full px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg transition"
                        >
                            {lang === "es" ? "Descargar CSV" : "Download CSV"}
                        </button>
                    </div>

                    <!-- JSON Export -->
                    <div class="border border-slate-200 rounded-lg p-4 space-y-3">
                        <div class="flex items-start gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v10a2 2 0 002 2h5m4 0h5a2 2 0 002-2V8a2 2 0 00-2-2h-5m4 0V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v1" />
                            </svg>
                            <div class="flex-1">
                                <p class="font-semibold text-slate-900">{lang === "es" ? "JSON" : "JSON Format"}</p>
                                <p class="text-sm text-slate-600">{lang === "es" ? "Backup completo con todos los detalles" : "Complete backup with all details"}</p>
                            </div>
                        </div>
                        <button 
                            onclick="exportAsJSON()"
                            class="w-full px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition"
                        >
                            {lang === "es" ? "Descargar JSON" : "Download JSON"}
                        </button>
                    </div>
                </div>

                <!-- Manual Backup -->
                <div class="bg-slate-50 border border-slate-200 rounded-lg p-4 space-y-3">
                    <p class="text-sm font-semibold text-slate-800">{lang === "es" ? "Crear Backup Manual" : "Create Manual Backup"}</p>
                    <p class="text-sm text-slate-600">{lang === "es" ? "Respaldar toda tu información financiera" : "Back up all your financial data"}</p>
                    <button 
                        onclick="createManualBackup()"
                        class="w-full px-4 py-2 bg-slate-700 hover:bg-slate-800 text-white font-semibold rounded-lg transition"
                    >
                        {lang === "es" ? "Crear Backup Ahora" : "Create Backup Now"}
                    </button>
                </div>
            </div>

            <!-- Import Section -->
            <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6 space-y-4">
                <div>
                    <h2 class="text-lg font-bold text-slate-900">{lang === "es" ? "Restaurar desde Backup" : "Restore from Backup"}</h2>
                    <p class="text-sm text-slate-600">{lang === "es" ? "Cargar datos desde un archivo guardado" : "Load data from a saved backup file"}</p>
                </div>

                <div class="border border-dashed border-slate-300 rounded-lg p-8 text-center space-y-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
                    </svg>
                    <div>
                        <p class="text-sm font-semibold text-slate-800">{lang === "es" ? "Arrastra aquí o haz clic" : "Drag and drop or click"}</p>
                        <p class="text-xs text-slate-600">{lang === "es" ? "Soporta archivos JSON y CSV" : "Supports JSON and CSV files"}</p>
                    </div>
                    <input 
                        type="file" 
                        id="backup-file" 
                        accept=".json,.csv"
                        onchange="importBackup(event)"
                        class="hidden"
                    />
                    <button 
                        onclick="document.getElementById('backup-file').click()"
                        class="px-6 py-2 bg-slate-200 hover:bg-slate-300 text-slate-800 font-semibold rounded-lg transition"
                    >
                        {lang === "es" ? "Seleccionar Archivo" : "Select File"}
                    </button>
                </div>

                <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 space-y-2 text-sm text-amber-800">
                    <p class="font-semibold">{lang === "es" ? "Advertencia" : "Warning"}</p>
                    <p class="text-xs text-amber-900">{lang === "es" ? "Importar un backup reemplazará tus datos actuales. Se recomienda hacer backup primero." : "Importing a backup will replace your current data. Please backup first."}</p>
                </div>
            </div>

            <!-- Backup History -->
            <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6 space-y-4">
                <div>
                    <h2 class="text-lg font-bold text-slate-900">{lang === "es" ? "Historial de Backups" : "Backup History"}</h2>
                    <p class="text-sm text-slate-600">{lang === "es" ? "Tus backups anteriores" : "Your previous backups"}</p>
                </div>

                <div class="text-center py-8 text-slate-600">
                    <p>{lang === "es" ? "No hay backups previos" : "No previous backups"}</p>
                    <p class="text-sm mt-1">{lang === "es" ? "Los backups creados aparecerán aquí" : "Created backups will appear here"}</p>
                </div>
            </div>

            <!-- Best Practices -->
            <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-6 space-y-3 text-sm">
                <p class="font-semibold text-indigo-900">{lang === "es" ? "Mejores Prácticas" : "Best Practices"}</p>
                <ul class="list-disc list-inside space-y-2 text-indigo-800 text-xs">
                    <li>{lang === "es" ? "Hacer backup mensual de tus datos" : "Create monthly backups of your data"}</li>
                    <li>{lang === "es" ? "Almacenar backups en múltiples ubicaciones" : "Store backups in multiple locations"}</li>
                    <li>{lang === "es" ? "Probar restauraciones ocasionalmente" : "Test restores occasionally"}</li>
                    <li>{lang === "es" ? "Usar backups para cambios importantes" : "Use backups before major changes"}</li>
                </ul>
            </div>
        </main>

        <BottomNav active="budget" role={user.role} lang={lang} />
    </div>
</Layout>

<script>
    import { showToast } from '../../../lib/toast';

    document.addEventListener('astro:page-load', () => {
    (window as any).exportAsCSV = function() {
        showToast("CSV export feature coming soon", 'info');
    };

    (window as any).exportAsJSON = function() {
        showToast("JSON export feature coming soon", 'info');
    };

    (window as any).createManualBackup = function() {
        showToast("Manual backup feature coming soon", 'info');
    };

    (window as any).importBackup = function(event: Event) {
        const file = (event.target as HTMLInputElement).files?.[0];
        if (file) {
            showToast(`Import feature coming soon for ${file.name}`, 'info');
        }
    };
    });
</script>
