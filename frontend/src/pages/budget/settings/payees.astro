---
/**
 * Payees Management Page
 * View, edit, and merge budget payees
 */

import Layout from "@layouts/Layout.astro";
import BudgetNav from "@components/BudgetNav.astro";
import BottomNav from "@components/BottomNav.astro";
import { apiFetch } from "@lib/api";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = Astro.cookies.get("lang")?.value ?? "en";

const { data: user, ok } = await apiFetch<any>("/api/auth/me", { token });
if (!ok) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

const { data: payees = [] } = await apiFetch<any[]>("/api/budget/payees/", { token });
const isEs = lang === "es";
---

<Layout title="Beneficiarios - Presupuesto">
    <div class="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto bg-slate-50 min-h-screen flex flex-col">
        <header class="bg-slate-700 text-white pt-12 pb-6 px-6 rounded-b-3xl shadow-md">
            <div class="flex items-center justify-between mb-2">
                <a href="/budget/settings" class="text-white hover:text-slate-200 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <h1 class="text-2xl font-bold">{isEs ? "Beneficiarios" : "Payees"}</h1>
                <div class="w-6"></div>
            </div>
            <p class="text-slate-300 text-sm">{payees.length} {isEs ? "beneficiarios" : "payees"}</p>
        </header>

        <BudgetNav active="settings" />

        <main class="px-6 py-6 flex-1 space-y-4">

            <!-- Merge payees section -->
            <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-5 space-y-4">
                <h2 class="text-base font-bold text-slate-800">{isEs ? "Fusionar Beneficiarios" : "Merge Payees"}</h2>
                <p class="text-xs text-slate-500">
                    {isEs
                        ? "Combina dos beneficiarios duplicados. Las transacciones del origen se moverán al destino y el origen será eliminado."
                        : "Combine duplicate payees. Source transactions move to target, source is deleted."}
                </p>

                <div class="grid grid-cols-1 gap-3">
                    <div>
                        <label class="block text-xs font-semibold text-slate-600 mb-1">{isEs ? "Origen (será eliminado)" : "Source (will be deleted)"}</label>
                        <select id="merge-source" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-slate-400">
                            <option value="">{isEs ? "Seleccionar..." : "Select..."}</option>
                            {payees.map((p: any) => <option value={p.id}>{p.name}</option>)}
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-600 mb-1">{isEs ? "Destino (se conservará)" : "Target (will be kept)"}</label>
                        <select id="merge-target" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-slate-400">
                            <option value="">{isEs ? "Seleccionar..." : "Select..."}</option>
                            {payees.map((p: any) => <option value={p.id}>{p.name}</option>)}
                        </select>
                    </div>
                </div>

                <div id="merge-error" class="hidden text-sm text-red-700 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
                <div id="merge-result" class="hidden text-sm text-green-700 bg-green-50 border border-green-200 rounded-lg px-3 py-2"></div>

                <button id="merge-btn" class="w-full bg-slate-700 text-white font-semibold py-2.5 rounded-lg hover:bg-slate-800 transition text-sm">
                    {isEs ? "Fusionar" : "Merge"}
                </button>
            </div>

            <!-- Payees list -->
            <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
                <div class="bg-slate-100 px-4 py-3 border-b border-slate-200">
                    <h2 class="text-sm font-bold text-slate-700">{isEs ? "Lista de Beneficiarios" : "Payees List"}</h2>
                </div>
                {payees.length === 0 ? (
                    <p class="text-center text-slate-500 text-sm py-8">{isEs ? "No hay beneficiarios" : "No payees yet"}</p>
                ) : (
                    <div class="divide-y divide-slate-100">
                        {payees.map((p: any) => (
                            <div class="flex items-center justify-between px-4 py-3 hover:bg-slate-50 transition">
                                <span class="text-sm font-medium text-slate-700">{p.name}</span>
                                <button
                                    class="delete-payee-btn text-slate-300 hover:text-red-500 transition p-1"
                                    data-id={p.id}
                                    data-name={p.name}
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </div>
                        ))}
                    </div>
                )}
            </div>
        </main>

        <BottomNav active="budget" role={user.role} lang={lang} />
    </div>
</Layout>

<script>
    // Merge payees
    document.getElementById('merge-btn')?.addEventListener('click', async () => {
        const sourceId = (document.getElementById('merge-source') as HTMLSelectElement).value;
        const targetId = (document.getElementById('merge-target') as HTMLSelectElement).value;
        const errEl = document.getElementById('merge-error')!;
        const resEl = document.getElementById('merge-result')!;

        errEl.classList.add('hidden');
        resEl.classList.add('hidden');

        if (!sourceId || !targetId) {
            errEl.textContent = 'Selecciona origen y destino';
            errEl.classList.remove('hidden');
            return;
        }
        if (sourceId === targetId) {
            errEl.textContent = 'Origen y destino deben ser diferentes';
            errEl.classList.remove('hidden');
            return;
        }

        const res = await fetch('/api/budget/payees/merge', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ source_id: sourceId, target_id: targetId }),
        });

        if (res.ok) {
            const data = await res.json();
            resEl.textContent = `✓ "${data.source_name}" fusionado en "${data.target_name}". ${data.merged_count} transacciones actualizadas.`;
            resEl.classList.remove('hidden');
            setTimeout(() => location.reload(), 2000);
        } else {
            const err = await res.json().catch(() => ({}));
            errEl.textContent = err.detail || 'Error al fusionar';
            errEl.classList.remove('hidden');
        }
    });

    // Delete payee
    document.querySelectorAll('.delete-payee-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const id = btn.getAttribute('data-id')!;
            const name = btn.getAttribute('data-name')!;
            if (!confirm(`¿Eliminar beneficiario "${name}"?`)) return;

            const res = await fetch(`/api/budget/payees/${id}`, { method: 'DELETE' });
            if (res.ok || res.status === 204) {
                (btn.closest('div') as HTMLElement)?.remove();
            } else {
                const err = await res.json().catch(() => ({}));
                alert(err.detail || 'Error al eliminar');
            }
        });
    });
</script>
