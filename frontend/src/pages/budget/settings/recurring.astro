---
/**
 * Budget Recurring Transactions Management Page
 * 
 * Manage scheduled/recurring transactions that should be automatically created.
 */

import Layout from "@layouts/Layout.astro";
import BudgetNav from "@components/BudgetNav.astro";
import BottomNav from "@components/BottomNav.astro";
import { t } from "@lib/i18n";
import { apiFetch } from "@lib/api";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = Astro.cookies.get("lang")?.value ?? "en";

const { data: user, ok } = await apiFetch<any>("/api/auth/me", { token });
if (!ok) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}

if (user.role !== "parent") {
    return Astro.redirect("/dashboard");
}

// Fetch recurring transactions
const { data: recurring = [], ok: recurringOk } = await apiFetch<any[]>(
    "/api/budget/recurring-transactions",
    { token }
);

// Fetch accounts and categories for form
const { data: accounts = [], ok: accountsOk } = await apiFetch<any[]>(
    "/api/budget/accounts",
    { token }
);

const { data: categories = [], ok: categoriesOk } = await apiFetch<any[]>(
    "/api/budget/categories",
    { token }
);
---

<Layout title={`${t(lang, 'fin_settings_recurring')} - Budget`}>
    <div class="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto bg-slate-50 min-h-screen flex flex-col">
        <header class="bg-slate-700 text-white pt-12 pb-6 px-6 rounded-b-3xl shadow-md">
            <div class="flex items-center justify-between mb-4">
                <a href="/budget/settings" class="text-white hover:text-slate-200 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <h1 class="text-2xl font-bold">{t(lang, 'fin_settings_recurring')}</h1>
                <div class="w-6"></div>
            </div>
            <p class="text-slate-100 text-sm">{t(lang, 'fin_settings_recurring_body')}</p>
        </header>

        <BudgetNav active="settings" />

        <main class="px-6 py-6 flex-1 space-y-6">
            <!-- Create Recurring Transaction -->
            <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6 space-y-4">
                <div>
                    <h2 class="text-lg font-bold text-slate-900">{lang === "es" ? "Nueva Transacción Recurrente" : "Create New Recurring Transaction"}</h2>
                    <p class="text-sm text-slate-600">{lang === "es" ? "Configurar ingresos y gastos automáticos" : "Set up automatic income and expenses"}</p>
                </div>

                <form id="recurring-form" class="space-y-4">
                    <!-- Description -->
                    <div>
                        <label for="description" class="block text-sm font-semibold text-slate-800 mb-1">
                            {lang === "es" ? "Descripción" : "Description"}
                        </label>
                        <input 
                            type="text" 
                            id="description" 
                            name="description" 
                            placeholder={lang === "es" ? "ej: Salario, Alquiler..." : "e.g. Salary, Rent..."}
                            class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                            required
                        />
                    </div>

                    <!-- Amount -->
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="amount" class="block text-sm font-semibold text-slate-800 mb-1">
                                {lang === "es" ? "Monto" : "Amount"}
                            </label>
                            <div class="relative">
                                <span class="absolute left-3 top-2 text-slate-600">$</span>
                                <input 
                                    type="number" 
                                    id="amount" 
                                    name="amount"
                                    step="0.01"
                                    placeholder="0.00"
                                    class="w-full pl-8 pr-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                                    required
                                />
                            </div>
                        </div>

                        <div>
                            <label for="type" class="block text-sm font-semibold text-slate-800 mb-1">
                                {lang === "es" ? "Tipo" : "Type"}
                            </label>
                            <select 
                                id="type" 
                                name="type"
                                class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                                required
                            >
                                <option value="income">{lang === "es" ? "Ingreso" : "Income"}</option>
                                <option value="expense">{lang === "es" ? "Gasto" : "Expense"}</option>
                            </select>
                        </div>
                    </div>

                    <!-- Account -->
                    <div>
                        <label for="account_id" class="block text-sm font-semibold text-slate-800 mb-1">
                            {lang === "es" ? "Cuenta" : "Account"}
                        </label>
                        <select 
                            id="account_id" 
                            name="account_id"
                            class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                            required
                        >
                            <option value="">{lang === "es" ? "Selecciona una cuenta..." : "Select an account..."}</option>
                            {accounts.map((acc: any) => (
                                <option value={acc.id}>{acc.name}</option>
                            ))}
                        </select>
                    </div>

                    <!-- Category (Optional) -->
                    <div>
                        <label for="category_id" class="block text-sm font-semibold text-slate-800 mb-1">
                            {lang === "es" ? "Categoría (Opcional)" : "Category (Optional)"}
                        </label>
                        <select 
                            id="category_id" 
                            name="category_id"
                            class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                        >
                            <option value="">{lang === "es" ? "Sin categoría" : "No category"}</option>
                            {categories.map((cat: any) => (
                                <option value={cat.id}>{cat.name}</option>
                            ))}
                        </select>
                    </div>

                    <!-- Frequency -->
                    <div>
                        <label for="frequency" class="block text-sm font-semibold text-slate-800 mb-1">
                            {lang === "es" ? "Frecuencia" : "Frequency"}
                        </label>
                        <select 
                            id="frequency" 
                            name="frequency"
                            class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                            required
                        >
                            <option value="daily">{lang === "es" ? "Diaria" : "Daily"}</option>
                            <option value="weekly">{lang === "es" ? "Semanal" : "Weekly"}</option>
                            <option value="biweekly">{lang === "es" ? "Quincenal" : "Biweekly"}</option>
                            <option value="monthly" selected>{lang === "es" ? "Mensual" : "Monthly"}</option>
                            <option value="quarterly">{lang === "es" ? "Trimestral" : "Quarterly"}</option>
                            <option value="annual">{lang === "es" ? "Anual" : "Annual"}</option>
                        </select>
                    </div>

                    <!-- Next Due Date -->
                    <div>
                        <label for="next_due_date" class="block text-sm font-semibold text-slate-800 mb-1">
                            {lang === "es" ? "Próxima Fecha" : "Next Due Date"}
                        </label>
                        <input 
                            type="date" 
                            id="next_due_date" 
                            name="next_due_date"
                            class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                            required
                        />
                    </div>

                    <!-- Submit -->
                    <button 
                        type="submit"
                        class="w-full px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition"
                    >
                        {lang === "es" ? "Crear Transacción Recurrente" : "Create Recurring Transaction"}
                    </button>
                </form>
            </div>

            <!-- Recurring Transactions List -->
            <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6 space-y-4">
                <div>
                    <h2 class="text-lg font-bold text-slate-900">{lang === "es" ? "Transacciones Recurrentes" : "Scheduled Transactions"}</h2>
                    <p class="text-sm text-slate-600">{recurring.length} {lang === "es" ? "transacción(es)" : "transaction(s)"}</p>
                </div>

                {recurring && recurring.length > 0 ? (
                    <div class="space-y-3">
                        {recurring.map((txn: any) => (
                            <div class="border border-slate-200 rounded-lg p-4 flex items-between justify-between hover:bg-slate-50">
                                <div class="flex-1">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class={`px-2 py-1 text-xs font-semibold rounded-full ${txn.amount >= 0 ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                                            {txn.amount >= 0 ? (lang === "es" ? "Ingreso" : "Income") : (lang === "es" ? "Gasto" : "Expense")}
                                        </span>
                                        <span class="px-2 py-1 text-xs font-semibold rounded-full bg-slate-100 text-slate-700">
                                            {txn.frequency}
                                        </span>
                                    </div>
                                    <p class="font-semibold text-slate-900">{txn.description}</p>
                                    <p class="text-sm text-slate-600">{txn.account?.name || "Unknown Account"} · {lang === "es" ? "Próxima:" : "Next:"} {txn.next_due_date}</p>
                                </div>
                                <div class="text-right flex flex-col items-end gap-2">
                                    <p class={`font-bold ${txn.amount >= 0 ? 'text-green-700' : 'text-red-700'}`}>
                                        {txn.amount >= 0 ? `+$${(txn.amount / 100).toFixed(2)}` : `-$${Math.abs(txn.amount / 100).toFixed(2)}`}
                                    </p>
                                    <div class="flex gap-2">
                                        <button class="px-3 py-1 text-sm bg-slate-100 hover:bg-slate-200 rounded transition">
                                            {lang === "es" ? "Editar" : "Edit"}
                                        </button>
                                        <button class="px-3 py-1 text-sm bg-red-100 hover:bg-red-200 text-red-700 rounded transition">
                                            {lang === "es" ? "Borrar" : "Delete"}
                                        </button>
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                ) : (
                    <div class="text-center py-8 text-slate-600">
                        <p>{lang === "es" ? "No hay transacciones recurrentes" : "No recurring transactions yet"}</p>
                        <p class="text-sm mt-1">{lang === "es" ? "Crea tu primera arriba para empezar" : "Create your first one above to get started"}</p>
                    </div>
                )}
            </div>

            <!-- How It Works -->
            <div class="bg-green-50 border border-green-200 rounded-xl p-6 space-y-3 text-sm">
                <p class="font-semibold text-green-900">{lang === "es" ? "¿Cómo funcionan?" : "How it works"}</p>
                <ul class="list-disc list-inside space-y-2 text-green-800 text-xs">
                    <li>{lang === "es" ? "Se crean automáticamente en la fecha programada" : "Automatically created on the scheduled date"}</li>
                    <li>{lang === "es" ? "Puedes omitir o editar antes de que se publiquen" : "You can skip or edit before they post"}</li>
                    <li>{lang === "es" ? "Apoyamos frecuencias diarias, semanales, mensuales y anuales" : "We support daily, weekly, monthly, and annual frequencies"}</li>
                    <li>{lang === "es" ? "Perfecto para salarios, alquileres, suscripciones, etc." : "Perfect for salary, rent, subscriptions, etc."}</li>
                </ul>
            </div>
        </main>

        <BottomNav active="budget" role={user.role} lang={lang} />
    </div>
</Layout>

<script>
    const form = document.getElementById("recurring-form");
    if (form) {
        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            
            const formData = new FormData(form);
            const amount = parseFloat(formData.get("amount") as string);
            const isExpense = formData.get("type") === "expense";
            
            const data = {
                description: formData.get("description"),
                amount: Math.round((isExpense ? -amount : amount) * 100), // Convert to cents
                frequency: formData.get("frequency"),
                next_due_date: formData.get("next_due_date"),
                account_id: formData.get("account_id"),
                category_id: formData.get("category_id") || null,
                enabled: true,
            };
            
            try {
                const response = await fetch("/api/budget/recurring-transactions", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify(data),
                });
                
                if (response.ok) {
                    // Reload page to show new transaction
                    window.location.reload();
                } else {
                    alert("Failed to create recurring transaction");
                }
            } catch (error) {
                console.error("Error creating recurring transaction:", error);
                alert("Error creating recurring transaction");
            }
        });
    }
</script>
