---
/**
 * Budget Rules Management Page
 * 
 * Manage automatic transaction categorization rules.
 * Rules automatically assign categories to new transactions based on payee or description patterns.
 */

import Layout from "@layouts/Layout.astro";
import BudgetNav from "@components/BudgetNav.astro";
import BottomNav from "@components/BottomNav.astro";
import { t } from "@lib/i18n";
import { apiFetch } from "@lib/api";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = Astro.cookies.get("lang")?.value ?? "en";

const { data: user, ok } = await apiFetch<any>("/api/auth/me", { token });
if (!ok) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}

if (user.role !== "parent") {
    return Astro.redirect("/dashboard");
}

// Fetch existing rules
const { data: rules = [] } = await apiFetch<any[]>(
    "/api/budget/categorization-rules/",
    { token }
);

// Fetch categories for rule creation
const { data: categories = [] } = await apiFetch<any[]>(
    "/api/budget/categories/",
    { token }
);

const isEs = lang === "es";
---

<Layout title={`${t(lang, 'fin_settings_rules')} - Budget`}>
    <div class="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto bg-slate-50 min-h-screen flex flex-col">
        <header class="bg-slate-700 text-white pt-12 pb-6 px-6 rounded-b-3xl shadow-md">
            <div class="flex items-center justify-between mb-4">
                <a href="/budget/settings" class="text-white hover:text-slate-200 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <h1 class="text-2xl font-bold">{t(lang, 'fin_settings_rules')}</h1>
                <div class="w-6"></div>
            </div>
            <p class="text-slate-100 text-sm">{t(lang, 'fin_settings_rules_body')}</p>
        </header>

        <BudgetNav active="settings" />

        <main class="px-6 py-6 flex-1 space-y-6">
            <!-- Create Rule Section -->
            <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6 space-y-4">
                <div>
                    <h2 class="text-lg font-bold text-slate-900">{isEs ? "Nueva Regla" : "Create New Rule"}</h2>
                    <p class="text-sm text-slate-600">{isEs ? "Configurar categorización automática de transacciones" : "Set up automatic transaction categorization"}</p>
                </div>

                <div id="create-error" class="hidden bg-red-50 border border-red-200 rounded-lg px-4 py-2 text-sm text-red-700"></div>

                <form id="rule-form" class="space-y-4">
                    <!-- Pattern Input -->
                    <div>
                        <label for="pattern" class="block text-sm font-semibold text-slate-800 mb-1">
                            {isEs ? "Patrón" : "Pattern"}
                        </label>
                        <input 
                            type="text" 
                            id="pattern" 
                            name="pattern" 
                            placeholder={isEs ? "ej: Starbucks, Netflix..." : "e.g. Starbucks, Netflix..."}
                            class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                            required
                        />
                        <p class="text-xs text-slate-500 mt-1">{isEs ? "Buscar texto exacto o contiene" : "Exact text or contains"}</p>
                    </div>

                    <!-- Match Field -->
                    <div>
                        <label for="match_field" class="block text-sm font-semibold text-slate-800 mb-1">
                            {isEs ? "Buscar en" : "Search Field"}
                        </label>
                        <select 
                            id="match_field" 
                            name="match_field"
                            class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                            required
                        >
                            <option value="payee">{isEs ? "Beneficiario" : "Payee"}</option>
                            <option value="description">{isEs ? "Descripción" : "Description"}</option>
                            <option value="both">{isEs ? "Ambos" : "Both"}</option>
                        </select>
                    </div>

                    <!-- Rule Type -->
                    <div>
                        <label for="rule_type" class="block text-sm font-semibold text-slate-800 mb-1">
                            {isEs ? "Tipo de Regla" : "Rule Type"}
                        </label>
                        <select 
                            id="rule_type" 
                            name="rule_type"
                            class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                            required
                        >
                            <option value="exact">{isEs ? "Coincidencia Exacta" : "Exact Match"}</option>
                            <option value="contains">{isEs ? "Contiene" : "Contains"}</option>
                            <option value="startswith">{isEs ? "Comienza con" : "Starts With"}</option>
                        </select>
                    </div>

                    <!-- Category -->
                    <div>
                        <label for="category_id" class="block text-sm font-semibold text-slate-800 mb-1">
                            {isEs ? "Categoría" : "Category"}
                        </label>
                        <select 
                            id="category_id" 
                            name="category_id"
                            class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                            required
                        >
                            <option value="">{isEs ? "Selecciona una categoría..." : "Select a category..."}</option>
                            {categories.map((cat: any) => (
                                <option value={cat.id}>{cat.name}</option>
                            ))}
                        </select>
                    </div>

                    <!-- Priority -->
                    <div>
                        <label for="priority" class="block text-sm font-semibold text-slate-800 mb-1">
                            {isEs ? "Prioridad (Mayor = Primero)" : "Priority (Higher = First)"}
                        </label>
                        <input 
                            type="number" 
                            id="priority" 
                            name="priority"
                            value="0"
                            class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                        />
                    </div>

                    <!-- Submit -->
                    <button 
                        type="submit"
                        class="w-full px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition"
                    >
                        {isEs ? "Crear Regla" : "Create Rule"}
                    </button>
                </form>
            </div>

            <!-- Rules List -->
            <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6 space-y-4">
                <div>
                    <h2 class="text-lg font-bold text-slate-900">{isEs ? "Reglas Activas" : "Active Rules"}</h2>
                    <p class="text-sm text-slate-600">{rules.length} {isEs ? "regla(s)" : "rule(s)"}</p>
                </div>

                {rules && rules.length > 0 ? (
                    <div class="space-y-2">
                        {rules.map((rule: any) => (
                            <div class="border border-slate-200 rounded-lg p-4 flex items-start justify-between hover:bg-slate-50">
                                <div class="flex-1">
                                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                                        <span class="px-2 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-700">
                                            {rule.match_field}
                                        </span>
                                        <span class="px-2 py-1 text-xs font-semibold rounded-full bg-slate-100 text-slate-700">
                                            {rule.rule_type}
                                        </span>
                                        {rule.priority > 0 && (
                                            <span class="px-2 py-1 text-xs font-semibold rounded-full bg-amber-100 text-amber-700">
                                                {isEs ? "Prioridad" : "Priority"}: {rule.priority}
                                            </span>
                                        )}
                                        {!rule.enabled && (
                                            <span class="px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-500">
                                                {isEs ? "Desactivada" : "Disabled"}
                                            </span>
                                        )}
                                    </div>
                                    <p class="font-semibold text-slate-900">{rule.pattern}</p>
                                    <p class="text-sm text-slate-600">→ {rule.category?.name || (isEs ? "Categoría desconocida" : "Unknown Category")}</p>
                                </div>
                                <div class="flex gap-2 ml-4 shrink-0">
                                    <button
                                        class="edit-rule-btn px-3 py-1 text-sm bg-slate-100 hover:bg-slate-200 rounded transition"
                                        data-id={rule.id}
                                        data-pattern={rule.pattern}
                                        data-match-field={rule.match_field}
                                        data-rule-type={rule.rule_type}
                                        data-category={rule.category_id}
                                        data-priority={rule.priority}
                                        data-enabled={rule.enabled ? "true" : "false"}
                                    >
                                        {isEs ? "Editar" : "Edit"}
                                    </button>
                                    <button
                                        class="delete-rule-btn px-3 py-1 text-sm bg-red-100 hover:bg-red-200 text-red-700 rounded transition"
                                        data-id={rule.id}
                                        data-pattern={rule.pattern}
                                    >
                                        {isEs ? "Borrar" : "Delete"}
                                    </button>
                                </div>
                            </div>
                        ))}
                    </div>
                ) : (
                    <div class="text-center py-8 text-slate-600">
                        <p>{isEs ? "No hay reglas creadas aún" : "No rules created yet"}</p>
                        <p class="text-sm mt-1">{isEs ? "Crea tu primera regla arriba para empezar" : "Create your first rule above to get started"}</p>
                    </div>
                )}
            </div>

            <!-- How It Works -->
            <div class="bg-blue-50 border border-blue-200 rounded-xl p-6 space-y-3 text-sm">
                <p class="font-semibold text-blue-900">{isEs ? "¿Cómo funcionan las reglas?" : "How rules work"}</p>
                <ul class="list-disc list-inside space-y-2 text-blue-800 text-xs">
                    <li>{isEs ? "Cada nueva transacción se compara con tus reglas en orden de prioridad" : "Each new transaction is matched against your rules in priority order"}</li>
                    <li>{isEs ? "Si coincide, se asigna automáticamente a la categoría especificada" : "If it matches, the transaction is automatically assigned to the specified category"}</li>
                    <li>{isEs ? "Puedes editar transacciones categorizadas manualmente después" : "You can manually edit categorized transactions afterward"}</li>
                    <li>{isEs ? "Las reglas mayores prioridad se aplican primero, más específicas primero" : "Higher priority rules are applied first, most specific first"}</li>
                </ul>
            </div>
        </main>

        <BottomNav active="budget" role={user.role} lang={lang} />
    </div>

    <!-- Edit Rule Modal -->
    <div id="edit-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md max-h-[90vh] overflow-y-auto">
            <div class="bg-slate-700 text-white px-6 py-4 rounded-t-2xl flex items-center justify-between">
                <h2 class="text-lg font-bold">{isEs ? "Editar Regla" : "Edit Rule"}</h2>
                <button id="edit-close" class="text-white hover:text-slate-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div class="p-6 space-y-4">
                <div id="edit-error" class="hidden bg-red-50 border border-red-200 rounded-lg px-4 py-2 text-sm text-red-700"></div>

                <input type="hidden" id="edit-id" />

                <div>
                    <label class="block text-sm font-semibold text-slate-800 mb-1">{isEs ? "Patrón" : "Pattern"}</label>
                    <input type="text" id="edit-pattern"
                        class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                        required />
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-800 mb-1">{isEs ? "Buscar en" : "Search Field"}</label>
                    <select id="edit-match-field"
                        class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="payee">{isEs ? "Beneficiario" : "Payee"}</option>
                        <option value="description">{isEs ? "Descripción" : "Description"}</option>
                        <option value="both">{isEs ? "Ambos" : "Both"}</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-800 mb-1">{isEs ? "Tipo de Regla" : "Rule Type"}</label>
                    <select id="edit-rule-type"
                        class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="exact">{isEs ? "Coincidencia Exacta" : "Exact Match"}</option>
                        <option value="contains">{isEs ? "Contiene" : "Contains"}</option>
                        <option value="startswith">{isEs ? "Comienza con" : "Starts With"}</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-800 mb-1">{isEs ? "Categoría" : "Category"}</label>
                    <select id="edit-category"
                        class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="">{isEs ? "Selecciona una categoría..." : "Select a category..."}</option>
                        {categories.map((cat: any) => (
                            <option value={cat.id}>{cat.name}</option>
                        ))}
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-800 mb-1">{isEs ? "Prioridad" : "Priority"}</label>
                    <input type="number" id="edit-priority" value="0"
                        class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                </div>

                <div class="flex items-center gap-3">
                    <input type="checkbox" id="edit-enabled" class="w-4 h-4 rounded" />
                    <label for="edit-enabled" class="text-sm font-semibold text-slate-800">{isEs ? "Activa" : "Enabled"}</label>
                </div>

                <div class="flex gap-3 pt-2">
                    <button id="edit-cancel"
                        class="flex-1 px-4 py-2 border border-slate-200 text-slate-700 font-semibold rounded-lg hover:bg-slate-50 transition">
                        {isEs ? "Cancelar" : "Cancel"}
                    </button>
                    <button id="edit-save"
                        class="flex-1 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition">
                        {isEs ? "Guardar" : "Save"}
                    </button>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    import { showToast } from '../../../lib/toast';

    document.addEventListener('astro:page-load', () => {
    // ── Create form ──────────────────────────────────────────────────────────────
    const form = document.getElementById("rule-form") as HTMLFormElement;
    const createError = document.getElementById("create-error") as HTMLDivElement;

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        createError.classList.add("hidden");

        const formData = new FormData(form);
        const data = {
            pattern: formData.get("pattern"),
            match_field: formData.get("match_field"),
            rule_type: formData.get("rule_type"),
            category_id: formData.get("category_id"),
            priority: parseInt((formData.get("priority") as string) || "0"),
            enabled: true,
        };

        const res = await fetch("/api/budget/categorization-rules/", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
        });

        if (res.ok) {
            window.location.reload();
        } else {
            const err = await res.json().catch(() => ({}));
            createError.textContent = err.detail ?? "Error al crear la regla";
            createError.classList.remove("hidden");
        }
    });

    // ── Edit modal ───────────────────────────────────────────────────────────────
    const editModal = document.getElementById("edit-modal") as HTMLDivElement;
    const editError = document.getElementById("edit-error") as HTMLDivElement;
    const editId = document.getElementById("edit-id") as HTMLInputElement;
    const editPattern = document.getElementById("edit-pattern") as HTMLInputElement;
    const editMatchField = document.getElementById("edit-match-field") as HTMLSelectElement;
    const editRuleType = document.getElementById("edit-rule-type") as HTMLSelectElement;
    const editCategory = document.getElementById("edit-category") as HTMLSelectElement;
    const editPriority = document.getElementById("edit-priority") as HTMLInputElement;
    const editEnabled = document.getElementById("edit-enabled") as HTMLInputElement;

    function openEditModal(btn: HTMLButtonElement) {
        editError.classList.add("hidden");
        editId.value = btn.dataset.id!;
        editPattern.value = btn.dataset.pattern!;
        editMatchField.value = btn.dataset.matchField!;
        editRuleType.value = btn.dataset.ruleType!;
        editCategory.value = btn.dataset.category ?? "";
        editPriority.value = btn.dataset.priority ?? "0";
        editEnabled.checked = btn.dataset.enabled === "true";
        editModal.classList.remove("hidden");
    }

    function closeEditModal() {
        editModal.classList.add("hidden");
    }

    document.getElementById("edit-close")?.addEventListener("click", closeEditModal);
    document.getElementById("edit-cancel")?.addEventListener("click", closeEditModal);
    editModal.addEventListener("click", (e) => { if (e.target === editModal) closeEditModal(); });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeEditModal(); });

    document.querySelectorAll(".edit-rule-btn").forEach((btn) => {
        btn.addEventListener("click", () => openEditModal(btn as HTMLButtonElement));
    });

    document.getElementById("edit-save")?.addEventListener("click", async () => {
        editError.classList.add("hidden");
        const id = editId.value;

        const data = {
            pattern: editPattern.value.trim(),
            match_field: editMatchField.value,
            rule_type: editRuleType.value,
            category_id: editCategory.value,
            priority: parseInt(editPriority.value || "0"),
            enabled: editEnabled.checked,
        };

        const res = await fetch(`/api/budget/categorization-rules/${id}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
        });

        if (res.ok) {
            window.location.reload();
        } else {
            const err = await res.json().catch(() => ({}));
            editError.textContent = err.detail ?? "Error al guardar los cambios";
            editError.classList.remove("hidden");
        }
    });

    // ── Delete buttons ───────────────────────────────────────────────────────────
    document.querySelectorAll(".delete-rule-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
            const b = btn as HTMLButtonElement;
            const pattern = b.dataset.pattern ?? "esta regla";
            if (!confirm(`¿Eliminar la regla "${pattern}"?`)) return;

            const res = await fetch(`/api/budget/categorization-rules/${b.dataset.id}`, {
                method: "DELETE",
            });

            if (res.ok || res.status === 204) {
                window.location.reload();
            } else {
                const err = await res.json().catch(() => ({}));
                showToast(err.detail ?? "Error al eliminar la regla", 'error');
            }
        });
    });
    });
</script>
