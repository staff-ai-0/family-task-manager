---
/**
 * All Transactions Page
 * Shows all budget transactions with filtering, edit, and delete.
 */

import BudgetShell from "@components/ui/BudgetShell.astro";
import FABButton from "@components/FABButton.astro";
import FABModal from "@components/FABModal.astro";
import { apiFetch } from "@lib/api";
import { getTransactions, getAccounts, getCategories, getCategoryGroups, formatCurrency, formatDate } from "@lib/api/budget";
import type { BudgetTransaction, BudgetAccount, BudgetCategory } from "@lib/api/budget";

// Authentication check
const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = (Astro.cookies.get("lang")?.value ?? "en") as "en" | "es";
const es = lang === "es";

// Get user info
const { data: user, ok: userOk } = await apiFetch<any>("/api/auth/me", { token });
if (!userOk) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}

// Only parents can view budget
if (user.role !== "parent") {
    return Astro.redirect("/dashboard");
}

const { data: draftsCount } = await apiFetch<{count: number}>("/api/budget/receipt-drafts/count", { token });
const pendingDraftsCount = draftsCount?.count ?? 0;

// Read filter params from URL
const accountFilter = Astro.url.searchParams.get("account") || "";
const categoryFilter = Astro.url.searchParams.get("category") || "";
const searchFilter = Astro.url.searchParams.get("search") || "";

// Month from URL (?year=&month=), defaulting to the current month — without
// this the list was hard-locked to "now" and last month's spending was
// unreachable.
const now = new Date();
const yearParam = parseInt(Astro.url.searchParams.get("year") || "", 10);
const monthParam = parseInt(Astro.url.searchParams.get("month") || "", 10);
const hasValidYear = yearParam >= 2000 && yearParam <= 2100;
const hasValidMonth = monthParam >= 1 && monthParam <= 12;
const year = hasValidYear ? yearParam : now.getFullYear();
const month = hasValidMonth ? monthParam : now.getMonth() + 1;

// A ?tx= deep link (scan-receipt Edit / duplicate) may point at a transaction
// dated outside the default month. Resolve its month and REDIRECT with
// year/month in the URL — the client later strips only ?tx, so the month
// survives save-reloads, filter changes, and refreshes.
const txDeepLink = Astro.url.searchParams.get("tx");
if (txDeepLink && !(hasValidYear && hasValidMonth)) {
    const { data: deepTx } = await apiFetch<{ date?: string }>(
        `/api/budget/transactions/${encodeURIComponent(txDeepLink)}`,
        { token },
    );
    const m = deepTx?.date?.match(/^(\d{4})-(\d{2})/);
    if (m) {
        const p = new URLSearchParams(Astro.url.searchParams);
        p.set("year", m[1]);
        p.set("month", String(parseInt(m[2], 10)));
        return Astro.redirect(`/budget/transactions?${p.toString()}`);
    }
}
const startOfMonth = `${year}-${String(month).padStart(2, '0')}-01`;
const endOfMonth = new Date(year, month, 0);
const endDate = `${year}-${String(month).padStart(2, '0')}-${String(endOfMonth.getDate()).padStart(2, '0')}`;

const monthUrl = (y: number, m: number) => {
    const p = new URLSearchParams(Astro.url.searchParams);
    p.set("year", String(y));
    p.set("month", String(m));
    p.delete("tx");
    return `/budget/transactions?${p.toString()}`;
};
const prevMonthDate = new Date(year, month - 2, 1);
const nextMonthDate = new Date(year, month, 1);
const prevMonthUrl = monthUrl(prevMonthDate.getFullYear(), prevMonthDate.getMonth() + 1);
const nextMonthUrl = monthUrl(nextMonthDate.getFullYear(), nextMonthDate.getMonth() + 1);
const monthLabel = new Date(year, month - 1, 1).toLocaleDateString(es ? "es-MX" : "en-US", { month: "long", year: "numeric" });
const isCurrentMonth = year === now.getFullYear() && month === now.getMonth() + 1;

// Build transaction fetch params with filters
let txParams: any = { startDate: startOfMonth, endDate: endDate, limit: 200 };
if (accountFilter) txParams.accountId = accountFilter;
if (categoryFilter) txParams.categoryId = categoryFilter;

// Fetch transactions for current month (with optional account/category filters)
const { data: transactions, ok: transOk, error: transError } = await getTransactions(token, txParams);

// Fetch accounts, categories, and category groups
const { data: accounts } = await getAccounts(token);
const { data: categories } = await getCategories(token);
const { data: groups } = await getCategoryGroups(token);

// Build flat category list for FAB modal
const allCategories = (groups || [])
    .filter((g: any) => !g.is_income)
    .flatMap((g: any) => (g.categories || []).map((c: any) => ({
        id: c.id, name: c.name, group_name: g.name,
    })));

// All categories including income for edit modal
const allCategoriesForEdit = (groups || [])
    .flatMap((g: any) => (g.categories || []).map((c: any) => ({
        id: c.id, name: c.name, group_name: g.name, is_income: g.is_income,
    })));

// Create lookup maps
const accountMap = new Map(accounts?.map(a => [a.id, a]) || []);
const categoryMap = new Map(categories?.map(c => [c.id, c]) || []);

// Sort transactions by date (newest first)
const sortedTransactions = transactions?.sort((a, b) =>
    new Date(b.date).getTime() - new Date(a.date).getTime()
) || [];

// Client-side search filtering
let filteredTransactions = sortedTransactions;
if (searchFilter) {
    const q = searchFilter.toLowerCase();
    filteredTransactions = sortedTransactions.filter(tx =>
        (tx.payee_name || "").toLowerCase().includes(q) ||
        (tx.notes || "").toLowerCase().includes(q)
    );
}

// Group by date
const transactionsByDate = filteredTransactions.reduce((acc, t) => {
    const dateKey = t.date;
    if (!acc[dateKey]) acc[dateKey] = [];
    acc[dateKey].push(t);
    return acc;
}, {} as Record<string, BudgetTransaction[]>);

const dates = Object.keys(transactionsByDate).sort((a, b) =>
    new Date(b).getTime() - new Date(a).getTime()
);

// Calculate totals
const totalIncome = filteredTransactions.filter(t => t.amount > 0).reduce((sum, t) => sum + t.amount, 0);
const totalExpenses = Math.abs(filteredTransactions.filter(t => t.amount < 0).reduce((sum, t) => sum + t.amount, 0));
const netAmount = totalIncome - totalExpenses;

// Serialize data for client-side use
const accountsJson = JSON.stringify(accounts || []);
const categoriesJson = JSON.stringify(allCategoriesForEdit);
---

<BudgetShell
    title={`${es ? "Transacciones" : "Transactions"} - Presupuesto`}
    budgetActive="transactions"
    pendingDrafts={pendingDraftsCount}
    role={user.role}
    lang={lang}
    mainClass="px-4 py-4 flex-grow"
    containerClass="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto bg-brand-cream-deep flex flex-col"
>
        <!-- Header -->
        <header slot="before-nav" class="bg-brand-sky-deep text-white pt-12 pb-6 px-6 rounded-b-[var(--radius-tile)] shadow-[var(--shadow-card)]">
            <div class="flex items-center justify-between mb-6">
                <a href="/budget" class="text-white hover:text-brand-cream transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <h1 class="text-2xl font-bold">{es ? "Transacciones" : "Transactions"}</h1>
                <a href="/budget/scan-receipt" class="text-white hover:text-brand-cream transition" title={es ? "Escanear recibo" : "Scan receipt"}>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                </a>
            </div>

            <!-- Month navigation -->
            <div class="flex items-center justify-center gap-4 mb-4">
                <a href={prevMonthUrl} class="p-1.5 rounded-full hover:bg-white/20 transition" aria-label={es ? "Mes anterior" : "Previous month"}>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <span class="text-sm font-bold capitalize min-w-[10rem] text-center">{monthLabel}</span>
                {isCurrentMonth ? (
                    <span class="p-1.5 opacity-30" aria-hidden="true">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </span>
                ) : (
                    <a href={nextMonthUrl} class="p-1.5 rounded-full hover:bg-white/20 transition" aria-label={es ? "Mes siguiente" : "Next month"}>
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                )}
            </div>

            <!-- Summary -->
            <div class="bg-brand-cream/20 backdrop-blur-md rounded-2xl p-4 border border-white/30">
                <div class="grid grid-cols-3 gap-3 text-center">
                    <div>
                        <p class="text-brand-cream text-xs font-semibold uppercase tracking-wider mb-1">
                            {es ? "Ingresos" : "Income"}
                        </p>
                        <p class="text-lg font-bold text-green-300">{formatCurrency(totalIncome)}</p>
                    </div>
                    <div>
                        <p class="text-brand-cream text-xs font-semibold uppercase tracking-wider mb-1">
                            {es ? "Gastos" : "Expenses"}
                        </p>
                        <p class="text-lg font-bold text-red-300">{formatCurrency(totalExpenses)}</p>
                    </div>
                    <div>
                        <p class="text-brand-cream text-xs font-semibold uppercase tracking-wider mb-1">Neto</p>
                        <p class={`text-lg font-bold ${netAmount >= 0 ? 'text-white' : 'text-red-300'}`}>
                            {formatCurrency(netAmount)}
                        </p>
                    </div>
                </div>
            </div>
        </header>

        <!-- Filter Bar -->
        <div slot="after-nav" class="px-4 py-3 bg-brand-cream border-b border-brand-ink/10 flex flex-wrap gap-2">
            <select id="filter-account" class="text-sm border border-brand-ink/10 rounded-lg px-2 py-1.5 bg-brand-cream-deep flex-1 min-w-[100px]">
                <option value="">{es ? "Todas las cuentas" : "All accounts"}</option>
                {(accounts || []).map((acc) => (
                    <option value={acc.id} selected={acc.id === accountFilter}>{acc.name}</option>
                ))}
            </select>
            <select id="filter-category" class="text-sm border border-brand-ink/10 rounded-lg px-2 py-1.5 bg-brand-cream-deep flex-1 min-w-[100px]">
                <option value="">{es ? "Todas las categorías" : "All categories"}</option>
                {(categories || []).map((cat) => (
                    <option value={cat.id} selected={cat.id === categoryFilter}>{cat.name}</option>
                ))}
            </select>
            <input
                id="filter-search"
                type="text"
                placeholder={es ? "Buscar..." : "Search..."}
                value={searchFilter}
                class="text-sm border border-brand-ink/10 rounded-lg px-2 py-1.5 bg-brand-cream-deep flex-1 min-w-[120px]"
            />
            {user.role === "parent" && (
                <button id="dedup-btn" title={es ? "Limpiar duplicados" : "Remove duplicates"}
                    class="text-xs px-2 py-1.5 rounded-lg border border-brand-ink/10 bg-brand-cream-deep text-brand-ink-soft hover:bg-amber-100 hover:text-amber-700 hover:border-amber-300 transition flex items-center gap-1 whitespace-nowrap">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                    {es ? "Dedup" : "Dedup"}
                </button>
            )}
            {user.role === "parent" && (
                <button id="autocat-btn" title={es ? "Categorizar con IA" : "AI categorize"}
                    class="text-xs px-2 py-1.5 rounded-lg border border-brand-ink/10 bg-brand-cream-deep text-brand-ink-soft hover:bg-violet-100 hover:text-violet-700 hover:border-violet-300 transition flex items-center gap-1 whitespace-nowrap">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
                    {es ? "Auto-categorizar" : "Auto-categorize"}
                </button>
            )}
        </div>

        <!-- Transactions List -->
            {!transOk ? (
                <div class="bg-red-100 border border-red-200 rounded-xl p-4 text-red-700">
                    <p class="font-semibold">{es ? "Error al cargar transacciones" : "Error loading transactions"}</p>
                    <p class="text-sm">{transError || "Unknown error"}</p>
                </div>
            ) : filteredTransactions.length === 0 ? (
                <div class="bg-brand-cream-deep border border-brand-ink/10 rounded-xl p-8 text-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-brand-ink-soft mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <p class="text-brand-ink-soft font-medium">{es ? "No hay transacciones" : "No transactions"}</p>
                    <p class="text-sm text-brand-ink-soft mt-1">
                        {es ? "Usa el botón + para agregar" : "Use the + button to add one"}
                    </p>
                </div>
            ) : (
                <div class="space-y-4">
                    {dates.map(date => {
                        const dayTransactions = transactionsByDate[date];
                        const dayTotal = dayTransactions.reduce((sum, t) => sum + t.amount, 0);
                        return (
                            <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] overflow-hidden">
                                <div class="bg-brand-cream-deep px-4 py-2 border-b border-brand-ink/10 flex items-center justify-between">
                                    <h2 class="font-semibold text-brand-ink text-sm">{formatDate(date, lang)}</h2>
                                    <span class={`text-sm font-bold ${dayTotal >= 0 ? 'text-brand-mint-deep' : 'text-red-600'}`}>
                                        {formatCurrency(dayTotal)}
                                    </span>
                                </div>
                                <div class="divide-y divide-brand-ink/10">
                                    {dayTransactions.map(transaction => {
                                        const account = accountMap.get(transaction.account_id);
                                        const category = transaction.category_id ? categoryMap.get(transaction.category_id) : null;
                                        const isIncome = transaction.amount > 0;
                                        return (
                                            <button
                                                class="tx-row w-full text-left px-4 py-3 hover:bg-brand-cream-deep active:bg-brand-cream-deep transition flex items-center justify-between gap-3"
                                                data-tx-id={transaction.id}
                                                data-tx-amount={transaction.amount}
                                                data-tx-date={transaction.date}
                                                data-tx-payee={transaction.payee_name || ""}
                                                data-tx-category={transaction.category_id || ""}
                                                data-tx-account={transaction.account_id}
                                                data-tx-notes={transaction.notes || ""}
                                                data-tx-cleared={transaction.cleared ? "1" : "0"}
                                                data-has-receipt-image={transaction.receipt_image_path ? "1" : "0"}
                                                aria-label={es ? "Editar transacción" : "Edit transaction"}
                                            >
                                                <div class="flex-1 min-w-0">
                                                    <p class="text-sm font-medium text-brand-ink truncate">
                                                        {transaction.payee_name || category?.name || (es ? "Sin categoría" : "No category")}
                                                    </p>
                                                    <p class="text-xs text-brand-ink-soft">
                                                        {category?.name || (es ? "Sin categoría" : "No category")}
                                                        {account && <span> · {account.name}</span>}
                                                    </p>
                                                    {transaction.notes && (
                                                        <p class="text-xs text-brand-ink-soft mt-0.5 truncate">{transaction.notes}</p>
                                                    )}
                                                </div>
                                                <div class="text-right flex-shrink-0 flex items-center gap-2">
                                                    <div>
                                                        <p class={`text-sm font-bold ${isIncome ? 'text-brand-mint-deep' : 'text-red-600'}`}>
                                                            {isIncome ? '+' : ''}{formatCurrency(transaction.amount)}
                                                        </p>
                                                        {transaction.cleared && (
                                                            <span class="inline-block w-2 h-2 bg-brand-mint-deep rounded-full ml-auto" title={es ? "Conciliado" : "Cleared"}></span>
                                                        )}
                                                    </div>
                                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand-ink-soft flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                                    </svg>
                                                </div>
                                            </button>
                                        );
                                    })}
                                </div>
                            </div>
                        );
                    })}
                </div>
            )}

            <div class="mt-6 text-center">
                <p class="text-xs text-brand-ink-soft">
                    {es ? "Mostrando" : "Showing"} {formatDate(startOfMonth, lang)} — {formatDate(endDate, lang)}
                </p>
            </div>

    <Fragment slot="overlays">
        <!-- Edit Transaction Bottom Sheet -->
        <div id="edit-backdrop" class="fixed inset-0 bg-black/50 z-[60] hidden opacity-0 transition-opacity duration-300"></div>
        <div id="edit-modal" class="fixed bottom-0 left-0 right-0 z-[70] translate-y-full transition-transform duration-300 ease-out">
            <div class="max-w-md mx-auto bg-brand-cream rounded-t-[var(--radius-card)] shadow-[var(--shadow-stamp)] max-h-[90vh] overflow-y-auto overscroll-contain">
                <div class="flex justify-center pt-3 pb-1">
                    <div class="w-10 h-1 bg-brand-cream-deep rounded-full"></div>
                </div>
                <div class="px-5 pb-6">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-lg font-semibold text-brand-ink">
                            {es ? "Editar transacción" : "Edit Transaction"}
                        </h2>
                        <button id="edit-delete-btn" class="text-red-500 hover:text-red-700 transition p-1" title={es ? "Eliminar" : "Delete"}>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </div>

                    <!-- Type toggle -->
                    <div class="flex gap-2 mb-4">
                        <button id="edit-type-expense" class="flex-1 py-2 text-sm font-semibold rounded-lg border-2 transition-colors border-red-400 bg-red-100 text-red-700">
                            {es ? "Gasto" : "Expense"}
                        </button>
                        <button id="edit-type-income" class="flex-1 py-2 text-sm font-semibold rounded-lg border-2 transition-colors border-brand-ink/10 bg-brand-cream text-brand-ink-soft">
                            {es ? "Ingreso" : "Income"}
                        </button>
                    </div>

                    <!-- Amount -->
                    <div class="mb-3">
                        <label class="block text-sm font-medium text-brand-ink-soft mb-1">{es ? "Monto" : "Amount"}</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-2xl font-bold text-brand-ink-soft">$</span>
                            <input id="edit-amount" type="number" step="0.01" min="0" inputmode="decimal" placeholder="0.00"
                                class="w-full text-2xl font-bold text-center py-3 pl-8 pr-4 border border-brand-ink/10 rounded-xl focus:ring-2 focus:ring-brand-sky-deep outline-none" />
                        </div>
                    </div>

                    <!-- Date -->
                    <div class="mb-3">
                        <label class="block text-sm font-medium text-brand-ink-soft mb-1">{es ? "Fecha" : "Date"}</label>
                        <input id="edit-date" type="date"
                            class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg focus:ring-2 focus:ring-brand-sky-deep outline-none text-sm" />
                    </div>

                    <!-- Payee -->
                    <div class="mb-3">
                        <label class="block text-sm font-medium text-brand-ink-soft mb-1">{es ? "Beneficiario" : "Payee"}</label>
                        <input id="edit-payee" type="text" autocomplete="off"
                            class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg focus:ring-2 focus:ring-brand-sky-deep outline-none text-sm" />
                    </div>

                    <!-- Category -->
                    <div class="mb-3">
                        <label class="block text-sm font-medium text-brand-ink-soft mb-1">{es ? "Categoría" : "Category"}</label>
                        <select id="edit-category"
                            class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg focus:ring-2 focus:ring-brand-sky-deep outline-none text-sm bg-brand-cream">
                            <option value="">-- {es ? "Sin categoría" : "No category"} --</option>
                            {allCategoriesForEdit.map((cat) => (
                                <option value={cat.id}>{cat.group_name} → {cat.name}</option>
                            ))}
                        </select>
                    </div>

                    <!-- Account -->
                    <div class="mb-3">
                        <label class="block text-sm font-medium text-brand-ink-soft mb-1">{es ? "Cuenta" : "Account"}</label>
                        <select id="edit-account"
                            class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg focus:ring-2 focus:ring-brand-sky-deep outline-none text-sm bg-brand-cream">
                            <option value="">--</option>
                            {(accounts || []).map((acc) => (
                                <option value={acc.id}>{acc.name}</option>
                            ))}
                        </select>
                    </div>

                    <!-- Notes -->
                    <div class="mb-3">
                        <label class="block text-sm font-medium text-brand-ink-soft mb-1">{es ? "Nota" : "Note"}</label>
                        <input id="edit-notes" type="text"
                            class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg focus:ring-2 focus:ring-brand-sky-deep outline-none text-sm" />
                    </div>

                    <!-- Receipt image thumbnail (when present) -->
                    <div id="receipt-thumb-wrap" class="hidden mt-3">
                        <a id="receipt-thumb-link" href="#" target="_blank" rel="noopener" class="block">
                            <img id="receipt-thumb" src="" alt="Receipt" class="max-h-32 rounded-lg border border-brand-ink/10" />
                        </a>
                    </div>

                    <!-- Cleared -->
                    <div class="mb-4 flex items-center gap-3">
                        <input id="edit-cleared" type="checkbox" class="h-4 w-4 rounded text-brand-sky-deep border-brand-ink/20" />
                        <label for="edit-cleared" class="text-sm text-brand-ink-soft">
                            {es ? "Conciliado" : "Cleared"}
                        </label>
                    </div>

                    <div id="edit-error" class="hidden text-sm text-red-600 mb-3 px-1"></div>

                    <!-- Price Comparison Panel -->
                    <section id="price-comparison-panel" class="mt-6 mb-4 hidden" data-tx="">
                        <h2 class="text-base font-display font-extrabold text-brand-ink mb-2">
                            {lang === "es" ? "Comparación de precios" : "Price comparison"}
                        </h2>
                        <div id="pc-content" class="text-sm text-brand-ink-soft">
                            {lang === "es" ? "Cargando…" : "Loading…"}
                        </div>
                    </section>

                    <div class="flex gap-3 pb-[calc(1.5rem+env(safe-area-inset-bottom))]">
                        <button id="edit-cancel-btn" class="flex-1 py-3 bg-brand-cream-deep hover:bg-brand-cream-deep text-brand-ink font-semibold rounded-xl transition">
                            {es ? "Cancelar" : "Cancel"}
                        </button>
                        <button id="edit-save-btn" class="flex-1 py-3 bg-brand-sky-deep hover:bg-brand-ink text-white font-semibold rounded-xl shadow-[var(--shadow-card)] transition">
                            {es ? "Guardar" : "Save"}
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Delete confirm dialog -->
        <div id="delete-confirm-overlay" class="fixed inset-0 bg-black/60 z-[80] hidden flex items-center justify-center px-4">
            <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink shadow-[var(--shadow-pop)] p-6 max-w-sm w-full">
                <h3 class="text-lg font-bold text-brand-ink mb-2">{es ? "¿Eliminar transacción?" : "Delete transaction?"}</h3>
                <p class="text-sm text-brand-ink-soft mb-6">{es ? "Esta acción no se puede deshacer." : "This action cannot be undone."}</p>
                <div class="flex gap-3">
                    <button id="delete-cancel" class="flex-1 py-2.5 bg-brand-cream-deep hover:bg-brand-cream-deep text-brand-ink font-semibold rounded-xl transition">
                        {es ? "Cancelar" : "Cancel"}
                    </button>
                    <button id="delete-confirm" class="flex-1 py-2.5 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-xl shadow-[var(--shadow-card)] transition">
                        {es ? "Eliminar" : "Delete"}
                    </button>
                </div>
            </div>
        </div>

        <FABButton />
        <FABModal lang={lang} token={token} accounts={accounts || []} categories={allCategories} />
    </Fragment>
</BudgetShell>

<script>
function initFilters() {
    const account = document.getElementById("filter-account") as HTMLSelectElement | null;
    const category = document.getElementById("filter-category") as HTMLSelectElement | null;
    const search = document.getElementById("filter-search") as HTMLInputElement | null;

    function applyFilters() {
        const params = new URLSearchParams();
        // Keep the selected month when re-filtering.
        const current = new URLSearchParams(window.location.search);
        if (current.get("year")) params.set("year", current.get("year")!);
        if (current.get("month")) params.set("month", current.get("month")!);
        if (account?.value) params.set("account", account.value);
        if (category?.value) params.set("category", category.value);
        if (search?.value) params.set("search", search.value);
        const qs = params.toString();
        window.location.href = "/budget/transactions" + (qs ? "?" + qs : "");
    }

    account?.addEventListener("change", applyFilters);
    category?.addEventListener("change", applyFilters);

    let searchTimer: ReturnType<typeof setTimeout>;
    search?.addEventListener("input", () => {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(applyFilters, 500);
    });
}
initFilters();
document.addEventListener("astro:after-swap", initFilters);
</script>

<script define:vars={{ token, lang }}>
(function initEditModal() {
    const backdrop = document.getElementById("edit-backdrop");
    const modal = document.getElementById("edit-modal");
    const deleteConfirmOverlay = document.getElementById("delete-confirm-overlay");

    if (!backdrop || !modal) return;

    let currentTxId = null;
    let isExpense = true;

    const amountInput = document.getElementById("edit-amount");
    const dateInput = document.getElementById("edit-date");
    const payeeInput = document.getElementById("edit-payee");
    const categorySelect = document.getElementById("edit-category");
    const accountSelect = document.getElementById("edit-account");
    const notesInput = document.getElementById("edit-notes");
    const clearedCheck = document.getElementById("edit-cleared");
    const errorDiv = document.getElementById("edit-error");
    const saveBtn = document.getElementById("edit-save-btn");
    const cancelBtn = document.getElementById("edit-cancel-btn");
    const deleteBtn = document.getElementById("edit-delete-btn");
    const typeExpenseBtn = document.getElementById("edit-type-expense");
    const typeIncomeBtn = document.getElementById("edit-type-income");

    function openModal(txData) {
        currentTxId = txData.id;
        const amountCents = parseInt(txData.amount);
        isExpense = amountCents < 0;

        // Fill fields
        amountInput.value = (Math.abs(amountCents) / 100).toFixed(2);
        dateInput.value = txData.date;
        payeeInput.value = txData.payee || "";
        categorySelect.value = txData.category || "";
        accountSelect.value = txData.account || "";
        notesInput.value = txData.notes || "";
        clearedCheck.checked = txData.cleared === "1";

        setTypeUI(isExpense);

        if (errorDiv) { errorDiv.textContent = ""; errorDiv.classList.add("hidden"); }

        lockBodyScroll();
        backdrop.classList.remove("hidden");
        requestAnimationFrame(() => {
            backdrop.classList.remove("opacity-0");
            backdrop.classList.add("opacity-100");
            modal.classList.remove("translate-y-full");
        });
    }

    function closeModal() {
        backdrop.classList.remove("opacity-100");
        backdrop.classList.add("opacity-0");
        modal.classList.add("translate-y-full");
        setTimeout(() => backdrop.classList.add("hidden"), 300);
        currentTxId = null;
        unlockBodyScroll();
    }

    // Body scroll lock — position:fixed is the only reliable way to stop the
    // background page from scrolling behind the sheet on iOS Safari. Capture
    // and restore scroll position so the page doesn't jump on close.
    let _savedScrollY = 0;
    function lockBodyScroll() {
        _savedScrollY = window.scrollY;
        document.body.style.position = "fixed";
        document.body.style.top = `-${_savedScrollY}px`;
        document.body.style.left = "0";
        document.body.style.right = "0";
        document.body.style.width = "100%";
    }
    function unlockBodyScroll() {
        document.body.style.position = "";
        document.body.style.top = "";
        document.body.style.left = "";
        document.body.style.right = "";
        document.body.style.width = "";
        window.scrollTo(0, _savedScrollY);
    }

    function setTypeUI(expense) {
        isExpense = expense;
        if (expense) {
            typeExpenseBtn.className = "flex-1 py-2 text-sm font-semibold rounded-lg border-2 transition-colors border-red-400 bg-red-100 text-red-700";
            typeIncomeBtn.className = "flex-1 py-2 text-sm font-semibold rounded-lg border-2 transition-colors border-brand-ink/10 bg-brand-cream text-brand-ink-soft";
        } else {
            typeExpenseBtn.className = "flex-1 py-2 text-sm font-semibold rounded-lg border-2 transition-colors border-brand-ink/10 bg-brand-cream text-brand-ink-soft";
            typeIncomeBtn.className = "flex-1 py-2 text-sm font-semibold rounded-lg border-2 transition-colors border-brand-mint-deep bg-brand-mint/20 text-brand-mint-deep";
        }
    }

    typeExpenseBtn?.addEventListener("click", () => setTypeUI(true));
    typeIncomeBtn?.addEventListener("click", () => setTypeUI(false));
    cancelBtn?.addEventListener("click", closeModal);
    backdrop?.addEventListener("click", closeModal);
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !backdrop.classList.contains("hidden")) closeModal();
    });

    // Row click handlers
    function attachRowHandlers() {
        document.querySelectorAll(".tx-row").forEach((row) => {
            row.addEventListener("click", () => {
                const txId = row.dataset.txId;
                openModal({
                    id: txId,
                    amount: row.dataset.txAmount,
                    date: row.dataset.txDate,
                    payee: row.dataset.txPayee,
                    category: row.dataset.txCategory,
                    account: row.dataset.txAccount,
                    notes: row.dataset.txNotes,
                    cleared: row.dataset.txCleared,
                });

                // Receipt thumbnail: show when this txn has an image,
                // otherwise hide. The /receipt endpoint 302-redirects to a
                // 15-min signed GCS URL.
                const thumbWrap = document.getElementById("receipt-thumb-wrap");
                const thumb = document.getElementById("receipt-thumb");
                const thumbLink = document.getElementById("receipt-thumb-link");
                if (thumbWrap && thumb && thumbLink && row.dataset.hasReceiptImage === "1") {
                    const url = `/api/budget/transactions/${txId}/receipt`;
                    thumb.src = url;
                    thumbLink.href = url;
                    thumbWrap.classList.remove("hidden");
                } else if (thumbWrap) {
                    thumbWrap.classList.add("hidden");
                    if (thumb) thumb.src = "";
                }
            });
        });
    }
    attachRowHandlers();

    // Deep link: /budget/transactions?tx=<id> auto-opens the edit sheet for
    // that transaction (scan-receipt's Edit / duplicate links point here).
    const txParam = new URLSearchParams(window.location.search).get("tx");
    if (txParam) {
        const openDeepLink = () => {
            const row = document.querySelector(`.tx-row[data-tx-id="${CSS.escape(txParam)}"]`);
            if (row) {
                row.scrollIntoView({ block: "center" });
                row.click();
            }
            // Strip ?tx so save's location.reload() doesn't reopen the sheet.
            const u = new URL(window.location);
            u.searchParams.delete("tx");
            history.replaceState(null, "", u);
        };
        // Defer past parse so the price-comparison script (loaded after this
        // one) has attached its own .tx-row click handlers.
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", openDeepLink, { once: true });
        } else {
            openDeepLink();
        }
    }

    // Save
    saveBtn?.addEventListener("click", async () => {
        if (!currentTxId) return;
        if (errorDiv) { errorDiv.textContent = ""; errorDiv.classList.add("hidden"); }

        const rawAmount = parseFloat(amountInput?.value || "0");
        if (!rawAmount || rawAmount <= 0) {
            if (errorDiv) { errorDiv.textContent = "Enter a valid amount"; errorDiv.classList.remove("hidden"); }
            return;
        }
        const amountCents = Math.round(rawAmount * 100) * (isExpense ? -1 : 1);

        saveBtn.disabled = true;
        saveBtn.textContent = "...";

        try {
            if (!accountSelect?.value) {
                if (errorDiv) { errorDiv.textContent = lang === "es" ? "Selecciona una cuenta" : "Select an account"; errorDiv.classList.remove("hidden"); }
                saveBtn.disabled = false;
                saveBtn.textContent = saveBtn.dataset.originalText || "Save";
                return;
            }

            const body = {
                amount: amountCents,
                date: dateInput?.value,
                payee_name: payeeInput?.value?.trim() || undefined,
                category_id: categorySelect?.value || null,
                account_id: accountSelect.value,
                notes: notesInput?.value?.trim() || "",
                cleared: clearedCheck?.checked || false,
            };

            const res = await fetch(`/api/budget/transactions/${currentTxId}`, {
                method: "PUT",
                headers: { "Content-Type": "application/json", Authorization: `Bearer ${token}` },
                body: JSON.stringify(body),
            });

            if (!res.ok) {
                const err = await res.json().catch(() => ({}));
                throw new Error(err.detail || `Error ${res.status}`);
            }

            closeModal();
            window.location.reload();
        } catch (err) {
            if (errorDiv) { errorDiv.textContent = err.message; errorDiv.classList.remove("hidden"); }
            saveBtn.disabled = false;
            saveBtn.textContent = saveBtn.dataset.originalText || "Save";
        }
    });
    if (saveBtn) saveBtn.dataset.originalText = saveBtn.textContent;

    // Delete
    deleteBtn?.addEventListener("click", () => {
        deleteConfirmOverlay?.classList.remove("hidden");
        deleteConfirmOverlay?.classList.add("flex");
    });

    document.getElementById("delete-cancel")?.addEventListener("click", () => {
        deleteConfirmOverlay?.classList.add("hidden");
        deleteConfirmOverlay?.classList.remove("flex");
    });

    document.getElementById("delete-confirm")?.addEventListener("click", async () => {
        if (!currentTxId) return;
        deleteConfirmOverlay?.classList.add("hidden");
        deleteConfirmOverlay?.classList.remove("flex");

        try {
            const res = await fetch(`/api/budget/transactions/${currentTxId}`, {
                method: "DELETE",
                headers: { Authorization: `Bearer ${token}` },
            });
            if (!res.ok) throw new Error(`Error ${res.status}`);
            closeModal();
            window.location.reload();
        } catch (err) {
            if (errorDiv) { errorDiv.textContent = err.message; errorDiv.classList.remove("hidden"); }
        }
    });

    document.addEventListener("astro:after-swap", () => {
        initEditModal();
    });
})();
</script>

<script define:vars={{ lang }}>
(function initPriceComparison() {
    function attachPriceComparison() {
        const modal = document.getElementById("edit-modal");
        const panel = document.getElementById("price-comparison-panel");
        const out = document.getElementById("pc-content");
        if (!modal || !panel || !out) return;

        // Observe when the modal slides into view by watching for class removal
        document.querySelectorAll(".tx-row").forEach((row) => {
            row.addEventListener("click", async () => {
                const txId = row.dataset.txId;
                if (!txId) return;

                panel.dataset.tx = txId;
                panel.classList.remove("hidden");
                out.textContent = lang === "es" ? "Cargando…" : "Loading…";

                try {
                    const r = await fetch(`/api/budget/price-comparison/${txId}`, {
                        credentials: "include",
                    });
                    if (r.status === 404) {
                        out.textContent = lang === "es"
                            ? "Pendiente — revisa en 5 minutos."
                            : "Pending — check back in 5 min.";
                        return;
                    }
                    if (!r.ok) {
                        out.textContent = lang === "es"
                            ? "No disponible por ahora."
                            : "Not available right now.";
                        return;
                    }
                    const data = await r.json();
                    const items = Array.isArray(data.items) ? data.items : [];
                    if (!items.length) {
                        out.textContent = lang === "es" ? "Sin artículos." : "No items.";
                        return;
                    }

                    out.innerHTML = "";
                    const list = document.createElement("ul");
                    list.className = "space-y-3 divide-y divide-brand-ink/10";
                    for (const it of items) {
                        const li = document.createElement("li");
                        li.className = "pt-3 first:pt-0";

                        const head = document.createElement("div");
                        head.className = "flex justify-between items-baseline";
                        const name = document.createElement("span");
                        name.className = "font-semibold text-brand-ink";
                        name.textContent = it.item_name || it.normalized_name || "?";
                        const paid = document.createElement("span");
                        paid.className = "text-brand-ink-soft text-xs";
                        paid.textContent = `$${(it.line_total_cents / 100).toFixed(2)} MXN`;
                        head.append(name, paid);
                        li.append(head);

                        if (it.status === "done" && it.cheapest) {
                            const row2 = document.createElement("div");
                            row2.className = "mt-1 text-xs";
                            const savings = it.cheapest.savings_cents;
                            const verb = savings > 0
                                ? (lang === "es" ? "ahorras" : "save")
                                : (lang === "es" ? "ya tienes el mejor precio" : "you have the best price");
                            const text = savings > 0
                                ? `${it.cheapest.store}: $${it.cheapest.price_mxn} MXN — ${verb} $${(savings / 100).toFixed(2)}`
                                : `${it.cheapest.store}: $${it.cheapest.price_mxn} MXN — ${verb}`;
                            row2.textContent = text;
                            if (it.cheapest.url) {
                                const a = document.createElement("a");
                                a.href = it.cheapest.url;
                                a.target = "_blank";
                                a.rel = "noopener";
                                a.className = "ml-2 underline text-brand-coral-deep";
                                a.textContent = lang === "es" ? "Ver →" : "View →";
                                row2.append(a);
                            }
                            li.append(row2);
                        } else if (it.status === "pending") {
                            const row2 = document.createElement("div");
                            row2.className = "mt-1 text-xs text-brand-ink-soft";
                            row2.textContent = lang === "es" ? "Comparando…" : "Comparing…";
                            li.append(row2);
                        } else {
                            const row2 = document.createElement("div");
                            row2.className = "mt-1 text-xs text-brand-ink-soft";
                            row2.textContent = lang === "es"
                                ? "Sin datos disponibles."
                                : "No data available.";
                            li.append(row2);
                        }

                        list.append(li);
                    }
                    out.innerHTML = "";
                    out.append(list);
                } catch (e) {
                    out.textContent = lang === "es"
                        ? "Error cargando comparación."
                        : "Error loading comparison.";
                }
            });
        });

        // Hide panel when modal closes
        const cancelBtn = document.getElementById("edit-cancel-btn");
        const backdrop = document.getElementById("edit-backdrop");
        function hidePanel() {
            panel.classList.add("hidden");
            panel.dataset.tx = "";
            if (out) out.textContent = "";
        }
        cancelBtn?.addEventListener("click", hidePanel);
        backdrop?.addEventListener("click", hidePanel);
    }

    attachPriceComparison();
    document.addEventListener("astro:after-swap", attachPriceComparison);
    document.addEventListener("astro:page-load", attachPriceComparison);

    // Dedup button
    function attachDedup() {
        const btn = document.getElementById("dedup-btn");
        if (!btn) return;
        btn.addEventListener("click", async () => {
            const es = document.documentElement.lang === "es";
            btn.disabled = true;
            btn.textContent = es ? "Buscando..." : "Scanning...";
            try {
                // Dry run first to see count.
                const preview = await fetch("/api/budget/transactions/deduplicate?dry_run=true", {
                    method: "POST",
                });
                const data = await preview.json();
                if (!data.pairs || data.pairs.length === 0) {
                    alert(es ? "No se encontraron duplicados." : "No duplicates found.");
                    return;
                }
                const msg = es
                    ? `Se encontraron ${data.pairs.length} par(es) duplicado(s). ¿Limpiar ahora?`
                    : `Found ${data.pairs.length} duplicate pair(s). Clean up now?`;
                if (!confirm(msg)) return;
                const res = await fetch("/api/budget/transactions/deduplicate", { method: "POST" });
                const result = await res.json();
                alert(es
                    ? `${result.merged} duplicado(s) eliminado(s). Recargando...`
                    : `${result.merged} duplicate(s) removed. Reloading...`);
                window.location.reload();
            } catch (e) {
                alert(es ? "Error al limpiar duplicados." : "Error removing duplicates.");
            } finally {
                btn.disabled = false;
                btn.textContent = "Dedup";
            }
        });
    }
    attachDedup();
    document.addEventListener("astro:page-load", attachDedup);

    // Auto-categorize button
    function attachAutoCat() {
        const btn = document.getElementById("autocat-btn");
        if (!btn) return;
        btn.addEventListener("click", async () => {
            const es = document.documentElement.lang === "es";
            if (!confirm(es
                ? "Categorizar con IA todas las transacciones sin categoría. ¿Continuar?"
                : "AI-categorize all uncategorized transactions. Continue?")) return;
            btn.disabled = true;
            const label = btn.querySelector("svg")?.nextSibling;
            btn.textContent = es ? "Categorizando..." : "Categorizing...";
            try {
                const res = await fetch("/api/budget/transactions/auto-categorize", { method: "POST" });
                const r = await res.json();
                alert(es
                    ? `${r.applied} de ${r.scanned} categorizadas. Recargando...`
                    : `${r.applied} of ${r.scanned} categorized. Reloading...`);
                window.location.reload();
            } catch (e) {
                alert(es ? "Error al categorizar." : "Categorization error.");
            } finally {
                btn.disabled = false;
            }
        });
    }
    attachAutoCat();
    document.addEventListener("astro:page-load", attachAutoCat);
})();
</script>
