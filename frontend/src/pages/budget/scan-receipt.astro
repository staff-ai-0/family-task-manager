---
/**
 * Receipt Scanner Page (v2 — one-tap snap UX)
 *
 * The user picks a photo or file. The page kicks off the v2 scan-receipt
 * endpoint, shows an animated overlay through the 4 server-side stages, then
 * renders a confirm card with auto-detected account, total, optional FX line,
 * optional IVA pill, itemized list with inline price-trend badges, and a
 * primary "Looks good — save" plus "Delete & re-scan" actions.
 *
 * Branching:
 *   - 409 Conflict + dup_warning → modal with "Open original" / "Save anyway"
 *   - body.draft_id            → redirect to /budget/receipt-drafts (low confidence)
 *   - otherwise                → confirm card
 *
 * Premium feature (Plus/Pro plans), parent-only.
 */

import BudgetShell from "@components/ui/BudgetShell.astro";
import { apiFetch } from "@lib/api";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";

const { data: user, ok: userOk } = await apiFetch<any>("/api/auth/me", { token });
if (!userOk) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}

if (user.role !== "parent") {
    return Astro.redirect("/dashboard");
}

const { data: draftsCount } = await apiFetch<{ count: number }>(
    "/api/budget/receipt-drafts/count",
    { token },
);
const pendingDraftsCount = draftsCount?.count ?? 0;

const title = lang === "es" ? "Escanear ticket" : "Scan receipt";
---

<BudgetShell
    title={`${title} - Budget`}
    budgetActive="none"
    pendingDrafts={pendingDraftsCount}
    role={user.role}
    lang={lang}
    mainClass="px-6 py-8 flex-grow max-w-lg mx-auto w-full"
    containerClass="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto bg-brand-cream-deep flex flex-col min-h-screen"
>
        <!-- Header -->
        <header slot="before-nav" class="bg-gradient-to-br from-brand-coral to-brand-sky-deep text-white pt-12 pb-6 px-6 rounded-b-[var(--radius-tile)] shadow-[var(--shadow-card)]">
            <div class="flex items-center justify-between mb-2">
                <a href="/budget/transactions" class="text-white hover:text-brand-cream transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <h1 class="text-2xl font-display font-extrabold">{title}</h1>
                <div class="w-6"></div>
            </div>
            <p class="text-white/80 text-sm text-center">
                {lang === "es"
                    ? "Toma una foto y deja que la IA llene todo."
                    : "Snap a photo and let AI fill in the rest."}
            </p>
        </header>

        <!-- Main Content -->
            <div id="scan-actions" class="flex flex-col gap-3">
                <label class="cursor-pointer block w-full text-center bg-brand-coral-deep text-white px-6 py-4 rounded-2xl font-bold text-lg shadow-[var(--shadow-card)] press">
                    {lang === "es" ? "📷 Tomar foto" : "📷 Snap receipt"}
                    <input
                        id="cam-input"
                        type="file"
                        accept="image/*,application/pdf"
                        capture="environment"
                        class="hidden"
                    />
                </label>
                <label class="cursor-pointer block w-full text-center bg-brand-cream text-brand-ink px-6 py-4 rounded-2xl font-bold text-lg border-2 border-brand-ink/10 press">
                    {lang === "es" ? "⬆ Subir imagen" : "⬆ Upload image"}
                    <input
                        id="up-input"
                        type="file"
                        accept="image/jpeg,image/png,image/webp,image/gif,application/pdf"
                        class="hidden"
                    />
                </label>
                <label class="cursor-pointer block w-full text-center bg-brand-cream text-brand-ink-soft px-6 py-3 rounded-2xl font-semibold text-sm border border-dashed border-brand-ink/20 press">
                    {lang === "es" ? "📦 Subir varios (lote)" : "📦 Bulk upload (batch)"}
                    <input
                        id="bulk-input"
                        type="file"
                        multiple
                        accept="image/jpeg,image/png,image/webp,image/gif,application/pdf"
                        class="hidden"
                    />
                </label>
            </div>

            <!-- Bulk progress panel — hidden until a batch is in flight -->
            <section id="bulk-panel" class="hidden mt-6 bg-brand-cream rounded-2xl shadow-[var(--shadow-card)] border border-brand-ink/10 p-5 space-y-3">
                <div class="flex items-baseline justify-between">
                    <h2 id="bulk-title" class="text-lg font-display font-extrabold text-brand-ink">
                        {lang === "es" ? "Procesando lote" : "Processing batch"}
                    </h2>
                    <span id="bulk-counter" class="text-sm text-brand-ink-soft num"></span>
                </div>
                <div class="w-full h-2 bg-brand-cream-deep rounded-full overflow-hidden">
                    <div id="bulk-bar" class="h-full bg-brand-coral-deep transition-all duration-300" style="width:0%"></div>
                </div>
                <ul id="bulk-list" class="text-sm divide-y divide-brand-ink/5"></ul>
                <div id="bulk-summary" class="hidden pt-2 text-sm text-brand-ink-soft"></div>
                <a id="bulk-done-link" href="/budget/transactions" class="hidden block w-full text-center bg-brand-coral-deep text-white px-4 py-3 rounded-xl font-semibold press">
                    {lang === "es" ? "Ver transacciones" : "View transactions"}
                </a>
            </section>

            <!-- Confirm card target (populated from #confirm-card-tpl via cloneNode + textContent) -->
            <section id="confirm-card" class="hidden mt-8"></section>

            <!-- Duplicate modal -->
            <dialog
                id="dup-modal"
                class="rounded-2xl p-0 bg-transparent backdrop:bg-brand-ink/40"
            ></dialog>

            <!--
              ══════════════════════════════════════════════════════════════════
              Templates — Astro renders these once at SSR with the static structure.
              JS clones the template and uses .textContent (not innerHTML) to fill
              user-controlled values (payee name, item name, etc.), so injected
              HTML from a malicious LLM payload renders as text, not markup.
              Any future field added to either template is XSS-safe by default —
              you'd have to explicitly switch to innerHTML to introduce a vuln.
              ══════════════════════════════════════════════════════════════════
            -->
            <template id="confirm-card-tpl">
                <div class="bg-brand-cream rounded-2xl shadow-[var(--shadow-card)] border border-brand-ink/10 p-5 space-y-4">
                    <div>
                        <h2 data-slot="payee-name" class="text-xl font-display font-extrabold text-brand-ink"></h2>
                        <div data-slot="total" class="text-3xl font-display font-extrabold text-brand-coral-deep num mt-1"></div>
                        <div data-slot="fx-line" class="text-sm text-brand-ink-soft mt-1 hidden"></div>
                    </div>

                    <div class="text-sm">
                        <div data-slot="account-label" class="text-brand-ink-soft text-xs uppercase tracking-wider font-semibold mb-1">
                            {lang === "es" ? "Cuenta" : "Account"}
                        </div>
                        <div class="flex items-center gap-2">
                            <span data-slot="match-badge" class="inline-block font-bold"></span>
                            <span data-slot="account-name" class="text-brand-ink font-medium"></span>
                        </div>
                    </div>

                    <div data-slot="iva-pill" class="inline-block px-3 py-1 rounded-full bg-brand-cream-deep text-xs font-semibold text-brand-ink hidden"></div>

                    <ul data-slot="items" class="border-t border-brand-ink/10 pt-3 divide-y divide-brand-ink/5 hidden"></ul>

                    <div class="flex flex-col gap-2 pt-3">
                        <a
                            href="/budget/transactions"
                            class="block w-full text-center bg-brand-coral-deep text-white px-4 py-3 rounded-xl font-semibold press"
                        >
                            {lang === "es" ? "✓ Listo, guardar" : "✓ Looks good — save"}
                        </a>
                        <div class="flex gap-2">
                            <a
                                data-slot="edit-link"
                                class="flex-1 text-center bg-brand-cream-deep text-brand-ink px-4 py-3 rounded-xl font-semibold border border-brand-ink/10 press"
                            >{lang === "es" ? "Editar" : "Edit"}</a>
                            <button
                                id="del-tx"
                                type="button"
                                class="flex-1 text-center bg-brand-cream-deep text-brand-ink px-4 py-3 rounded-xl font-semibold border border-brand-ink/10 press"
                            >{lang === "es" ? "Borrar y re-escanear" : "Delete & re-scan"}</button>
                        </div>
                    </div>
                </div>
            </template>

            <template id="confirm-item-tpl">
                <li class="flex justify-between items-center py-1.5 text-sm">
                    <span class="text-brand-ink">
                        <span data-slot="qty" class="text-xs text-brand-ink-soft mr-1 hidden"></span>
                        <a data-slot="name-link" class="underline-offset-4 hover:underline"></a>
                        <span data-slot="trend-badge" class="ml-2 text-xs font-semibold hidden"></span>
                    </span>
                    <span data-slot="total" class="text-brand-ink font-medium num"></span>
                </li>
            </template>

            <template id="dup-modal-tpl">
                <form method="dialog" class="bg-brand-cream rounded-2xl shadow-[var(--shadow-card)] border border-brand-ink/10 p-5 space-y-3 max-w-sm mx-auto">
                    <h3 class="text-lg font-display font-extrabold text-brand-ink">
                        {lang === "es" ? "⚠ Ya escaneado" : "⚠ Already scanned"}
                    </h3>
                    <p data-slot="summary" class="text-sm text-brand-ink-soft"></p>
                    <div class="flex gap-2 justify-end pt-2">
                        <a
                            data-slot="open-original"
                            class="bg-brand-cream-deep text-brand-ink px-4 py-2 rounded-xl font-semibold border border-brand-ink/10 press"
                        >{lang === "es" ? "Ver original" : "Open original"}</a>
                        <button
                            id="force-save"
                            type="button"
                            class="bg-brand-coral-deep text-white px-4 py-2 rounded-xl font-semibold press"
                        >{lang === "es" ? "Guardar de todas formas" : "Save anyway"}</button>
                    </div>
                </form>
            </template>

        <!-- Full-screen overlay (covers the page during scan) -->
        <div
            slot="overlays"
            id="scan-overlay"
            class="hidden fixed inset-0 z-50 bg-brand-cream/95 flex flex-col items-center justify-center p-6"
        >
            <div class="size-32 rounded-2xl bg-brand-coral/15 mb-6 animate-pulse flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-brand-coral-deep animate-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </div>
            <ul id="scan-stages" class="text-brand-ink text-sm space-y-1 text-center font-medium">
                <li data-stage="0">{lang === "es" ? "Leyendo…" : "Reading…"}</li>
                <li data-stage="1" class="opacity-30">{lang === "es" ? "Detectando cuenta…" : "Matching account…"}</li>
                <li data-stage="2" class="opacity-30">{lang === "es" ? "Categorizando…" : "Categorizing…"}</li>
                <li data-stage="3" class="opacity-30">{lang === "es" ? "Buscando duplicados…" : "Checking duplicates…"}</li>
            </ul>
        </div>
</BudgetShell>

<script define:vars={{ lang, token }}>
    document.addEventListener("astro:page-load", () => {
        const camInput = document.getElementById("cam-input");
        const upInput = document.getElementById("up-input");
        const bulkInput = document.getElementById("bulk-input");
        const bulkPanel = document.getElementById("bulk-panel");
        const overlay = document.getElementById("scan-overlay");
        const confirmCard = document.getElementById("confirm-card");
        const dupModal = document.getElementById("dup-modal");

        if (!camInput || !upInput || !overlay || !confirmCard || !dupModal) return;

        // ── Helpers ───────────────────────────────────────────────────────────
        function money(cents, ccy) {
            const c = Number(cents || 0);
            const sign = c < 0 ? "-" : "";
            const abs = Math.abs(c) / 100;
            return `${sign}$${abs.toFixed(2)} ${ccy || ""}`.trim();
        }

        // esc() removed: all rendering now goes through textContent on cloned
        // <template> nodes (XSS-safe by default).

        function timeAgo(iso, l) {
            const sec = Math.round((Date.now() - new Date(iso).getTime()) / 1000);
            if (sec < 60) return l === "es" ? `hace ${sec}s` : `${sec}s ago`;
            return l === "es"
                ? `hace ${Math.round(sec / 60)}m`
                : `${Math.round(sec / 60)}m ago`;
        }

        // ── Overlay tick animation (advances stage labels every 700ms) ───────
        function tickStages() {
            const stages = overlay.querySelectorAll("#scan-stages li");
            let i = 0;
            return setInterval(() => {
                if (i > 0 && stages[i - 1]) stages[i - 1].classList.remove("opacity-30");
                if (i < stages.length && stages[i]) stages[i].classList.remove("opacity-30");
                i = Math.min(stages.length, i + 1);
            }, 700);
        }

        function resetStages() {
            const stages = overlay.querySelectorAll("#scan-stages li");
            stages.forEach((el, idx) => {
                if (idx === 0) el.classList.remove("opacity-30");
                else el.classList.add("opacity-30");
            });
        }

        // ── Scan helpers (inline fetch — keeps script self-contained) ─────────
        async function scanReceipt(file, opts) {
            // account_id rides the multipart form body (Form(...) on the
            // route); force stays as a Query parameter.
            const form = new FormData();
            form.append("file", file);
            if (opts && opts.account_id) form.append("account_id", opts.account_id);
            const q = new URLSearchParams();
            if (opts && opts.force) q.set("force", "true");
            const url = `/api/budget/transactions/scan-receipt${q.toString() ? "?" + q : ""}`;
            const resp = await fetch(url, {
                method: "POST",
                body: form,
                headers: { "Authorization": `Bearer ${token}` },
            });
            const body = await resp.json().catch(() => ({}));
            return { status: resp.status, body };
        }

        // ── Top-level: run a scan ─────────────────────────────────────────────
        async function runScan(file) {
            resetStages();
            overlay.classList.remove("hidden");
            const ticker = tickStages();
            try {
                const { status, body } = await scanReceipt(file);
                clearInterval(ticker);
                overlay.classList.add("hidden");

                if (status === 403) {
                    // Premium gate — give a real path to upgrade instead of a
                    // dead-end alert.
                    const go = confirm(lang === "es"
                        ? "El escaneo de recibos requiere un plan Plus o Pro. ¿Ver los planes?"
                        : "Receipt scanning requires a Plus or Pro plan. See the plans?");
                    if (go) window.location.href = "/parent/settings/subscription";
                    return;
                }
                if (status === 409 && body && body.dup_warning) {
                    showDupModal(file, body);
                    return;
                }
                if (body && body.draft_id) {
                    window.location.href = "/budget/receipt-drafts";
                    return;
                }
                if (status >= 400 || !body || !body.success) {
                    alert(lang === "es"
                        ? "Error escaneando."
                        : "Scan failed.");
                    return;
                }
                showConfirmCard(body);
            } catch (e) {
                clearInterval(ticker);
                overlay.classList.add("hidden");
                alert(lang === "es" ? "Error escaneando." : "Scan failed.");
            }
        }

        // ── Render the confirm card from a successful response ────────────────
        // Clones the static <template id="confirm-card-tpl"> and populates each
        // data-slot via textContent (XSS-safe — browser never parses HTML from
        // the value). Item rows clone <template id="confirm-item-tpl">.
        function showConfirmCard(body) {
            const tx = body.transaction || {};
            const currency = tx.currency || "MXN";

            const tpl = document.getElementById("confirm-card-tpl");
            const node = tpl.content.firstElementChild.cloneNode(true);
            const slot = (name) => node.querySelector(`[data-slot="${name}"]`);

            slot("payee-name").textContent =
                tx.payee_name || (lang === "es" ? "Ticket" : "Receipt");

            slot("total").textContent = money(
                typeof tx.amount === "number" ? Math.abs(tx.amount) : 0,
                currency,
            );

            if (body.fx) {
                const fx = slot("fx-line");
                fx.textContent = `≈ ${money(body.fx.original_amount_cents, body.fx.original_currency)} @ ${body.fx.rate}`;
                fx.classList.remove("hidden");
            }

            // Match strategy → indicator (no user-controlled text; safe to set
            // textContent + colour class)
            const strategy = body.account_match && body.account_match.strategy;
            const badge = slot("match-badge");
            if (strategy === "card_last4") {
                badge.textContent = "✓";
                badge.classList.add("text-brand-mint-deep");
            } else if (strategy === "override") {
                badge.textContent = "●";
                badge.classList.add("text-brand-ink");
            } else {
                badge.textContent = "●";
                badge.classList.add("text-yellow-600");
                badge.title = lang === "es" ? "Mejor estimación" : "Best guess";
            }
            slot("account-name").textContent = tx.account_name || "—";

            if (tx.iva_cents) {
                const iva = slot("iva-pill");
                iva.textContent = `IVA ${money(tx.iva_cents, currency)}`;
                iva.classList.remove("hidden");
            }

            const items = body.items || [];
            if (items.length) {
                const trendsMap = new Map(
                    (body.trends || []).map((t) => [t.normalized_name, t]),
                );
                const itemTpl = document.getElementById("confirm-item-tpl");
                const itemsList = slot("items");
                itemsList.classList.remove("hidden");
                for (const it of items) {
                    const row = itemTpl.content.firstElementChild.cloneNode(true);
                    const rslot = (n) => row.querySelector(`[data-slot="${n}"]`);

                    if (it.qty && Number(it.qty) > 1) {
                        const q = rslot("qty");
                        q.textContent = `${it.qty}×`;
                        q.classList.remove("hidden");
                    }

                    const link = rslot("name-link");
                    link.textContent = it.name || "";
                    link.href = `/budget/items/${encodeURIComponent(it.normalized_name || "")}`;

                    const t = trendsMap.get(it.normalized_name);
                    if (t && t.sample_size >= 3 && Math.abs(t.pct_change) >= 0.05) {
                        const up = t.pct_change > 0;
                        const tb = rslot("trend-badge");
                        tb.textContent = `${up ? "📈" : "📉"} ${(t.pct_change * 100).toFixed(0)}%`;
                        tb.classList.add(up ? "text-red-600" : "text-brand-mint-deep");
                        tb.classList.remove("hidden");
                    }

                    rslot("total").textContent = money(it.total_cents, currency);
                    itemsList.appendChild(row);
                }
            }

            const editLink = slot("edit-link");
            if (body.transaction_id) {
                editLink.href = `/budget/transactions?tx=${encodeURIComponent(body.transaction_id)}`;
            } else {
                editLink.removeAttribute("href");
            }

            confirmCard.replaceChildren(node);
            confirmCard.classList.remove("hidden");

            // Hide CTAs once the card is visible
            const actions = document.getElementById("scan-actions");
            if (actions) actions.classList.add("hidden");

            const delBtn = document.getElementById("del-tx");
            if (delBtn) {
                delBtn.onclick = async () => {
                    if (!body.transaction_id) {
                        window.location.reload();
                        return;
                    }
                    try {
                        await fetch(`/api/budget/transactions/${body.transaction_id}`, {
                            method: "DELETE",
                            headers: { "Authorization": `Bearer ${token}` },
                        });
                    } catch (_) {
                        // swallow — reload regardless so user can re-try
                    }
                    window.location.reload();
                };
            }
        }

        // ── Duplicate modal: open original or force-save through ──────────────
        // Clones <template id="dup-modal-tpl"> and fills via textContent + safe
        // anchor href (encodeURIComponent on the txn id).
        function showDupModal(file, body) {
            const dup = body.dup_warning || {};
            const ccy = (body.transaction && body.transaction.currency) || "MXN";

            const tpl = document.getElementById("dup-modal-tpl");
            const node = tpl.content.firstElementChild.cloneNode(true);
            const slot = (n) => node.querySelector(`[data-slot="${n}"]`);

            slot("summary").textContent = [
                dup.payee || (lang === "es" ? "Comercio" : "Merchant"),
                money(dup.amount_cents, ccy),
                timeAgo(dup.scanned_at, lang),
            ].join(" · ");

            const openLink = slot("open-original");
            if (dup.existing_transaction_id) {
                openLink.href = `/budget/transactions?tx=${encodeURIComponent(dup.existing_transaction_id)}`;
            } else {
                openLink.removeAttribute("href");
            }

            dupModal.replaceChildren(node);
            try {
                dupModal.showModal();
            } catch (_) {
                // <dialog> not supported — fall back to inline render
                dupModal.classList.remove("hidden");
            }

            const forceBtn = document.getElementById("force-save");
            if (forceBtn) {
                forceBtn.addEventListener("click", async (e) => {
                    e.preventDefault();
                    try { dupModal.close(); } catch (_) {}
                    resetStages();
                    overlay.classList.remove("hidden");
                    const ticker = tickStages();
                    try {
                        const { body: r2 } = await scanReceipt(file, { force: true });
                        clearInterval(ticker);
                        overlay.classList.add("hidden");
                        if (r2 && r2.success) {
                            showConfirmCard(r2);
                        } else {
                            alert(lang === "es" ? "Error guardando." : "Save failed.");
                        }
                    } catch (_) {
                        clearInterval(ticker);
                        overlay.classList.add("hidden");
                        alert(lang === "es" ? "Error guardando." : "Save failed.");
                    }
                });
            }
        }

        // ── Bulk: client-side serial loop over the existing /scan-receipt API
        // (each file = one premium-metered scan). Sequential to keep ordering
        // stable + avoid hammering Gemini's rate limit. Each file emits a row
        // into #bulk-list with its outcome (✓ created / ⚠ to drafts / ✗ error).
        async function runBulk(files) {
            const filesArr = Array.from(files);
            if (!filesArr.length) return;

            // Hide other panels, show bulk panel.
            confirmCard.classList.add("hidden");
            const actions = document.getElementById("scan-actions");
            if (actions) actions.classList.add("hidden");
            bulkPanel.classList.remove("hidden");

            const counter = document.getElementById("bulk-counter");
            const bar = document.getElementById("bulk-bar");
            const list = document.getElementById("bulk-list");
            const summary = document.getElementById("bulk-summary");
            const doneLink = document.getElementById("bulk-done-link");
            list.replaceChildren();

            let created = 0, drafts = 0, dups = 0, errors = 0;
            const total = filesArr.length;

            for (let i = 0; i < total; i++) {
                const file = filesArr[i];
                const row = document.createElement("li");
                row.className = "flex items-center justify-between py-2 gap-2";
                const name = document.createElement("span");
                name.className = "truncate flex-1 text-brand-ink";
                name.textContent = file.name;
                const status = document.createElement("span");
                status.className = "text-xs font-semibold whitespace-nowrap";
                status.textContent = lang === "es" ? "Procesando…" : "Processing…";
                row.append(name, status);
                list.append(row);

                counter.textContent = `${i + 1} / ${total}`;
                bar.style.width = `${Math.round((i / total) * 100)}%`;

                try {
                    const { status: code, body } = await scanReceipt(file, { force: false });
                    if (code === 409 && body.dup_warning) {
                        // Auto-skip duplicates in bulk mode (user can re-scan
                        // individually later if intentional).
                        dups++;
                        status.textContent = lang === "es" ? "⚠ Duplicado" : "⚠ Duplicate";
                        status.classList.add("text-yellow-600");
                    } else if (body && body.draft_id) {
                        drafts++;
                        status.textContent = lang === "es" ? "📋 Revisión" : "📋 Drafts";
                        status.classList.add("text-yellow-600");
                    } else if (body && body.success) {
                        created++;
                        status.textContent = lang === "es" ? "✓ Creado" : "✓ Created";
                        status.classList.add("text-brand-mint-deep");
                    } else {
                        errors++;
                        status.textContent = lang === "es" ? "✗ Falló" : "✗ Failed";
                        status.classList.add("text-red-600");
                    }
                } catch (_e) {
                    errors++;
                    status.textContent = lang === "es" ? "✗ Error" : "✗ Error";
                    status.classList.add("text-red-600");
                }
            }

            bar.style.width = "100%";
            counter.textContent = `${total} / ${total}`;
            summary.classList.remove("hidden");
            summary.textContent = lang === "es"
                ? `✓ ${created} creados · 📋 ${drafts} en revisión · ⚠ ${dups} duplicados · ✗ ${errors} errores`
                : `✓ ${created} created · 📋 ${drafts} drafts · ⚠ ${dups} duplicates · ✗ ${errors} errors`;
            doneLink.classList.remove("hidden");
        }

        // ── Wire up the inputs ────────────────────────────────────────────────
        camInput.addEventListener("change", (e) => {
            const f = e.target && e.target.files && e.target.files[0];
            if (f) runScan(f);
        });
        upInput.addEventListener("change", (e) => {
            const f = e.target && e.target.files && e.target.files[0];
            if (f) runScan(f);
        });
        if (bulkInput) {
            bulkInput.addEventListener("change", (e) => {
                const files = e.target && e.target.files;
                if (files && files.length > 0) runBulk(files);
            });
        }
    });
</script>
