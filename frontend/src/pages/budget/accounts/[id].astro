---
/**
 * Account Detail Page
 * Shows account details and transaction list
 */

import Layout from "@layouts/Layout.astro";
import BottomNav from "@components/BottomNav.astro";
import { apiFetch } from "@lib/api";
import { getAccount, getTransactions, getCategories, getAccounts, formatCurrency, formatDate } from "@lib/api/budget";
import type { BudgetTransaction, BudgetCategory, BudgetAccount } from "@lib/api/budget";

// Authentication check
const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = Astro.cookies.get("lang")?.value ?? "en";

// Get user info
const { data: user, ok: userOk } = await apiFetch<any>("/api/auth/me", { token });
if (!userOk) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}

// Only parents can view budget
if (user.role !== "parent") {
    return Astro.redirect("/dashboard");
}

// Get account ID from URL
const { id } = Astro.params;
if (!id) return Astro.redirect("/budget/accounts");

// Fetch account details
const { data: account, ok: accountOk, error: accountError } = await getAccount(token, id);
if (!accountOk || !account) {
    return Astro.redirect("/budget/accounts");
}

// Get account balance
const { data: balance } = await apiFetch<{ total: number; cleared: number; uncleared: number }>(
    `/api/budget/accounts/${id}/balance`,
    { token }
);

// Fetch all accounts for transfer dropdown
const { data: allAccounts = [] } = await getAccounts(token);
const otherAccounts = (allAccounts ?? []).filter((a: BudgetAccount) => a.id !== id);

// Fetch transactions for this account
const { data: transactions, ok: transOk } = await getTransactions(token, {
    accountId: id,
    limit: 100,
});

// Fetch categories for display
const { data: categories } = await getCategories(token);
const categoryMap = new Map(categories?.map(c => [c.id, c]) || []);

// Sort transactions by date (newest first)
const sortedTransactions = transactions?.sort((a, b) => 
    new Date(b.date).getTime() - new Date(a.date).getTime()
) || [];

// Group by date
const transactionsByDate = sortedTransactions.reduce((acc, t) => {
    const dateKey = t.date;
    if (!acc[dateKey]) acc[dateKey] = [];
    acc[dateKey].push(t);
    return acc;
}, {} as Record<string, BudgetTransaction[]>);

const dates = Object.keys(transactionsByDate).sort((a, b) => 
    new Date(b).getTime() - new Date(a).getTime()
);

// Calculate statistics
const totalIncome = sortedTransactions.filter(t => t.amount > 0).reduce((sum, t) => sum + t.amount, 0);
const totalExpenses = Math.abs(sortedTransactions.filter(t => t.amount < 0).reduce((sum, t) => sum + t.amount, 0));

// Today's ISO date for transfer default
const todayISO = new Date().toISOString().slice(0, 10);

// Account type labels
const typeLabels: Record<string, string> = lang === "es" ? {
    checking: "Cuenta Corriente",
    savings: "Ahorro",
    credit: "Crédito",
    investment: "Inversión",
    other: "Otra",
} : {
    checking: "Checking",
    savings: "Savings",
    credit: "Credit",
    investment: "Investment",
    other: "Other",
};
---

<Layout title={`${account.name} - Cuentas`}>
    <div class="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto  bg-slate-50 flex flex-col ">
        <!-- Header -->
        <header class="bg-primary-600 text-white pt-12 pb-6 px-6 rounded-b-3xl shadow-md">
            <div class="flex items-center justify-between mb-6">
                <a href="/budget/accounts" class="text-white hover:text-primary-100 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <h1 class="text-2xl font-bold truncate max-w-xs">{account.name}</h1>
                <div class="w-6"></div>
            </div>

            <!-- Account Info -->
            <div class="bg-white/20 backdrop-blur-md rounded-2xl p-4 border border-white/30">
                <div class="flex items-center justify-between mb-3">
                    <p class="text-primary-50 text-xs font-semibold uppercase tracking-wider">
                        {typeLabels[account.type]}
                    </p>
                    {account.offbudget && (
                        <span class="bg-white/30 text-white text-xs px-2 py-1 rounded-full font-semibold">
                            {lang === "es" ? "Fuera del presupuesto" : "Off budget"}
                        </span>
                    )}
                </div>
                <p class="text-3xl font-extrabold tracking-tight text-white mb-2">
                    {formatCurrency(balance?.total || 0)}
                </p>
                {balance && balance.uncleared !== 0 && (
                    <p class="text-primary-50 text-sm">
                        {formatCurrency(balance.cleared)} {lang === "es" ? "conciliado" : "cleared"}
                        {balance.uncleared > 0 ? ' + ' : ' - '}
                        {formatCurrency(Math.abs(balance.uncleared))} {lang === "es" ? "pendiente" : "pending"}
                    </p>
                )}
            </div>

            <!-- Account Stats -->
            <div class="grid grid-cols-2 gap-3 mt-3">
                <div class="bg-white/20 backdrop-blur-md rounded-xl p-3 border border-white/30">
                    <p class="text-primary-50 text-xs font-semibold uppercase tracking-wider mb-1">
                        {lang === "es" ? "Ingresos" : "Income"}
                    </p>
                    <p class="text-lg font-bold text-green-300">
                        {formatCurrency(totalIncome)}
                    </p>
                </div>
                <div class="bg-white/20 backdrop-blur-md rounded-xl p-3 border border-white/30">
                    <p class="text-primary-50 text-xs font-semibold uppercase tracking-wider mb-1">
                        {lang === "es" ? "Gastos" : "Expenses"}
                    </p>
                    <p class="text-lg font-bold text-red-300">
                        {formatCurrency(totalExpenses)}
                    </p>
                </div>
            </div>
        </header>

        <!-- Quick Actions -->
        <div class="px-6 py-4 flex gap-3">
            <a
                href={`/budget/transactions/new?account=${id}`}
                class="flex-1 bg-primary-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-primary-700 transition text-center text-sm flex items-center justify-center gap-2"
            >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Nueva Transacción
            </a>
            {otherAccounts.length > 0 && (
                <button
                    id="open-transfer-btn"
                    class="flex-1 bg-indigo-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-indigo-700 transition text-center text-sm flex items-center justify-center gap-2"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                    </svg>
                    {lang === "es" ? "Transferir" : "Transfer"}
                </button>
            )}
            <a
                href={`/budget/accounts/${id}/reconcile`}
                class="flex-1 bg-green-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-green-700 transition text-center text-sm flex items-center justify-center gap-2"
            >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {lang === "es" ? "Conciliar" : "Reconcile"}
            </a>
        </div>

        <!-- Transactions List -->
        <main class="px-6 pb-6 flex-grow">
            {!transOk ? (
                <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-red-700">
                    <p class="font-semibold">{lang === "es" ? "Error al cargar transacciones" : "Error loading transactions"}</p>
                </div>
            ) : sortedTransactions.length === 0 ? (
                <div class="bg-slate-100 border border-slate-200 rounded-xl p-8 text-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-slate-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <p class="text-slate-600 font-medium">{lang === "es" ? "No hay transacciones" : "No transactions yet"}</p>
                    <p class="text-sm text-slate-500 mt-1">{lang === "es" ? "Agrega tu primera transacción en esta cuenta" : "Add your first transaction to this account"}</p>
                    <a 
                        href={`/budget/transactions/new?account=${id}`}
                        class="inline-block mt-4 bg-primary-600 text-white px-6 py-2 rounded-lg font-semibold hover:bg-primary-700 transition"
                    >
                {lang === "es" ? "Nueva Transacción" : "New Transaction"}
                    </a>
                </div>
            ) : (
                <div class="space-y-4">
                    {dates.map(date => {
                        const dayTransactions = transactionsByDate[date];
                        const dayTotal = dayTransactions.reduce((sum, t) => sum + t.amount, 0);
                        
                        return (
                            <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                                <div class="bg-slate-100 px-4 py-2 border-b border-slate-200 flex items-center justify-between">
                                    <h2 class="font-semibold text-slate-700 text-sm">
                                        {formatDate(date, lang)}
                                    </h2>
                                    <span class={`text-sm font-bold ${dayTotal >= 0 ? 'text-green-600' : 'text-red-600'}`}>
                                        {formatCurrency(dayTotal)}
                                    </span>
                                </div>
                                <div class="divide-y divide-slate-100">
                                    {dayTransactions.map(transaction => {
                                        const category = transaction.category_id ? categoryMap.get(transaction.category_id) : null;
                                        const isIncome = transaction.amount > 0;
                                        
                                        return (
                                            <a 
                                                href={`/budget/transactions/${transaction.id}`}
                                                class="block px-4 py-3 hover:bg-slate-50 transition"
                                            >
                                                <div class="flex items-center justify-between mb-1">
                                                    <div class="flex-1">
                                                        <p class="text-sm font-medium text-slate-700">
                                                            {category?.name || (lang === "es" ? "Sin categoría" : "Uncategorized")}
                                                        </p>
                                                        {transaction.notes && (
                                                            <p class="text-xs text-slate-500 mt-0.5">
                                                                {transaction.notes}
                                                            </p>
                                                        )}
                                                    </div>
                                                    <div class="text-right flex items-center gap-2">
                                                        <p class={`text-sm font-bold ${isIncome ? 'text-green-600' : 'text-red-600'}`}>
                                                            {isIncome ? '+' : ''}{formatCurrency(transaction.amount)}
                                                        </p>
                                                        {transaction.cleared && (
                                                            <span class="inline-block w-2 h-2 bg-green-500 rounded-full" title={lang === "es" ? "Conciliado" : "Cleared"}></span>
                                                        )}
                                                    </div>
                                                </div>
                                            </a>
                                        );
                                    })}
                                </div>
                            </div>
                        );
                    })}
                </div>
            )}
        </main>

        <BottomNav active="budget" role={user.role} lang={lang} />
    </div>

    <!-- Account Transfer Modal -->
    {otherAccounts.length > 0 && (
    <div id="account-transfer-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-6">
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full">
            <div class="bg-indigo-600 text-white px-6 py-4 rounded-t-2xl flex items-center justify-between">
                <h2 class="text-xl font-bold">{lang === "es" ? "Transferir entre Cuentas" : "Transfer Between Accounts"}</h2>
                <button id="close-account-transfer" class="text-white hover:text-indigo-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">{lang === "es" ? "Desde" : "From"}</label>
                    <div class="px-4 py-2 bg-slate-100 rounded-lg text-sm font-medium text-slate-700">{account.name}</div>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">{lang === "es" ? "Hacia" : "To"}</label>
                    <select id="transfer-to-account" class="w-full px-4 py-2 border-2 border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm">
                        {otherAccounts.map((a: BudgetAccount) => (
                            <option value={a.id}>{a.name}</option>
                        ))}
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">{lang === "es" ? "Monto" : "Amount"}</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 font-medium">$</span>
                        <input type="number" id="transfer-amount" step="0.01" min="0.01" placeholder="0.00"
                            class="w-full pl-8 pr-4 py-2 border-2 border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" />
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">{lang === "es" ? "Fecha" : "Date"}</label>
                    <input type="date" id="transfer-date" value={todayISO}
                        class="w-full px-4 py-2 border-2 border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">{lang === "es" ? "Notas (opcional)" : "Notes (optional)"}</label>
                    <input type="text" id="transfer-notes" placeholder={lang === "es" ? "ej. Ahorro mensual" : "e.g. Monthly savings"}
                        class="w-full px-4 py-2 border-2 border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" />
                </div>
                <div id="account-transfer-error" class="hidden bg-red-50 border border-red-200 rounded-lg px-4 py-2 text-sm text-red-700"></div>
                <div class="flex gap-3 pt-2">
                    <button id="cancel-account-transfer"
                        class="flex-1 bg-slate-200 text-slate-700 px-4 py-3 rounded-lg font-semibold hover:bg-slate-300 transition">
                        {lang === "es" ? "Cancelar" : "Cancel"}
                    </button>
                    <button id="confirm-account-transfer"
                        class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-4 py-3 rounded-lg transition">
                        {lang === "es" ? "Transferir" : "Transfer"}
                    </button>
                </div>
            </div>
        </div>
    </div>
    )}
</Layout>

<script define:vars={{ accountId: id }}>
    const transferModal = document.getElementById('account-transfer-modal');
    const openBtn = document.getElementById('open-transfer-btn');
    const closeBtn = document.getElementById('close-account-transfer');
    const cancelBtn = document.getElementById('cancel-account-transfer');
    const confirmBtn = document.getElementById('confirm-account-transfer');
    const errorDiv = document.getElementById('account-transfer-error');

    function openModal() {
        if (!transferModal) return;
        const amountInput = document.getElementById('transfer-amount');
        const notesInput = document.getElementById('transfer-notes');
        if (amountInput) amountInput.value = '';
        if (notesInput) notesInput.value = '';
        if (errorDiv) errorDiv.classList.add('hidden');
        transferModal.classList.remove('hidden');
        if (amountInput) amountInput.focus();
    }

    function closeModal() {
        if (transferModal) transferModal.classList.add('hidden');
        if (errorDiv) errorDiv.classList.add('hidden');
    }

    async function confirmTransfer() {
        const toAccount = document.getElementById('transfer-to-account').value;
        const amountStr = document.getElementById('transfer-amount').value;
        const dateVal = document.getElementById('transfer-date').value;
        const notes = document.getElementById('transfer-notes').value.trim();

        if (!amountStr || parseFloat(amountStr) <= 0) {
            errorDiv.textContent = 'El monto debe ser mayor a 0';
            errorDiv.classList.remove('hidden');
            return;
        }
        if (!dateVal) {
            errorDiv.textContent = 'La fecha es requerida';
            errorDiv.classList.remove('hidden');
            return;
        }

        const amountCents = Math.round(parseFloat(amountStr) * 100);

        try {
            const res = await fetch('/api/budget/transfers/accounts', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    from_account_id: accountId,
                    to_account_id: toAccount,
                    amount: amountCents,
                    date: dateVal,
                    notes: notes || null,
                }),
            });
            if (!res.ok) {
                let msg = 'Error al realizar transferencia';
                try { const d = await res.json(); msg = d?.detail || d?.message || msg; } catch {}
                throw new Error(msg);
            }
            window.location.reload();
        } catch (err) {
            if (errorDiv) {
                errorDiv.textContent = err.message;
                errorDiv.classList.remove('hidden');
            }
        }
    }

    openBtn?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    cancelBtn?.addEventListener('click', closeModal);
    confirmBtn?.addEventListener('click', confirmTransfer);
    transferModal?.addEventListener('click', (e) => { if (e.target === transferModal) closeModal(); });
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && transferModal && !transferModal.classList.contains('hidden')) closeModal();
    });
</script>
