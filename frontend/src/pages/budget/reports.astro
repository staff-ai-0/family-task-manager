---
/**
 * Unified Reports Page
 * Combines spending, cashflow, net worth, and budget-vs-actual into
 * a single page with sub-tabs and a period selector.
 */

import Layout from "@layouts/Layout.astro";
import BottomNav from "@components/BottomNav.astro";
import BudgetNavNew from "@components/BudgetNavNew.astro";
import DrawerMenu from "@components/DrawerMenu.astro";
import ReportSubTabs from "@components/ReportSubTabs.astro";
import PeriodSelector from "@components/PeriodSelector.astro";
import FABButton from "@components/FABButton.astro";
import FABModal from "@components/FABModal.astro";
import { apiFetch } from "@lib/api";
import {
    getSpendingReport,
    getIncomeVsExpenseReport,
    getNetWorthReport,
    getCategoryGroups,
    formatCurrency,
    getMonthName,
} from "@lib/api/budget";
import { t } from "@lib/i18n";

// --- Auth ---
const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = (Astro.cookies.get("lang")?.value ?? "en") as "en" | "es";
const es = lang === "es";

const { data: user, ok } = await apiFetch<any>("/api/auth/me", { token });
if (!ok) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

// --- Query params ---
const tab = (Astro.url.searchParams.get("tab") || "spending") as
    "spending" | "cashflow" | "networth" | "analysis";
const period = (Astro.url.searchParams.get("period") || "3m") as
    "1m" | "3m" | "6m" | "1y";

// --- Date range from period ---
const now = new Date();
const monthsBack = period === "1m" ? 1 : period === "3m" ? 3 : period === "6m" ? 6 : 12;
const startD = new Date(now.getFullYear(), now.getMonth() - monthsBack + 1, 1);
const startDate = startD.toISOString().split("T")[0].slice(0, 7) + "-01";
const endDate = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}-${String(now.getDate()).padStart(2, "0")}`;

// Current month string for budget-vs-actual
const currentMonthStr = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}-01`;

// --- Fetch ALL reports in parallel ---
const [spendingRes, cashflowRes, networthRes, analysisRes, accountsRes, groupsRes] = await Promise.all([
    getSpendingReport(token, startDate, endDate, "category"),
    getIncomeVsExpenseReport(token, startDate, endDate, "month"),
    getNetWorthReport(token),
    apiFetch<any>(`/api/budget/reports/budget-vs-actual?month=${currentMonthStr}`, { token }),
    apiFetch<any[]>("/api/budget/accounts/", { token }),
    getCategoryGroups(token),
]);

// --- Extract data ---
const spendingItems: any[] = spendingRes.data?.items || [];
const totalSpent = spendingItems.reduce((s: number, i: any) => s + Math.abs(i.total), 0);

const cashflowItems: any[] = cashflowRes.data?.items || [];
const totalIncome = cashflowItems.reduce((s: number, i: any) => s + i.income, 0);
const totalExpense = cashflowItems.reduce((s: number, i: any) => s + Math.abs(i.expense), 0);

const networth = networthRes.data || { net_worth: 0, total_assets: 0, total_liabilities: 0, accounts: [] };
const nwAccounts: any[] = networth.accounts || [];

const analysisGroups: any[] = analysisRes.data?.groups || [];
const analysisTotals = analysisRes.data?.totals || { budgeted: 0, actual: 0, variance: 0 };

const accounts: any[] = accountsRes.data || [];
const allGroups: any[] = groupsRes.data || [];
const allCategories = allGroups
    .flatMap((g: any) => (g.categories || []).map((c: any) => ({ id: c.id, name: c.name, group_name: g.name })));

// Month label for analysis section
const analysisMonthLabel = new Date(now.getFullYear(), now.getMonth(), 1).toLocaleDateString(
    es ? "es-MX" : "en-US",
    { month: "long", year: "numeric" }
);
---

<Layout title={es ? "Reportes - Presupuesto" : "Reports - Budget"}>
    <div class="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto bg-slate-50 flex flex-col min-h-screen">
        <BudgetNavNew active="reports" lang={lang} />
        <DrawerMenu lang={lang} />
        <ReportSubTabs active={tab} lang={lang} />
        <PeriodSelector activePeriod={period} />

        <!-- ==================== SPENDING ==================== -->
        <div id="report-spending" class={tab !== "spending" ? "hidden" : ""}>
            <main class="px-4 pb-6">
                {spendingItems.length === 0 ? (
                    <div class="bg-slate-100 border border-slate-200 rounded-xl p-8 text-center mt-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                        <p class="text-slate-600 font-medium">{es ? "Sin datos para este periodo" : "No data for this period"}</p>
                    </div>
                ) : (
                    <div class="space-y-3 mt-2">
                        {/* Total card */}
                        <div class="bg-white rounded-xl shadow-sm p-4 text-center">
                            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                                {es ? "Total Gastado" : "Total Spent"}
                            </p>
                            <p class="text-3xl font-extrabold text-red-600">{formatCurrency(totalSpent)}</p>
                        </div>

                        {/* Category list */}
                        <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                            <div class="divide-y divide-slate-100">
                                {spendingItems.map((item: any) => {
                                    const pct = totalSpent > 0 ? (Math.abs(item.total) / totalSpent) * 100 : 0;
                                    return (
                                        <div class="px-4 py-3">
                                            <div class="flex items-center justify-between mb-1.5">
                                                <span class="text-sm font-medium text-slate-700 truncate max-w-[55%]">
                                                    {item.name || (es ? "Sin especificar" : "Unspecified")}
                                                </span>
                                                <span class="text-sm font-bold text-red-600">
                                                    {formatCurrency(Math.abs(item.total))}
                                                </span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <div class="flex-1 bg-slate-200 rounded-full h-2 overflow-hidden">
                                                    <div
                                                        class="h-full bg-red-500 transition-all"
                                                        style={`width: ${pct}%`}
                                                    ></div>
                                                </div>
                                                <span class="text-xs font-semibold text-slate-500 w-10 text-right">
                                                    {pct.toFixed(0)}%
                                                </span>
                                            </div>
                                        </div>
                                    );
                                })}
                            </div>
                        </div>
                    </div>
                )}
            </main>
        </div>

        <!-- ==================== CASHFLOW ==================== -->
        <div id="report-cashflow" class={tab !== "cashflow" ? "hidden" : ""}>
            <main class="px-4 pb-6">
                {cashflowItems.length === 0 ? (
                    <div class="bg-slate-100 border border-slate-200 rounded-xl p-8 text-center mt-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                        <p class="text-slate-600 font-medium">{es ? "Sin datos para este periodo" : "No data for this period"}</p>
                    </div>
                ) : (
                    <div class="space-y-2 mt-2">
                        {cashflowItems.map((item: any) => {
                            const net = item.income - Math.abs(item.expense);
                            const isPositive = net >= 0;
                            const [yr, mo] = (item.period || "").split("-");
                            const periodLabel = yr && mo
                                ? `${getMonthName(parseInt(mo), lang)} ${yr}`
                                : item.period;

                            return (
                                <div class="bg-white rounded-xl shadow-sm p-4">
                                    <div class="flex items-center justify-between mb-3">
                                        <span class="text-sm font-semibold text-slate-800 capitalize">{periodLabel}</span>
                                        <span class={`text-sm font-bold ${isPositive ? 'text-green-600' : 'text-red-600'}`}>
                                            {isPositive ? '+' : ''}{formatCurrency(net)}
                                        </span>
                                    </div>
                                    {/* Income bar */}
                                    <div class="mb-2">
                                        <div class="flex items-center justify-between mb-0.5">
                                            <span class="text-xs text-slate-500">{es ? "Ingresos" : "Income"}</span>
                                            <span class="text-xs font-bold text-green-600">{formatCurrency(item.income)}</span>
                                        </div>
                                        <div class="bg-slate-200 rounded-full h-2 overflow-hidden">
                                            <div
                                                class="h-full bg-green-500 transition-all"
                                                style={`width: ${totalIncome > 0 ? (item.income / totalIncome) * 100 : 0}%`}
                                            ></div>
                                        </div>
                                    </div>
                                    {/* Expense bar */}
                                    <div>
                                        <div class="flex items-center justify-between mb-0.5">
                                            <span class="text-xs text-slate-500">{es ? "Gastos" : "Expenses"}</span>
                                            <span class="text-xs font-bold text-red-600">{formatCurrency(Math.abs(item.expense))}</span>
                                        </div>
                                        <div class="bg-slate-200 rounded-full h-2 overflow-hidden">
                                            <div
                                                class="h-full bg-red-500 transition-all"
                                                style={`width: ${totalExpense > 0 ? (Math.abs(item.expense) / totalExpense) * 100 : 0}%`}
                                            ></div>
                                        </div>
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                )}
            </main>
        </div>

        <!-- ==================== NET WORTH ==================== -->
        <div id="report-networth" class={tab !== "networth" ? "hidden" : ""}>
            <main class="px-4 pb-6">
                {nwAccounts.length === 0 ? (
                    <div class="bg-slate-100 border border-slate-200 rounded-xl p-8 text-center mt-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                        </svg>
                        <p class="text-slate-600 font-medium">{es ? "Sin datos para este periodo" : "No data for this period"}</p>
                    </div>
                ) : (
                    <div class="space-y-3 mt-2">
                        {/* Big net worth number */}
                        <div class="bg-white rounded-xl shadow-sm p-5 text-center">
                            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                                {es ? "Valor Neto" : "Net Worth"}
                            </p>
                            <p class={`text-4xl font-extrabold tracking-tight ${networth.net_worth >= 0 ? 'text-green-600' : 'text-red-600'}`}>
                                {formatCurrency(networth.net_worth)}
                            </p>
                            <div class="flex justify-center gap-6 mt-3 text-sm">
                                <div>
                                    <span class="text-slate-500">{es ? "Activos" : "Assets"}: </span>
                                    <span class="font-bold text-green-600">{formatCurrency(networth.total_assets)}</span>
                                </div>
                                <div>
                                    <span class="text-slate-500">{es ? "Pasivos" : "Liabilities"}: </span>
                                    <span class="font-bold text-red-600">{formatCurrency(Math.abs(networth.total_liabilities))}</span>
                                </div>
                            </div>
                        </div>

                        {/* Account list */}
                        <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                            <div class="divide-y divide-slate-100">
                                {nwAccounts.map((account: any) => {
                                    const isNeg = account.balance < 0;
                                    return (
                                        <div class="px-4 py-3 flex items-center justify-between">
                                            <div class="flex items-center gap-3">
                                                <div class={`w-2.5 h-2.5 rounded-full ${isNeg ? 'bg-red-500' : 'bg-green-500'}`}></div>
                                                <div>
                                                    <p class="text-sm font-medium text-slate-700">{account.name}</p>
                                                    <p class="text-xs text-slate-400 capitalize">{account.type}</p>
                                                </div>
                                            </div>
                                            <span class={`text-sm font-bold ${isNeg ? 'text-red-600' : 'text-slate-900'}`}>
                                                {formatCurrency(isNeg ? Math.abs(account.balance) : account.balance)}
                                            </span>
                                        </div>
                                    );
                                })}
                            </div>
                        </div>
                    </div>
                )}
            </main>
        </div>

        <!-- ==================== BUDGET vs ACTUAL ==================== -->
        <div id="report-analysis" class={tab !== "analysis" ? "hidden" : ""}>
            <main class="px-4 pb-6">
                {analysisGroups.length === 0 ? (
                    <div class="bg-slate-100 border border-slate-200 rounded-xl p-8 text-center mt-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                        <p class="text-slate-600 font-medium">{es ? "Sin datos para este periodo" : "No data for this period"}</p>
                    </div>
                ) : (
                    <div class="space-y-3 mt-2">
                        {/* Month label + totals */}
                        <div class="bg-white rounded-xl shadow-sm p-4 text-center">
                            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1 capitalize">{analysisMonthLabel}</p>
                            <div class="flex justify-center gap-6 text-sm mt-2">
                                <div>
                                    <span class="text-slate-500">{es ? "Presupuestado" : "Budgeted"}: </span>
                                    <span class="font-bold text-slate-800">{formatCurrency(analysisTotals.budgeted)}</span>
                                </div>
                                <div>
                                    <span class="text-slate-500">{es ? "Gastado" : "Spent"}: </span>
                                    <span class="font-bold text-slate-800">{formatCurrency(analysisTotals.actual)}</span>
                                </div>
                            </div>
                            <p class={`text-lg font-extrabold mt-1 ${analysisTotals.variance >= 0 ? 'text-green-600' : 'text-red-600'}`}>
                                {analysisTotals.variance >= 0 ? '+' : ''}{formatCurrency(analysisTotals.variance)}
                            </p>
                        </div>

                        {/* Category groups */}
                        {analysisGroups.map((group: any) => {
                            const grpPct = group.total_budgeted > 0
                                ? Math.min(100, Math.round(group.total_actual / group.total_budgeted * 100))
                                : 0;
                            const overBudget = group.total_actual > group.total_budgeted && group.total_budgeted > 0;

                            return (
                                <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                                    <div class="bg-slate-100 px-4 py-2.5 border-b border-slate-200">
                                        <div class="flex items-center justify-between mb-1">
                                            <h2 class="font-bold text-slate-800 text-sm">{group.group_name}</h2>
                                            <span class={`text-xs font-bold ${overBudget ? 'text-red-600' : 'text-green-600'}`}>
                                                {grpPct}%
                                            </span>
                                        </div>
                                        <div class="w-full bg-slate-200 rounded-full h-1.5">
                                            <div
                                                class={`h-1.5 rounded-full transition-all ${overBudget ? 'bg-red-500' : 'bg-emerald-500'}`}
                                                style={`width: ${grpPct}%`}
                                            ></div>
                                        </div>
                                    </div>
                                    <div class="divide-y divide-slate-100">
                                        {(group.categories || []).map((cat: any) => {
                                            const pct = cat.pct_used ?? 0;
                                            const over = pct > 100;
                                            const barWidth = Math.min(100, pct);
                                            const barColor = over ? 'bg-red-500' : pct >= 90 ? 'bg-amber-500' : 'bg-emerald-500';

                                            return (
                                                <div class="px-4 py-3">
                                                    <div class="flex items-center justify-between mb-1">
                                                        <span class="text-sm font-medium text-slate-700">{cat.category_name}</span>
                                                        <div class="text-right">
                                                            <span class={`text-sm font-bold ${cat.variance >= 0 ? 'text-slate-700' : 'text-red-600'}`}>
                                                                {formatCurrency(cat.actual_currency * 100)}
                                                            </span>
                                                            <span class="text-xs text-slate-400 ml-1">/ {formatCurrency(cat.budgeted_currency * 100)}</span>
                                                        </div>
                                                    </div>
                                                    {cat.budgeted > 0 && (
                                                        <div class="w-full bg-slate-100 rounded-full h-1 mt-1">
                                                            <div
                                                                class={`h-1 rounded-full ${barColor}`}
                                                                style={`width: ${barWidth}%`}
                                                            ></div>
                                                        </div>
                                                    )}
                                                    {cat.budgeted === 0 && cat.actual > 0 && (
                                                        <p class="text-xs text-amber-600 mt-0.5">{es ? "Sin presupuesto asignado" : "No budget set"}</p>
                                                    )}
                                                </div>
                                            );
                                        })}
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                )}
            </main>
        </div>

        <BottomNav active="budget" role={user.role} lang={lang} />
    </div>

    <FABButton />
    <FABModal lang={lang} token={token} accounts={accounts} categories={allCategories} />
</Layout>

<script>
function initReportTabs() {
    // Tab switching
    document.querySelectorAll(".report-tab").forEach(tab => {
        tab.addEventListener("click", () => {
            const el = tab as HTMLElement;
            const id = el.dataset.tab;
            if (!id) return;

            const url = new URL(window.location.href);
            url.searchParams.set("tab", id);
            history.replaceState(null, "", url.toString());

            // Toggle sections
            ["spending", "cashflow", "networth", "analysis"].forEach(s => {
                document.getElementById("report-" + s)?.classList.toggle("hidden", s !== id);
            });

            // Toggle tab styles
            document.querySelectorAll(".report-tab").forEach(t => {
                const btn = t as HTMLElement;
                const isActive = btn.dataset.tab === id;
                btn.classList.toggle("bg-primary-600", isActive);
                btn.classList.toggle("text-white", isActive);
                btn.classList.toggle("bg-slate-100", !isActive);
                btn.classList.toggle("text-slate-500", !isActive);
            });
        });
    });

    // Period switching
    document.querySelectorAll(".period-btn").forEach(btn => {
        btn.addEventListener("click", () => {
            const el = btn as HTMLElement;
            const url = new URL(window.location.href);
            url.searchParams.set("period", el.dataset.period || "3m");
            window.location.href = url.toString();
        });
    });

    // Prev/Next period arrows
    const periodOrder = ["1m", "3m", "6m", "1y"];
    function getCurrentPeriod(): string {
        return new URL(window.location.href).searchParams.get("period") || "3m";
    }
    document.getElementById("period-prev")?.addEventListener("click", () => {
        const cur = getCurrentPeriod();
        const idx = periodOrder.indexOf(cur);
        if (idx > 0) {
            const url = new URL(window.location.href);
            url.searchParams.set("period", periodOrder[idx - 1]);
            window.location.href = url.toString();
        }
    });
    document.getElementById("period-next")?.addEventListener("click", () => {
        const cur = getCurrentPeriod();
        const idx = periodOrder.indexOf(cur);
        if (idx < periodOrder.length - 1) {
            const url = new URL(window.location.href);
            url.searchParams.set("period", periodOrder[idx + 1]);
            window.location.href = url.toString();
        }
    });
}

initReportTabs();
document.addEventListener("astro:after-swap", initReportTabs);
</script>
