---
/**
 * Unified Reports Page
 * Combines spending, cashflow, net worth, and budget-vs-actual into
 * a single page with sub-tabs and a period selector.
 */

import BudgetShell from "@components/ui/BudgetShell.astro";
import ReportSubTabs from "@components/ReportSubTabs.astro";
import PeriodSelector from "@components/PeriodSelector.astro";
import FABButton from "@components/FABButton.astro";
import FABModal from "@components/FABModal.astro";
import UpgradePrompt from "@components/UpgradePrompt.astro";
import { apiFetch } from "@lib/api";
import {
    getSpendingReport,
    getIncomeVsExpenseReport,
    getNetWorthReport,
    getCashFlowForecast,
    getCategoryGroups,
    formatCurrency,
    getMonthName,
    formatDate,
} from "@lib/api/budget";
import { t } from "@lib/i18n";

// --- Auth ---
const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";
const es = lang === "es";

const { data: user, ok } = await apiFetch<any>("/api/auth/me", { token });
if (!ok) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

// --- Query params ---
const tab = (Astro.url.searchParams.get("tab") || "spending") as
    "spending" | "cashflow" | "networth" | "forecast" | "analysis";
const period = (Astro.url.searchParams.get("period") || "3m") as
    "1m" | "3m" | "6m" | "1y";

// Forecast horizon is independent of the spending/cashflow period selector.
const horizonRaw = parseInt(Astro.url.searchParams.get("horizon") || "30", 10);
const horizon = ([30, 60, 90].includes(horizonRaw) ? horizonRaw : 30) as 30 | 60 | 90;

// --- Date range from period ---
const now = new Date();
const monthsBack = period === "1m" ? 1 : period === "3m" ? 3 : period === "6m" ? 6 : 12;
const startD = new Date(now.getFullYear(), now.getMonth() - monthsBack + 1, 1);
const startDate = startD.toISOString().split("T")[0].slice(0, 7) + "-01";
const endDate = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}-${String(now.getDate()).padStart(2, "0")}`;

// --- Fetch ALL reports in parallel ---
const bvaYear = now.getFullYear();
const bvaMonth = now.getMonth() + 1;
const [spendingRes, cashflowRes, networthRes, forecastRes, accountsRes, groupsRes, draftsCountRes, bvaRes] = await Promise.all([
    getSpendingReport(token, startDate, endDate, "category"),
    getIncomeVsExpenseReport(token, startDate, endDate, "month"),
    getNetWorthReport(token),
    getCashFlowForecast(token, horizon),
    apiFetch<any[]>("/api/budget/accounts/", { token }),
    getCategoryGroups(token),
    apiFetch<{count: number}>("/api/budget/receipt-drafts/count", { token }),
    apiFetch<any>(`/api/budget/reports/budget-vs-actual?year=${now.getFullYear()}&month=${now.getMonth() + 1}`, { token }),
]);
const bva = bvaRes.data ?? { categories: [], totals: { budgeted: 0, actual: 0, diff: 0 } };
const bvaRows = (bva.categories ?? []).filter((c: any) => c.budgeted !== 0 || c.actual !== 0);
const pendingDraftsCount = draftsCountRes.data?.count ?? 0;

// --- Extract data ---
// API shape: {categories:[{category_name, group_name, amount(cents; income
// rows positive, spending negative), ...}]}. The page previously read
// data.items[].total — a field the endpoint never returned — so the
// Spending tab always said "No data" even with months of transactions.
// Keep only spending rows (negative amounts, non-income groups).
const spendingItems: any[] = (spendingRes.data?.categories || [])
    .filter((c: any) => (c.amount ?? 0) < 0)
    .map((c: any) => ({
        name: c.category_name
            ? `${c.category_name}${c.group_name ? ` · ${c.group_name}` : ""}`
            : c.group_name,
        total: c.amount,
    }))
    .sort((a: any, b: any) => Math.abs(b.total) - Math.abs(a.total));
const totalSpent = spendingItems.reduce((s: number, i: any) => s + Math.abs(i.total), 0);

const cashflowItems: any[] = cashflowRes.data?.items || [];
const totalIncome = cashflowItems.reduce((s: number, i: any) => s + i.income, 0);
const totalExpense = cashflowItems.reduce((s: number, i: any) => s + Math.abs(i.expense), 0);

const networth = networthRes.data || { net_worth: 0, total_assets: 0, total_liabilities: 0, accounts: [] };
const nwAccounts: any[] = networth.accounts || [];

// --- Forecast: group upcoming items by date for a bill-calendar list ---
const forecast = forecastRes.data || {
    starting_balance: 0, projected_balance: 0, projected_low: 0,
    scheduled_income: 0, scheduled_expense: 0, upcoming: [], accounts: [],
};
const forecastUpcoming: any[] = forecast.upcoming || [];
const forecastAccounts: any[] = forecast.accounts || [];
const forecastNet = (forecast.scheduled_income || 0) - (forecast.scheduled_expense || 0);
const forecastByDate: { date: string; items: any[] }[] = [];
for (const item of forecastUpcoming) {
    const last = forecastByDate[forecastByDate.length - 1];
    if (last && last.date === item.date) last.items.push(item);
    else forecastByDate.push({ date: item.date, items: [item] });
}

const accounts: any[] = accountsRes.data || [];
const allGroups: any[] = groupsRes.data || [];
const allCategories = allGroups
    .flatMap((g: any) => (g.categories || []).map((c: any) => ({ id: c.id, name: c.name, group_name: g.name })));

// Budget Reports is a Plus/Pro feature — free-plan families otherwise hit
// empty/blocked charts with no explanation. Show the upsell instead.
// /api/subscriptions/current returns the plan name at plan.name for a paid
// subscription (SubscriptionResponse) but as a flat plan_name on the free
// fallback dict — read both. Fail OPEN: only lock when we positively know the
// plan is free (a fetch error/unknown shape must not upsell a paying parent;
// the backend still enforces require_feature so nothing leaks).
const { data: subRaw } = await apiFetch<any>("/api/subscriptions/current", { token });
const planName = (subRaw?.plan?.name ?? subRaw?.plan_name ?? "").toLowerCase();
const reportsLocked = planName === "free";

---

<BudgetShell
    title={es ? "Reportes - Presupuesto" : "Reports - Budget"}
    budgetActive="reports"
    pendingDrafts={pendingDraftsCount}
    role={user.role}
    lang={lang}
    mainClass=""
    containerClass="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto bg-brand-cream-deep flex flex-col min-h-screen"
>
    <ReportSubTabs slot="after-nav" active={tab} lang={lang} />
    <PeriodSelector slot="after-nav" activePeriod={period} lang={lang} />

    {reportsLocked && (
        <div class="p-6">
            <UpgradePrompt feature="budget_reports" planNeeded="Plus" lang={lang} />
        </div>
    )}
    {!reportsLocked && (
      <>
        <!-- ==================== SPENDING ==================== -->
        <div id="report-spending" class={tab !== "spending" ? "hidden" : ""}>
            <div class="px-4 pb-6">
                {spendingItems.length === 0 ? (
                    <div class="bg-brand-cream-deep border border-brand-ink/10 rounded-xl p-8 text-center mt-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-brand-ink-soft mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                        <p class="text-brand-ink-soft font-medium">{es ? "Sin datos para este periodo" : "No data for this period"}</p>
                    </div>
                ) : (
                    <div class="space-y-3 mt-2">
                        {/* Total card */}
                        <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] p-4 text-center">
                            <p class="text-xs font-semibold text-brand-ink-soft uppercase tracking-wider mb-1">
                                {es ? "Total Gastado" : "Total Spent"}
                            </p>
                            <p class="text-3xl font-extrabold text-red-600">{formatCurrency(totalSpent)}</p>
                        </div>

                        {/* Category list */}
                        <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] overflow-hidden">
                            <div class="divide-y divide-brand-ink/10">
                                {spendingItems.map((item: any) => {
                                    const pct = totalSpent > 0 ? (Math.abs(item.total) / totalSpent) * 100 : 0;
                                    return (
                                        <div class="px-4 py-3">
                                            <div class="flex items-center justify-between mb-1.5">
                                                <span class="text-sm font-medium text-brand-ink truncate max-w-[55%]">
                                                    {item.name || (es ? "Sin especificar" : "Unspecified")}
                                                </span>
                                                <span class="text-sm font-bold text-red-600">
                                                    {formatCurrency(Math.abs(item.total))}
                                                </span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <div class="flex-1 bg-brand-cream-deep rounded-full h-2 overflow-hidden">
                                                    <div
                                                        class="h-full bg-red-500 transition-all"
                                                        style={`width: ${pct}%`}
                                                    ></div>
                                                </div>
                                                <span class="text-xs font-semibold text-brand-ink-soft w-10 text-right">
                                                    {pct.toFixed(0)}%
                                                </span>
                                            </div>
                                        </div>
                                    );
                                })}
                            </div>
                        </div>
                    </div>
                )}
            </div>
        </div>

        <!-- ==================== CASHFLOW ==================== -->
        <div id="report-cashflow" class={tab !== "cashflow" ? "hidden" : ""}>
            <div class="px-4 pb-6">
                {cashflowItems.length === 0 ? (
                    <div class="bg-brand-cream-deep border border-brand-ink/10 rounded-xl p-8 text-center mt-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-brand-ink-soft mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                        <p class="text-brand-ink-soft font-medium">{es ? "Sin datos para este periodo" : "No data for this period"}</p>
                    </div>
                ) : (
                    <div class="space-y-2 mt-2">
                        {cashflowItems.map((item: any) => {
                            const net = item.income - Math.abs(item.expense);
                            const isPositive = net >= 0;
                            const [yr, mo] = (item.period || "").split("-");
                            const periodLabel = yr && mo
                                ? `${getMonthName(parseInt(mo), lang)} ${yr}`
                                : item.period;

                            return (
                                <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] p-4">
                                    <div class="flex items-center justify-between mb-3">
                                        <span class="text-sm font-semibold text-brand-ink capitalize">{periodLabel}</span>
                                        <span class={`text-sm font-bold ${isPositive ? 'text-brand-mint-deep' : 'text-red-600'}`}>
                                            {isPositive ? '+' : ''}{formatCurrency(net)}
                                        </span>
                                    </div>
                                    {/* Income bar */}
                                    <div class="mb-2">
                                        <div class="flex items-center justify-between mb-0.5">
                                            <span class="text-xs text-brand-ink-soft">{es ? "Ingresos" : "Income"}</span>
                                            <span class="text-xs font-bold text-brand-mint-deep">{formatCurrency(item.income)}</span>
                                        </div>
                                        <div class="bg-brand-cream-deep rounded-full h-2 overflow-hidden">
                                            <div
                                                class="h-full bg-brand-mint-deep transition-all"
                                                style={`width: ${totalIncome > 0 ? (item.income / totalIncome) * 100 : 0}%`}
                                            ></div>
                                        </div>
                                    </div>
                                    {/* Expense bar */}
                                    <div>
                                        <div class="flex items-center justify-between mb-0.5">
                                            <span class="text-xs text-brand-ink-soft">{es ? "Gastos" : "Expenses"}</span>
                                            <span class="text-xs font-bold text-red-600">{formatCurrency(Math.abs(item.expense))}</span>
                                        </div>
                                        <div class="bg-brand-cream-deep rounded-full h-2 overflow-hidden">
                                            <div
                                                class="h-full bg-red-500 transition-all"
                                                style={`width: ${totalExpense > 0 ? (Math.abs(item.expense) / totalExpense) * 100 : 0}%`}
                                            ></div>
                                        </div>
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                )}
            </div>
        </div>

        <!-- ==================== FORECAST ==================== -->
        <div id="report-forecast" class={tab !== "forecast" ? "hidden" : ""}>
            <div class="px-4 pb-6">
                <!-- Horizon selector: 30 / 60 / 90 days -->
                <div class="flex items-center justify-center gap-2 mt-2 mb-3">
                    {[30, 60, 90].map((h) => (
                        <button
                            type="button"
                            class={`horizon-btn px-3 py-1 rounded-full text-xs font-bold transition-colors ${
                                horizon === h
                                    ? "bg-brand-sky-deep text-white"
                                    : "bg-brand-cream-deep text-brand-ink-soft"
                            }`}
                            data-horizon={h}
                        >
                            {h} {es ? "días" : "days"}
                        </button>
                    ))}
                </div>

                <!-- Projected balance hero -->
                <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] p-5 text-center">
                    <p class="text-xs font-semibold text-brand-ink-soft uppercase tracking-wider mb-1">
                        {es ? `Saldo proyectado (${horizon} días)` : `Projected balance (${horizon} days)`}
                    </p>
                    <p class={`text-4xl font-extrabold tracking-tight ${forecast.projected_balance >= 0 ? 'text-brand-mint-deep' : 'text-red-600'}`}>
                        {formatCurrency(forecast.projected_balance)}
                    </p>
                    <p class="text-xs text-brand-ink-soft mt-1">
                        {es ? "Saldo actual" : "Current balance"}: <span class="font-semibold text-brand-ink">{formatCurrency(forecast.starting_balance)}</span>
                    </p>
                    {forecast.projected_low < 0 && (
                        <p class="mt-2 text-xs font-semibold text-red-600">
                            {es
                                ? `Advertencia: el saldo llega a ${formatCurrency(forecast.projected_low)}`
                                : `Heads up: balance dips to ${formatCurrency(forecast.projected_low)}`}
                        </p>
                    )}
                </div>

                <!-- Income / expense summary -->
                <div class="grid grid-cols-3 gap-2 mt-3">
                    <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] p-3 text-center">
                        <p class="text-[10px] font-semibold text-brand-ink-soft uppercase tracking-wide">{es ? "Ingresos" : "Income"}</p>
                        <p class="text-sm font-bold text-brand-mint-deep mt-0.5">+{formatCurrency(forecast.scheduled_income)}</p>
                    </div>
                    <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] p-3 text-center">
                        <p class="text-[10px] font-semibold text-brand-ink-soft uppercase tracking-wide">{es ? "Gastos" : "Bills"}</p>
                        <p class="text-sm font-bold text-red-600 mt-0.5">-{formatCurrency(forecast.scheduled_expense)}</p>
                    </div>
                    <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] p-3 text-center">
                        <p class="text-[10px] font-semibold text-brand-ink-soft uppercase tracking-wide">{es ? "Neto" : "Net"}</p>
                        <p class={`text-sm font-bold mt-0.5 ${forecastNet >= 0 ? 'text-brand-mint-deep' : 'text-red-600'}`}>
                            {forecastNet >= 0 ? '+' : ''}{formatCurrency(forecastNet)}
                        </p>
                    </div>
                </div>

                <!-- Bill calendar: upcoming items grouped by date -->
                <h3 class="text-sm font-bold text-brand-ink mt-5 mb-2">
                    {es ? "Próximos movimientos" : "Upcoming items"}
                </h3>
                {forecastByDate.length === 0 ? (
                    <div class="bg-brand-cream-deep border border-brand-ink/10 rounded-xl p-8 text-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-brand-ink-soft mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        <p class="text-brand-ink-soft font-medium">
                            {es ? "Sin pagos recurrentes en este periodo" : "No recurring items in this window"}
                        </p>
                        <p class="text-sm text-brand-ink-soft mt-1">
                            {es ? "Agrega transacciones recurrentes para ver el pronóstico." : "Add recurring transactions to see the forecast."}
                        </p>
                    </div>
                ) : (
                    <div class="space-y-3">
                        {forecastByDate.map((group) => (
                            <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] overflow-hidden">
                                <div class="px-4 py-2 bg-brand-cream-deep/60 border-b border-brand-ink/10">
                                    <span class="text-xs font-bold text-brand-ink capitalize">{formatDate(group.date, lang)}</span>
                                </div>
                                <div class="divide-y divide-brand-ink/10">
                                    {group.items.map((item: any) => (
                                        <div class="px-4 py-2.5 flex items-center justify-between">
                                            <div class="flex items-center gap-2.5 min-w-0">
                                                <div class={`w-2 h-2 rounded-full shrink-0 ${item.is_income ? 'bg-brand-mint-deep' : 'bg-red-500'}`}></div>
                                                <div class="min-w-0">
                                                    <p class="text-sm font-medium text-brand-ink truncate">{item.name}</p>
                                                    <p class="text-xs text-brand-ink-soft truncate">
                                                        {item.category_name || item.payee_name || item.account_name}
                                                    </p>
                                                </div>
                                            </div>
                                            <span class={`text-sm font-bold shrink-0 ${item.is_income ? 'text-brand-mint-deep' : 'text-red-600'}`}>
                                                {item.is_income ? '+' : ''}{formatCurrency(item.amount)}
                                            </span>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        ))}
                    </div>
                )}

                <!-- Per-account projection -->
                {forecastAccounts.length > 0 && (
                    <>
                        <h3 class="text-sm font-bold text-brand-ink mt-5 mb-2">
                            {es ? "Por cuenta" : "By account"}
                        </h3>
                        <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] overflow-hidden">
                            <div class="divide-y divide-brand-ink/10">
                                {forecastAccounts.map((acct: any) => (
                                    <div class="px-4 py-3">
                                        <div class="flex items-center justify-between mb-0.5">
                                            <span class="text-sm font-medium text-brand-ink truncate max-w-[55%]">{acct.account_name}</span>
                                            <span class={`text-sm font-bold ${acct.projected_balance >= 0 ? 'text-brand-ink' : 'text-red-600'}`}>
                                                {formatCurrency(acct.projected_balance)}
                                            </span>
                                        </div>
                                        <div class="flex items-center justify-between text-xs text-brand-ink-soft">
                                            <span>{es ? "Actual" : "Now"}: {formatCurrency(acct.starting_balance)}</span>
                                            <span>
                                                <span class="text-brand-mint-deep">+{formatCurrency(acct.scheduled_income)}</span>
                                                {" / "}
                                                <span class="text-red-600">-{formatCurrency(acct.scheduled_expense)}</span>
                                            </span>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </>
                )}
            </div>
        </div>

        <!-- ==================== NET WORTH ==================== -->
        <div id="report-networth" class={tab !== "networth" ? "hidden" : ""}>
            <div class="px-4 pb-6">
                {nwAccounts.length === 0 ? (
                    <div class="bg-brand-cream-deep border border-brand-ink/10 rounded-xl p-8 text-center mt-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-brand-ink-soft mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                        </svg>
                        <p class="text-brand-ink-soft font-medium">{es ? "Sin datos para este periodo" : "No data for this period"}</p>
                    </div>
                ) : (
                    <div class="space-y-3 mt-2">
                        {/* Big net worth number */}
                        <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] p-5 text-center">
                            <p class="text-xs font-semibold text-brand-ink-soft uppercase tracking-wider mb-1">
                                {es ? "Valor Neto" : "Net Worth"}
                            </p>
                            <p class={`text-4xl font-extrabold tracking-tight ${networth.net_worth >= 0 ? 'text-brand-mint-deep' : 'text-red-600'}`}>
                                {formatCurrency(networth.net_worth)}
                            </p>
                            <div class="flex justify-center gap-6 mt-3 text-sm">
                                <div>
                                    <span class="text-brand-ink-soft">{es ? "Activos" : "Assets"}: </span>
                                    <span class="font-bold text-brand-mint-deep">{formatCurrency(networth.total_assets)}</span>
                                </div>
                                <div>
                                    <span class="text-brand-ink-soft">{es ? "Pasivos" : "Liabilities"}: </span>
                                    <span class="font-bold text-red-600">{formatCurrency(Math.abs(networth.total_liabilities))}</span>
                                </div>
                            </div>
                        </div>

                        {/* Account list */}
                        <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] overflow-hidden">
                            <div class="divide-y divide-brand-ink/10">
                                {nwAccounts.map((account: any) => {
                                    const isNeg = account.balance < 0;
                                    return (
                                        <div class="px-4 py-3 flex items-center justify-between">
                                            <div class="flex items-center gap-3">
                                                <div class={`w-2.5 h-2.5 rounded-full ${isNeg ? 'bg-red-500' : 'bg-brand-mint-deep'}`}></div>
                                                <div>
                                                    <p class="text-sm font-medium text-brand-ink">{account.name}</p>
                                                    <p class="text-xs text-brand-ink-soft capitalize">{account.type}</p>
                                                </div>
                                            </div>
                                            <span class={`text-sm font-bold ${isNeg ? 'text-red-600' : 'text-brand-ink'}`}>
                                                {formatCurrency(isNeg ? Math.abs(account.balance) : account.balance)}
                                            </span>
                                        </div>
                                    );
                                })}
                            </div>
                        </div>
                    </div>
                )}
            </div>
        </div>

        <!-- ==================== BUDGET vs ACTUAL ==================== -->
        <div id="report-analysis" class={tab !== "analysis" ? "hidden" : ""}>
            <div class="px-4 pb-6 space-y-4">
                {bvaRows.length === 0 ? (
                    <div class="bg-brand-cream-deep border border-brand-ink/10 rounded-xl p-8 text-center mt-2">
                        <p class="text-brand-ink-soft font-medium">{es ? "Sin datos para este mes" : "No data for this month"}</p>
                        <p class="text-sm text-brand-ink-soft mt-1">{es ? "Asigna presupuesto o registra gastos para comparar." : "Assign budget or record spending to compare."}</p>
                    </div>
                ) : (
                    <>
                        <div class="grid grid-cols-3 gap-2 mt-2">
                            <div class="bg-brand-cream rounded-xl border border-brand-ink/10 p-3 text-center">
                                <p class="text-[11px] uppercase tracking-wide text-brand-ink-soft">{es ? "Presupuestado" : "Budgeted"}</p>
                                <p class="text-lg font-extrabold text-brand-ink">{formatCurrency(bva.totals.budgeted)}</p>
                            </div>
                            <div class="bg-brand-cream rounded-xl border border-brand-ink/10 p-3 text-center">
                                <p class="text-[11px] uppercase tracking-wide text-brand-ink-soft">{es ? "Gastado" : "Spent"}</p>
                                <p class="text-lg font-extrabold text-red-600">{formatCurrency(Math.abs(bva.totals.actual))}</p>
                            </div>
                            <div class="bg-brand-cream rounded-xl border border-brand-ink/10 p-3 text-center">
                                <p class="text-[11px] uppercase tracking-wide text-brand-ink-soft">{es ? "Diferencia" : "Difference"}</p>
                                <p class={`text-lg font-extrabold ${bva.totals.diff >= 0 ? "text-brand-mint-deep" : "text-red-600"}`}>{formatCurrency(bva.totals.diff)}</p>
                            </div>
                        </div>
                        <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink/10 shadow-[var(--shadow-card)] overflow-hidden">
                            <div class="divide-y divide-brand-ink/10">
                                {bvaRows.map((c: any) => {
                                    const spent = Math.abs(c.actual);
                                    const pct = c.budgeted > 0 ? Math.min((spent / c.budgeted) * 100, 100) : (spent > 0 ? 100 : 0);
                                    const over = c.diff < 0;
                                    return (
                                        <div class="px-4 py-3">
                                            <div class="flex items-center justify-between mb-1">
                                                <span class="text-sm font-medium text-brand-ink truncate max-w-[50%]">{c.category_name} <span class="text-brand-ink-soft text-xs">· {c.group_name}</span></span>
                                                <span class={`text-xs font-bold ${over ? "text-red-600" : "text-brand-mint-deep"}`}>
                                                    {over ? (es ? "Excedido " : "Over ") : (es ? "Libre " : "Left ")}{formatCurrency(Math.abs(c.diff))}
                                                </span>
                                            </div>
                                            <div class="flex items-center gap-2 text-xs text-brand-ink-soft">
                                                <div class="flex-1 bg-brand-cream-deep rounded-full h-2 overflow-hidden">
                                                    <div class={`h-full ${over ? "bg-red-500" : "bg-brand-mint-deep"}`} style={`width: ${pct}%`}></div>
                                                </div>
                                                <span class="w-32 text-right tabular-nums">{formatCurrency(spent)} / {formatCurrency(c.budgeted)}</span>
                                            </div>
                                        </div>
                                    );
                                })}
                            </div>
                        </div>
                    </>
                )}
            </div>
        </div>
      </>
    )}

    <Fragment slot="overlays">
        <FABButton />
        <FABModal lang={lang} accounts={accounts} categories={allCategories} />
    </Fragment>
</BudgetShell>

<script>
function initReportTabs() {
    // Tab switching
    document.querySelectorAll(".report-tab").forEach(tab => {
        tab.addEventListener("click", () => {
            const el = tab as HTMLElement;
            const id = el.dataset.tab;
            if (!id) return;

            const url = new URL(window.location.href);
            url.searchParams.set("tab", id);
            history.replaceState(null, "", url.toString());

            // Toggle sections
            ["spending", "cashflow", "forecast", "networth", "analysis"].forEach(s => {
                document.getElementById("report-" + s)?.classList.toggle("hidden", s !== id);
            });

            // Toggle tab styles
            document.querySelectorAll(".report-tab").forEach(t => {
                const btn = t as HTMLElement;
                const isActive = btn.dataset.tab === id;
                btn.classList.toggle("bg-brand-sky-deep", isActive);
                btn.classList.toggle("text-white", isActive);
                btn.classList.toggle("bg-brand-cream-deep", !isActive);
                btn.classList.toggle("text-brand-ink-soft", !isActive);
            });
        });
    });

    // Forecast horizon switching (reloads to refetch, keeps the forecast tab)
    document.querySelectorAll(".horizon-btn").forEach(btn => {
        btn.addEventListener("click", () => {
            const el = btn as HTMLElement;
            const url = new URL(window.location.href);
            url.searchParams.set("tab", "forecast");
            url.searchParams.set("horizon", el.dataset.horizon || "30");
            window.location.href = url.toString();
        });
    });

    // Period switching
    document.querySelectorAll(".period-btn").forEach(btn => {
        btn.addEventListener("click", () => {
            const el = btn as HTMLElement;
            const url = new URL(window.location.href);
            url.searchParams.set("period", el.dataset.period || "3m");
            window.location.href = url.toString();
        });
    });

    // Prev/Next period arrows
    const periodOrder = ["1m", "3m", "6m", "1y"];
    function getCurrentPeriod(): string {
        return new URL(window.location.href).searchParams.get("period") || "3m";
    }
    document.getElementById("period-prev")?.addEventListener("click", () => {
        const cur = getCurrentPeriod();
        const idx = periodOrder.indexOf(cur);
        if (idx > 0) {
            const url = new URL(window.location.href);
            url.searchParams.set("period", periodOrder[idx - 1]);
            window.location.href = url.toString();
        }
    });
    document.getElementById("period-next")?.addEventListener("click", () => {
        const cur = getCurrentPeriod();
        const idx = periodOrder.indexOf(cur);
        if (idx < periodOrder.length - 1) {
            const url = new URL(window.location.href);
            url.searchParams.set("period", periodOrder[idx + 1]);
            window.location.href = url.toString();
        }
    });
}

initReportTabs();
document.addEventListener("astro:after-swap", initReportTabs);
</script>
