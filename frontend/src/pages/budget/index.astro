---
/**
 * Budget Hub + Month View Page
 * Main budget view showing monthly budget with category groups,
 * summary bar, FAB for quick expense, and assign-funds modal.
 */

import BudgetShell from "@components/ui/BudgetShell.astro";
import BudgetMonthNav from "@components/BudgetMonthNav.astro";
import MonthSummaryBar from "@components/MonthSummaryBar.astro";
import BudgetCategoryGroup from "@components/BudgetCategoryGroup.astro";
import AssignFundsModal from "@components/AssignFundsModal.astro";
import CoverOverspendingModal from "@components/CoverOverspendingModal.astro";
import MoveMoneyModal from "@components/MoveMoneyModal.astro";
import FABButton from "@components/FABButton.astro";
import FABModal from "@components/FABModal.astro";
import { apiFetch } from "@lib/api";
import { getMonthBudget, getCategoryGroups, formatCurrency, getMonthStatus } from "@lib/api/budget";
import { t } from "@lib/i18n";

// --- Auth ---
const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";

const { data: user, ok } = await apiFetch<any>("/api/auth/me", { token });
if (!ok) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}

if (user.role !== "parent") {
    return Astro.redirect("/dashboard");
}

// --- Month params from query string (default to current month) ---
const now = new Date();
const yearParam = Astro.url.searchParams.get("year");
const monthParam = Astro.url.searchParams.get("month");
const year = yearParam ? parseInt(yearParam, 10) : now.getFullYear();
const month = monthParam ? parseInt(monthParam, 10) : now.getMonth() + 1;

// --- Parallel data fetching ---
const [budgetRes, allGroupsRes, accountsRes, goalsRes, monthStatusRes, draftsCountRes] = await Promise.all([
    getMonthBudget(token, year, month),
    getCategoryGroups(token),
    apiFetch<any[]>("/api/budget/accounts/", { token }),
    apiFetch<any[]>("/api/budget/goals/", { token }),
    getMonthStatus(token, year, month),
    apiFetch<{count: number}>("/api/budget/receipt-drafts/count", { token }),
]);
const pendingDraftsCount = draftsCountRes.data?.count ?? 0;
const monthClosed = !!monthStatusRes.data?.is_closed;

const budget = budgetRes.data;
const allGroups = allGroupsRes.data;
const accounts = accountsRes.data || [];
const goals = goalsRes.data || [];

// --- Derived calculations ---
const incomeGroups = budget?.category_groups?.filter((g: any) => g.is_income) || [];
const expenseGroups = budget?.category_groups?.filter((g: any) => !g.is_income) || [];

const totalIncome = budget?.totals?.income ?? incomeGroups.reduce((sum: number, g: any) => sum + g.total_activity, 0);
const totalBudgeted = expenseGroups.reduce((sum: number, g: any) => sum + g.total_budgeted, 0);
const totalSpent = Math.abs(expenseGroups.reduce((sum: number, g: any) => sum + g.total_activity, 0));
const readyToAssign = budget?.ready_to_assign !== undefined ? budget.ready_to_assign : (totalIncome - totalBudgeted);

// --- Goals by category map ---
const goalsByCategory: Record<string, any> = {};
for (const goal of goals) {
    if (goal.category_id) {
        goalsByCategory[goal.category_id] = goal;
    }
}

// --- All expense categories (flat list for FAB & AssignFunds) ---
const allExpenseCategories = (allGroups || [])
    .filter((g: any) => !g.is_income)
    .flatMap((g: any) => g.categories.map((c: any) => ({ id: c.id, name: c.name, groupName: g.name, group_name: g.name })));

// --- All categories for FAB modal ---
const allCategories = (allGroups || [])
    .flatMap((g: any) => g.categories.map((c: any) => ({ id: c.id, name: c.name, group_name: g.name })));

// --- Jarvis entry point (P1-KIOSK #6) ---
// Suggested money questions deep-link into the Jarvis chat with the question
// pre-filled (/parent/jarvis?q=… — the chat page reads ?q into the composer).
const jarvisQuestions: string[] =
    lang === "es"
        ? [
              "¿Cuánto gastamos en comida este mes?",
              "¿En qué categorías nos pasamos del presupuesto este mes?",
              "¿Cuánto llevamos gastado esta semana y en qué?",
          ]
        : [
              "How much did we spend on food this month?",
              "Which categories are over budget this month?",
              "How much have we spent this week, and on what?",
          ];
---

<BudgetShell
    title={t(lang, 'fin_budget_home')}
    budgetActive="month"
    pendingDrafts={pendingDraftsCount}
    role={user.role}
    lang={lang}
    mainClass="px-4 py-4 space-y-3"
    containerClass="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto bg-brand-cream-deep min-h-screen pb-20"
>
    <div slot="after-nav">
        <!-- Header with month nav + ready to assign -->
        <header class="bg-brand-sky-deep text-white pt-3 pb-5 px-4 rounded-b-[var(--radius-tile)] shadow-[var(--shadow-card)]">
            <BudgetMonthNav
                year={year}
                month={month}
                readyToAssign={readyToAssign}
                lang={lang}
                t={t}
                formatCurrency={formatCurrency}
                baseRoute="/budget"
            />
        </header>

        <!-- Month summary bar -->
        <MonthSummaryBar
            income={totalIncome}
            spent={totalSpent}
            budgeted={totalBudgeted}
            lang={lang}
            formatCurrency={formatCurrency}
        />
    </div>

    {/* Budget cold start (P1-W3): with zero accounts nothing else works —
        transactions error out and every list is empty. Front-load account
        creation with an inline modal (no detour to /budget/settings). */}
    {accounts.length === 0 && (
        <div class="px-4 mt-3">
            <div class="bg-brand-cream rounded-2xl p-5 border-2 border-dashed border-brand-sky-deep/40 shadow-[var(--shadow-card)] text-center">
                <div class="text-4xl mb-2">🏦</div>
                <h2 class="font-bold text-brand-ink text-base mb-1">
                    {lang === "es" ? "Crea tu primera cuenta" : "Create your first account"}
                </h2>
                <p class="text-sm text-brand-ink-soft mb-4">
                    {lang === "es"
                        ? "Tu presupuesto vive en cuentas (banco, efectivo, tarjeta). Crea la primera para empezar a registrar gastos."
                        : "Your budget lives in accounts (bank, cash, card). Create the first one to start tracking spending."}
                </p>
                <button
                    type="button"
                    data-open-account-modal="reload"
                    class="px-5 py-2.5 rounded-xl bg-brand-sky-deep hover:bg-brand-ink text-white font-semibold text-sm shadow-[var(--shadow-card)] active:scale-[0.98] transition-all"
                >
                    + {lang === "es" ? "Nueva cuenta" : "New account"}
                </button>
            </div>
        </div>
    )}

    {/* Copy last month — exposes the existing auto-fill (copy_previous) so a
        parent can seed the whole month in one tap instead of one modal per
        category. Skips categories already budgeted (overwrite_existing=false). */}
    <div class="px-4 mt-3">
        <button
            type="button"
            id="copy-last-month"
            data-month={`${year}-${String(month).padStart(2, "0")}-01`}
            data-busy={lang === "es" ? "Copiando…" : "Copying…"}
            class="w-full py-2.5 rounded-xl border border-brand-sky-deep/30 bg-brand-sky-deep/10 text-brand-sky-deep font-semibold text-sm hover:bg-brand-sky-deep/20 transition-colors"
        >
            {lang === "es" ? "📋 Copiar presupuesto del mes anterior" : "📋 Copy last month's budget"}
        </button>
        <p id="copy-last-month-msg" class="text-xs text-brand-ink-soft mt-1 hidden text-center"></p>
        <div class="flex justify-center mt-1">
            <button type="button" id="autofill-more"
                class="text-xs text-brand-ink-soft underline hover:text-brand-sky-deep">
                {lang === "es" ? "Más estrategias ▾" : "More strategies ▾"}
            </button>
        </div>
        <div class="flex justify-center mt-1">
            <button type="button" id="month-lock-btn" data-closed={monthClosed ? "1" : "0"}
                data-year={year} data-month={month}
                class="text-xs underline text-brand-ink-soft hover:text-brand-sky-deep">
                {monthClosed
                    ? (lang === "es" ? "🔓 Reabrir este mes" : "🔓 Reopen this month")
                    : (lang === "es" ? "🔒 Cerrar este mes (bloquear cambios)" : "🔒 Close this month (lock changes)")}
            </button>
        </div>
        <div id="autofill-menu" class="hidden mt-1 rounded-xl border border-brand-ink/10 bg-brand-cream divide-y divide-brand-ink/10 text-sm">
            <button type="button" data-strategy="average_3" class="autofill-opt w-full px-4 py-2.5 text-left hover:bg-brand-cream-deep">
                {lang === "es" ? "Promedio de los últimos 3 meses" : "Average of last 3 months"}
            </button>
            <button type="button" data-strategy="average_6" class="autofill-opt w-full px-4 py-2.5 text-left hover:bg-brand-cream-deep">
                {lang === "es" ? "Promedio de los últimos 6 meses" : "Average of last 6 months"}
            </button>
            <button type="button" data-strategy="average_12" class="autofill-opt w-full px-4 py-2.5 text-left hover:bg-brand-cream-deep">
                {lang === "es" ? "Promedio de los últimos 12 meses" : "Average of last 12 months"}
            </button>
            <button type="button" data-strategy="from_goals" class="autofill-opt w-full px-4 py-2.5 text-left hover:bg-brand-cream-deep">
                {lang === "es" ? "Desde metas de categoría" : "From category goals"}
            </button>
        </div>
    </div>

    {/* Jarvis entry point — compact card with suggested money questions that
        deep-link into the chat with the question pre-filled. */}
    <div class="px-4">
        <div class="bg-brand-cream rounded-2xl p-3 border border-violet-200 shadow-[var(--shadow-card)]">
            <div class="flex items-center justify-between gap-2 mb-2">
                <p class="text-sm font-bold text-brand-ink">
                    🤖 {lang === "es" ? "Pregúntale a Jarvis" : "Ask Jarvis"}
                </p>
                <a href="/parent/jarvis" class="text-xs font-semibold text-violet-700 hover:underline whitespace-nowrap">
                    {lang === "es" ? "Abrir chat →" : "Open chat →"}
                </a>
            </div>
            <div class="flex flex-wrap gap-1.5">
                {jarvisQuestions.map((q) => (
                    <a
                        href={`/parent/jarvis?q=${encodeURIComponent(q)}`}
                        class="px-2.5 py-1.5 rounded-full bg-violet-100 text-violet-700 text-xs font-semibold hover:bg-violet-200 active:scale-95 transition-all"
                    >
                        {q}
                    </a>
                ))}
            </div>
        </div>
    </div>
    {/* Income groups */}
    {incomeGroups.map((group: any) => (
        <BudgetCategoryGroup
            group={group}
            isIncome={true}
            lang={lang}
            t={t}
            formatCurrency={formatCurrency}
            token={token}
            allExpenseCategories={allExpenseCategories}
            goalsByCategory={goalsByCategory}
        />
    ))}

    {/* Expense groups */}
    {expenseGroups.map((group: any) => (
        <BudgetCategoryGroup
            group={group}
            isIncome={false}
            lang={lang}
            t={t}
            formatCurrency={formatCurrency}
            token={token}
            allExpenseCategories={allExpenseCategories}
            goalsByCategory={goalsByCategory}
        />
    ))}

    {/* Empty state */}
    {incomeGroups.length === 0 && expenseGroups.length === 0 && (
        <div class="text-center py-12">
            <p class="text-brand-ink-soft text-sm">
                {lang === "es" ? "No hay categorias configuradas para este mes." : "No categories set up for this month."}
            </p>
            <a href="/budget/settings#categories" class="text-brand-sky-deep font-semibold text-sm mt-2 inline-block">
                {lang === "es" ? "Crear categorias" : "Create categories"}
            </a>
        </div>
    )}

    {/*
        FAB + modals — fixed-position overlays. overlays slot renders AFTER
        BottomNav (matches the pre-migration DOM: same-z-index sheets must
        paint over the nav, and DOM order decides that).
    */}
    <Fragment slot="overlays">
        <!-- FAB + modal -->
        <FABButton />
        <FABModal lang={lang} accounts={accounts} categories={allCategories} />

        <!-- Assign Funds modal (triggered from BudgetMonthNav ready-to-assign button) -->
<script>
    // "+" on each expense group header: create a category in that group.
    // Delegated once at page level (BudgetCategoryGroup renders many times).
    document.addEventListener("click", async (ev) => {
        const t = ev.target;
        const btn = t instanceof Element ? t.closest(".quick-add-btn") : null;
        if (!btn) return;
        const isEs = document.documentElement.lang !== "en";
        const name = prompt(
            (isEs ? "Nueva categoría en " : "New category in ") +
                (btn.getAttribute("data-group-name") || "") + ":"
        );
        if (!name || !name.trim()) return;
        // The /api/budget proxy injects the auth cookie server-side.
        const res = await fetch("/api/budget/categories/", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                group_id: btn.getAttribute("data-group-id"),
                name: name.trim(),
            }),
        });
        if (res.ok) {
            location.reload();
        } else {
            const data = await res.json().catch(() => ({}));
            alert(
                (isEs ? "No se pudo crear la categoría. " : "Could not create the category. ") +
                    (data.message || data.detail || "")
            );
        }
    });
</script>

        <MoveMoneyModal
            categories={allExpenseCategories}
            lang={lang}
            formatCurrency={formatCurrency}
            year={year}
            month={month}
        />

        <AssignFundsModal
            readyToAssign={readyToAssign}
            categories={allExpenseCategories}
            lang={lang}
            t={t}
            formatCurrency={formatCurrency}
            year={year}
            month={month}
        />

        <!-- Cover-overspending modal (P2) — opened by each overspent row's red
             "Cover" pill; moves available money from another category to cover
             the deficit within this month. -->
        <CoverOverspendingModal
            lang={lang}
            t={t}
            year={year}
            month={month}
        />
    </Fragment>
</BudgetShell>

<script>
    document.addEventListener("astro:page-load", () => {
        const btn = document.getElementById("copy-last-month") as HTMLButtonElement | null;
        const msg = document.getElementById("copy-last-month-msg");
        if (!btn) return;
        const es = document.documentElement.lang === "es";
        const lockBtn = document.getElementById("month-lock-btn");
        lockBtn?.addEventListener("click", async () => {
            const closed = lockBtn.dataset.closed === "1";
            const verb = closed
                ? (es ? "reabrir" : "reopen")
                : (es ? "cerrar" : "close");
            if (!window.confirm(closed
                ? (es ? "¿Reabrir este mes para permitir cambios?" : "Reopen this month to allow changes?")
                : (es ? "¿Cerrar este mes? Las asignaciones quedan bloqueadas hasta reabrir." : "Close this month? Allocations lock until reopened."))) return;
            try {
                const res = await fetch(`/api/budget/months/${lockBtn.dataset.year}/${lockBtn.dataset.month}/${closed ? "reopen" : "close"}`, { method: "POST" });
                if (!res.ok) throw new Error(String(res.status));
                window.location.reload();
            } catch {
                alert(es ? `No se pudo ${verb} el mes.` : `Could not ${verb} the month.`);
            }
        });
        document.getElementById("autofill-more")?.addEventListener("click", () => {
            document.getElementById("autofill-menu")?.classList.toggle("hidden");
        });
        document.querySelectorAll<HTMLButtonElement>(".autofill-opt").forEach((opt) => {
            opt.addEventListener("click", async () => {
                const strategy = opt.dataset.strategy;
                if (!window.confirm(es
                    ? "¿Llenar las categorías sin presupuesto con esta estrategia?"
                    : "Fill un-budgeted categories using this strategy?")) return;
                opt.disabled = true;
                try {
                    const res = await fetch("/api/budget/allocations/auto-fill", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            target_month: btn.dataset.month,
                            strategy,
                            overwrite_existing: false,
                        }),
                    });
                    if (!res.ok) throw new Error(String(res.status));
                    const data = await res.json();
                    if (data.filled_count > 0) { window.location.reload(); return; }
                    if (msg) {
                        msg.textContent = es
                            ? "No hay nada que llenar con esa estrategia."
                            : "Nothing to fill with that strategy.";
                        msg.classList.remove("hidden");
                    }
                } catch {
                    if (msg) {
                        msg.textContent = es ? "Error al llenar." : "Fill failed.";
                        msg.classList.remove("hidden");
                    }
                } finally {
                    opt.disabled = false;
                }
            });
        });
        btn.addEventListener("click", async () => {
            if (!window.confirm(es
                ? "¿Copiar los montos del mes anterior a las categorías sin presupuesto de este mes?"
                : "Copy last month's amounts into this month's un-budgeted categories?")) return;
            const original = btn.textContent;
            btn.disabled = true;
            btn.textContent = btn.dataset.busy || "…";
            try {
                // Same-origin proxy injects the httpOnly token.
                const res = await fetch("/api/budget/allocations/auto-fill", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        target_month: btn.dataset.month,
                        strategy: "copy_previous",
                        overwrite_existing: false,
                    }),
                });
                if (!res.ok) throw new Error(String(res.status));
                const data = await res.json();
                if (data.filled_count > 0) {
                    // Amounts changed — reload to show them.
                    window.location.reload();
                    return;
                }
                // Nothing to copy (no prior month, or all categories already
                // budgeted) — a silent reload looks like a failure, so say so.
                if (msg) {
                    msg.textContent = es
                        ? "No hay nada que copiar (el mes anterior está vacío o ya tienes presupuesto)."
                        : "Nothing to copy (last month is empty or already budgeted).";
                    msg.classList.remove("hidden");
                }
                btn.disabled = false;
                btn.textContent = original;
            } catch (e) {
                btn.disabled = false;
                btn.textContent = original;
                alert(es ? "No se pudo copiar el mes anterior." : "Could not copy last month.");
            }
        });
    });
</script>
