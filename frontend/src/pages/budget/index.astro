---
/**
 * Budget Hub + Month View Page
 * Main budget view showing monthly budget with category groups,
 * summary bar, FAB for quick expense, and assign-funds modal.
 */

import Layout from "@layouts/Layout.astro";
import BottomNav from "@components/BottomNav.astro";
import BudgetNavNew from "@components/BudgetNavNew.astro";
import DrawerMenu from "@components/DrawerMenu.astro";
import BudgetMonthNav from "@components/BudgetMonthNav.astro";
import MonthSummaryBar from "@components/MonthSummaryBar.astro";
import BudgetCategoryGroup from "@components/BudgetCategoryGroup.astro";
import AssignFundsModal from "@components/AssignFundsModal.astro";
import FABButton from "@components/FABButton.astro";
import FABModal from "@components/FABModal.astro";
import { apiFetch } from "@lib/api";
import { getMonthBudget, getCategoryGroups, formatCurrency, getMonthStatus } from "@lib/api/budget";
import { t } from "@lib/i18n";

// --- Auth ---
const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = (Astro.cookies.get("lang")?.value ?? "en") as "en" | "es";

const { data: user, ok } = await apiFetch<any>("/api/auth/me", { token });
if (!ok) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}

if (user.role !== "parent") {
    return Astro.redirect("/dashboard");
}

// --- Month params from query string (default to current month) ---
const now = new Date();
const yearParam = Astro.url.searchParams.get("year");
const monthParam = Astro.url.searchParams.get("month");
const year = yearParam ? parseInt(yearParam, 10) : now.getFullYear();
const month = monthParam ? parseInt(monthParam, 10) : now.getMonth() + 1;

// --- Parallel data fetching ---
const [budgetRes, allGroupsRes, accountsRes, goalsRes, monthStatusRes, draftsCountRes] = await Promise.all([
    getMonthBudget(token, year, month),
    getCategoryGroups(token),
    apiFetch<any[]>("/api/budget/accounts/", { token }),
    apiFetch<any[]>("/api/budget/goals/", { token }),
    getMonthStatus(token, year, month),
    apiFetch<{count: number}>("/api/budget/receipt-drafts/count", { token }),
]);
const pendingDraftsCount = draftsCountRes.data?.count ?? 0;

const budget = budgetRes.data;
const allGroups = allGroupsRes.data;
const accounts = accountsRes.data || [];
const goals = goalsRes.data || [];

// --- Derived calculations ---
const incomeGroups = budget?.category_groups?.filter((g: any) => g.is_income) || [];
const expenseGroups = budget?.category_groups?.filter((g: any) => !g.is_income) || [];

const totalIncome = budget?.totals?.income ?? incomeGroups.reduce((sum: number, g: any) => sum + g.total_activity, 0);
const totalBudgeted = expenseGroups.reduce((sum: number, g: any) => sum + g.total_budgeted, 0);
const totalSpent = Math.abs(expenseGroups.reduce((sum: number, g: any) => sum + g.total_activity, 0));
const readyToAssign = budget?.ready_to_assign !== undefined ? budget.ready_to_assign : (totalIncome - totalBudgeted);

// --- Goals by category map ---
const goalsByCategory: Record<string, any> = {};
for (const goal of goals) {
    if (goal.category_id) {
        goalsByCategory[goal.category_id] = goal;
    }
}

// --- All expense categories (flat list for FAB & AssignFunds) ---
const allExpenseCategories = (allGroups || [])
    .filter((g: any) => !g.is_income)
    .flatMap((g: any) => g.categories.map((c: any) => ({ id: c.id, name: c.name, groupName: g.name, group_name: g.name })));

// --- All categories for FAB modal ---
const allCategories = (allGroups || [])
    .flatMap((g: any) => g.categories.map((c: any) => ({ id: c.id, name: c.name, group_name: g.name })));
---

<Layout title={t(lang, 'fin_budget_home')}>
    <div class="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto bg-slate-50 min-h-screen pb-20">
        <!-- Top nav: 3 tabs -->
        <BudgetNavNew active="month" lang={lang} pendingDrafts={pendingDraftsCount} />

        <!-- Drawer menu (hidden, toggled by hamburger) -->
        <DrawerMenu lang={lang} />

        <!-- Header with month nav + ready to assign -->
        <header class="bg-primary-600 text-white pt-3 pb-5 px-4 rounded-b-3xl shadow-md">
            <BudgetMonthNav
                year={year}
                month={month}
                readyToAssign={readyToAssign}
                lang={lang}
                t={t}
                formatCurrency={formatCurrency}
                baseRoute="/budget"
            />
        </header>

        <!-- Month summary bar -->
        <MonthSummaryBar
            income={totalIncome}
            spent={totalSpent}
            budgeted={totalBudgeted}
            lang={lang}
            formatCurrency={formatCurrency}
        />

        <!-- Category groups -->
        <main class="px-4 py-4 space-y-3">
            {/* Income groups */}
            {incomeGroups.map((group: any) => (
                <BudgetCategoryGroup
                    group={group}
                    isIncome={true}
                    lang={lang}
                    t={t}
                    formatCurrency={formatCurrency}
                    token={token}
                    allExpenseCategories={allExpenseCategories}
                    goalsByCategory={goalsByCategory}
                />
            ))}

            {/* Expense groups */}
            {expenseGroups.map((group: any) => (
                <BudgetCategoryGroup
                    group={group}
                    isIncome={false}
                    lang={lang}
                    t={t}
                    formatCurrency={formatCurrency}
                    token={token}
                    allExpenseCategories={allExpenseCategories}
                    goalsByCategory={goalsByCategory}
                />
            ))}

            {/* Empty state */}
            {incomeGroups.length === 0 && expenseGroups.length === 0 && (
                <div class="text-center py-12">
                    <p class="text-slate-400 text-sm">
                        {lang === "es" ? "No hay categorias configuradas para este mes." : "No categories set up for this month."}
                    </p>
                    <a href="/budget/settings#categories" class="text-primary-600 font-semibold text-sm mt-2 inline-block">
                        {lang === "es" ? "Crear categorias" : "Create categories"}
                    </a>
                </div>
            )}
        </main>

        <!-- Bottom nav -->
        <BottomNav active="budget" role={user.role} lang={lang} />

        <!-- FAB + modal -->
        <FABButton />
        <FABModal lang={lang} token={token} accounts={accounts} categories={allCategories} />

        <!-- Assign Funds modal (triggered from BudgetMonthNav ready-to-assign button) -->
        <AssignFundsModal
            readyToAssign={readyToAssign}
            categories={allExpenseCategories}
            lang={lang}
            t={t}
            formatCurrency={formatCurrency}
        />
    </div>
</Layout>
