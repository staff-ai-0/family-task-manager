window.openRecurringModal = function(txn) {
    const isEdit = !!txn;
    const accOptions = accountsData.map(a =>
        `<option value="${a.id}" ${txn?.account_id === a.id ? 'selected' : ''}>${a.name}</option>`
    ).join('');
    const catOptions = allCategoriesData.map(c =>
        `<option value="${c.id}" ${txn?.category_id === c.id ? 'selected' : ''}>${c.group_name} → ${c.name}</option>`
    ).join('');

    document.getElementById("modal-title").textContent = isEdit ? (es ? "Editar recurrente" : "Edit Recurring") : (es ? "Nueva recurrente" : "New Recurring");
    // Determine current recurrence_type for edit, mapping legacy frequency values
    const currentRecType = txn?.recurrence_type || txn?.frequency || 'monthly_dayofmonth';
    document.getElementById("modal-body").innerHTML = `
        <div class="space-y-3">
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Nombre" : "Name"} *</label>
                <input id="rec-desc" type="text" value="${escapeHtml(txn?.name || txn?.description)}"
                    class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none">
            </div>
            <div class="flex gap-2">
                <div class="flex-1">
                    <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Monto ($)" : "Amount ($)"} *</label>
                    <input id="rec-amount" type="number" step="0.01" min="0.01"
                        value="${txn ? (Math.abs(txn.amount)/100).toFixed(2) : ''}"
                        class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none">
                </div>
                <div class="flex-1">
                    <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Tipo" : "Type"}</label>
                    <select id="rec-txtype" class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm bg-brand-cream focus:ring-2 focus:ring-brand-sky-deep outline-none">
                        <option value="expense" ${(txn ? txn.amount < 0 : true) ?'selected':''}>expense</option>
                        <option value="income" ${(txn && txn.amount > 0) ?'selected':''}>income</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Cuenta" : "Account"} *</label>
                <select id="rec-account" class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm bg-brand-cream focus:ring-2 focus:ring-brand-sky-deep outline-none">
                    <option value="">--</option>${accOptions}
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Categoría" : "Category"}</label>
                <select id="rec-category" class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm bg-brand-cream focus:ring-2 focus:ring-brand-sky-deep outline-none">
                    <option value="">--</option>${catOptions}
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Frecuencia" : "Frequency"}</label>
                <select id="rec-freq" class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm bg-brand-cream focus:ring-2 focus:ring-brand-sky-deep outline-none">
                    ${['daily','weekly','monthly_dayofmonth','monthly_dayofweek','yearly'].map(f =>
                        `<option value="${f}" ${currentRecType===f?'selected':''}>${f}</option>`
                    ).join('')}
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Fecha de inicio" : "Start date"} *</label>
                <input id="rec-date" type="date" value="${txn?.start_date || txn?.next_due_date || new Date().toISOString().split('T')[0]}"
                    class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none">
            </div>
            <div class="flex items-center gap-2">
                <input id="rec-active" type="checkbox" class="h-4 w-4 rounded" ${!txn || txn.is_active ? 'checked' : ''}>
                <label for="rec-active" class="text-sm text-brand-ink-soft">${es ? "Activa" : "Active"}</label>
            </div>
        </div>
    `;
    document.getElementById("settings-modal-overlay")?.classList.remove("hidden");
    document.getElementById("rec-desc").focus();

    setModalSaveHandler(async () => {
        const name = document.getElementById("rec-desc").value.trim();
        const rawAmt = parseFloat(document.getElementById("rec-amount").value || "0");
        const account_id = document.getElementById("rec-account").value;
        const start_date = document.getElementById("rec-date").value;
        if (!name) { showModalError(es ? "El nombre es requerido" : "Name required"); return; }
        if (rawAmt <= 0) { showModalError(es ? "Ingresa un monto mayor a 0" : "Enter an amount greater than 0"); return; }
        if (!account_id) { showModalError(es ? "Selecciona una cuenta" : "Select an account"); return; }
        if (!start_date) { showModalError(es ? "Selecciona una fecha" : "Select a date"); return; }
        const isExpense = document.getElementById("rec-txtype").value === "expense";
        try {
            const body = {
                name,
                amount: Math.round(rawAmt * 100) * (isExpense ? -1 : 1),
                account_id,
                category_id: document.getElementById("rec-category").value || null,
                recurrence_type: document.getElementById("rec-freq").value,
                start_date,
                is_active: document.getElementById("rec-active").checked,
            };
            if (isEdit) {
                await apiCall(`/api/budget/recurring-transactions/${txn.id}`, "PUT", body);
            } else {
                await apiCall("/api/budget/recurring-transactions/", "POST", body);
            }
            closeSettingsModal();
            showToast(isEdit ? (es ? "Actualizada" : "Updated") : (es ? "Creada" : "Created"));
            setTimeout(() => location.reload(), 800);
        } catch(e) { showModalError(e.message); }
    });
};

