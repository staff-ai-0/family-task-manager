            <div class="flex gap-2">
                <div class="flex-1">
                    <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Monto ($)" : "Amount ($)"} *</label>
                    <input id="goal-amount" type="number" step="0.01" min="0"
                        value="${g ? (Math.abs(g.target_amount)/100).toFixed(2) : ''}"
                        class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none">
                </div>
                <div class="flex-1">
                    <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Periodo" : "Period"}</label>
                    <select id="goal-period" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white focus:ring-2 focus:ring-primary-500 outline-none">
                        <option value="monthly" ${g?.period==='monthly'||!g?'selected':''}>${es ? 'Mensual' : 'Monthly'}</option>
                        <option value="quarterly" ${g?.period==='quarterly'?'selected':''}>${es ? 'Trimestral' : 'Quarterly'}</option>
                        <option value="annual" ${g?.period==='annual'?'selected':''}>${es ? 'Anual' : 'Annual'}</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Fecha inicio" : "Start date"} *</label>
                <input id="goal-start" type="date" value="${g?.start_date || new Date().toISOString().split('T')[0]}"
                    class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none">
            </div>
            <div class="flex items-center gap-2">
                <input id="goal-active" type="checkbox" class="h-4 w-4 rounded" ${!g || g.is_active ? 'checked' : ''}>
                <label for="goal-active" class="text-sm text-slate-600">${es ? "Activa" : "Active"}</label>
            </div>
        </div>
    `;
    document.getElementById("settings-modal-overlay")?.classList.remove("hidden");
    document.getElementById("goal-name").focus();

    setModalSaveHandler(async () => {
        const name = document.getElementById("goal-name").value.trim();
        const category_id = document.getElementById("goal-category").value;
        const rawAmt = parseFloat(document.getElementById("goal-amount").value || "0");
        const start_date = document.getElementById("goal-start").value;
        if (!name) { showModalError(es ? "El nombre es requerido" : "Name is required"); return; }
        if (!category_id) { showModalError(es ? "Selecciona una categoría" : "Select a category"); return; }
        if (!rawAmt) { showModalError(es ? "Ingresa un monto" : "Enter an amount"); return; }
        try {
            const body = {
                name,
                category_id,
                goal_type: document.getElementById("goal-type").value,
                target_amount: Math.round(rawAmt * 100),
                period: document.getElementById("goal-period").value,
                start_date,
                is_active: document.getElementById("goal-active").checked,
            };
            if (isEdit) {
                await apiCall(`/api/budget/goals/${g.id}`, "PUT", body);
            } else {
                await apiCall("/api/budget/goals/", "POST", body);
            }
            closeSettingsModal();
            showToast(isEdit ? (es ? "Meta actualizada" : "Goal updated") : (es ? "Meta creada" : "Goal created"));
            setTimeout(() => location.reload(), 800);
        } catch(e) { showModalError(e.message); }
    });
};

window.confirmDeleteGoal = function(id) {
    openConfirm(es ? "¿Eliminar esta meta?" : "Delete this goal?", async () => {
        try {
            await apiCall(`/api/budget/goals/${id}`, "DELETE");
            showToast(es ? "Meta eliminada" : "Goal deleted");
            setTimeout(() => location.reload(), 800);
        } catch(e) { showToast(e.message, "error"); }
    });
};

// ─── TAGS ─────────────────────────────────────────────────────────────────────

window.openTagModal = function(tag) {
    const isEdit = !!tag;
    document.getElementById("modal-title").textContent = isEdit ? (es ? "Editar etiqueta" : "Edit Tag") : (es ? "Nueva etiqueta" : "New Tag");
    document.getElementById("modal-body").innerHTML = `
        <div>
            <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Nombre" : "Name"} *</label>
            <input id="tag-name" type="text" value="${escapeHtml(tag?.name)}"
                class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none">
        </div>
    `;
    document.getElementById("settings-modal-overlay")?.classList.remove("hidden");
    document.getElementById("tag-name").focus();

    setModalSaveHandler(async () => {
        const name = document.getElementById("tag-name").value.trim();
        if (!name) { showModalError(es ? "El nombre es requerido" : "Name is required"); return; }
        try {
            if (isEdit) {
                await apiCall(`/api/budget/tags/${tag.id}`, "PUT", { name });
            } else {
                await apiCall("/api/budget/tags/", "POST", { name });
            }
            closeSettingsModal();
            showToast(isEdit ? (es ? "Etiqueta actualizada" : "Tag updated") : (es ? "Etiqueta creada" : "Tag created"));
            setTimeout(() => location.reload(), 800);
        } catch(e) { showModalError(e.message); }
    });
};

window.confirmDeleteTag = function(id) {
    openConfirm(es ? "¿Eliminar esta etiqueta?" : "Delete this tag?", async () => {
        try {
            await apiCall(`/api/budget/tags/${id}`, "DELETE");
            showToast(es ? "Etiqueta eliminada" : "Tag deleted");
            setTimeout(() => location.reload(), 800);
        } catch(e) { showToast(e.message, "error"); }
    });
};

// Close modals on overlay click
document.getElementById("settings-modal-overlay")?.addEventListener("click", (e) => {
    if (e.target === document.getElementById("settings-modal-overlay")) closeSettingsModal();
});
document.getElementById("confirm-overlay")?.addEventListener("click", (e) => {
    if (e.target === document.getElementById("confirm-overlay")) closeConfirm();
});
</script>
