// Favorite toggle
document.querySelectorAll(".favorite-btn").forEach(btn => {
    btn.addEventListener("click", async () => {
        const id = btn.dataset.payeeId;
        const isFav = btn.dataset.favorite === "1";
        try {
            await apiCall(`/api/budget/payees/${id}`, "PUT", { is_favorite: !isFav });
            btn.dataset.favorite = isFav ? "0" : "1";
            btn.className = `favorite-btn text-base transition ${!isFav ? 'text-amber-400 hover:text-amber-300' : 'text-slate-300 hover:text-amber-400'}`;
        } catch(e) { showToast(e.message, "error"); }
    });
});

// ─── CATEGORIZATION RULES ─────────────────────────────────────────────────────

window.openRuleModal = function(rule) {
    const isEdit = !!rule;
    const catOptions = allCategoriesData.map(c =>
        `<option value="${c.id}" ${rule?.category_id === c.id ? 'selected' : ''}>${c.group_name} → ${c.name}</option>`
    ).join('');

    document.getElementById("modal-title").textContent = isEdit ? (es ? "Editar regla" : "Edit Rule") : (es ? "Nueva regla" : "New Rule");
    document.getElementById("modal-body").innerHTML = `
        <div class="space-y-3">
            <div>
                <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Patrón" : "Pattern"} *</label>
                <input id="rule-pattern" type="text" value="${escapeHtml(rule?.pattern)}" placeholder="Netflix"
                    class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none">
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Tipo de coincidencia" : "Match type"}</label>
                <select id="rule-type" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white focus:ring-2 focus:ring-primary-500 outline-none">
                    <option value="contains" ${rule?.rule_type==='contains'?'selected':''}>contains</option>
                    <option value="exact" ${rule?.rule_type==='exact'?'selected':''}>exact</option>
                    <option value="startswith" ${rule?.rule_type==='startswith'?'selected':''}>startswith</option>
                    <option value="regex" ${rule?.rule_type==='regex'?'selected':''}>regex</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Aplicar a" : "Match field"}</label>
                <select id="rule-field" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white focus:ring-2 focus:ring-primary-500 outline-none">
                    <option value="payee" ${rule?.match_field==='payee'?'selected':''}>payee</option>
                    <option value="description" ${rule?.match_field==='description'?'selected':''}>description</option>
                    <option value="both" ${rule?.match_field==='both'?'selected':''}>both</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Categoría" : "Category"} *</label>
                <select id="rule-category" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white focus:ring-2 focus:ring-primary-500 outline-none">
                    <option value="">--</option>${catOptions}
                </select>
            </div>
            <div class="flex items-center gap-2">
                <input id="rule-enabled" type="checkbox" class="h-4 w-4 rounded" ${!rule || rule.enabled ? 'checked' : ''}>
                <label for="rule-enabled" class="text-sm text-slate-600">${es ? "Activa" : "Enabled"}</label>
            </div>
        </div>
    `;
    document.getElementById("settings-modal-overlay")?.classList.remove("hidden");
    document.getElementById("rule-pattern").focus();

    setModalSaveHandler(async () => {
        const pattern = document.getElementById("rule-pattern").value.trim();
        const category_id = document.getElementById("rule-category").value;
        if (!pattern) { showModalError(es ? "El patrón es requerido" : "Pattern is required"); return; }
        if (!category_id) { showModalError(es ? "Selecciona una categoría" : "Select a category"); return; }
        try {
            const body = {
                pattern,
                rule_type: document.getElementById("rule-type").value,
                match_field: document.getElementById("rule-field").value,
                category_id,
                enabled: document.getElementById("rule-enabled").checked,
            };
            if (isEdit) {
                await apiCall(`/api/budget/categorization-rules/${rule.id}`, "PUT", body);
            } else {
                await apiCall("/api/budget/categorization-rules/", "POST", body);
            }
            closeSettingsModal();
            showToast(isEdit ? (es ? "Regla actualizada" : "Rule updated") : (es ? "Regla creada" : "Rule created"));
            setTimeout(() => location.reload(), 800);
        } catch(e) { showModalError(e.message); }
    });
};

window.confirmDeleteRule = function(id) {
    openConfirm(es ? "¿Eliminar esta regla?" : "Delete this rule?", async () => {
        try {
            await apiCall(`/api/budget/categorization-rules/${id}`, "DELETE");
            showToast(es ? "Regla eliminada" : "Rule deleted");
            setTimeout(() => location.reload(), 800);
        } catch(e) { showToast(e.message, "error"); }
    });
};

// ─── RECURRING TRANSACTIONS ───────────────────────────────────────────────────

window.openRecurringModal = function(txn) {
    const isEdit = !!txn;
    const accOptions = accountsData.map(a =>
        `<option value="${a.id}" ${txn?.account_id === a.id ? 'selected' : ''}>${a.name}</option>`
    ).join('');
    const catOptions = allCategoriesData.map(c =>
        `<option value="${c.id}" ${txn?.category_id === c.id ? 'selected' : ''}>${c.group_name} → ${c.name}</option>`
    ).join('');

    document.getElementById("modal-title").textContent = isEdit ? (es ? "Editar recurrente" : "Edit Recurring") : (es ? "Nueva recurrente" : "New Recurring");
    // Determine current recurrence_type for edit, mapping legacy frequency values
    const currentRecType = txn?.recurrence_type || txn?.frequency || 'monthly_dayofmonth';
    document.getElementById("modal-body").innerHTML = `
        <div class="space-y-3">
            <div>
                <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Nombre" : "Name"} *</label>
                <input id="rec-desc" type="text" value="${escapeHtml(txn?.name || txn?.description)}"
                    class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none">
            </div>
            <div class="flex gap-2">
                <div class="flex-1">
                    <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Monto ($)" : "Amount ($)"} *</label>
                    <input id="rec-amount" type="number" step="0.01" min="0.01"
                        value="${txn ? (Math.abs(txn.amount)/100).toFixed(2) : ''}"
                        class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none">
                </div>
                <div class="flex-1">
                    <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Tipo" : "Type"}</label>
                    <select id="rec-txtype" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white focus:ring-2 focus:ring-primary-500 outline-none">
                        <option value="expense" ${(txn ? txn.amount < 0 : true) ?'selected':''}>expense</option>
                        <option value="income" ${(txn && txn.amount > 0) ?'selected':''}>income</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Cuenta" : "Account"} *</label>
                <select id="rec-account" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white focus:ring-2 focus:ring-primary-500 outline-none">
                    <option value="">--</option>${accOptions}
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Categoría" : "Category"}</label>
                <select id="rec-category" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white focus:ring-2 focus:ring-primary-500 outline-none">
                    <option value="">--</option>${catOptions}
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Frecuencia" : "Frequency"}</label>
                <select id="rec-freq" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white focus:ring-2 focus:ring-primary-500 outline-none">
                    ${['daily','weekly','monthly_dayofmonth','monthly_dayofweek','yearly'].map(f =>
                        `<option value="${f}" ${currentRecType===f?'selected':''}>${f}</option>`
                    ).join('')}
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-500 mb-1">${es ? "Fecha de inicio" : "Start date"} *</label>
                <input id="rec-date" type="date" value="${txn?.start_date || txn?.next_due_date || new Date().toISOString().split('T')[0]}"
                    class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none">
            </div>
            <div class="flex items-center gap-2">
                <input id="rec-active" type="checkbox" class="h-4 w-4 rounded" ${!txn || txn.is_active ? 'checked' : ''}>
                <label for="rec-active" class="text-sm text-slate-600">${es ? "Activa" : "Active"}</label>
            </div>
        </div>
    `;
    document.getElementById("settings-modal-overlay")?.classList.remove("hidden");
    document.getElementById("rec-desc").focus();

    setModalSaveHandler(async () => {
        const name = document.getElementById("rec-desc").value.trim();
        const rawAmt = parseFloat(document.getElementById("rec-amount").value || "0");
        const account_id = document.getElementById("rec-account").value;
        const start_date = document.getElementById("rec-date").value;
        if (!name) { showModalError(es ? "El nombre es requerido" : "Name required"); return; }
        if (rawAmt <= 0) { showModalError(es ? "Ingresa un monto mayor a 0" : "Enter an amount greater than 0"); return; }
        if (!account_id) { showModalError(es ? "Selecciona una cuenta" : "Select an account"); return; }
        if (!start_date) { showModalError(es ? "Selecciona una fecha" : "Select a date"); return; }
        const isExpense = document.getElementById("rec-txtype").value === "expense";
        try {
            const body = {
                name,
                amount: Math.round(rawAmt * 100) * (isExpense ? -1 : 1),
                account_id,
                category_id: document.getElementById("rec-category").value || null,
                recurrence_type: document.getElementById("rec-freq").value,
                start_date,
                is_active: document.getElementById("rec-active").checked,
            };
            if (isEdit) {
                await apiCall(`/api/budget/recurring-transactions/${txn.id}`, "PUT", body);
            } else {
                await apiCall("/api/budget/recurring-transactions/", "POST", body);
            }
            closeSettingsModal();
            showToast(isEdit ? (es ? "Actualizada" : "Updated") : (es ? "Creada" : "Created"));
            setTimeout(() => location.reload(), 800);
        } catch(e) { showModalError(e.message); }
    });
};

window.confirmDeleteRecurring = function(id) {
    openConfirm(es ? "¿Eliminar esta recurrente?" : "Delete this recurring transaction?", async () => {
        try {
            await apiCall(`/api/budget/recurring-transactions/${id}`, "DELETE");
            showToast(es ? "Eliminada" : "Deleted");
            setTimeout(() => location.reload(), 800);
        } catch(e) { showToast(e.message, "error"); }
    });
};

window.postRecurring = function(id) {
    openConfirm(es ? "¿Registrar esta transacción hoy?" : "Post this transaction for today?", async () => {
        try {
            await apiCall(`/api/budget/recurring-transactions/${id}/post`, "POST");
            showToast(es ? "Transacción registrada" : "Transaction posted");
        } catch(e) { showToast(e.message, "error"); }
    });
};

// ─── GOALS ────────────────────────────────────────────────────────────────────

window.openGoalModal = function(g) {
