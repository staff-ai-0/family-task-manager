---
/**
 * Budget Settings - Full CRUD for accounts, payees, rules, recurring, goals, tags.
 */

import BudgetShell from "@components/ui/BudgetShell.astro";
import SettingsAccordion from "@components/SettingsAccordion.astro";
import { apiFetch } from "@lib/api";
import { formatCurrency } from "@lib/api/budget";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";
const es = lang === "es";

const { data: user, ok } = await apiFetch<any>("/api/auth/me", { token });
if (!ok) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}

const { data: draftsCount } = await apiFetch<{count: number}>("/api/budget/receipt-drafts/count", { token });
const pendingDraftsCount = draftsCount?.count ?? 0;

if (user.role !== "parent") return Astro.redirect("/dashboard");

// Parallel fetch all settings data
const [accountsRes, payeesRes, rulesRes, recurringRes, goalsRes, tagsRes, groupsRes, aiModelsRes, aiUsageRes] = await Promise.all([
    apiFetch<any[]>("/api/budget/accounts/", { token }),
    apiFetch<any[]>("/api/budget/payees/", { token }),
    apiFetch<any[]>("/api/budget/categorization-rules/", { token }),
    apiFetch<any[]>("/api/budget/recurring-transactions/", { token }),
    apiFetch<any[]>("/api/budget/goals/", { token }),
    apiFetch<any[]>("/api/budget/tags/", { token }),
    apiFetch<any[]>("/api/budget/categories/groups", { token }),
    apiFetch<any>("/api/budget/ai-settings/models", { token }),
    apiFetch<any>("/api/budget/ai-settings/usage", { token }),
]);

const accounts = accountsRes.data || [];
const payees = payeesRes.data || [];
const rules = rulesRes.data || [];
const recurring = recurringRes.data || [];
const goals = goalsRes.data || [];
const tags = tagsRes.data || [];
const groups = groupsRes.data || [];
const aiModels = aiModelsRes.data || { current_model: "gemini-2.5-flash", models: [] };
const aiUsage = aiUsageRes.data || null;

const allCategories = groups.flatMap((g: any) =>
    (g.categories || []).map((c: any) => ({ id: c.id, name: c.name, group_name: g.name }))
);

const accountTypeLabel = (type: string) => {
    const labels: Record<string, string> = {
        checking: es ? "Cheques" : "Checking", savings: es ? "Ahorros" : "Savings",
        credit_card: es ? "Tarjeta de crédito" : "Credit Card", cash: es ? "Efectivo" : "Cash",
        investment: es ? "Inversión" : "Investment", loan: es ? "Préstamo" : "Loan", other: es ? "Otro" : "Other",
        credit: es ? "Crédito" : "Credit",
    };
    return labels[type] || type;
};

const frequencyLabel = (freq: string) => {
    const labels: Record<string, string> = {
        daily: es ? "Diaria" : "Daily",
        weekly: es ? "Semanal" : "Weekly",
        biweekly: es ? "Quincenal" : "Biweekly",
        monthly: es ? "Mensual" : "Monthly",
        monthly_dayofmonth: es ? "Mensual" : "Monthly",
        monthly_dayofweek: es ? "Mensual (día de semana)" : "Monthly (weekday)",
        quarterly: es ? "Trimestral" : "Quarterly",
        annual: es ? "Anual" : "Annual",
        yearly: es ? "Anual" : "Annual",
    };
    return labels[freq] || freq;
};
---

<BudgetShell
    title={`${es ? "Configuración" : "Settings"} - Budget`}
    budgetActive="none"
    pendingDrafts={pendingDraftsCount}
    role={user.role}
    lang={lang}
    mainClass="px-4 py-4 flex-1"
    containerClass="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto bg-brand-cream-deep min-h-screen flex flex-col"
>
    <div slot="after-nav" class="px-4 pt-6 pb-2">
        <h1 class="text-xl font-bold text-brand-ink">{es ? "Configuración" : "Settings"}</h1>
        <p class="text-sm text-brand-ink-soft mt-1">{es ? "Gestiona cuentas, beneficiarios, reglas y más" : "Manage accounts, payees, rules & more"}</p>
    </div>

        <!-- ACCOUNTS -->
        <SettingsAccordion id="accounts" title={es ? "Cuentas" : "Accounts"} icon="🏦">
            <div class="flex justify-end gap-2 mb-3">
                <button onclick="openTransferModal()" class="px-3 py-1.5 border border-brand-sky-deep text-brand-sky-deep hover:bg-brand-sky-deep hover:text-white text-sm font-semibold rounded-lg transition">
                    ⇄ {es ? "Transferir" : "Transfer"}
                </button>
                <button onclick="openAccountModal()" class="px-3 py-1.5 bg-brand-sky-deep hover:bg-brand-ink text-white text-sm font-semibold rounded-lg transition">
                    + {es ? "Nueva cuenta" : "New account"}
                </button>
            </div>
            {accounts.length === 0 ? (
                <p class="text-sm text-brand-ink-soft text-center py-4">{es ? "No hay cuentas" : "No accounts yet"}</p>
            ) : (
                <div class="divide-y divide-brand-ink/10">
                    {accounts.map((acc: any) => (
                        <div class="flex items-center justify-between py-3 -mx-4 px-4">
                            <div>
                                <p class="text-sm font-medium text-brand-ink">{acc.name}</p>
                                <p class="text-xs text-brand-ink-soft">{accountTypeLabel(acc.account_type || acc.type)}</p>
                                {acc.notes && <p class="text-xs text-brand-ink-soft">{acc.notes}</p>}
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="text-sm font-semibold text-brand-ink">
                                    {formatCurrency(acc.balance_cents ?? acc.balance ?? 0)}
                                </span>
                                <button onclick={`openReconcileModal('${acc.id}','${acc.name.replace(/'/g,"\\'")}')`}
                                    title={es ? "Conciliar" : "Reconcile"}
                                    class="text-brand-ink-soft hover:text-brand-mint-deep transition text-sm font-semibold">
                                    ✓$
                                </button>
                                <button onclick={`openAccountModal(${JSON.stringify(acc)})`}
                                    class="text-brand-ink-soft hover:text-brand-sky-deep transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </button>
                                <button onclick={`confirmDeleteAccount('${acc.id}','${acc.name.replace(/'/g,"\\'")}' )`}
                                    class="text-brand-ink-soft hover:text-red-600 transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    ))}
                </div>
            )}
        </SettingsAccordion>

        <!-- CATEGORIES -->
        <SettingsAccordion id="categories" title={es ? "Categorías" : "Categories"} icon="🏷️">
            <div class="flex justify-end mb-3">
                <button onclick="promptNewGroup()" class="px-3 py-1.5 bg-brand-sky-deep hover:bg-brand-ink text-white text-sm font-semibold rounded-lg transition">
                    + {es ? "Nuevo grupo" : "New group"}
                </button>
            </div>
            {groups.length === 0 ? (
                <p class="text-sm text-brand-ink-soft text-center py-4">{es ? "No hay categorías" : "No categories yet"}</p>
            ) : (
                <div class="space-y-4">
                    {groups.map((g: any) => (
                        <div class="border border-brand-ink/10 rounded-xl overflow-hidden">
                            <div class={`flex items-center justify-between px-3 py-2 ${g.is_income ? "bg-brand-mint/15" : "bg-brand-cream-deep"}`}>
                                <span class={`text-sm font-bold ${g.hidden ? "line-through text-brand-ink-soft" : "text-brand-ink"}`}>
                                    {g.name}{g.is_income ? " 💰" : ""}
                                </span>
                                <div class="flex items-center gap-2 text-xs">
                                    <button onclick={`promptRenameGroup('${g.id}','${(g.name||"").replace(/'/g,"\'")}')`}
                                        class="text-brand-ink-soft hover:text-brand-sky-deep underline">{es ? "Renombrar" : "Rename"}</button>
                                    <button onclick={`toggleGroupHidden('${g.id}',${g.hidden ? "false" : "true"})`}
                                        class="text-brand-ink-soft hover:text-brand-sky-deep underline">
                                        {g.hidden ? (es ? "Mostrar" : "Unhide") : (es ? "Ocultar" : "Hide")}
                                    </button>
                                    <button onclick={`promptAddCategory('${g.id}','${(g.name||"").replace(/'/g,"\'")}')`}
                                        class="text-brand-ink-soft hover:text-brand-sky-deep underline">+ {es ? "Categoría" : "Category"}</button>
                                    <button onclick={`confirmDeleteGroup('${g.id}','${(g.name||"").replace(/'/g,"\'")}')`}
                                        class="text-brand-ink-soft hover:text-red-600 underline">{es ? "Eliminar" : "Delete"}</button>
                                </div>
                            </div>
                            <div class="divide-y divide-brand-ink/10">
                                {(g.categories || []).map((c: any) => (
                                    <div class="flex items-center justify-between px-3 py-2">
                                        <span class={`text-sm ${c.hidden ? "line-through text-brand-ink-soft" : "text-brand-ink"}`}>{c.name}</span>
                                        <div class="flex items-center gap-2 text-xs">
                                            <button onclick={`promptRenameCategory('${c.id}','${(c.name||"").replace(/'/g,"\'")}')`}
                                                class="text-brand-ink-soft hover:text-brand-sky-deep underline">{es ? "Renombrar" : "Rename"}</button>
                                            <button onclick={`toggleCategoryHidden('${c.id}',${c.hidden ? "false" : "true"})`}
                                                class="text-brand-ink-soft hover:text-brand-sky-deep underline">
                                                {c.hidden ? (es ? "Mostrar" : "Unhide") : (es ? "Ocultar" : "Hide")}
                                            </button>
                                            <button onclick={`confirmDeleteCategory('${c.id}','${(c.name||"").replace(/'/g,"\'")}')`}
                                                class="text-brand-ink-soft hover:text-red-600 underline">{es ? "Eliminar" : "Delete"}</button>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            )}
            <p class="text-xs text-brand-ink-soft mt-3">
                {es
                    ? "Eliminar manda a la Papelera (restaurable). Ocultar solo la esconde de las listas."
                    : "Delete moves to the Recycle Bin (restorable). Hide only removes it from pickers."}
            </p>
        </SettingsAccordion>

        <!-- PAYEES -->
        <SettingsAccordion id="payees" title={es ? "Beneficiarios" : "Payees"} icon="👤">
            <div class="flex justify-end mb-3">
                <button onclick="openPayeeModal()" class="px-3 py-1.5 bg-brand-sky-deep hover:bg-brand-ink text-white text-sm font-semibold rounded-lg transition">
                    + {es ? "Nuevo" : "New"}
                </button>
            </div>
            {payees.length === 0 ? (
                <p class="text-sm text-brand-ink-soft text-center py-4">{es ? "No hay beneficiarios" : "No payees yet"}</p>
            ) : (
                <div class="divide-y divide-brand-ink/10">
                    {payees.map((p: any) => (
                        <div class="flex items-center justify-between py-2.5">
                            <span class="text-sm text-brand-ink">{p.name}</span>
                            <div class="flex items-center gap-2">
                                <button
                                    class={`favorite-btn text-base transition ${p.is_favorite ? 'text-amber-400 hover:text-amber-300' : 'text-brand-ink-soft hover:text-amber-400'}`}
                                    data-payee-id={p.id}
                                    data-favorite={p.is_favorite ? "1" : "0"}
                                    title={es ? "Favorito" : "Favorite"}
                                >&#9733;</button>
                                <button onclick={`openPayeeModal(${JSON.stringify(p)})`}
                                    class="text-brand-ink-soft hover:text-brand-sky-deep transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </button>
                                <button onclick={`confirmDeletePayee('${p.id}','${p.name.replace(/'/g,"\\'")}' )`}
                                    class="text-brand-ink-soft hover:text-red-600 transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    ))}
                </div>
            )}
        </SettingsAccordion>

        <!-- CATEGORIZATION RULES -->
        <SettingsAccordion id="rules" title={es ? "Reglas de categorización" : "Categorization Rules"} icon="🤖">
            <div class="flex justify-end mb-3">
                <button onclick="openRuleModal()" class="px-3 py-1.5 bg-brand-sky-deep hover:bg-brand-ink text-white text-sm font-semibold rounded-lg transition">
                    + {es ? "Nueva regla" : "New rule"}
                </button>
            </div>
            {rules.length === 0 ? (
                <p class="text-sm text-brand-ink-soft text-center py-4">{es ? "No hay reglas" : "No rules yet"}</p>
            ) : (
                <div class="divide-y divide-brand-ink/10">
                    {rules.map((rule: any) => (
                        <div class="py-2.5 flex items-start justify-between gap-2">
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-1.5 flex-wrap">
                                    <span class="text-sm font-medium text-brand-ink">"{rule.pattern}"</span>
                                    <span class="text-xs text-brand-ink-soft">&rarr;</span>
                                    <span class="text-sm text-brand-ink-soft">{rule.category?.name || (es ? "Sin cat." : "No cat.")}</span>
                                    <span class="px-1.5 py-0.5 text-[10px] font-semibold rounded bg-brand-cream-deep text-brand-ink-soft uppercase">{rule.rule_type}</span>
                                    {!rule.enabled && (
                                        <span class="px-1.5 py-0.5 text-[10px] font-semibold rounded bg-brand-sun/20 text-brand-ink">{es ? "Inactiva" : "Off"}</span>
                                    )}
                                </div>
                            </div>
                            <div class="flex items-center gap-1.5 flex-shrink-0">
                                <button onclick={`openRuleModal(${JSON.stringify(rule)})`} class="text-brand-ink-soft hover:text-brand-sky-deep transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </button>
                                <button onclick={`confirmDeleteRule('${rule.id}')`} class="text-brand-ink-soft hover:text-red-600 transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    ))}
                </div>
            )}
        </SettingsAccordion>

        <!-- RECURRING TRANSACTIONS -->
        <SettingsAccordion id="recurring" title={es ? "Transacciones recurrentes" : "Recurring Transactions"} icon="🔄">
            <div class="flex justify-end mb-3">
                <button onclick="openRecurringModal()" class="px-3 py-1.5 bg-brand-sky-deep hover:bg-brand-ink text-white text-sm font-semibold rounded-lg transition">
                    + {es ? "Nueva" : "New"}
                </button>
            </div>
            {recurring.length === 0 ? (
                <p class="text-sm text-brand-ink-soft text-center py-4">{es ? "No hay recurrentes" : "No recurring transactions yet"}</p>
            ) : (
                <div class="divide-y divide-brand-ink/10">
                    {recurring.map((txn: any) => (
                        <div class="py-2.5 flex items-center justify-between gap-2">
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-brand-ink truncate">{txn.name || txn.description}</p>
                                <p class="text-xs text-brand-ink-soft">
                                    {frequencyLabel(txn.recurrence_type || txn.frequency)}
                                    {txn.next_due_date && <span> · {es ? "Prox:" : "Next:"} {txn.next_due_date}</span>}
                                    {!txn.is_active && <span class="ml-1 text-yellow-600">({es ? "inactiva" : "inactive"})</span>}
                                </p>
                            </div>
                            <div class="flex items-center gap-1.5 flex-shrink-0">
                                <span class={`text-sm font-semibold ${txn.amount > 0 ? 'text-brand-mint-deep' : 'text-red-600'}`}>
                                    {txn.amount > 0 ? '+' : '-'}{formatCurrency(Math.abs(txn.amount))}
                                </span>
                                <button onclick={`postRecurring('${txn.id}')`}
                                    class="text-brand-ink-soft hover:text-brand-mint-deep transition" title={es ? "Registrar ahora" : "Post now"}>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                </button>
                                <button onclick={`openRecurringModal(${JSON.stringify(txn)})`} class="text-brand-ink-soft hover:text-brand-sky-deep transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </button>
                                <button onclick={`confirmDeleteRecurring('${txn.id}')`} class="text-brand-ink-soft hover:text-red-600 transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    ))}
                </div>
            )}
        </SettingsAccordion>

        <!-- GOALS -->
        <SettingsAccordion id="goals" title={es ? "Metas" : "Goals"} icon="🎯">
            <div class="flex justify-end mb-3">
                <button onclick="openGoalModal()" class="px-3 py-1.5 bg-brand-sky-deep hover:bg-brand-ink text-white text-sm font-semibold rounded-lg transition">
                    + {es ? "Nueva meta" : "New goal"}
                </button>
            </div>
            {goals.length === 0 ? (
                <p class="text-sm text-brand-ink-soft text-center py-4">{es ? "No hay metas" : "No goals yet"}</p>
            ) : (
                <div class="divide-y divide-brand-ink/10">
                    {goals.map((g: any) => (
                        <div class="py-2.5 flex items-center justify-between gap-2">
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-brand-ink truncate">{g.name}</p>
                                <p class="text-xs text-brand-ink-soft">
                                    {g.goal_type === 'spending_limit' ? (es ? 'Límite de gasto' : 'Spending limit') : (es ? 'Meta de ahorro' : 'Savings target')}
                                    {' · '}{formatCurrency(g.target_amount)}
                                    {' · '}{g.period}
                                    {!g.is_active && <span class="ml-1 text-yellow-600">({es ? 'inactiva' : 'inactive'})</span>}
                                </p>
                            </div>
                            <div class="flex items-center gap-1.5 flex-shrink-0">
                                <button onclick={`openGoalModal(${JSON.stringify(g)})`} class="text-brand-ink-soft hover:text-brand-sky-deep transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </button>
                                <button onclick={`confirmDeleteGoal('${g.id}')`} class="text-brand-ink-soft hover:text-red-600 transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    ))}
                </div>
            )}
        </SettingsAccordion>

        <!-- TAGS -->
        <SettingsAccordion id="tags" title={es ? "Etiquetas" : "Tags"} icon="🏷️">
            <div class="flex justify-end mb-3">
                <button onclick="openTagModal()" class="px-3 py-1.5 bg-brand-sky-deep hover:bg-brand-ink text-white text-sm font-semibold rounded-lg transition">
                    + {es ? "Nueva etiqueta" : "New tag"}
                </button>
            </div>
            {tags.length === 0 ? (
                <p class="text-sm text-brand-ink-soft text-center py-4">{es ? "No hay etiquetas" : "No tags yet"}</p>
            ) : (
                <div class="flex flex-wrap gap-2">
                    {tags.map((tag: any) => (
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-brand-cream-deep rounded-full text-sm text-brand-ink">
                            {tag.name}
                            <button onclick={`openTagModal(${JSON.stringify(tag)})`} class="text-brand-ink-soft hover:text-brand-sky-deep transition">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                            </button>
                            <button onclick={`confirmDeleteTag('${tag.id}')`} class="text-brand-ink-soft hover:text-red-600 transition">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </button>
                        </span>
                    ))}
                </div>
            )}
        </SettingsAccordion>

        <!-- AI & SCANNER -->
        <SettingsAccordion id="ai-scanner" title={es ? "IA y escáner" : "AI & Scanner"} icon="🤖">
            <!-- Model selector -->
            <div class="mb-5">
                <label class="block text-sm font-semibold text-brand-ink mb-1.5">
                    {es ? "Modelo de visión para recibos" : "Vision model for receipts"}
                </label>
                <p class="text-xs text-brand-ink-soft mb-2">
                    {es ? "Modelo usado al escanear recibos. Se aplica a toda la familia." : "Model used when scanning receipts. Applies to the whole family."}
                </p>
                <div class="flex gap-2">
                    <select id="ai-model-select" class="flex-1 py-2 px-3 border border-brand-ink/10 rounded-lg text-sm bg-brand-cream focus:ring-2 focus:ring-brand-sky-deep outline-none">
                        {aiModels.models?.map((m: any) => (
                            <option value={m.id} selected={m.id === aiModels.current_model}>{m.label}</option>
                        ))}
                    </select>
                    <button id="ai-model-save-btn" class="px-4 py-2 bg-brand-sky-deep hover:bg-brand-ink text-white text-sm font-semibold rounded-lg transition">
                        {es ? "Guardar" : "Save"}
                    </button>
                </div>
                <p id="ai-model-current" class="text-xs text-brand-ink-soft mt-1.5">
                    {es ? "Activo:" : "Active:"} <span class="font-mono font-semibold text-brand-ink">{aiModels.current_model}</span>
                </p>
            </div>

            <!-- Token consumption -->
            <div>
                <div class="flex items-center justify-between mb-2">
                    <p class="text-sm font-semibold text-brand-ink">{es ? "Consumo de tokens (LiteLLM)" : "Token consumption (LiteLLM)"}</p>
                    <button id="ai-usage-refresh-btn" class="text-xs text-brand-sky-deep hover:text-brand-ink font-semibold transition">
                        {es ? "Actualizar" : "Refresh"}
                    </button>
                </div>
                <div id="ai-usage-panel" class="bg-brand-cream-deep rounded-xl p-3 text-sm">
                    {aiUsage ? (
                        <div class="space-y-1.5">
                            {aiUsage.key_alias && (
                                <div class="flex justify-between">
                                    <span class="text-brand-ink-soft">{es ? "Clave" : "Key"}</span>
                                    <span class="font-mono text-xs text-brand-ink">{aiUsage.key_alias}</span>
                                </div>
                            )}
                            <div class="flex justify-between">
                                <span class="text-brand-ink-soft">{es ? "Gasto" : "Spend"}</span>
                                <span class="font-semibold text-brand-ink">${Number(aiUsage.spend ?? 0).toFixed(4)}</span>
                            </div>
                            {aiUsage.max_budget != null && (
                                <div>
                                    <div class="flex justify-between mb-1">
                                        <span class="text-brand-ink-soft">{es ? "Presupuesto" : "Budget"}</span>
                                        <span class="text-brand-ink">${Number(aiUsage.max_budget).toFixed(2)} / {aiUsage.budget_duration ?? "?"}</span>
                                    </div>
                                    <div class="w-full bg-brand-ink/10 rounded-full h-1.5">
                                        <div class="bg-brand-sky-deep rounded-full h-1.5 transition-all"
                                            style={`width:${Math.min(100, (Number(aiUsage.spend ?? 0) / Number(aiUsage.max_budget)) * 100).toFixed(1)}%`}></div>
                                    </div>
                                </div>
                            )}
                            {aiUsage.budget_reset_at && (
                                <div class="flex justify-between">
                                    <span class="text-brand-ink-soft">{es ? "Reseteo" : "Resets"}</span>
                                    <span class="text-brand-ink text-xs">{new Date(aiUsage.budget_reset_at).toLocaleDateString(es ? "es-MX" : "en-US")}</span>
                                </div>
                            )}
                            {aiUsage.models?.length > 0 && (
                                <div class="pt-1 border-t border-brand-ink/10">
                                    <span class="text-xs text-brand-ink-soft">{es ? "Modelos permitidos:" : "Allowed models:"} </span>
                                    <span class="text-xs font-mono text-brand-ink">{aiUsage.models.join(", ")}</span>
                                </div>
                            )}
                        </div>
                    ) : (
                        <p class="text-brand-ink-soft text-xs text-center py-2">{es ? "No disponible — verifica LITELLM_API_KEY" : "Not available — check LITELLM_API_KEY"}</p>
                    )}
                </div>
            </div>
        </SettingsAccordion>

        <!-- BACKUPS & TOOLS -->
        <SettingsAccordion id="backups" title={es ? "Respaldos y herramientas" : "Backups & Tools"} icon="💾">
            <p class="text-sm text-brand-ink-soft mb-4">
                {es ? "Descarga una copia de seguridad de tu presupuesto." : "Download a backup of your budget data."}
            </p>
            <div class="flex flex-col gap-2">
                <button id="export-btn"
                    class="inline-flex items-center justify-center gap-2 w-full px-4 py-2.5 bg-slate-700 hover:bg-slate-800 text-white text-sm font-semibold rounded-lg transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h4a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                    </svg>
                    {es ? "Exportar datos (ZIP)" : "Export data (ZIP)"}
                </button>
                <a href="/budget/recycle-bin"
                    class="inline-flex items-center justify-center gap-2 w-full px-4 py-2.5 bg-brand-cream-deep hover:bg-brand-cream-deep text-brand-ink text-sm font-semibold rounded-lg transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                    {es ? "Papelera de reciclaje" : "Recycle Bin"}
                </a>
            </div>
        </SettingsAccordion>

    <Fragment slot="overlays">
<!-- ================================================================
     SHARED MODAL OVERLAY
     ================================================================ -->
<div id="settings-modal-overlay" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center px-4">
    <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink shadow-[var(--shadow-pop)] w-full max-w-sm max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between px-5 pt-5 pb-3 border-b border-brand-ink/10">
            <h3 id="modal-title" class="text-lg font-bold text-brand-ink"></h3>
            <button onclick="closeSettingsModal()" class="text-brand-ink-soft hover:text-brand-ink-soft transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <div id="modal-body" class="px-5 py-4"></div>
        <div id="modal-error" class="hidden mx-5 mb-2 text-sm text-red-600 px-1"></div>
        <div class="flex gap-3 px-5 pb-5">
            <button onclick="closeSettingsModal()" class="flex-1 py-2.5 bg-brand-cream-deep hover:bg-brand-cream-deep text-brand-ink font-semibold rounded-xl transition">
                {es ? "Cancelar" : "Cancel"}
            </button>
            <button id="modal-save-btn" class="flex-1 py-2.5 bg-brand-sky-deep hover:bg-brand-ink text-white font-semibold rounded-xl shadow-[var(--shadow-card)] transition">
                {es ? "Guardar" : "Save"}
            </button>
        </div>
    </div>
</div>

<!-- CONFIRM DELETE DIALOG -->
<div id="confirm-overlay" class="hidden fixed inset-0 bg-black/60 z-[60] flex items-center justify-center px-4">
    <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink shadow-[var(--shadow-pop)] p-6 max-w-sm w-full">
        <h3 class="text-lg font-bold text-brand-ink mb-2">{es ? "¿Eliminar?" : "Delete?"}</h3>
        <p id="confirm-msg" class="text-sm text-brand-ink-soft mb-6"></p>
        <div class="flex gap-3">
            <button onclick="closeConfirm()" class="flex-1 py-2.5 bg-brand-cream-deep hover:bg-brand-cream-deep text-brand-ink font-semibold rounded-xl transition">
                {es ? "Cancelar" : "Cancel"}
            </button>
            <button id="confirm-ok-btn" class="flex-1 py-2.5 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-xl shadow-[var(--shadow-card)] transition">
                {es ? "Eliminar" : "Delete"}
            </button>
        </div>
    </div>
</div>

<!-- TOAST -->
<div id="settings-toast" class="hidden fixed bottom-24 left-1/2 -translate-x-1/2 z-[70] px-4 py-2.5 rounded-xl text-white text-sm font-semibold shadow-[var(--shadow-pop)] transition-all"></div>
    </Fragment>

<script define:vars={{ token, accountsData: accounts, allCategoriesData: allCategories, es, aiModelsData: aiModels }}>
// ─── Helpers ──────────────────────────────────────────────────────────────────

function showToast(msg, type = "success") {
    const t = document.getElementById("settings-toast");
    if (!t) return;
    t.textContent = msg;
    t.className = `fixed bottom-24 left-1/2 -translate-x-1/2 z-[70] px-4 py-2.5 rounded-xl text-white text-sm font-semibold shadow-[var(--shadow-pop)] ${type === "success" ? "bg-brand-mint-deep" : "bg-red-600"}`;
    t.classList.remove("hidden");
    setTimeout(() => t.classList.add("hidden"), 3000);
}

function showModalError(msg) {
    const e = document.getElementById("modal-error");
    if (!e) return;
    e.textContent = msg;
    e.classList.remove("hidden");
}

function clearModalError() {
    const e = document.getElementById("modal-error");
    if (e) { e.textContent = ""; e.classList.add("hidden"); }
}

function closeSettingsModal() {
    document.getElementById("settings-modal-overlay")?.classList.add("hidden");
    clearModalError();
}

function closeConfirm() {
    document.getElementById("confirm-overlay")?.classList.add("hidden");
}

// The modal's X / Cancel buttons use inline onclick="closeSettingsModal()",
// which only resolves if the function is on window. Expose it explicitly so the
// close/cancel buttons work regardless of how Astro scopes this script.
window.closeSettingsModal = closeSettingsModal;
window.closeConfirm = closeConfirm;

function openConfirm(msg, onConfirm) {
    document.getElementById("confirm-msg").textContent = msg;
    document.getElementById("confirm-overlay")?.classList.remove("hidden");
    const btn = document.getElementById("confirm-ok-btn");
    btn.onclick = async () => {
        closeConfirm();
        await onConfirm();
    };
}

function setModalSaveHandler(fn) {
    const btn = document.getElementById("modal-save-btn");
    if (btn) btn.onclick = fn;
}

async function apiCall(url, method, body) {
    const res = await fetch(url, {
        method,
        headers: { "Content-Type": "application/json", Authorization: `Bearer ${token}` },
        body: body ? JSON.stringify(body) : undefined,
    });
    if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.detail || `Error ${res.status}`);
    }
    return res.status === 204 ? null : res.json();
}

function escapeHtml(str) {
    return String(str ?? "")
        .replace(/&/g, "&amp;")
        .replace(/"/g, "&quot;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
}

// ─── EXPORT ───────────────────────────────────────────────────────────────────

document.getElementById("export-btn")?.addEventListener("click", async () => {
    const btn = document.getElementById("export-btn");
    const originalText = btn.textContent.trim();
    btn.disabled = true;
    btn.textContent = es ? "Exportando…" : "Exporting…";
    try {
        const res = await fetch("/api/budget/export", {
            headers: { Authorization: `Bearer ${token}` },
        });
        if (!res.ok) throw new Error(`Error ${res.status}`);
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `budget-export-${new Date().toISOString().split("T")[0]}.zip`;
        a.click();
        URL.revokeObjectURL(url);
    } catch(e) {
        showToast(e.message, "error");
    } finally {
        btn.disabled = false;
        btn.textContent = originalText;
    }
});

// ─── ACCOUNTS ─────────────────────────────────────────────────────────────────

// ─── ACCOUNT TRANSFERS + RECONCILE ───────────────────────────────────────────
window.openTransferModal = function() {
    document.getElementById("modal-title").textContent = es ? "Transferir entre cuentas" : "Transfer between accounts";
    const opts = accountsData.map(a => `<option value="${a.id}">${escapeHtml(a.name)}</option>`).join("");
    document.getElementById("modal-body").innerHTML = `
        <div class="space-y-3">
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Desde" : "From"} *</label>
                <select id="tr-from" class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm bg-brand-cream">${opts}</select>
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Hacia" : "To"} *</label>
                <select id="tr-to" class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm bg-brand-cream">${opts}</select>
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Cantidad ($)" : "Amount ($)"} *</label>
                <input id="tr-amount" type="number" step="0.01" min="0.01" placeholder="0.00"
                    class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm">
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Fecha" : "Date"}</label>
                <input id="tr-date" type="date" value="${new Date().toISOString().slice(0,10)}"
                    class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm">
            </div>
        </div>`;
    if (accountsData.length > 1) document.getElementById("tr-to").selectedIndex = 1;
    document.getElementById("settings-modal-overlay")?.classList.remove("hidden");
    setModalSaveHandler(async () => {
        const from = document.getElementById("tr-from").value;
        const to = document.getElementById("tr-to").value;
        const amt = Math.round(parseFloat(document.getElementById("tr-amount").value || "") * 100);
        if (from === to) { showModalError(es ? "Elige cuentas distintas" : "Pick two different accounts"); return; }
        if (!amt || amt <= 0) { showModalError(es ? "Cantidad inválida" : "Invalid amount"); return; }
        try {
            await apiCall("/api/budget/transfers/accounts", "POST", {
                from_account_id: from, to_account_id: to, amount: amt,
                date: document.getElementById("tr-date").value,
            });
            showToast(es ? "Transferencia creada" : "Transfer created");
            setTimeout(() => location.reload(), 800);
        } catch(e) { showModalError(e.message); }
    });
};

window.openReconcileModal = async function(accountId, accountName) {
    document.getElementById("modal-title").textContent = (es ? "Conciliar " : "Reconcile ") + accountName;
    document.getElementById("modal-body").innerHTML = `<p class="text-sm text-brand-ink-soft">${es ? "Cargando..." : "Loading..."}</p>`;
    document.getElementById("settings-modal-overlay")?.classList.remove("hidden");

    const [bal, txns] = await Promise.all([
        apiCall(`/api/budget/accounts/${accountId}/balance`, "GET"),
        apiCall(`/api/budget/transactions/?account_id=${accountId}&limit=200`, "GET"),
    ]);
    const uncleared = (txns || []).filter(t => !t.cleared || !t.reconciled);
    const fmtc = (c) => (c/100).toLocaleString(es ? "es-MX" : "en-US", {style:"currency", currency:"MXN"});

    document.getElementById("modal-body").innerHTML = `
        <div class="space-y-3">
            <div class="grid grid-cols-2 gap-2 text-sm">
                <div class="bg-brand-cream-deep rounded-lg p-2">
                    <span class="block text-xs text-brand-ink-soft">${es ? "Saldo en app" : "App balance"}</span>
                    <b>${fmtc(bal.balance_cents ?? 0)}</b>
                </div>
                <div class="bg-brand-cream-deep rounded-lg p-2">
                    <span class="block text-xs text-brand-ink-soft">${es ? "Confirmado (cleared)" : "Cleared"}</span>
                    <b>${fmtc(bal.cleared_balance_cents ?? 0)}</b>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Saldo del estado de cuenta ($)" : "Bank statement balance ($)"} *</label>
                <input id="rec-statement" type="number" step="0.01"
                    class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm">
            </div>
            <div>
                <p class="text-xs text-brand-ink-soft mb-1">${es ? "Palomea lo que aparece en tu estado de cuenta:" : "Check what appears on your statement:"}</p>
                <div class="max-h-52 overflow-y-auto divide-y divide-brand-ink/10 border border-brand-ink/10 rounded-lg">
                    ${uncleared.length === 0
                        ? `<p class="text-xs text-brand-ink-soft p-3 text-center">${es ? "Todo conciliado" : "Everything reconciled"}</p>`
                        : uncleared.map(t => `
                        <label class="flex items-center gap-2 px-3 py-2 text-sm cursor-pointer hover:bg-brand-cream-deep">
                            <input type="checkbox" class="rec-check" value="${t.id}" ${t.cleared ? "checked" : ""}>
                            <span class="flex-1 truncate">${escapeHtml(t.notes || t.date)}</span>
                            <span class="${t.amount < 0 ? "text-red-600" : "text-brand-mint-deep"} font-semibold">${fmtc(t.amount)}</span>
                        </label>`).join("")}
                </div>
            </div>
            <p class="text-[11px] text-brand-ink-soft">${es
                ? "Al confirmar: lo palomeado se marca conciliado; si el saldo no cuadra se crea un ajuste automático."
                : "On confirm: checked items become reconciled; if the balance doesn't match, an adjustment transaction is created."}</p>
        </div>`;

    setModalSaveHandler(async () => {
        const stmt = document.getElementById("rec-statement").value;
        if (stmt === "") { showModalError(es ? "Ingresa el saldo del estado de cuenta" : "Enter the statement balance"); return; }
        const ids = [...document.querySelectorAll(".rec-check:checked")].map(c => c.value);
        try {
            const r = await apiCall("/api/budget/transactions/finish-reconciliation", "POST", {
                account_id: accountId,
                statement_balance: Math.round(parseFloat(stmt) * 100),
                transaction_ids: ids,
            });
            const adj = r.adjustment_amount;
            showToast((es ? "Conciliado. " : "Reconciled. ") + (adj ? (es ? `Ajuste: ${fmtc(adj)}` : `Adjustment: ${fmtc(adj)}`) : ""));
            setTimeout(() => location.reload(), 1200);
        } catch(e) { showModalError(e.message); }
    });
};

window.openAccountModal = function(acc) {
    const isEdit = !!acc;
    document.getElementById("modal-title").textContent = isEdit ? (es ? "Editar cuenta" : "Edit Account") : (es ? "Nueva cuenta" : "New Account");
    document.getElementById("modal-body").innerHTML = `
        <div class="space-y-3">
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Nombre" : "Name"} *</label>
                <input id="acc-name" type="text" value="${escapeHtml(acc?.name)}"
                    class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none">
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Tipo" : "Type"} *</label>
                <select id="acc-type" class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm bg-brand-cream focus:ring-2 focus:ring-brand-sky-deep outline-none">
                    ${['checking','savings','credit','investment','loan','other'].map(t =>
                        `<option value="${t}" ${(acc?.account_type||acc?.type)===t?'selected':''}>${t}</option>`
                    ).join('')}
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Notas" : "Notes"}</label>
                <input id="acc-notes" type="text" value="${escapeHtml(acc?.notes)}"
                    class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none">
            </div>
            ${!isEdit ? `<div>
                <label class="block text-sm font-medium text-brand-ink-soft mb-1">${es ? "Balance inicial ($)" : "Starting balance ($)"}</label>
                <input id="acc-balance" type="number" step="0.01" placeholder="0.00"
                    class="w-full py-2 px-3 border border-brand-ink/10 rounded-lg text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none">
            </div>` : ''}
        </div>
    `;
    document.getElementById("settings-modal-overlay")?.classList.remove("hidden");
    document.getElementById("acc-name").focus();

    setModalSaveHandler(async () => {
        const name = document.getElementById("acc-name").value.trim();
        const type = document.getElementById("acc-type").value;
        if (!name) { showModalError(es ? "El nombre es requerido" : "Name is required"); return; }
        try {
            // Backend AccountCreate/AccountUpdate expect `type` (account_type
            // is only a response/list-filter name) — sending account_type made
            // creates 422 with "type: Field required".
            const body = { name, type, notes: document.getElementById("acc-notes").value.trim() || undefined };
            if (!isEdit) {
                const bal = parseFloat(document.getElementById("acc-balance").value || "0");
                if (bal) body.starting_balance = Math.round(bal * 100);
            }
            if (isEdit) {
                await apiCall(`/api/budget/accounts/${acc.id}`, "PUT", body);
            } else {
                await apiCall("/api/budget/accounts/", "POST", body);
            }
            closeSettingsModal();
            showToast(isEdit ? (es ? "Cuenta actualizada" : "Account updated") : (es ? "Cuenta creada" : "Account created"));
            setTimeout(() => location.reload(), 800);
        } catch(e) { showModalError(e.message); }
    });
};

