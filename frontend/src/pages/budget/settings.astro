        if (!name) { showModalError(es ? "El nombre es requerido" : "Name is required"); return; }
        try {
            if (isEdit) {
                await apiCall(`/api/budget/payees/${p.id}`, "PUT", { name });
            } else {
                await apiCall("/api/budget/payees/", "POST", { name });
            }
            closeSettingsModal();
            showToast(isEdit ? (es ? "Actualizado" : "Updated") : (es ? "Creado" : "Created"));
            setTimeout(() => location.reload(), 800);
        } catch(e) { showModalError(e.message); }
    });
};

window.confirmDeletePayee = function(id, name) {
    openConfirm(`${es ? "¿Eliminar beneficiario" : "Delete payee"} "${name}"?`, async () => {
        try {
            await apiCall(`/api/budget/payees/${id}`, "DELETE");
