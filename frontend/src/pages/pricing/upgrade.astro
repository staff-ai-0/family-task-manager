---
import Layout from "../../layouts/Layout.astro";
import BottomNav from "../../components/BottomNav.astro";
import { apiFetch } from "../../lib/api";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = Astro.cookies.get("lang")?.value ?? "en";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

let errorMsg = "";

if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    const plan_name = data.get("plan_name");
    const billing_cycle = data.get("billing_cycle");
    if (plan_name && billing_cycle) {
        const { ok, data: res, error } = await apiFetch<any>("/api/subscriptions/checkout", {
            method: "POST",
            token,
            body: JSON.stringify({ plan_name, billing_cycle }),
        });
        if (ok && res?.approval_url) {
            return Astro.redirect(res.approval_url);
        }
        errorMsg = error || "Error";
    }
}

const [{ data: plansRaw }, { data: currentRaw }] = await Promise.all([
    apiFetch<any[]>("/api/subscriptions/plans", { token }),
    apiFetch<any>("/api/subscriptions/current", { token }),
]);
const plans: any[] = Array.isArray(plansRaw) ? plansRaw : [];
const current = currentRaw ?? {};
const currentName = current?.plan_name ?? "free";

const labels = {
    title: lang === "es" ? "Planes" : "Plans",
    subtitle: lang === "es" ? "Vía PayPal — cambia cuando quieras" : "Via PayPal — change anytime",
    monthly: lang === "es" ? "Mensual" : "Monthly",
    annual: lang === "es" ? "Anual (ahorras 2 meses)" : "Annual (2 mo free)",
    upgrade: lang === "es" ? "Suscribirse" : "Subscribe",
    current: lang === "es" ? "Plan actual" : "Current plan",
    manage: lang === "es" ? "Administrar suscripción" : "Manage subscription",
};

const planFeatures: Record<string, string[]> = lang === "es"
    ? {
        free: ["1 hijo", "Tareas básicas", "Calendario familiar"],
        plus: ["Hijos ilimitados", "Photo proof", "Gigs cap medio", "5 receipt scans/mes"],
        pro: ["Todo Plus +", "Budget completo", "AI scan ilimitado", "Jarvis copilot", "Analytics"],
    }
    : {
        free: ["1 kid", "Basic tasks", "Family calendar"],
        plus: ["Unlimited kids", "Photo proof", "Mid gig cap", "5 receipt scans/mo"],
        pro: ["All Plus +", "Full budget", "Unlimited AI scan", "Jarvis copilot", "Analytics"],
    };
---

<Layout title={`${labels.title} - Family Task Manager`}>
    <div class="w-full max-w-md md:max-w-4xl mx-auto bg-brand-cream-deep flex flex-col">
        <header class="bg-gradient-to-br from-emerald-500 to-teal-600 text-white pt-12 pb-6 px-6 rounded-b-[var(--radius-tile)] shadow-[var(--shadow-card)]">
            <h1 class="text-2xl font-bold mb-1">💳 {labels.title}</h1>
            <p class="text-emerald-100 text-xs">{labels.subtitle}</p>
            {currentName && (
                <p class="text-emerald-100 text-xs mt-2">
                    {labels.current}: <span class="font-bold capitalize">{currentName}</span>
                </p>
            )}
        </header>

        <main class="flex-1 px-4 py-6 space-y-4">
            {errorMsg && (
                <div class="p-3 bg-red-100 border border-red-200 text-red-700 text-sm rounded-xl">
                    {errorMsg}
                </div>
            )}

            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                {plans.map((p: any) => {
                    const isCurrent = p.name === currentName;
                    const features = planFeatures[p.name] ?? [];
                    return (
                        <div class={`bg-brand-cream rounded-2xl p-5 border-2 shadow-[var(--shadow-card)] space-y-3 ${
                            isCurrent ? "border-emerald-500" : "border-brand-ink/10"
                        }`}>
                            <div>
                                <h2 class="font-bold text-brand-ink text-xl capitalize">
                                    {p.display_name ?? p.name}
                                    {isCurrent && <span class="ml-2 text-[10px] px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700">★</span>}
                                </h2>
                                <p class="text-brand-ink-soft text-xs">
                                    ${(p.price_monthly_cents / 100).toFixed(2)}/mo · ${(p.price_annual_cents / 100).toFixed(2)}/yr
                                </p>
                            </div>
                            <ul class="space-y-1 text-sm text-brand-ink">
                                {features.map((f) => (<li>✓ {f}</li>))}
                            </ul>
                            {p.name !== "free" && !isCurrent && (
                                <div class="flex gap-2">
                                    <form method="POST" class="flex-1">
                                        <input type="hidden" name="plan_name" value={p.name} />
                                        <input type="hidden" name="billing_cycle" value="monthly" />
                                        <button type="submit"
                                            class="w-full py-2 rounded-lg bg-emerald-600 text-white text-xs font-bold hover:bg-emerald-700">
                                            {labels.monthly}
                                        </button>
                                    </form>
                                    <form method="POST" class="flex-1">
                                        <input type="hidden" name="plan_name" value={p.name} />
                                        <input type="hidden" name="billing_cycle" value="annual" />
                                        <button type="submit"
                                            class="w-full py-2 rounded-lg bg-emerald-700 text-white text-xs font-bold hover:bg-emerald-800">
                                            {labels.annual}
                                        </button>
                                    </form>
                                </div>
                            )}
                        </div>
                    );
                })}
            </div>

            <a href="/parent/settings/subscription"
                class="block text-center text-xs font-semibold text-brand-ink-soft hover:text-brand-ink underline py-2">
                {labels.manage}
            </a>
        </main>

        <BottomNav active="parent" role={user.role} lang={lang} />
    </div>
</Layout>
