---
import Layout from "../../layouts/Layout.astro";
import BottomNav from "../../components/BottomNav.astro";
import { apiFetch } from "../../lib/api";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = Astro.cookies.get("lang")?.value ?? "en";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

let errorMsg = "";

if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    const action = data.get("action");
    const origin = Astro.url.origin;

    if (action === "checkout") {
        const plan_name = data.get("plan_name");
        const billing_cycle = data.get("billing_cycle");
        const { ok, data: res, error } = await apiFetch<any>("/api/stripe/checkout", {
            method: "POST",
            token,
            body: JSON.stringify({
                plan_name,
                billing_cycle,
                success_url: `${origin}/parent/settings?stripe=ok`,
                cancel_url: `${origin}/pricing/upgrade?stripe=cancel`,
            }),
        });
        if (ok && res?.checkout_url) {
            return Astro.redirect(res.checkout_url);
        }
        errorMsg = error || "Error";
    } else if (action === "portal") {
        const { ok, data: res, error } = await apiFetch<any>("/api/stripe/portal", {
            method: "POST",
            token,
            body: JSON.stringify({ return_url: `${origin}/parent/settings` }),
        });
        if (ok && res?.portal_url) {
            return Astro.redirect(res.portal_url);
        }
        errorMsg = error || "Error";
    }
}

const { data: health } = await apiFetch<any>("/api/stripe/health", { token });
const stripeConfigured = health?.configured ?? false;

const plans = [
    {
        name: "plus",
        title: "Plus",
        price_monthly: "$4.99",
        price_annual: "$49",
        features: lang === "es"
            ? ["Tareas ilimitadas", "Photo proof", "Calendario familiar", "5 receipt scans/mes"]
            : ["Unlimited tasks", "Photo proof", "Family calendar", "5 receipt scans/mo"],
    },
    {
        name: "pro",
        title: "Pro",
        price_monthly: "$9.99",
        price_annual: "$99",
        features: lang === "es"
            ? ["Todo Plus +", "Budget completo", "AI scan ilimitado", "Frankie copilot", "Analytics"]
            : ["All Plus +", "Full budget", "Unlimited AI scan", "Frankie copilot", "Analytics"],
    },
];

const labels = {
    title: lang === "es" ? "Planes" : "Plans",
    subtitle: lang === "es" ? "Sube de plan cuando quieras" : "Upgrade anytime",
    monthly: lang === "es" ? "Mensual" : "Monthly",
    annual: lang === "es" ? "Anual" : "Annual (2 mo free)",
    upgrade: lang === "es" ? "Suscribirse" : "Subscribe",
    portal: lang === "es" ? "Administrar suscripción" : "Manage subscription",
    not_configured: lang === "es"
        ? "Stripe no está configurado todavía"
        : "Stripe not configured yet",
};
---

<Layout title={`${labels.title} - Family Task Manager`}>
    <div class="w-full max-w-md md:max-w-4xl mx-auto bg-brand-cream-deep flex flex-col">
        <header class="bg-gradient-to-br from-emerald-500 to-teal-600 text-white pt-12 pb-6 px-6 rounded-b-[var(--radius-tile)] shadow-[var(--shadow-card)]">
            <h1 class="text-2xl font-bold mb-1">💳 {labels.title}</h1>
            <p class="text-emerald-100 text-xs">{labels.subtitle}</p>
        </header>

        <main class="flex-1 px-4 py-6 space-y-4">
            {errorMsg && (
                <div class="p-3 bg-red-100 border border-red-200 text-red-700 text-sm rounded-xl">
                    {errorMsg}
                </div>
            )}

            {!stripeConfigured && (
                <div class="p-3 bg-amber-100 border border-amber-300 text-amber-800 text-sm rounded-xl">
                    ⚠️ {labels.not_configured}
                </div>
            )}

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                {plans.map((p) => (
                    <div class="bg-brand-cream rounded-2xl p-5 border-2 border-brand-ink/10 shadow-[var(--shadow-card)] space-y-3">
                        <div>
                            <h2 class="font-bold text-brand-ink text-xl">{p.title}</h2>
                            <p class="text-brand-ink-soft text-xs">
                                {p.price_monthly}/mo · {p.price_annual}/yr
                            </p>
                        </div>
                        <ul class="space-y-1 text-sm text-brand-ink">
                            {p.features.map((f) => (
                                <li>✓ {f}</li>
                            ))}
                        </ul>
                        <div class="flex gap-2">
                            <form method="POST" class="flex-1">
                                <input type="hidden" name="action" value="checkout" />
                                <input type="hidden" name="plan_name" value={p.name} />
                                <input type="hidden" name="billing_cycle" value="monthly" />
                                <button type="submit" disabled={!stripeConfigured}
                                    class="w-full py-2 rounded-lg bg-emerald-600 text-white text-xs font-bold hover:bg-emerald-700 disabled:opacity-50 disabled:cursor-not-allowed">
                                    {labels.monthly}
                                </button>
                            </form>
                            <form method="POST" class="flex-1">
                                <input type="hidden" name="action" value="checkout" />
                                <input type="hidden" name="plan_name" value={p.name} />
                                <input type="hidden" name="billing_cycle" value="annual" />
                                <button type="submit" disabled={!stripeConfigured}
                                    class="w-full py-2 rounded-lg bg-emerald-700 text-white text-xs font-bold hover:bg-emerald-800 disabled:opacity-50 disabled:cursor-not-allowed">
                                    {labels.annual}
                                </button>
                            </form>
                        </div>
                    </div>
                ))}
            </div>

            <form method="POST" class="bg-brand-cream rounded-2xl p-3 border border-brand-ink/10 text-center">
                <input type="hidden" name="action" value="portal" />
                <button type="submit" disabled={!stripeConfigured}
                    class="text-xs font-semibold text-brand-ink-soft hover:text-brand-ink underline disabled:opacity-50">
                    {labels.portal}
                </button>
            </form>
        </main>

        <BottomNav active="parent" role={user.role} lang={lang} />
    </div>
</Layout>
