---
import { apiFetch } from "../lib/api";

const token = Astro.url.searchParams.get("token");
if (!token) {
    return new Response("Missing token", { status: 400 });
}

const { data, ok, status } = await apiFetch<any>(
    `/api/kiosk/snapshot?token=${encodeURIComponent(token)}`,
);
if (!ok || !data) {
    return new Response("Invalid token", { status: status ?? 401 });
}

const lang = Astro.cookies.get("lang")?.value ?? "en";

function formatTime(iso: string, allDay: boolean): string {
    if (allDay) return lang === "es" ? "Todo el día" : "All day";
    const d = new Date(iso);
    return d.toLocaleTimeString(lang === "es" ? "es-MX" : "en-US", {
        hour: "numeric",
        minute: "2-digit",
    });
}

const labels = {
    today: lang === "es" ? "Hoy" : "Today",
    tomorrow: lang === "es" ? "Mañana" : "Tomorrow",
    tasks: lang === "es" ? "Tareas" : "Tasks",
    no_events: lang === "es" ? "Sin eventos" : "No events",
    no_tasks: lang === "es" ? "Sin tareas" : "No tasks",
    shopping: lang === "es" ? "Compras" : "Shopping",
    pending: lang === "es" ? "pendientes" : "pending",
};
---

<html lang={lang} class="bg-slate-950 text-white">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{data.family_name} — Kiosk</title>
        <style>
            html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; font-family: system-ui, -apple-system, sans-serif; }
            .grid { display: grid; gap: 1rem; padding: 1rem; height: 100vh; box-sizing: border-box; }
            @media (orientation: landscape) {
                .grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto 1fr auto; }
            }
            @media (orientation: portrait) {
                .grid { grid-template-rows: auto auto 1fr auto; }
            }
        </style>
    </head>
    <body class="bg-slate-950 text-white">
        <div class="grid">
            <header class="col-span-full flex items-baseline justify-between border-b border-white/10 pb-2">
                <h1 class="text-3xl font-bold">{data.family_name}</h1>
                <span id="clock" class="text-4xl font-mono tabular-nums"></span>
            </header>

            <section class="bg-white/5 rounded-xl p-4 overflow-auto">
                <h2 class="text-xl font-semibold mb-3 text-sky-300">📅 {labels.today}</h2>
                {data.events_today.length === 0 ? (
                    <p class="text-white/50 text-sm">{labels.no_events}</p>
                ) : (
                    <ul class="space-y-2">
                        {data.events_today.map((e: any) => (
                            <li class="flex items-baseline gap-3">
                                <span class="text-amber-300 font-mono text-sm w-20 flex-shrink-0">
                                    {formatTime(e.start_ts, e.all_day)}
                                </span>
                                <div class="flex-1">
                                    <p class="font-medium">{e.title}</p>
                                    {e.location && (
                                        <p class="text-white/50 text-xs">{e.location}</p>
                                    )}
                                </div>
                            </li>
                        ))}
                    </ul>
                )}
                {data.events_tomorrow.length > 0 && (
                    <div class="mt-4 pt-3 border-t border-white/10">
                        <h3 class="text-sm font-semibold text-white/60 mb-2">📅 {labels.tomorrow}</h3>
                        <ul class="space-y-1">
                            {data.events_tomorrow.slice(0, 3).map((e: any) => (
                                <li class="text-sm">
                                    <span class="text-amber-300">{formatTime(e.start_ts, e.all_day)}</span>
                                    <span class="ml-2">{e.title}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                )}
            </section>

            <section class="bg-white/5 rounded-xl p-4 overflow-auto">
                <h2 class="text-xl font-semibold mb-3 text-emerald-300">✅ {labels.tasks}</h2>
                {data.tasks.length === 0 ? (
                    <p class="text-white/50 text-sm">{labels.no_tasks}</p>
                ) : (
                    <ul class="space-y-2">
                        {data.tasks.map((t: any) => (
                            <li class={`flex items-center gap-3 py-1 ${t.is_done ? "opacity-50" : ""}`}>
                                <span class={`w-5 h-5 rounded border-2 ${t.is_done ? "bg-emerald-400 border-emerald-400" : "border-white/30"} flex-shrink-0`}>
                                    {t.is_done && (
                                        <svg class="w-full h-full text-slate-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                                        </svg>
                                    )}
                                </span>
                                <span class={`flex-1 ${t.is_done ? "line-through" : ""}`}>
                                    {t.is_bonus && "⭐ "}{t.title}
                                </span>
                                <span class="text-white/40 text-sm">{t.user_name}</span>
                            </li>
                        ))}
                    </ul>
                )}
            </section>

            <section class="col-span-full bg-white/5 rounded-xl p-4 overflow-auto">
                <div class="flex flex-wrap gap-3">
                    {data.members.map((m: any) => (
                        <div class="bg-white/10 rounded-lg px-3 py-2 flex-1 min-w-[120px]">
                            <p class="text-sm font-semibold">{m.name}</p>
                            <p class="text-xs text-white/60">
                                {m.tasks_done}/{m.tasks_today} {labels.tasks.toLowerCase()}
                            </p>
                        </div>
                    ))}
                </div>
                {data.shopping.length > 0 && (
                    <div class="mt-3 pt-3 border-t border-white/10 flex flex-wrap gap-2">
                        <span class="text-sm text-white/60">🛒 {labels.shopping}:</span>
                        {data.shopping.map((l: any) => (
                            <span class="text-sm">
                                <span class="font-semibold">{l.name}</span>
                                <span class="ml-1 text-rose-300">{l.pending}</span>
                            </span>
                        ))}
                    </div>
                )}
            </section>
        </div>

        <script define:vars={{ token }}>
            // Live clock
            function updateClock() {
                const el = document.getElementById("clock");
                if (el) el.textContent = new Date().toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
            }
            updateClock();
            setInterval(updateClock, 1000);

            // Auto-refresh page every 60s to pull latest snapshot
            setTimeout(() => location.reload(), 60_000);
        </script>
    </body>
</html>
