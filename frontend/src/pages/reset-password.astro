---
import Layout from "../layouts/Layout.astro";

const lang = Astro.cookies.get("lang")?.value ?? "en";
const token = Astro.url.searchParams.get("token") ?? "";

const copy = {
  es: {
    title: "Nueva contraseña",
    heading: "Crear nueva contraseña",
    subtitle: "Elige una contraseña segura para tu cuenta.",
    label_pw: "Nueva contraseña",
    label_confirm: "Confirmar contraseña",
    btn: "Guardar contraseña",
    saving: "Guardando...",
    success: "¡Contraseña restablecida! Ahora puedes iniciar sesión.",
    login: "Ir al inicio de sesión",
    mismatch: "Las contraseñas no coinciden.",
    short: "La contraseña debe tener al menos 8 caracteres.",
    invalid_token: "Este enlace no es válido o ha expirado. Solicita uno nuevo.",
    request_new: "Solicitar nuevo enlace",
  },
  en: {
    title: "New password",
    heading: "Create a new password",
    subtitle: "Choose a strong password for your account.",
    label_pw: "New password",
    label_confirm: "Confirm password",
    btn: "Save password",
    saving: "Saving...",
    success: "Password reset! You can now log in.",
    login: "Go to login",
    mismatch: "Passwords don't match.",
    short: "Password must be at least 8 characters.",
    invalid_token: "This link is invalid or has expired. Request a new one.",
    request_new: "Request a new link",
  },
}[lang] ?? {};
---

<Layout title={`${copy.title} — Family Task Manager`}>
  <main class="min-h-screen flex items-center justify-center p-4 bg-brand-cream-deep">
    <div class="w-full max-w-md bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink shadow-[var(--shadow-pop)] p-8">

      {!token ? (
        <div class="text-center">
          <p class="text-brand-ink-soft mb-4">{copy.invalid_token}</p>
          <a href="/forgot-password" class="text-brand-coral-deep hover:text-brand-coral-deep font-medium text-sm">{copy.request_new}</a>
        </div>
      ) : (
        <>
          <div class="mb-8 text-center">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-indigo-50 mb-4">
              <svg class="w-7 h-7 text-brand-coral-deep" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h1 class="text-2xl font-bold text-brand-ink">{copy.heading}</h1>
            <p class="text-brand-ink-soft mt-1 text-sm">{copy.subtitle}</p>
          </div>

          <div id="success-block" class="hidden text-center">
            <p class="text-brand-mint-deep bg-brand-mint/20 border border-brand-mint rounded-lg p-4 mb-6 text-sm">{copy.success}</p>
            <a href="/login" class="inline-block px-6 py-3 rounded-lg bg-brand-coral-deep text-white font-medium hover:bg-brand-coral-deep transition-colors">{copy.login}</a>
          </div>

          <form id="reset-form" class="space-y-5">
            <div id="error-msg" class="hidden p-4 rounded-lg bg-red-100 border border-red-200 text-red-700 text-sm"></div>
            <div>
              <label for="password" class="block text-sm font-medium text-brand-ink mb-1">{copy.label_pw}</label>
              <input
                type="password" id="password" name="password" required minlength="8" autocomplete="new-password"
                class="w-full px-4 py-3 rounded-lg border border-brand-ink/20 focus:ring-2 focus:ring-brand-coral focus:border-brand-coral outline-none transition-shadow-[var(--shadow-card)]"
              />
            </div>
            <div>
              <label for="confirm" class="block text-sm font-medium text-brand-ink mb-1">{copy.label_confirm}</label>
              <input
                type="password" id="confirm" name="confirm" required autocomplete="new-password"
                class="w-full px-4 py-3 rounded-lg border border-brand-ink/20 focus:ring-2 focus:ring-brand-coral focus:border-brand-coral outline-none transition-shadow-[var(--shadow-card)]"
              />
            </div>
            <button
              type="submit" id="submit-btn"
              class="w-full py-3 px-4 rounded-lg text-white font-medium bg-brand-coral-deep hover:bg-brand-coral-deep transition-colors shadow-[var(--shadow-card)]"
            >
              {copy.btn}
            </button>
          </form>
        </>
      )}
    </div>
  </main>

  <script define:vars={{ token, saving: copy.saving, btnLabel: copy.btn, mismatch: copy.mismatch, short: copy.short, invalidToken: copy.invalid_token }}>
    document.addEventListener('astro:page-load', () => {
    const form = document.getElementById("reset-form");
    const btn = document.getElementById("submit-btn");
    const successBlock = document.getElementById("success-block");
    const errorMsg = document.getElementById("error-msg");

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const pw = document.getElementById("password").value;
      const confirm = document.getElementById("confirm").value;

      errorMsg.classList.add("hidden");

      if (pw.length < 8) {
        errorMsg.textContent = short;
        errorMsg.classList.remove("hidden");
        return;
      }
      if (pw !== confirm) {
        errorMsg.textContent = mismatch;
        errorMsg.classList.remove("hidden");
        return;
      }

      btn.disabled = true;
      btn.textContent = saving;

      try {
        const res = await fetch("/api/auth/reset-password", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token, new_password: pw }),
        });
        const data = await res.json();

        if (res.ok) {
          form.classList.add("hidden");
          successBlock.classList.remove("hidden");
        } else {
          errorMsg.textContent = data.detail || invalidToken;
          errorMsg.classList.remove("hidden");
          btn.disabled = false;
          btn.textContent = btnLabel;
        }
      } catch {
        errorMsg.textContent = "An error occurred. Please try again.";
        errorMsg.classList.remove("hidden");
        btn.disabled = false;
        btn.textContent = btnLabel;
      }
    });
    });
  </script>
</Layout>
