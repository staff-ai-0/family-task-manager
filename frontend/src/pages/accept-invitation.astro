---
import Layout from "../layouts/Layout.astro";

// Redirect if already authenticated
if (Astro.cookies.has("access_token")) {
    return Astro.redirect("/dashboard");
}

const lang = Astro.cookies.get("lang")?.value ?? "es";
const invitationCode = Astro.url.searchParams.get("code") || "";
---

<Layout title={lang === "es" ? "Aceptar invitación - Family Task Manager" : "Accept invitation - Family Task Manager"}>
    <main class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 flex items-center justify-center p-4">
        <div class="w-full max-w-5xl">
            <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
                    <!-- Left column: Hero -->
                    <div class="hidden md:flex md:flex-col md:justify-center md:items-start p-12 lg:p-16 bg-gradient-to-br from-cyan-500 via-blue-500 to-blue-600 text-white">
                        <h2 class="text-5xl font-black leading-tight mb-6">
                            {lang === "es" ? "¡Te han invitado!" : "You're invited!"}
                        </h2>
                        <p class="text-xl text-blue-100 leading-relaxed mb-12">
                            {lang === "es" 
                                ? "Únete a tu familia y empieza a colaborar en tareas, recompensas y finanzas" 
                                : "Join your family and start collaborating on tasks, rewards, and finances"}
                        </p>

                        <div class="space-y-6">
                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0 bg-white bg-opacity-20 rounded-full p-3">
                                    <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="font-semibold text-lg">{lang === "es" ? "Conexión instantánea" : "Instant connection"}</p>
                                    <p class="text-sm text-blue-100">{lang === "es" ? "Conecta con tu familia al instante" : "Connect with your family instantly"}</p>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0 bg-white bg-opacity-20 rounded-full p-3">
                                    <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="font-semibold text-lg">{lang === "es" ? "Seguro y privado" : "Safe & private"}</p>
                                    <p class="text-sm text-blue-100">{lang === "es" ? "Tus datos solo los ve tu familia" : "Your data only visible to family"}</p>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0 bg-white bg-opacity-20 rounded-full p-3">
                                    <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="font-semibold text-lg">{lang === "es" ? "Totalmente gratis" : "100% free"}</p>
                                    <p class="text-sm text-blue-100">{lang === "es" ? "Sin costos ocultos" : "No hidden costs"}</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right column: Accept form -->
                    <div class="p-8 lg:p-12 flex flex-col justify-center">
                        <div class="mb-8">
                            <h1 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-2">
                                {lang === "es" ? "Aceptar invitación" : "Accept invitation"}
                            </h1>
                            <p class="text-slate-500 text-lg">
                                {lang === "es"
                                    ? "Completa tu perfil para unirte"
                                    : "Complete your profile to join"}
                            </p>
                        </div>

                        <div id="error-message" class="hidden mb-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-700 text-sm font-medium"></div>
                        <div id="success-message" class="hidden mb-6 p-4 rounded-xl bg-green-50 border border-green-200 text-green-700 text-sm font-medium"></div>

                        <form id="accept-form" class="space-y-5">
                            <!-- Invitation code (if not in URL) -->
                            {!invitationCode && (
                                <div>
                                    <label for="invitation_code" class="block text-sm font-semibold text-slate-700 mb-2">
                                        {lang === "es" ? "Código de invitación" : "Invitation code"}
                                    </label>
                                    <input
                                        type="text"
                                        id="invitation_code"
                                        name="invitation_code"
                                        maxlength="32"
                                        placeholder={lang === "es" ? "Ingresa el código de la invitación" : "Enter invitation code"}
                                        class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition-all hover:border-slate-400 font-mono text-sm"
                                    />
                                </div>
                            )}

                            <!-- Your name -->
                            <div>
                                <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">
                                    {lang === "es" ? "Tu nombre" : "Your name"}
                                </label>
                                <input
                                    type="text"
                                    id="name"
                                    name="name"
                                    required
                                    maxlength="100"
                                    placeholder={lang === "es" ? "Ej: María" : "e.g. John"}
                                    class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition-all hover:border-slate-400"
                                />
                            </div>

                            <!-- Password -->
                            <div>
                                <label for="password" class="block text-sm font-semibold text-slate-700 mb-2">
                                    {lang === "es" ? "Contraseña" : "Password"}
                                </label>
                                <input
                                    type="password"
                                    id="password"
                                    name="password"
                                    required
                                    minlength="8"
                                    placeholder={lang === "es" ? "Mínimo 8 caracteres" : "At least 8 characters"}
                                    class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition-all hover:border-slate-400"
                                />
                                <p class="text-xs text-slate-500 mt-2">
                                    {lang === "es" ? "Tu contraseña es personal y confidencial" : "Your password is personal and confidential"}
                                </p>
                            </div>

                            <!-- Confirm password -->
                             <div>
                                 <label for="confirm_password" class="block text-sm font-semibold text-slate-700 mb-2">
                                     {lang === "es" ? "Confirmar contraseña" : "Confirm password"}
                                 </label>
                                 <input
                                     type="password"
                                     id="confirm_password"
                                     name="confirm_password"
                                     required
                                     minlength="8"
                                     placeholder={lang === "es" ? "Repite tu contraseña" : "Repeat your password"}
                                     class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition-all hover:border-slate-400"
                                 />
                             </div>

                             <!-- Age verification checkbox -->
                             <div class="flex items-start gap-3 p-4 rounded-lg bg-slate-50 border border-slate-200">
                                 <input
                                     type="checkbox"
                                     id="age_confirmation"
                                     name="age_confirmation"
                                     required
                                     class="w-5 h-5 mt-0.5 rounded border-slate-300 text-cyan-600 focus:ring-2 focus:ring-cyan-500 cursor-pointer"
                                 />
                                 <label for="age_confirmation" class="text-sm text-slate-700 cursor-pointer flex-1">
                                     {lang === "es" 
                                         ? "Confirmo que tengo 18 años o más y soy un padre o adulto responsable"
                                         : "I confirm that I am 18+ and a parent or responsible adult"}
                                 </label>
                             </div>

                            <!-- Submit button -->
                            <button
                                type="submit"
                                id="submit-btn"
                                class="w-full mt-8 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-600 hover:to-blue-700 text-white font-bold py-3 rounded-lg transition-all transform hover:scale-105 active:scale-95 shadow-lg flex items-center justify-center gap-2"
                            >
                                <span>{lang === "es" ? "Aceptar invitación" : "Accept invitation"}</span>
                            </button>

                            <!-- Already have account -->
                            <p class="text-center text-slate-600 text-sm mt-6">
                                {lang === "es" 
                                    ? "¿Ya tienes cuenta? " 
                                    : "Already have an account? "}
                                <a href="/login" class="font-semibold text-cyan-600 hover:text-cyan-700">
                                    {lang === "es" ? "Inicia sesión" : "Sign in"}
                                </a>
                            </p>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script define:vars={{ invitationCode, lang }}>
        document.addEventListener('astro:page-load', () => {
        const form = document.getElementById("accept-form");
        const errorDiv = document.getElementById("error-message");
        const successDiv = document.getElementById("success-message");
        const submitBtn = document.getElementById("submit-btn");
        if (!form) return;

        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const nameInput = document.getElementById("name");
            const passwordInput = document.getElementById("password");
            const confirmPasswordInput = document.getElementById("confirm_password");
            const invitationCodeInput = document.getElementById("invitation_code");
            const ageConfirmationInput = document.getElementById("age_confirmation");

            const name = nameInput.value.trim();
            const password = passwordInput.value;
            const confirmPassword = confirmPasswordInput.value;
            const code = invitationCode || (invitationCodeInput?.value?.trim() || "");
            const ageConfirmed = ageConfirmationInput?.checked || false;

            // Clear messages
            errorDiv.classList.add("hidden");
            successDiv.classList.add("hidden");

            // Validation
            if (!name) {
                errorDiv.textContent = lang === "es" ? "El nombre es requerido" : "Name is required";
                errorDiv.classList.remove("hidden");
                return;
            }

            if (!password) {
                errorDiv.textContent = lang === "es" ? "La contraseña es requerida" : "Password is required";
                errorDiv.classList.remove("hidden");
                return;
            }

            if (password.length < 8) {
                errorDiv.textContent = lang === "es" ? "La contraseña debe tener al menos 8 caracteres" : "Password must be at least 8 characters";
                errorDiv.classList.remove("hidden");
                return;
            }

            if (password !== confirmPassword) {
                errorDiv.textContent = lang === "es" ? "Las contraseñas no coinciden" : "Passwords don't match";
                errorDiv.classList.remove("hidden");
                return;
            }

            if (!ageConfirmed) {
                errorDiv.textContent = lang === "es" 
                    ? "Debes confirmar que tienes 18 años o más"
                    : "You must confirm that you are 18 or older";
                errorDiv.classList.remove("hidden");
                return;
            }

            if (!code) {
                errorDiv.textContent = lang === "es" ? "El código de invitación es requerido" : "Invitation code is required";
                errorDiv.classList.remove("hidden");
                return;
            }

            // Submit
            submitBtn.disabled = true;
            submitBtn.textContent = lang === "es" ? "Procesando..." : "Processing...";

            try {
                const response = await fetch("/api/invitations/accept", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        invitation_code: code,
                        password,
                        name
                    })
                });

                const data = await response.json();

                if (data.success) {
                    successDiv.textContent = lang === "es" ? "¡Invitación aceptada! Redirigiendo..." : "Invitation accepted! Redirecting...";
                    successDiv.classList.remove("hidden");
                    setTimeout(() => {
                        window.location.href = data.redirect || "/dashboard";
                    }, 1500);
                } else {
                    errorDiv.textContent = data.error || (lang === "es" ? "Error al aceptar la invitación" : "Error accepting invitation");
                    errorDiv.classList.remove("hidden");
                    submitBtn.disabled = false;
                    submitBtn.textContent = lang === "es" ? "Aceptar invitación" : "Accept invitation";
                }
            } catch (e) {
                console.error("Error:", e);
                errorDiv.textContent = lang === "es" ? "Error de conexión. Intenta de nuevo." : "Connection error. Please try again.";
                errorDiv.classList.remove("hidden");
                submitBtn.disabled = false;
                submitBtn.textContent = lang === "es" ? "Aceptar invitación" : "Accept invitation";
            }
        });
        });
    </script>
</Layout>
