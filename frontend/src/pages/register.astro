---
import Layout from "../layouts/Layout.astro";
import { seoFor } from "../lib/seo";

if (Astro.cookies.has("access_token")) {
    return Astro.redirect("/dashboard");
}

const lang = Astro.cookies.get("lang")?.value ?? "es";
const seo = seoFor("/register", lang)!;

// Referral code from the invite link (?ref=CODE). Sanitized to the code
// alphabet so it is safe to echo into the page. When present we show an
// "invited" banner and pass it through to the backend, which credits both
// families a free month of Plus on a successful new-family signup.
const ref = (Astro.url.searchParams.get("ref") ?? "")
    .replace(/[^A-Za-z0-9]/g, "")
    .toUpperCase()
    .slice(0, 16);
---

<Layout title={seo.title} description={seo.description} lang={lang}>
    <main class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 flex items-center justify-center p-4">
        <div class="w-full max-w-5xl">
            <div class="bg-brand-cream rounded-3xl shadow-[var(--shadow-stamp)] overflow-hidden">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
                    <!-- Left column: Hero -->
                    <div class="hidden md:flex md:flex-col md:justify-center md:items-start p-12 lg:p-16 bg-gradient-to-br from-brand-coral via-brand-coral to-pink-600 text-white">
                        <h2 class="text-5xl font-black leading-tight mb-6">
                            {lang === "es" ? "¡Bienvenido!" : "Welcome!"}
                        </h2>
                        <p class="text-xl text-brand-coral-deep leading-relaxed mb-12">
                            {lang === "es" 
                                ? "Crea tu familia y empieza a organizar tareas, recompensas y finanzas hoy mismo" 
                                : "Create your family and start organizing tasks, rewards, and finances today"}
                        </p>

                        <div class="space-y-6">
                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0 bg-brand-cream bg-opacity-20 rounded-full p-3">
                                    <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="font-semibold text-lg">{lang === "es" ? "Gratis y fácil" : "Free & easy"}</p>
                                    <p class="text-sm text-brand-coral-deep">{lang === "es" ? "Sin tarjeta de crédito requerida" : "No credit card needed"}</p>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0 bg-brand-cream bg-opacity-20 rounded-full p-3">
                                    <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="font-semibold text-lg">{lang === "es" ? "Seguro" : "Secure"}</p>
                                    <p class="text-sm text-brand-coral-deep">{lang === "es" ? "Tus datos protegidos en todo momento" : "Your data protected at all times"}</p>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0 bg-brand-cream bg-opacity-20 rounded-full p-3">
                                    <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="font-semibold text-lg">{lang === "es" ? "Escalable" : "Scalable"}</p>
                                    <p class="text-sm text-brand-coral-deep">{lang === "es" ? "Invita a toda tu familia a participar" : "Invite your whole family to join"}</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right column: Register form -->
                    <div class="p-8 lg:p-12 flex flex-col justify-center">
                        <div class="mb-8">
                             <h1 class="text-3xl lg:text-4xl font-bold text-brand-ink mb-2">
                                 {lang === "es" ? "Crear cuenta" : "Create account"}
                             </h1>
                             <p class="text-brand-ink-soft text-lg">
                                 {lang === "es"
                                     ? "Registra tu familia en segundos"
                                     : "Register your family in seconds"}
                             </p>
                             <p class="text-brand-ink-soft text-sm mt-2">
                                 {lang === "es"
                                     ? "¿Ya tienes un código de familia? Úsalo para unirte a una familia existente"
                                     : "Already have a family code? Use it to join an existing family"}
                             </p>
                         </div>

                        {ref && (
                            <div class="mb-6 p-4 rounded-xl bg-brand-sun/15 border border-brand-sun text-brand-ink text-sm font-medium flex items-start gap-3">
                                <span class="text-xl leading-none">🎁</span>
                                <div>
                                    <p class="font-bold">
                                        {lang === "es" ? "¡Te invitaron!" : "You've been invited!"}
                                    </p>
                                    <p class="text-xs text-brand-ink-soft mt-0.5">
                                        {lang === "es"
                                            ? `Crea tu familia con el código ${ref} y tú y quien te invitó reciben un mes de Plus gratis.`
                                            : `Create your family with code ${ref} and both you and your inviter get a free month of Plus.`}
                                    </p>
                                </div>
                            </div>
                        )}

                        <div id="register-error" class="hidden mb-6 p-4 rounded-xl bg-red-100 border border-red-200 text-red-700 text-sm font-medium"></div>
                        <div id="register-pending" class="hidden mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-medium"></div>

                        <form id="register-form" class="space-y-5">
                             <!-- Family code (optional) -->
                             <div>
                                 <label for="family_code" class="block text-sm font-semibold text-brand-ink mb-2">
                                     {lang === "es" ? "Código de familia (opcional)" : "Family code (optional)"}
                                 </label>
                                 <input
                                     type="text"
                                     id="family_code"
                                     name="family_code"
                                     maxlength="10"
                                     placeholder={lang === "es" ? "Ej: ABC12345" : "e.g. ABC12345"}
                                     class="w-full px-4 py-3 rounded-lg border border-brand-ink/20 focus:ring-2 focus:ring-brand-coral focus:border-transparent outline-none transition-all hover:border-brand-ink/20 uppercase"
                                 />
                                 <p class="text-xs text-brand-ink-soft mt-1">
                                     {lang === "es"
                                         ? "Si tienes un código, tu cuenta se agregará a esa familia"
                                         : "If you have a code, your account will be added to that family"}
                                 </p>
                             </div>

                             <!-- Who is joining (only shown when a family code is entered) -->
                             <div id="join-role-wrap" class="hidden">
                                 <label for="join_role" class="block text-sm font-semibold text-brand-ink mb-2">
                                     {lang === "es" ? "¿Quién se une?" : "Who is joining?"}
                                 </label>
                                 <select
                                     id="join_role"
                                     name="join_role"
                                     class="w-full px-4 py-3 rounded-lg border border-brand-ink/20 focus:ring-2 focus:ring-brand-coral focus:border-transparent outline-none transition-all bg-white"
                                 >
                                     <option value="child" selected>{lang === "es" ? "Niño / Niña" : "Child"}</option>
                                     <option value="teen">{lang === "es" ? "Adolescente" : "Teen"}</option>
                                 </select>
                                 <p class="text-xs text-brand-ink-soft mt-1">
                                     {lang === "es"
                                         ? "Un papá o mamá deberá aprobar tu cuenta antes de que puedas entrar. Los papás se unen por invitación de correo."
                                         : "A parent must approve your account before you can sign in. Parents join via email invitation."}
                                 </p>
                             </div>

                             <!-- Birthdate (optional, join flow only) -->
                             <div id="join-birthdate-wrap" class="hidden">
                                 <label for="birthdate" class="block text-sm font-semibold text-brand-ink mb-2">
                                     {lang === "es" ? "Fecha de nacimiento (opcional)" : "Birthdate (optional)"}
                                 </label>
                                 <input
                                     type="date"
                                     id="birthdate"
                                     name="birthdate"
                                     class="w-full px-4 py-3 rounded-lg border border-brand-ink/20 focus:ring-2 focus:ring-brand-coral focus:border-transparent outline-none transition-all hover:border-brand-ink/20 bg-white"
                                 />
                             </div>

                             <!-- Family name -->
                             <div>
                                 <label for="family_name" class="block text-sm font-semibold text-brand-ink mb-2">
                                     {lang === "es" ? "Nombre de tu familia" : "Family name"}
                                 </label>
                                 <input
                                     type="text"
                                     id="family_name"
                                     name="family_name"
                                     maxlength="100"
                                     placeholder={lang === "es" ? "Ej: Familia García" : "e.g. The Smiths"}
                                     class="w-full px-4 py-3 rounded-lg border border-brand-ink/20 focus:ring-2 focus:ring-brand-coral focus:border-transparent outline-none transition-all hover:border-brand-ink/20"
                                 />
                                 <p class="text-xs text-brand-ink-soft mt-1">
                                     {lang === "es" 
                                         ? "Se ignorará si proporcionas un código de familia" 
                                         : "This will be ignored if you provide a family code"}
                                 </p>
                             </div>

                            <!-- Your name -->
                            <div>
                                <label for="name" class="block text-sm font-semibold text-brand-ink mb-2">
                                    {lang === "es" ? "Tu nombre" : "Your name"}
                                </label>
                                <input
                                    type="text"
                                    id="name"
                                    name="name"
                                    required
                                    maxlength="100"
                                    placeholder={lang === "es" ? "Ej: María" : "e.g. Maria"}
                                    class="w-full px-4 py-3 rounded-lg border border-brand-ink/20 focus:ring-2 focus:ring-brand-coral focus:border-transparent outline-none transition-all hover:border-brand-ink/20"
                                />
                            </div>

                            <!-- Email -->
                            <div>
                                <label for="email" class="block text-sm font-semibold text-brand-ink mb-2">
                                    {lang === "es" ? "Correo electrónico" : "Email address"}
                                </label>
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    placeholder="you@example.com"
                                    class="w-full px-4 py-3 rounded-lg border border-brand-ink/20 focus:ring-2 focus:ring-brand-coral focus:border-transparent outline-none transition-all hover:border-brand-ink/20"
                                />
                            </div>

                            <!-- Password -->
                            <div>
                                <label for="password" class="block text-sm font-semibold text-brand-ink mb-2">
                                    {lang === "es" ? "Contraseña" : "Password"}
                                </label>
                                <input
                                    type="password"
                                    id="password"
                                    name="password"
                                    required
                                    minlength="8"
                                    placeholder="••••••••"
                                    class="w-full px-4 py-3 rounded-lg border border-brand-ink/20 focus:ring-2 focus:ring-brand-coral focus:border-transparent outline-none transition-all hover:border-brand-ink/20"
                                />
                                <p class="text-xs text-brand-ink-soft mt-1">
                                    {lang === "es" ? "Mínimo 8 caracteres" : "Minimum 8 characters"}
                                </p>
                            </div>

                            <!-- Confirm password -->
                            <div>
                                <label for="password_confirm" class="block text-sm font-semibold text-brand-ink mb-2">
                                    {lang === "es" ? "Confirmar contraseña" : "Confirm password"}
                                </label>
                                <input
                                    type="password"
                                    id="password_confirm"
                                    name="password_confirm"
                                    required
                                    minlength="8"
                                    placeholder="••••••••"
                                    class="w-full px-4 py-3 rounded-lg border border-brand-ink/20 focus:ring-2 focus:ring-brand-coral focus:border-transparent outline-none transition-all hover:border-brand-ink/20"
                                />
                            </div>

                            <!-- Terms + privacy consent (required) -->
                            <div class="flex items-start gap-3 p-4 rounded-lg bg-brand-cream-deep border border-brand-ink/10">
                                <input
                                    type="checkbox"
                                    id="accept_terms"
                                    name="accept_terms"
                                    required
                                    class="w-5 h-5 mt-0.5 rounded border-brand-ink/20 text-brand-coral focus:ring-2 focus:ring-brand-coral cursor-pointer"
                                />
                                <label for="accept_terms" class="text-sm text-brand-ink cursor-pointer flex-1 leading-relaxed">
                                    {lang === "es" ? "Acepto los " : "I accept the "}
                                    <a href="/terminos" target="_blank" rel="noopener" class="font-bold underline text-brand-coral-deep hover:text-brand-coral transition-colors">
                                        {lang === "es" ? "Términos" : "Terms"}
                                    </a>
                                    {lang === "es" ? " y el " : " and the "}
                                    <a href="/privacidad" target="_blank" rel="noopener" class="font-bold underline text-brand-coral-deep hover:text-brand-coral transition-colors">
                                        {lang === "es" ? "Aviso de Privacidad" : "Privacy Notice"}
                                    </a>
                                </label>
                            </div>

                            <button
                                type="submit"
                                id="register-submit-btn"
                                class="w-full py-3 px-4 rounded-lg text-white font-bold bg-gradient-to-r from-brand-coral to-pink-600 hover:to-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-coral transition-all shadow-[var(--shadow-pop)] hover:shadow-[var(--shadow-pop)] active:scale-95"
                            >
                                {lang === "es" ? "Crear mi cuenta" : "Create my account"}
                            </button>
                        </form>

                        <!-- Login Link -->
                        <p class="mt-8 text-center text-sm text-brand-ink-soft">
                            {lang === "es" ? "¿Ya tienes cuenta?" : "Already have an account?"}
                            {" "}
                            <a href="/login" class="font-bold text-brand-coral-deep hover:text-brand-coral-deep transition-colors">
                                {lang === "es" ? "Inicia sesión aquí" : "Sign in"}
                            </a>
                        </p>

                        <!-- Language Toggle -->
                        <form method="POST" action="/api/lang" class="mt-6 flex justify-center">
                            <input type="hidden" name="lang" value={lang === "es" ? "en" : "es"} />
                            <button
                                type="submit"
                                class="text-xs text-brand-ink-soft hover:text-brand-coral-deep font-medium flex items-center gap-1.5 transition-colors"
                            >
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
                                </svg>
                                {lang === "es" ? "English" : "Español"}
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script is:inline define:vars={{ lang, ref }}>
        document.addEventListener('astro:page-load', () => {
        const form = document.getElementById('register-form');
        const errorDiv = document.getElementById('register-error');
        const pendingDiv = document.getElementById('register-pending');
        const submitBtn = document.getElementById('register-submit-btn');
        if (!form) return;

        // Role + birthdate pickers only apply when joining a family by code
        const codeInput = document.getElementById('family_code');
        const roleWrap = document.getElementById('join-role-wrap');
        const birthdateWrap = document.getElementById('join-birthdate-wrap');
        const syncRoleVisibility = () => {
            const hidden = !codeInput.value.trim();
            roleWrap.classList.toggle('hidden', hidden);
            birthdateWrap.classList.toggle('hidden', hidden);
        };
        codeInput.addEventListener('input', syncRoleVisibility);
        syncRoleVisibility();

        form.addEventListener('submit', async function(e) {
            e.preventDefault();

            const family_code = document.getElementById('family_code').value.trim().toUpperCase();
            const family_name = document.getElementById('family_name').value.trim();
            const name = document.getElementById('name').value.trim();
            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const passwordConfirm = document.getElementById('password_confirm').value;
            const acceptTerms = document.getElementById('accept_terms').checked;
            const birthdate = document.getElementById('birthdate').value;

            errorDiv.classList.add('hidden');
            errorDiv.textContent = '';
            pendingDiv.classList.add('hidden');
            pendingDiv.textContent = '';

            if (!acceptTerms) {
                errorDiv.textContent = lang === 'es'
                    ? 'Debes aceptar los Términos y el Aviso de Privacidad'
                    : 'You must accept the Terms and the Privacy Notice';
                errorDiv.classList.remove('hidden');
                return;
            }

            // Validate passwords
            if (password !== passwordConfirm) {
                errorDiv.textContent = lang === 'es'
                    ? 'Las contraseñas no coinciden'
                    : 'Passwords do not match';
                errorDiv.classList.remove('hidden');
                return;
            }
            if (password.length < 8) {
                errorDiv.textContent = lang === 'es'
                    ? 'La contraseña debe tener al menos 8 caracteres'
                    : 'Password must be at least 8 characters';
                errorDiv.classList.remove('hidden');
                return;
            }

            // Validate family name if no code provided
            if (!family_code && !family_name) {
                errorDiv.textContent = lang === 'es'
                    ? 'Proporciona un código de familia o un nombre de familia'
                    : 'Provide either a family code or family name';
                errorDiv.classList.remove('hidden');
                return;
            }

            const originalText = submitBtn.textContent;
            submitBtn.disabled = true;
            submitBtn.textContent = '...';

            try {
                // Build request body - only include family_name if no code provided
                const body = {
                    name,
                    email,
                    password,
                    preferred_lang: lang,
                    accept_terms: acceptTerms,
                };

                if (family_code) {
                    body.family_code = family_code;
                    body.role = document.getElementById('join_role').value;
                    if (birthdate) body.birthdate = birthdate;
                } else {
                    body.family_name = family_name;
                    // Referral code only applies when founding a new family.
                    if (ref) body.ref = ref;
                }

                const response = await fetch('/api/auth/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body),
                });

                const data = await response.json();

                if (data.success && data.pending) {
                    // Join-code signup: account created but pending parental
                    // approval — no session, tell them to wait for a parent.
                    form.classList.add('hidden');
                    pendingDiv.textContent = data.message || (lang === 'es'
                        ? 'Tu cuenta fue creada y está pendiente de aprobación. Pide a tu papá o mamá que la apruebe para poder iniciar sesión.'
                        : 'Your account was created and is pending approval. Ask a parent to approve it before you can log in.');
                    pendingDiv.classList.remove('hidden');
                    pendingDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
                } else if (data.success && data.redirect) {
                    window.location.href = data.redirect;
                } else {
                    errorDiv.textContent = data.error || (lang === 'es' ? 'Error al crear la cuenta' : 'Registration failed');
                    errorDiv.classList.remove('hidden');
                    submitBtn.disabled = false;
                    submitBtn.textContent = originalText;
                }
            } catch (err) {
                console.error('Register error:', err);
                errorDiv.textContent = lang === 'es'
                    ? 'Error de conexión. Intenta de nuevo.'
                    : 'Connection error. Please try again.';
                errorDiv.classList.remove('hidden');
                submitBtn.disabled = false;
                submitBtn.textContent = originalText;
            }
        });
        });
    </script>
</Layout>
