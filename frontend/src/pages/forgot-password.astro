---
import Layout from "../layouts/Layout.astro";

const lang = Astro.cookies.get("lang")?.value ?? "en";

const copy = {
  es: {
    title: "Olvidé mi contraseña",
    heading: "Recuperar contraseña",
    subtitle: "Te enviaremos un enlace de restablecimiento a tu correo.",
    label: "Correo electrónico",
    btn: "Enviar enlace",
    sending: "Enviando...",
    success: "Si existe una cuenta con ese correo, recibirás el enlace en unos minutos. Revisa también tu carpeta de spam.",
    back: "Volver al inicio de sesión",
  },
  en: {
    title: "Forgot password",
    heading: "Recover your password",
    subtitle: "We'll send a reset link to your email address.",
    label: "Email address",
    btn: "Send reset link",
    sending: "Sending...",
    success: "If an account with that email exists, you'll receive the link shortly. Check your spam folder too.",
    back: "Back to login",
  },
}[lang] ?? {};
---

<Layout title={`${copy.title} — Family Task Manager`}>
  <main class="min-h-screen flex items-center justify-center p-4 bg-slate-50">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl p-8">
      <div class="mb-8 text-center">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-indigo-50 mb-4">
          <svg class="w-7 h-7 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-slate-900">{copy.heading}</h1>
        <p class="text-slate-500 mt-1 text-sm">{copy.subtitle}</p>
      </div>

      <div id="success-msg" class="hidden mb-6 p-4 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm text-center">
        {copy.success}
      </div>

      <form id="forgot-form" class="space-y-5">
        <div id="error-msg" class="hidden p-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm"></div>
        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 mb-1">{copy.label}</label>
          <input
            type="email" id="email" name="email" required autocomplete="email"
            class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow"
          />
        </div>
        <button
          type="submit" id="submit-btn"
          class="w-full py-3 px-4 rounded-lg text-white font-medium bg-indigo-600 hover:bg-indigo-700 transition-colors shadow-sm"
        >
          {copy.btn}
        </button>
      </form>

      <div class="mt-6 text-center">
        <a href="/login" class="text-sm text-indigo-600 hover:text-indigo-800 font-medium transition-colors">
          &larr; {copy.back}
        </a>
      </div>
    </div>
  </main>

  <script define:vars={{ sending: copy.sending, btnLabel: copy.btn }}>
    document.addEventListener('astro:page-load', () => {
    const form = document.getElementById("forgot-form");
    const btn = document.getElementById("submit-btn");
    const successMsg = document.getElementById("success-msg");
    const errorMsg = document.getElementById("error-msg");

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = document.getElementById("email").value;

      btn.disabled = true;
      btn.textContent = sending;
      errorMsg.classList.add("hidden");

      try {
        const res = await fetch("/api/auth/forgot-password", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });

        // Always show success regardless of whether email exists (anti-enumeration)
        form.classList.add("hidden");
        successMsg.classList.remove("hidden");
      } catch {
        errorMsg.textContent = "An error occurred. Please try again.";
        errorMsg.classList.remove("hidden");
        btn.disabled = false;
        btn.textContent = btnLabel;
      }
    });
    });
  </script>
</Layout>
