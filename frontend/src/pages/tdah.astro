---
/**
 * /tdah — Spanish-first content/landing page: "Rutinas para niños con TDAH".
 *
 * Targets the high-empathy, low-competition long-tail cluster in
 * docs/SEO_ASO.md §2.4 (rutinas para niños con TDAH / tablero de rutinas
 * visual). Positions the pet + routine loop as the mechanism that makes daily
 * routines stick for neurodivergent kids, and funnels to /register (where the
 * matching "TDAH y rutinas" starter pack loads in one tap).
 *
 * Bilingual via the `lang` cookie (ES default, Mexico-first). SEO meta + JSON-LD
 * flow through Layout → Head; the page is whitelisted in middleware.ts and
 * listed in sitemap.xml. Two-currency honest: routines earn POINTS →
 * privileges/rewards, never cash.
 */
import Layout from "../layouts/Layout.astro";
import Logo from "../components/brand/Logo.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import Badge from "../components/ui/Badge.astro";
import {
  seoFor,
  organizationJsonLd,
  softwareAppJsonLd,
  tdahFaq,
  faqPageJsonLd,
} from "../lib/seo";

const lang = Astro.cookies.get("lang")?.value ?? "es";

if (Astro.cookies.has("access_token")) {
  return Astro.redirect("/dashboard");
}

const es = lang === "es";
const seo = seoFor("/tdah", lang)!;
const faq = tdahFaq(lang);
const jsonLd = [organizationJsonLd(), softwareAppJsonLd(lang), faqPageJsonLd(faq)];

// A few routines pulled from the "tdah" starter pack (backend/app/data/
// starter_packs.py) so the marketing copy mirrors what actually loads.
const sampleRoutines = es
  ? [
      "Rutina de la mañana: vestirse, desayunar y dientes",
      "Preparar la mochila la noche anterior",
      "Marcar tus tareas en el tablero visual",
      "Tomar un descanso de movimiento de 5 minutos",
      "Rutina de la noche: guardar pantallas, pijama y cuento",
    ]
  : [
      "Morning routine: dress, breakfast and teeth",
      "Pack your backpack the night before",
      "Check off your tasks on the visual board",
      "Take a 5-minute movement break",
      "Evening wind-down: screens away, pajamas, story",
    ];
---

<Layout title={seo.title} description={seo.description} lang={lang} jsonLd={jsonLd}>

  <!-- TOP BAR -->
  <header class="sticky top-0 z-50 bg-brand-cream border-b-2 border-brand-ink px-6 py-3 flex items-center gap-4">
    <Logo size="sm" href="/" />
    <nav class="ml-auto flex gap-2 items-center">
      <form method="POST" action="/api/lang" class="inline">
        <input type="hidden" name="lang" value={es ? "en" : "es"} />
        <button type="submit" class="press inline-flex items-center gap-1 px-3 py-1.5 border-2 border-brand-ink rounded-full text-xs font-extrabold font-display bg-brand-cream shadow-[2px_2px_0_var(--color-brand-ink)]">
          {es ? "EN" : "ES"}
        </button>
      </form>
      <a href="/login" class="hidden md:inline-flex font-display font-extrabold text-sm text-brand-ink px-3 py-2 hover:text-brand-coral-deep">{es ? "Iniciar sesión" : "Sign in"}</a>
      <Button variant="primary" size="sm" href="/register">{es ? "Comenzar gratis" : "Get started"}</Button>
    </nav>
  </header>

  <!-- HERO -->
  <section class="bg-brand-mint border-b-2 border-brand-ink px-6 py-20">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <Badge tone="cream">{es ? "Rutinas · TDAH" : "Routines · ADHD"}</Badge>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl mt-4 leading-[0.98] tracking-tight">
          {es
            ? <>Rutinas para niños<br/>con <span class="text-brand-coral">TDAH</span> que sí funcionan.</>
            : <>Routines for kids<br/>with <span class="text-brand-coral">ADHD</span> that actually stick.</>}
        </h1>
        <!-- Short answer first — featured-snippet bait (SEO_ASO.md §3). -->
        <p class="mt-5 text-lg font-sans font-medium text-brand-ink max-w-md">
          {es
            ? "Las rutinas visuales ayudan a los niños con TDAH porque convierten el día en pasos pequeños con logros inmediatos. Cada rutina completada alimenta a su mascota y suma puntos — la constancia se vuelve un juego, no una pelea."
            : "Visual routines help kids with ADHD because they turn the day into small steps with immediate wins. Every finished routine feeds their pet and earns points — consistency becomes a game, not a fight."}
        </p>
        <div class="mt-7 flex gap-3 flex-wrap">
          <Button variant="primary" size="lg" href="/register">{es ? "Empezar gratis →" : "Start free →"}</Button>
          <Button variant="ghost" size="lg" href="#como-funciona">{es ? "Ver cómo funciona" : "See how it works"}</Button>
        </div>
        <p class="mt-4 text-xs font-sans text-brand-ink-soft">{es ? "Sin tarjeta · Bilingüe español e inglés" : "No card · Bilingual Spanish & English"}</p>
      </div>
      <Card tone="cream" pop class="p-8">
        <p class="font-sans font-extrabold text-xs tracking-[0.14em] uppercase text-brand-ink-soft">{es ? "Tablero visual del día" : "Today's visual board"}</p>
        <ul class="mt-4 space-y-3">
          {sampleRoutines.map((r) => (
            <li class="flex items-center gap-3 bg-brand-cream border-2 border-brand-ink rounded-[var(--radius-card)] px-4 py-3 shadow-[var(--shadow-card)]">
              <span class="flex-none w-7 h-7 rounded-full bg-brand-mint border-2 border-brand-ink flex items-center justify-center text-sm font-display font-extrabold">✓</span>
              <span class="font-sans font-bold text-sm text-brand-ink">{r}</span>
            </li>
          ))}
        </ul>
      </Card>
    </div>
  </section>

  <!-- WHY ROUTINES HELP -->
  <section class="bg-brand-cream px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <p class="font-sans font-extrabold text-xs tracking-[0.18em] uppercase text-brand-ink-soft">{es ? "Por qué funciona" : "Why it works"}</p>
      <h2 class="font-display text-4xl md:text-5xl mt-2">{es ? "El cerebro con TDAH necesita estructura visible." : "The ADHD brain needs visible structure."}</h2>
      <p class="mt-4 text-lg font-sans font-medium text-brand-ink-soft max-w-2xl">
        {es
          ? "No es falta de voluntad: es dificultad para iniciar y sostener la atención. Estas tres piezas bajan la fricción para empezar."
          : "It isn't a lack of willpower: it's difficulty starting and sustaining attention. These three pieces lower the friction to begin."}
      </p>

      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <Card>
          <div class="text-4xl">👀</div>
          <h3 class="font-display text-2xl mt-3">{es ? "Estructura visible" : "Visible structure"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Un tablero muestra el día completo. Lo que se ve se recuerda — no depende de la memoria de trabajo." : "A board shows the whole day. What's visible gets remembered — it doesn't rely on working memory."}</p>
        </Card>
        <Card>
          <div class="text-4xl">🧩</div>
          <h3 class="font-display text-2xl mt-3">{es ? "Pasos pequeños" : "Small steps"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "\"Alístate\" abruma; \"vístete, desayuna, dientes\" no. Cada rutina se parte en tareas cortas y alcanzables." : "\"Get ready\" overwhelms; \"dress, breakfast, teeth\" doesn't. Each routine breaks into short, doable tasks."}</p>
        </Card>
        <Card>
          <div class="text-4xl">⚡</div>
          <h3 class="font-display text-2xl mt-3">{es ? "Logros inmediatos" : "Immediate wins"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "El TDAH pide recompensa ahora, no el domingo. Cada paso da puntos al instante y refuerza el hábito." : "ADHD wants the reward now, not on Sunday. Every step gives points instantly and reinforces the habit."}</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- PET + ROUTINE LOOP -->
  <section class="bg-brand-sky border-y-2 border-brand-ink px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <p class="font-sans font-extrabold text-xs tracking-[0.18em] uppercase text-brand-ink">{es ? "El bucle mágico" : "The magic loop"}</p>
      <h2 class="font-display text-4xl md:text-5xl mt-2 text-brand-ink">{es ? "Mascota + rutina = constancia." : "Pet + routine = consistency."}</h2>
      <p class="mt-4 text-lg font-sans font-medium text-brand-ink max-w-2xl">
        {es
          ? "Cada niño tiene una mascota virtual que cuida. Completar rutinas la mantiene feliz — un premio inmediato y visual que hace que quieran volver mañana."
          : "Each kid has a virtual pet they care for. Completing routines keeps it happy — an immediate, visual reward that makes them want to come back tomorrow."}
      </p>

      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <Card tone="cream" class="text-center">
          <div class="text-5xl">✅</div>
          <p class="font-display font-extrabold text-lg mt-3">{es ? "1. Completa una rutina" : "1. Finish a routine"}</p>
          <p class="text-sm text-brand-ink-soft mt-1 font-sans">{es ? "Marca un paso en su tablero visual." : "Check off a step on the visual board."}</p>
        </Card>
        <Card tone="cream" class="text-center">
          <div class="text-5xl">⭐</div>
          <p class="font-display font-extrabold text-lg mt-3">{es ? "2. Gana puntos" : "2. Earn points"}</p>
          <p class="text-sm text-brand-ink-soft mt-1 font-sans">{es ? "Puntos al instante, sin esperar." : "Points instantly, no waiting."}</p>
        </Card>
        <Card tone="cream" class="text-center">
          <div class="text-5xl">🐾</div>
          <p class="font-display font-extrabold text-lg mt-3">{es ? "3. La mascota crece feliz" : "3. The pet grows happy"}</p>
          <p class="text-sm text-brand-ink-soft mt-1 font-sans">{es ? "Recompensa visual e inmediata." : "Immediate, visual reward."}</p>
        </Card>
        <Card tone="cream" class="text-center">
          <div class="text-5xl">🔁</div>
          <p class="font-display font-extrabold text-lg mt-3">{es ? "4. Mañana, otra vez" : "4. Tomorrow, again"}</p>
          <p class="text-sm text-brand-ink-soft mt-1 font-sans">{es ? "El hábito se refuerza solo." : "The habit reinforces itself."}</p>
        </Card>
      </div>

      <p class="mt-8 text-sm font-sans font-bold text-brand-ink bg-brand-cream border-2 border-brand-ink rounded-[var(--radius-card)] px-4 py-3 inline-block shadow-[var(--shadow-card)]">
        {es
          ? "Los puntos se canjean por privilegios (tiempo de pantalla, elegir la música, tiempo 1 a 1) — nunca por dinero."
          : "Points redeem for privileges (screen time, picking the music, 1-on-1 time) — never for money."}
      </p>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="como-funciona" class="bg-brand-cream px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <p class="font-sans font-extrabold text-xs tracking-[0.18em] uppercase text-brand-ink-soft">{es ? "En 3 pasos" : "In 3 steps"}</p>
      <h2 class="font-display text-4xl md:text-5xl mt-2">{es ? "Listo en minutos, no en semanas." : "Ready in minutes, not weeks."}</h2>

      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <Card tone="sun">
          <Badge tone="cream">{es ? "Paso 1" : "Step 1"}</Badge>
          <h3 class="font-display text-2xl mt-3">{es ? "Carga el paquete TDAH" : "Load the ADHD pack"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Al crear tu familia, aplica el paquete \"TDAH y rutinas\" con un toque: rutinas de mañana y noche, descansos de movimiento y premios sensoriales." : "When you create your family, apply the \"ADHD & routines\" pack in one tap: morning and evening routines, movement breaks, and sensory rewards."}</p>
        </Card>
        <Card tone="coral">
          <Badge tone="cream">{es ? "Paso 2" : "Step 2"}</Badge>
          <h3 class="font-display text-2xl mt-3">{es ? "El niño ve su tablero" : "Your kid sees their board"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Números grandes, taps amplios y modo tutorial. El día completo, a la vista, sin recordatorios tuyos." : "Big numerals, larger taps, tutorial mode. The whole day, in plain view, with no reminders from you."}</p>
        </Card>
        <Card tone="mint">
          <Badge tone="cream">{es ? "Paso 3" : "Step 3"}</Badge>
          <h3 class="font-display text-2xl mt-3">{es ? "Cada logro cuenta" : "Every win counts"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Completar rutinas suma puntos, alimenta la mascota y desbloquea premios que tú defines. Todo editable cuando quieras." : "Completing routines earns points, feeds the pet, and unlocks rewards you define. All editable anytime."}</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- STARTER PACK CALLOUT -->
  <section class="bg-brand-cream-deep border-y-2 border-brand-ink px-6 py-20">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-center">
      <div>
        <p class="font-sans font-extrabold text-xs tracking-[0.18em] uppercase text-brand-ink-soft">{es ? "Paquete de inicio" : "Starter pack"}</p>
        <h2 class="font-display text-4xl mt-2">{es ? "\"TDAH y rutinas\", listo para cargar." : "\"ADHD & routines\", ready to load."}</h2>
        <p class="mt-4 text-base font-sans font-medium text-brand-ink-soft">
          {es
            ? "Rutinas visuales y calmadas, con logros pequeños y frecuentes. Nosotros precargamos las tareas con puntos y los premios; tú ajustas lo que quieras."
            : "Calm, visual routines with small, frequent wins. We preload the point-earning tasks and rewards; you tweak whatever you want."}
        </p>
        <div class="mt-6">
          <Button variant="primary" size="lg" href="/register">{es ? "Crear mi familia gratis →" : "Create my family free →"}</Button>
        </div>
      </div>
      <Card tone="cream" pop class="p-6">
        <ul class="space-y-2.5">
          {sampleRoutines.map((r) => (
            <li class="flex items-center gap-3">
              <span class="flex-none w-6 h-6 rounded-full bg-brand-sun border-2 border-brand-ink flex items-center justify-center text-xs font-display font-extrabold">★</span>
              <span class="font-sans font-semibold text-sm text-brand-ink">{r}</span>
            </li>
          ))}
          <li class="flex items-center gap-3 pt-1">
            <span class="flex-none w-6 h-6 rounded-full bg-brand-coral border-2 border-brand-ink flex items-center justify-center text-xs font-display font-extrabold">+</span>
            <span class="font-sans font-bold text-sm text-brand-ink-soft">{es ? "…y premios sensoriales y de tiempo 1 a 1" : "…plus sensory and 1-on-1 time rewards"}</span>
          </li>
        </ul>
      </Card>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="bg-brand-cream px-6 py-20">
    <div class="max-w-3xl mx-auto">
      <p class="font-sans font-extrabold text-xs tracking-[0.18em] uppercase text-brand-ink-soft">{es ? "Preguntas frecuentes" : "Frequently asked"}</p>
      <h2 class="font-display text-4xl md:text-5xl mt-2">{es ? "Lo que las familias preguntan." : "What families ask."}</h2>

      <div class="mt-8 space-y-3">
        {faq.map((item) => (
          <details class="group bg-brand-cream border-2 border-brand-ink rounded-[var(--radius-card)] shadow-[var(--shadow-card)] overflow-hidden">
            <summary class="cursor-pointer list-none px-5 py-4 flex items-center justify-between gap-4 font-display font-extrabold text-brand-ink">
              <span>{item.q}</span>
              <span class="flex-none text-xl transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="px-5 pb-5 -mt-1 text-sm font-sans text-brand-ink-soft leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>

      <!-- Honesty note: support tool, not a medical treatment. -->
      <p class="mt-8 text-xs font-sans text-brand-ink-soft leading-relaxed border-l-4 border-brand-sky pl-4">
        {es
          ? "Family Task es una herramienta de apoyo para crear rutinas y hábitos en casa. No es un diagnóstico ni un tratamiento médico y no reemplaza el consejo de un profesional de la salud."
          : "Family Task is a support tool for building routines and habits at home. It is not a diagnosis or a medical treatment and does not replace the advice of a health professional."}
      </p>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-brand-coral border-b-2 border-brand-ink px-6 py-24 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-4xl md:text-5xl text-brand-ink leading-tight tracking-tight">
        {es ? <>Menos peleas por la rutina.<br/>Empieza hoy.</> : <>Fewer fights over the routine.<br/>Start today.</>}
      </h2>
      <p class="mt-6 text-lg font-sans text-brand-ink font-medium">{es ? "Gratis para empezar. Sin tarjeta. En español." : "Free to start. No card. Bilingual."}</p>
      <div class="mt-8 flex gap-3 justify-center flex-wrap">
        <Button variant="primary" size="lg" href="/register" class="bg-brand-sun">{es ? "Comenzar gratis →" : "Get started →"}</Button>
        <Button variant="ghost" size="lg" href={es ? "/ayuda" : "/help"}>{es ? "Ver la guía" : "Read the guide"}</Button>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-brand-ink text-brand-cream px-6 py-10">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <Logo size="sm" tone="mono-cream" />
      <nav class="flex gap-4 text-xs font-sans font-bold" aria-label={es ? "Legal" : "Legal"}>
        <a href="/" class="text-brand-cream/80 hover:text-brand-sun transition">{es ? "Inicio" : "Home"}</a>
        <a href="/privacidad" class="text-brand-cream/80 hover:text-brand-sun transition">{es ? "Aviso de Privacidad" : "Privacy Notice"}</a>
        <a href="/terminos" class="text-brand-cream/80 hover:text-brand-sun transition">{es ? "Términos" : "Terms"}</a>
        <a href={es ? "/ayuda" : "/help"} class="text-brand-cream/80 hover:text-brand-sun transition">{es ? "Ayuda" : "Help"}</a>
        <a href="mailto:soporte@agent-ia.mx" class="text-brand-cream/80 hover:text-brand-sun transition">{es ? "Soporte" : "Support"}</a>
      </nav>
      <p class="font-sans text-xs text-brand-cream/70">family.agent-ia.mx · © 2026</p>
      <form method="POST" action="/api/lang" class="inline">
        <input type="hidden" name="lang" value={es ? "en" : "es"} />
        <button type="submit" class="text-xs text-brand-cream/80 hover:text-brand-sun font-sans font-bold transition">
          {es ? "Switch to English" : "Cambiar a Español"}
        </button>
      </form>
    </div>
  </footer>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (this: HTMLAnchorElement, e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href') as string);
        if (target) (target as HTMLElement).scrollIntoView({ behavior: 'smooth' });
      });
    });
  });
</script>
</Layout>
