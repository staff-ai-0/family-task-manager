---
import PageLayout from "@components/ui/PageLayout.astro";
import GigsIntroBanner from "../components/GigsIntroBanner.astro";
import VerifyEmailBanner from "../components/VerifyEmailBanner.astro";
import DifficultyChip from "../components/DifficultyChip.astro";
import EnablePushButton from "../components/EnablePushButton.astro";
import BossBattleBar from "../components/BossBattleBar.astro";
import PetAvatar from "../components/pet/PetAvatar.astro";
import { apiFetch } from "../lib/api";
import { t } from "../lib/i18n";
import { stageLabel } from "../lib/pet-art";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";

// /auth/me, daily progress (assignments + gating status) and the family-cup
// boss are independent — fetch in parallel instead of serially.
const [{ data: user, ok: userOk }, { data: progress }, { data: familyCup }] = await Promise.all([
    apiFetch<any>("/api/auth/me", { token }),
    apiFetch<any>("/api/task-assignments/progress", { token }),
    apiFetch<any>("/api/family-cup/", { token }),
]);
if (!userOk) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}

// Cooperative weekly boss battle (points/analytics based, no pet). Best-effort —
// a null just hides the bar.
const boss = familyCup?.boss ?? null;

const requiredTotal = progress?.required_total ?? 0;
const requiredCompleted = progress?.required_completed ?? 0;
const bonusUnlocked = progress?.bonus_unlocked ?? false;
const bonusTotal = progress?.bonus_total ?? 0;
const bonusCompleted = progress?.bonus_completed ?? 0;
const assignments: any[] = progress?.assignments ?? [];
// Prior-day mandatory tasks that went OVERDUE — invisible before, but still
// blocking bonus/gigs. Surface them so the kid can finish and unlock.
const overdueAssignments: any[] = progress?.overdue_assignments ?? [];

// Group overdue by template: N missed copies of the same daily chore collapse
// into ONE card with a ×N badge + the oldest date, instead of a wall of
// identical cards. Completing the card completes the OLDEST instance first
// (same per-instance endpoint — we just pick the oldest id).
const overdueByTemplate = new Map<string, any[]>();
for (const a of overdueAssignments) {
    const key = String(a.template_id ?? a.template_title);
    if (!overdueByTemplate.has(key)) overdueByTemplate.set(key, []);
    overdueByTemplate.get(key)!.push(a);
}
const overdueGroups = [...overdueByTemplate.values()].map((items) => {
    const sorted = [...items].sort((x: any, y: any) =>
        String(x.due_date ?? x.assigned_date ?? "").localeCompare(String(y.due_date ?? y.assigned_date ?? "")),
    );
    return { oldest: sorted[0], count: sorted.length };
});

function fmtShortDate(iso: string | null | undefined): string {
    if (!iso) return "";
    const s = String(iso);
    const d = new Date(s.includes("T") ? s : `${s}T00:00:00`);
    if (isNaN(d.getTime())) return "";
    return d.toLocaleDateString(lang === "es" ? "es-MX" : "en-US", {
        weekday: "short",
        day: "numeric",
        month: "short",
    });
}

const requiredAssignments = assignments.filter((a: any) => !a.template_is_bonus);
const bonusAssignments = assignments.filter((a: any) => a.template_is_bonus);

const pendingRequired = requiredAssignments.filter((a: any) => a.status === "pending");
const completedRequired = requiredAssignments.filter((a: any) => a.status === "completed");
// Gigs that are completed but awaiting/already had parent decision live in
// the "pending" bucket from a UI point of view (the assignment row is COMPLETED
// but approval_status drives the badge). Keep "completed" as the final state.
const pendingBonus = bonusAssignments.filter((a: any) => a.status === "pending");
const awaitingApprovalBonus = bonusAssignments.filter(
    (a: any) => a.status === "completed" && a.approval_status === "pending"
);
const completedBonus = bonusAssignments.filter(
    (a: any) => a.status === "completed" && a.approval_status !== "pending"
);

// Only celebrate when required-today AND overdue blockers are ALL clear —
// otherwise "All done!" renders while overdue chores still lock bonus/gigs.
const todayCleared = requiredCompleted >= requiredTotal && bonusCompleted >= bonusTotal && (requiredTotal + bonusTotal) > 0;
const allDone = todayCleared && overdueAssignments.length === 0;
// Today is clear but overdue blockers remain → nudge at the overdue section.
const doneButOverdue = todayCleared && overdueAssignments.length > 0;
const noTasks = requiredTotal === 0 && bonusTotal === 0;

const progressPercent = requiredTotal > 0 ? Math.round((requiredCompleted / requiredTotal) * 100) : 100;

// Gig trust streak — mirrors backend GIG_AUTO_APPROVE_STREAK default (3).
// Once a kid hits the threshold, their submitted gigs auto-approve.
const TRUST_THRESHOLD = 3;
const isKid = user.role === "teen" || user.role === "child";
// Star Mode (P2): young-kid display — render POINTS as stars, hide peso amounts.
const starMode = isKid && (user.star_mode ?? false);
const trustStreak = user.gig_trust_streak ?? 0;
const toAutoApprove = Math.max(0, TRUST_THRESHOLD - trustStreak);

let activeGoal: any = null;
// Payday surface: the most recent "Domingo de pago" notification (last 3 days).
// Backend localizes title/body to the kid's preferred_lang, so we render as-is.
let recentPayday: any = null;
// Virtual pet nudge (Quest Mode entry point). Best-effort — null just hides it.
let pet: any = null;
// Gigs submitted on PRIOR days that are still awaiting a parent decision (or
// were just rejected) vanish from today's progress payload — surface them.
let recentSubmittedGigs: any[] = [];
if (isKid) {
    // Anchor the /week fetch on YESTERDAY so a gig submitted yesterday is
    // found even when today is Monday (yesterday = previous week).
    const todayStr = String(progress?.date ?? new Date().toISOString().slice(0, 10));
    const yesterday = new Date(`${todayStr}T00:00:00`);
    yesterday.setDate(yesterday.getDate() - 1);
    const yesterdayStr = [
        yesterday.getFullYear(),
        String(yesterday.getMonth() + 1).padStart(2, "0"),
        String(yesterday.getDate()).padStart(2, "0"),
    ].join("-");
    // These four are independent of each other — parallelize.
    const [{ data: goalData }, { data: petData }, { data: notifData }, { data: weekDone }] = await Promise.all([
        apiFetch<any>("/api/rewards/goal", { token }),
        apiFetch<any>("/api/pet/", { token }),
        apiFetch<any>("/api/notifications/?limit=20", { token }),
        apiFetch<any>(
            `/api/task-assignments/week?week_of=${yesterdayStr}&status=completed&user_id=${user.id}`,
            { token },
        ),
    ]);
    activeGoal = goalData ?? null;
    pet = petData ?? null;
    const notifItems: any[] = notifData?.items ?? [];
    const paydayCutoff = Date.now() - 3 * 24 * 3600 * 1000;
    recentPayday = notifItems.find(
        (n: any) => n.type === "payday" && new Date(n.created_at).getTime() >= paydayCutoff,
    ) ?? null;
    recentSubmittedGigs = (Array.isArray(weekDone) ? weekDone : []).filter(
        (a: any) =>
            a.template_is_bonus &&
            String(a.assigned_date) < todayStr &&
            (a.approval_status === "pending" ||
                (a.approval_status === "rejected" && String(a.assigned_date) >= yesterdayStr)),
    );
}

const flash = Astro.cookies.get("flash")?.value;
if (flash) Astro.cookies.delete("flash", { path: "/" });
const flashError = Astro.cookies.get("flash_error")?.value;
if (flashError) Astro.cookies.delete("flash_error", { path: "/" });
---

<PageLayout
    title={t(lang, "dashboard_page_title") as string}
    role={user.role}
    active="tasks"
    lang={lang}
    completedTour={user.completed_welcome_tour ?? true}
    tourUserKey={user.id}
>
    <header slot="header" class="bg-brand-sky-deep text-white pt-12 pb-6 px-6 rounded-b-[var(--radius-tile)] shadow-[var(--shadow-card)]">
            <div class="flex justify-between items-center mb-6">
                <div>
                    <p class="text-brand-cream text-sm font-medium">{t(lang, "dashboard_hello")}</p>
                    <h1 class="text-2xl font-bold">{user.name}</h1>
                </div>
                <div class="h-12 w-12 rounded-full bg-brand-sky border-2 border-white flex items-center justify-center text-lg font-bold">
                    {user.name.charAt(0).toUpperCase()}
                </div>
            </div>
            <div class="bg-brand-cream/20 backdrop-blur-md rounded-2xl p-4 flex items-center justify-between border border-white/30">
                <div>
                    <p class="text-brand-cream text-xs font-semibold uppercase tracking-wider mb-1">
                        {starMode ? (lang === "es" ? "Mis estrellas" : "My stars") : t(lang, "dashboard_my_points")}
                    </p>
                    <p data-points-badge class="text-3xl font-extrabold tracking-tight">
                        {starMode ? `⭐ ${user.points}` : user.points}
                    </p>
                    {starMode && (
                        <div class="mt-1 text-lg leading-none tracking-wide" aria-hidden="true">
                            {"⭐".repeat(Math.min(Math.max(user.points, 0), 10))}
                            {user.points > 10 && <span class="text-sm font-bold text-brand-cream/90"> +{user.points - 10}</span>}
                        </div>
                    )}
                </div>
                <div class="bg-brand-sun p-3 rounded-xl shadow-inner">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-brand-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                    </svg>
                </div>
            </div>
            {isKid && !starMode && (
                <div class="mt-3 bg-brand-cream/20 backdrop-blur-md rounded-2xl p-4 flex items-center justify-between border border-white/30">
                    <div>
                        <p class="text-brand-cream text-xs font-semibold uppercase tracking-wider mb-1">
                            {lang === "es" ? "Mi dinero (de gigs)" : "My cash (from gigs)"}
                        </p>
                        <p data-cash-badge class="text-3xl font-extrabold tracking-tight">
                            ${(user.cash_cents / 100).toFixed(2)}<span class="text-base font-semibold"> MXN</span>
                        </p>
                        <p class="text-[11px] text-brand-cream/80 mt-0.5">
                            {lang === "es" ? "pendiente de pago" : "pending payout"}
                        </p>
                    </div>
                    <div class="bg-brand-mint p-3 rounded-xl shadow-inner">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-brand-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                </div>
            )}
            {isKid && !starMode && (
                <a href="/bank" class="mt-2 block text-center text-xs font-semibold text-brand-cream/90 hover:text-white py-1 transition-colors">
                    🏦 {lang === "es" ? "Abrir Mi Banco →" : "Open My Bank →"}
                </a>
            )}
            {isKid && trustStreak > 0 && (
                <div class="mt-3 bg-white/15 backdrop-blur-sm rounded-xl px-4 py-2.5 flex items-center gap-3 border border-white/20">
                    <span class="text-2xl">🔥</span>
                    <div class="flex-1">
                        <p class="text-sm font-bold text-white">
                            {lang === "es" ? `Racha de ${trustStreak} gigs` : `${trustStreak}-gig streak`}
                        </p>
                        <p class="text-xs text-brand-cream">
                            {toAutoApprove > 0
                                ? (lang === "es"
                                    ? `${toAutoApprove} más para auto-aprobación`
                                    : `${toAutoApprove} more to auto-approve`)
                                : (lang === "es"
                                    ? "¡Tus gigs se aprueban al instante!"
                                    : "Your gigs auto-approve instantly!")}
                        </p>
                    </div>
                </div>
            )}
            {isKid && (
                <div class="mt-3">
                    {activeGoal && !activeGoal.affordable && (
                        <a
                            href="/rewards"
                            class="flex items-center gap-3 bg-white/15 backdrop-blur-sm rounded-xl px-4 py-2.5 border border-white/20 hover:bg-white/25 transition-colors"
                        >
                            <span class="text-xl">{activeGoal.reward_icon ?? "🎯"}</span>
                            <div class="flex-1 min-w-0">
                                <p class="text-xs text-brand-cream font-semibold uppercase tracking-wider mb-0.5">
                                    {lang === "es" ? "Tu Meta" : "Your Goal"}
                                </p>
                                <p class="text-sm font-bold text-white truncate">{activeGoal.reward_title}</p>
                                <div class="w-full bg-white/20 rounded-full h-1.5 mt-1 overflow-hidden">
                                    <div
                                        class="h-1.5 bg-brand-sun rounded-full transition-all duration-500"
                                        style={`width: ${activeGoal.progress_pct}%`}
                                    ></div>
                                </div>
                                <p class="text-xs text-brand-cream mt-0.5">
                                    {starMode
                                        ? (lang === "es"
                                            ? `${activeGoal.pts_to_go} ⭐ para lograrlo`
                                            : `${activeGoal.pts_to_go} ⭐ to go`)
                                        : (lang === "es"
                                            ? `${activeGoal.pts_to_go} pts para lograrlo`
                                            : `${activeGoal.pts_to_go} pts to go`)}
                                </p>
                            </div>
                        </a>
                    )}
                    {activeGoal && activeGoal.affordable && (
                        <a
                            href="/rewards"
                            class="flex items-center gap-3 bg-brand-sun/30 backdrop-blur-sm rounded-xl px-4 py-2.5 border border-brand-sun/50 hover:bg-brand-sun/40 transition-colors"
                        >
                            <span class="text-2xl">🎉</span>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-bold text-white">
                                    {lang === "es" ? "¡Meta alcanzada!" : "Goal reached!"}
                                </p>
                                <p class="text-xs text-brand-cream truncate">
                                    {lang === "es"
                                        ? `Puedes canjear ${activeGoal.reward_title} →`
                                        : `Redeem ${activeGoal.reward_title} →`}
                                </p>
                            </div>
                        </a>
                    )}
                    {!activeGoal && (
                        <a
                            href="/rewards"
                            class="block text-center text-xs text-brand-cream/70 hover:text-brand-cream py-1 transition-colors"
                        >
                            {lang === "es" ? "Elige una meta →" : "Set a goal →"}
                        </a>
                    )}
                </div>
            )}
        </header>

    <Fragment slot="banner">
        {Astro.url.searchParams.get("module_off") === "1" && (
            <div class="mx-4 mt-3 rounded-xl border border-brand-ink/15 bg-brand-cream px-4 py-2.5 text-sm text-brand-ink-soft">
                {lang === "es"
                    ? "Esa sección está desactivada para tu familia. Un padre puede activarla en Ajustes → Módulos."
                    : "That section is switched off for your family. A parent can enable it in Settings → Modules."}
            </div>
        )}
        <VerifyEmailBanner lang={lang} show={!(user.email_verified ?? true)} userId={user.id} />
        <GigsIntroBanner lang={lang} show={!user.acknowledged_gigs_intro} />

        {isKid && (
            <div class="px-4 pb-2">
                <EnablePushButton lang={lang} />
            </div>
        )}

        {flash && (
            <div data-flash-success class="mx-4 mt-4 p-3 bg-brand-mint/20 border border-brand-mint text-brand-mint-deep text-sm rounded-xl">
                {flash}
            </div>
        )}
        {flashError && (
            <div class="mx-4 mt-4 p-3 bg-red-100 border border-red-200 text-red-700 text-sm rounded-xl">
                {flashError}
            </div>
        )}
    </Fragment>
            <!-- Payday surface: "Domingo de pago" summary after a payday sweep -->
            {isKid && recentPayday && (
                <a
                    href={recentPayday.link || "/bank"}
                    class="mb-6 flex items-center gap-4 bg-brand-mint/20 border-2 border-brand-ink rounded-[var(--radius-card)] p-4 shadow-[var(--shadow-card)] hover:-translate-y-0.5 transition-transform"
                >
                    <span class="text-3xl">🎉</span>
                    <div class="min-w-0 flex-1">
                        <p class="font-display font-extrabold text-brand-ink leading-tight">{recentPayday.title}</p>
                        {recentPayday.body && (
                            <p class="text-sm text-brand-ink-soft mt-0.5">{recentPayday.body}</p>
                        )}
                    </div>
                    <span class="text-brand-mint-deep font-bold flex-shrink-0">→</span>
                </a>
            )}

            <!-- Cooperative weekly boss battle (Family Cup) -->
            <a href="/family-cup" class="block mb-6">
                <BossBattleBar boss={boss} lang={lang} />
            </a>

            <!-- Virtual pet nudge → Quest Mode -->
            {isKid && pet && (
                <a
                    href="/pet/quests"
                    class="mb-6 flex items-center gap-4 bg-brand-cream rounded-[var(--radius-card)] p-4 border-2 border-brand-ink shadow-[var(--shadow-card)] hover:-translate-y-0.5 transition-transform"
                >
                    <PetAvatar species={pet.species} stage={pet.evolution_stage} status={pet.status_label} size="md" />
                    <div class="flex-1 min-w-0">
                        <p class="font-display font-extrabold text-brand-ink leading-tight truncate">{pet.name}</p>
                        <p class="text-xs text-brand-ink-soft">
                            {stageLabel(pet.evolution_stage, lang)} · {lang === "es" ? "Nivel" : "Level"} {pet.level}
                        </p>
                        <p class="text-sm font-semibold text-brand-sky-deep mt-0.5">
                            {pet.status_label === "starving"
                                ? (lang === "es" ? "🍖 ¡Tu mascota tiene hambre!" : "🍖 Your pet is hungry!")
                                : pet.status_label === "sad"
                                    ? (lang === "es" ? "😞 Tu mascota te extraña" : "😞 Your pet misses you")
                                    : (lang === "es" ? "🗺️ Completa misiones para alimentarla" : "🗺️ Finish quests to feed it")}
                        </p>
                    </div>
                    <span class="text-brand-sky-deep font-bold flex-shrink-0">→</span>
                </a>
            )}

            <!-- Today header + Progress bar -->
            <div class="mb-6" data-tour="today-tasks">
                <div class="flex justify-between items-end mb-2 px-1">
                    <h2 class="text-xl font-bold text-brand-ink tracking-tight">
                        {t(lang, "dashboard_today")}
                    </h2>
                    {requiredTotal > 0 && (
                        <span class="text-sm font-medium text-brand-ink-soft">
                            {t(lang, "dashboard_progress")(requiredCompleted, requiredTotal)}
                        </span>
                    )}
                </div>
                {requiredTotal > 0 && (
                    <div class="w-full bg-brand-cream-deep rounded-full h-2.5">
                        <div
                            class="bg-brand-sky h-2.5 rounded-full transition-all duration-500"
                            style={`width: ${progressPercent}%`}
                        ></div>
                    </div>
                )}
            </div>

            <!-- No tasks state -->
            {noTasks && (
                <div class="bg-brand-cream rounded-2xl p-8 text-center border border-brand-ink/10 shadow-[var(--shadow-card)]">
                    <div class="w-16 h-16 bg-brand-cream-deep rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-brand-ink-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                    </div>
                    <p class="text-brand-ink-soft text-sm">{t(lang, "dashboard_no_assignments")}</p>
                </div>
            )}

            <!-- All done state -->
            {allDone && !noTasks && (
                <div class="bg-brand-cream rounded-2xl p-8 text-center border border-brand-ink/10 shadow-[var(--shadow-card)] mb-6">
                    <div class="w-16 h-16 bg-brand-mint/20 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-brand-mint-deep" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                    <h3 class="text-lg font-bold text-brand-ink">{t(lang, "dashboard_all_done")}</h3>
                    <p class="text-brand-ink-soft mt-1 text-sm">{t(lang, "dashboard_all_done_subtitle")}</p>
                </div>
            )}

            <!-- Today cleared but overdue blockers remain: nudge, don't celebrate -->
            {doneButOverdue && !noTasks && (
                <a href="#overdue-section" class="block bg-brand-sun/20 rounded-2xl p-6 text-center border border-brand-sun shadow-[var(--shadow-card)] mb-6 hover:bg-brand-sun/30 transition-colors">
                    <span class="text-3xl">⏰</span>
                    <h3 class="text-lg font-bold text-brand-ink mt-2">
                        {lang === "es" ? "Aún tienes tareas atrasadas" : "You still have overdue chores"}
                    </h3>
                    <p class="text-brand-ink-soft mt-1 text-sm">
                        {lang === "es"
                            ? "Termínalas para desbloquear bonus y gigs ↓"
                            : "Finish them to unlock bonus tasks and gigs ↓"}
                    </p>
                </a>
            )}

            <!-- Overdue (Atrasadas) — prior-day mandatory tasks that block bonus/gigs -->
            {overdueGroups.length > 0 && (
                <div class="mb-8" id="overdue-section">
                    <div class="flex items-center gap-2 mb-3 px-1">
                        <span class="text-lg">⏰</span>
                        <h3 class="text-lg font-bold text-red-600">
                            {lang === "es" ? "Atrasadas" : "Overdue"}
                        </h3>
                    </div>
                    <p class="text-xs text-brand-ink-soft mb-3 px-1">
                        {lang === "es"
                            ? "Termina estas para desbloquear tareas bonus y gigs."
                            : "Finish these to unlock bonus tasks and gigs."}
                    </p>
                    <div class="space-y-3">
                        {overdueGroups.map(({ oldest: a, count }: any) => (
                            <div class="bg-red-50 rounded-2xl p-5 shadow-[var(--shadow-card)] border border-red-200 flex justify-between items-center">
                                <div class="pr-4 flex-1">
                                    <h3 class="font-bold text-brand-ink text-lg mb-1 flex items-center gap-2 flex-wrap">
                                        <span>{lang === "es" && a.template_title_es ? a.template_title_es : a.template_title}</span>
                                        {count > 1 && (
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-extrabold bg-red-600 text-white">
                                                ×{count}
                                            </span>
                                        )}
                                    </h3>
                                    <p class="text-brand-ink-soft text-sm line-clamp-2">
                                        {(lang === "es" && a.template_description_es ? a.template_description_es : a.template_description) || "--"}
                                    </p>
                                    <div class="flex items-center gap-2 mt-3 flex-wrap">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700">
                                            {lang === "es"
