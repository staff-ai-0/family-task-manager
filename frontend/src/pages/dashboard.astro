    <script>
        // Lightweight, dependency-free confetti burst. Respects reduced-motion.
        function fireConfetti() {
            if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
            if (document.getElementById("confetti-canvas")) return;
            const canvas = document.createElement("canvas");
            canvas.id = "confetti-canvas";
            canvas.style.cssText = "position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:9999";
            document.body.appendChild(canvas);
            const ctx = canvas.getContext("2d");
            if (!ctx) { canvas.remove(); return; }
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            const colors = ["#4FB8E6", "#FFC857", "#6BCB77", "#FF6B6B", "#A78BFA"];
            const N = 90;
            const parts = Array.from({ length: N }, () => ({
                x: canvas.width / 2,
                y: canvas.height / 3,
                vx: (Math.random() - 0.5) * 14,
                vy: Math.random() * -15 - 4,
                size: Math.random() * 7 + 4,
                color: colors[Math.floor(Math.random() * colors.length)],
                rot: Math.random() * Math.PI,
                vr: (Math.random() - 0.5) * 0.3,
            }));
            let frame = 0;
            const tick = () => {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                parts.forEach((p) => {
                    p.vy += 0.4; // gravity
                    p.x += p.vx; p.y += p.vy; p.rot += p.vr;
                    ctx.save();
                    ctx.translate(p.x, p.y); ctx.rotate(p.rot);
                    ctx.fillStyle = p.color;
                    ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size);
                    ctx.restore();
                });
                frame++;
                if (frame < 110) requestAnimationFrame(tick);
                else canvas.remove();
            };
            requestAnimationFrame(tick);
        }

        document.addEventListener("astro:page-load", () => {
            // Celebrate a just-completed task/gig (success flash present after redirect).
            if (document.querySelector("[data-flash-success]")) {
                fireConfetti();
                const pts = document.querySelector<HTMLElement>("[data-points-badge]");
                if (pts && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
                    pts.animate(
                        [{ transform: "scale(1)" }, { transform: "scale(1.25)" }, { transform: "scale(1)" }],
                        { duration: 600, easing: "ease-out" },
                    );
                }
            }

            const modal = document.getElementById("gig-proof-modal") as HTMLDialogElement | null;
            if (!modal) return;
            const textarea = document.getElementById("gig-proof-text") as HTMLTextAreaElement | null;
            const cancelBtn = document.getElementById("gig-proof-cancel");
            const submitBtn = document.getElementById("gig-proof-submit");
            if (!textarea || !cancelBtn || !submitBtn) return;

            // Track which form opened the modal so we can submit it on confirm.
            let pendingForm: HTMLFormElement | null = null;

            // In-flight guard: disable the Complete button + swap it for a
            // "Guardando… / Saving…" spinner pill so a double-tap can't fire
            // the request twice (the second one used to surface a raw English
            // backend error right after the success).
            function markInFlight(form: HTMLFormElement) {
                form.dataset.inflight = "1";
                const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
                if (!btn) return;
                const es = document.documentElement.lang === "es";
                btn.disabled = true;
                btn.className =
                    "h-12 px-4 rounded-full bg-brand-cream-deep text-brand-ink-soft flex items-center gap-2 flex-shrink-0 shadow-[var(--shadow-card)] text-sm font-semibold cursor-wait";
                btn.innerHTML =
                    '<svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path></svg>' +
                    (es ? "Guardando…" : "Saving…");
            }

            document.querySelectorAll<HTMLFormElement>("form[data-complete-form]").forEach((f) => {
                f.addEventListener("submit", (ev) => {
                    if (f.dataset.inflight === "1") {
                        ev.preventDefault();
                        return;
                    }
                    const isBonus = f.dataset.isBonus === "1";
                    const requiresProof = f.dataset.requiresProof === "1";
                    // mandatory WITHOUT photo proof: submit normally (locked
                    // against re-submission while the redirect is in flight)
                    if (!isBonus && !requiresProof) {
                        markInFlight(f);
                        return;
                    }
                    ev.preventDefault();
                    pendingForm = f;
                    textarea.value = "";
                    if (fileInput) fileInput.value = "";
                    if (fileStatus) {
                        fileStatus.textContent = "";
                        fileStatus.classList.remove("text-red-600");
                    }
                    const imgLabel = document.getElementById("gig-proof-image-label");
                    if (imgLabel) {
                        imgLabel.textContent = requiresProof
                            ? imgLabel.dataset.required ?? ""
                            : imgLabel.dataset.optional ?? "";
                    }
                    modal.showModal();
                    setTimeout(() => textarea.focus(), 50);
                });
            });

            cancelBtn.addEventListener("click", () => {
                pendingForm = null;
                modal.close();
            });

            const fileInput = document.getElementById("gig-proof-image") as HTMLInputElement | null;
            const fileStatus = document.getElementById("gig-proof-image-status");

            submitBtn.addEventListener("click", async () => {
                if (!pendingForm) {
                    modal.close();
                    return;
                }
                const isBonusForm = pendingForm.dataset.isBonus === "1";
                const requiresPhoto = pendingForm.dataset.requiresProof === "1";
                const es = document.documentElement.lang === "es";

                const text = textarea.value.trim();
                // Gigs still require proof text; proof-required chores only
                // need the photo (text optional).
                if (isBonusForm && !text) {
                    textarea.focus();
                    textarea.classList.add("ring-2", "ring-red-400");
                    setTimeout(() => textarea.classList.remove("ring-2", "ring-red-400"), 1500);
                    return;
                }
                if (requiresPhoto && !fileInput?.files?.length) {
                    if (fileStatus) {
                        fileStatus.textContent = es
                            ? "📸 Esta tarea requiere una foto del trabajo terminado."
                            : "📸 This task requires a photo of the finished work.";
                        fileStatus.classList.add("text-red-600");
                    }
                    return;
                }

                // Upload image first if present
                let imageUrl: string | null = null;
                if (fileInput?.files?.length) {
                    if (fileStatus) fileStatus.textContent = "Uploading…";
                    try {
                        const fd = new FormData();
                        fd.append("file", fileInput.files[0]);
                        const r = await fetch("/api/assignments/proof-upload", { method: "POST", body: fd });
                        if (!r.ok) throw new Error(`Upload failed: ${r.status}`);
                        const data = await r.json();
                        imageUrl = data.proof_image_url;
                    } catch (err) {
                        if (fileStatus) fileStatus.textContent = `Upload failed: ${err}`;
                        return;
                    }
                }

                const proofInput = pendingForm.querySelector<HTMLInputElement>('input[name="proof_text"]');
                if (proofInput) proofInput.value = text;
                const imageInput = pendingForm.querySelector<HTMLInputElement>('input[name="proof_image_url"]');
                if (imageInput) imageInput.value = imageUrl || "";

                const submittingForm = pendingForm;
                pendingForm = null;
                modal.close();
                markInFlight(submittingForm);
                // submit() bypasses our submit listener, avoiding a re-trigger of the modal.
                submittingForm.submit();
            });

            // Close on backdrop click
            modal.addEventListener("click", (e) => {
                const rect = (e.target as HTMLDialogElement).getBoundingClientRect?.();
                if (e.target === modal) {
                    pendingForm = null;
                    modal.close();
                }
            });
        });
    </script>

    <script>
        import { buildMission } from "../lib/tourSteps";
        import { runMission } from "../lib/missionRunner";

        function resumeMissions() {
            if ((window as any).__ftmMissionInit) return;
            (window as any).__ftmMissionInit = true;
            const lang = document.documentElement.lang === "es" ? "es" : "en";
            // /dashboard hosts none of the current mission targets, so this is
            // effectively the "user wandered off mid-flow" degrade path: the
            // runner finds no element for the active step and ends gracefully
            // instead of leaving a stale popover following the user around.
            for (const id of ["first-task", "first-gig"] as const) {
                if (sessionStorage.getItem("ftm_mission_" + id)) runMission(buildMission(id, lang), lang);
            }
        }

        document.addEventListener("astro:page-load", resumeMissions);
        // The one-shot astro:page-load fires on DOMContentLoaded; a module
        // that executes after that would miss it (see WelcomeTour.astro).
        // Self-trigger if the DOM is already ready — __ftmMissionInit keeps
        // this idempotent.
        if (document.readyState !== "loading") resumeMissions();
    </script>
</PageLayout>
