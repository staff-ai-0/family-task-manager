---
import PageLayout from "@components/ui/PageLayout.astro";
import { apiFetch } from "../../lib/api";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") {
    return Astro.redirect("/calendar");
}

const labels = {
    title: lang === "es" ? "Escanear documento" : "Scan document",
    subtitle:
        lang === "es"
            ? "Volante escolar, agenda deportiva, invitación"
            : "School flyer, sport schedule, invitation",
    pick: lang === "es" ? "Elegir foto o PDF" : "Choose photo or PDF",
    scanning: lang === "es" ? "Escaneando…" : "Scanning…",
    cancel: lang === "es" ? "Cancelar" : "Cancel",
    back: lang === "es" ? "Volver al calendario" : "Back to calendar",
};
---

<PageLayout
    title={`📄 ${labels.title}`}
    headerClass="bg-gradient-to-br from-purple-500 to-pink-500"
    dark
    backClass="text-purple-100 hover:text-white"
    backHref="/calendar"
    backLabel={labels.back}
    role={user.role}
    active="tasks"
    lang={lang}
    mainClass="flex-1 px-4 py-6 space-y-4"
    containerClass="w-full max-w-md md:max-w-4xl mx-auto bg-brand-cream-deep"
>
    <p slot="header-extra" class="text-purple-100 text-sm">{labels.subtitle}</p>

    <div id="error-box" class="hidden p-3 bg-red-100 border border-red-200 text-red-700 text-sm rounded-xl"></div>

    <label class="block bg-brand-cream rounded-2xl border-2 border-dashed border-brand-ink/30 p-12 text-center cursor-pointer hover:border-brand-ink transition-colors">
        <input
            type="file"
            id="scan-file"
            accept="image/jpeg,image/png,image/webp,image/gif,application/pdf"
            class="hidden"
        />
        <span class="text-5xl">📷</span>
        <p class="mt-3 text-sm font-semibold text-brand-ink">{labels.pick}</p>
        <p class="text-xs text-brand-ink-soft mt-1">JPG · PNG · WebP · PDF</p>
    </label>

    <div id="scanning" class="hidden bg-brand-cream rounded-2xl p-6 text-center border border-brand-ink/10">
        <div class="inline-block animate-spin h-8 w-8 border-4 border-brand-ink/20 border-t-brand-ink rounded-full"></div>
        <p class="mt-3 text-sm text-brand-ink-soft">{labels.scanning}</p>
    </div>

    <form id="results-form" method="POST" action="/calendar" class="hidden space-y-3">
        <input type="hidden" name="action" value="import_scanned" />
        <input type="hidden" name="scanned_count" id="scanned_count" value="0" />
        <div id="results"></div>
        <button
            type="submit"
            class="w-full py-3 rounded-xl bg-brand-ink text-brand-cream font-bold hover:bg-brand-ink-soft"
        >
            {lang === "es" ? "Importar eventos marcados" : "Import checked events"}
        </button>
    </form>
</PageLayout>

<script define:vars={{ lang }}>
    document.addEventListener("astro:page-load", () => {
        const fileInput = document.getElementById("scan-file");
        const scanning = document.getElementById("scanning");
        const resultsForm = document.getElementById("results-form");
        const resultsDiv = document.getElementById("results");
        const errorBox = document.getElementById("error-box");
        const countField = document.getElementById("scanned_count");
        if (!fileInput) return;

        fileInput.addEventListener("change", async (e) => {
            const file = e.target.files?.[0];
            if (!file) return;
            errorBox.classList.add("hidden");
            errorBox.textContent = "";
            resultsForm.classList.add("hidden");
            resultsDiv.innerHTML = "";
            scanning.classList.remove("hidden");

            const fd = new FormData();
            fd.append("file", file);

            try {
                const resp = await fetch("/api/calendar/scan-document", {
                    method: "POST",
                    body: fd,
                    credentials: "include",
                });
                scanning.classList.add("hidden");
                if (!resp.ok) {
                    const txt = await resp.text();
                    errorBox.textContent = txt || "Scan failed";
                    errorBox.classList.remove("hidden");
                    return;
                }
                const data = await resp.json();
                if (!data.events || data.events.length === 0) {
                    errorBox.textContent =
                        lang === "es"
                            ? "No se detectaron eventos. Intenta con otra foto."
                            : "No events detected. Try a different photo.";
                    errorBox.classList.remove("hidden");
                    return;
                }
                countField.value = String(data.events.length);

                const conf = Math.round((data.confidence || 0) * 100);
                const header = document.createElement("div");
                header.className =
                    "bg-brand-cream rounded-2xl p-4 border border-brand-ink/10 shadow-[var(--shadow-card)]";
                header.innerHTML = `
                    <p class="text-sm font-bold text-brand-ink">${lang === "es" ? "Tipo:" : "Type:"} ${data.doc_type}</p>
                    <p class="text-xs text-brand-ink-soft">${lang === "es" ? "Confianza:" : "Confidence:"} ${conf}% · ${data.events.length} ${lang === "es" ? "eventos" : "events"}</p>
                `;
                resultsDiv.appendChild(header);

                data.events.forEach((evt, i) => {
                    const card = document.createElement("div");
                    card.className =
                        "bg-brand-cream rounded-2xl p-4 border border-brand-ink/10 shadow-[var(--shadow-card)] space-y-2";
                    const startDate = new Date(evt.start_ts);
                    card.innerHTML = `
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input type="checkbox" name="accept_${i}" checked class="mt-1 w-5 h-5 rounded" />
                            <div class="flex-1 space-y-2">
                                <input type="text" name="title_${i}" value="${escapeAttr(evt.title)}" class="w-full px-2 py-1.5 rounded-lg border border-brand-ink/20 text-sm font-semibold" />
                                <input type="hidden" name="start_${i}" value="${evt.start_ts}" />
                                <input type="hidden" name="end_${i}" value="${evt.end_ts || ""}" />
                                <input type="hidden" name="all_day_${i}" value="${evt.all_day ? "true" : "false"}" />
                                <p class="text-xs text-brand-ink-soft">
                                    📅 ${startDate.toLocaleString(lang === "es" ? "es-MX" : "en-US")}
                                </p>
                                <input type="text" name="location_${i}" value="${escapeAttr(evt.location || "")}" placeholder="${lang === "es" ? "Lugar" : "Location"}" class="w-full px-2 py-1.5 rounded-lg border border-brand-ink/20 text-xs" />
                                <textarea name="description_${i}" rows="2" placeholder="${lang === "es" ? "Notas" : "Notes"}" class="w-full px-2 py-1.5 rounded-lg border border-brand-ink/20 text-xs">${escapeText(evt.description || "")}</textarea>
                            </div>
                        </label>
                    `;
                    resultsDiv.appendChild(card);
                });

                resultsForm.classList.remove("hidden");
            } catch (err) {
                scanning.classList.add("hidden");
                errorBox.textContent = String(err);
                errorBox.classList.remove("hidden");
            }
        });

        function escapeAttr(s) {
            return String(s ?? "").replace(/"/g, "&quot;").replace(/</g, "&lt;");
        }
        function escapeText(s) {
            return String(s ?? "").replace(/</g, "&lt;").replace(/>/g, "&gt;");
        }
    });
</script>
