---
import PageLayout from "@components/ui/PageLayout.astro";
import DifficultyChip from "../../components/DifficultyChip.astro";
import { apiFetch } from "../../lib/api";
import { t } from "../../lib/i18n";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";

const { data: user, ok: userOk } = await apiFetch<any>("/api/auth/me", { token });
if (!userOk) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role === "parent") return Astro.redirect("/parent/gigs");

const [{ data: items }, { data: myProposalsData }] = await Promise.all([
    apiFetch<any[]>("/api/gigs/offerings", { token }),
    apiFetch<any[]>("/api/gigs/offerings/proposals/mine", { token }),
]);
const offerings: any[] = items ?? [];
const myProposals: any[] = Array.isArray(myProposalsData) ? myProposalsData : [];

const flash = Astro.cookies.get("flash")?.value;
if (flash) Astro.cookies.delete("flash", { path: "/" });
const flashError = Astro.cookies.get("flash_error")?.value;
if (flashError) Astro.cookies.delete("flash_error", { path: "/" });

const categoryLabels: Record<string, Record<string, string>> = {
    chores:   { en: "Chores",   es: "Quehaceres" },
    errands:  { en: "Errands",  es: "Mandados" },
    creative: { en: "Creative", es: "Creativo" },
    learning: { en: "Learning", es: "Aprendizaje" },
    outdoor:  { en: "Outdoor",  es: "Al Aire Libre" },
    other:    { en: "Other",    es: "Otro" },
};
const catLabel = (cat: string) => categoryLabels[cat]?.[lang] ?? cat;
---

<PageLayout
    title="Gigs"
    role={user.role?.toLowerCase()}
    active="gigs"
    lang={lang}
>
    <!-- Eyebrow + glass-card header — page-owned via header slot -->
    <header slot="header" class="bg-gradient-to-br from-violet-700 to-violet-500 text-white pt-12 pb-6 px-6 rounded-b-[var(--radius-tile)] shadow-[var(--shadow-card)]">
            <div class="flex justify-between items-center mb-4">
                <div>
                    <p class="text-violet-200 text-sm font-medium">{lang === "es" ? "¡Gana dinero!" : "Earn cash!"}</p>
                    <h1 class="text-2xl font-bold">{lang === "es" ? "Gigs" : "Gigs"}</h1>
                </div>
                <a href="/gigs/my-gigs" class="bg-white/20 backdrop-blur-sm border border-white/30 text-white text-sm font-semibold px-4 py-2 rounded-xl hover:bg-white/30 transition-colors">
                    {lang === "es" ? "Mis Gigs" : "My Gigs"}
                </a>
            </div>
            <div class="bg-white/15 backdrop-blur-sm rounded-2xl px-4 py-3 text-sm text-violet-100">
                {lang === "es"
                    ? "Reclama gigs, complétalas con evidencia y gana dinero ($MXN)."
                    : "Claim gigs, complete them with proof, and earn cash ($MXN)."}
            </div>
            <button
                id="propose-gig-btn"
                type="button"
                class="mt-3 w-full py-2.5 rounded-xl bg-white text-violet-700 font-bold text-sm hover:bg-violet-50 active:scale-[.98] transition-all"
            >
                💡 {lang === "es" ? "Proponer una gig" : "Propose a gig"}
            </button>
        </header>
            {flash && (
                <div class="mb-4 p-3 bg-brand-mint/20 border border-brand-mint text-brand-mint-deep text-sm rounded-xl">
                    {flash}
                </div>
            )}
            {flashError && (
                <div class="mb-4 p-3 bg-red-100 border border-red-200 text-red-700 text-sm rounded-xl">
                    {flashError}
                </div>
            )}

            {myProposals.length > 0 && (
                <section class="mb-6">
                    <h2 class="text-sm font-bold text-brand-ink-soft uppercase tracking-wide mb-3 px-1">
                        💡 {lang === "es" ? "Mis propuestas" : "My proposals"}
                    </h2>
                    <div class="space-y-3">
                        {myProposals.map((p: any) => (
                            <div class={`bg-brand-cream rounded-2xl p-4 shadow-[var(--shadow-card)] border ${p.status === "rejected" ? "border-red-200" : "border-amber-200"}`}>
                                <div class="flex justify-between items-start gap-3">
                                    <div class="min-w-0 flex-1">
                                        <h3 class="font-bold text-brand-ink truncate">{p.title}</h3>
                                        {p.description && (
                                            <p class="text-brand-ink-soft text-xs mt-0.5 line-clamp-2">{p.description}</p>
                                        )}
                                    </div>
                                    <div class="text-right flex-shrink-0">
                                        <p class="text-lg font-extrabold text-emerald-600">${p.points}</p>
                                        <p class="text-[10px] text-brand-ink-soft font-medium">MXN</p>
                                    </div>
                                </div>
                                <div class="mt-2">
                                    {p.status === "pending" ? (
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-700">
                                            ⏳ {lang === "es" ? "Esperando a tus papás" : "Waiting for your parents"}
                                        </span>
                                    ) : (
                                        <div>
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700">
                                                ❌ {lang === "es" ? "No aprobada" : "Not approved"}
                                            </span>
                                            {p.review_notes && (
                                                <p class="text-xs text-brand-ink-soft mt-1 italic">"{p.review_notes}"</p>
                                            )}
                                        </div>
                                    )}
                                </div>
                            </div>
                        ))}
                    </div>
                </section>
            )}

            {offerings.length === 0 ? (
                <div class="bg-brand-cream rounded-2xl p-8 text-center border border-brand-ink/10 shadow-[var(--shadow-card)]">
                    <div class="w-16 h-16 bg-violet-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-brand-ink mb-1">{lang === "es" ? "Sin gigs disponibles" : "No gigs available"}</h3>
                    <p class="text-brand-ink-soft text-sm">{lang === "es" ? "Tu papá/mamá publicará gigs pronto." : "Your parent will post gigs soon."}</p>
                </div>
            ) : (
                <div class="space-y-4">
                    {offerings.map((item: any) => {
                        const o = item.offering;
                        const claim = item.my_claim;
                        const hasClaim = !!claim;
                        const isApproved = claim?.status === "approved";
                        const isCompleted = claim?.status === "completed";
                        const isClaimed = claim?.status === "claimed";
                        // Who else is actively on this gig (single-slot gigs
                        // can't be claimed once taken — show who has it).
                        const takenBy: string[] = item.active_claimers ?? [];
                        const lockedBySibling = !hasClaim && takenBy.length > 0 && !o.allow_multiple;
                        return (
                            <div class={`bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border ${hasClaim ? "border-violet-200" : "border-brand-ink/10"} transition-all`}>
                                <div class="flex justify-between items-start mb-3">
                                    <div class="flex-1 pr-3">
                                        <h3 class="font-bold text-brand-ink text-lg leading-tight">{o.title}</h3>
                                        {o.description && (
                                            <p class="text-brand-ink-soft text-sm mt-1 line-clamp-2">{o.description}</p>
                                        )}
                                    </div>
                                    <div class="text-right flex-shrink-0">
                                        <p class="text-2xl font-extrabold text-emerald-600">${o.points}</p>
                                        <p class="text-xs text-brand-ink-soft font-medium">MXN</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2 flex-wrap mb-4">
                                    <DifficultyChip level={o.difficulty ?? 1} lang={lang} />
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-violet-100 text-violet-700">
                                        {catLabel(o.category)}
                                    </span>
                                </div>

                                {lockedBySibling && (
                                    <div class="w-full py-2.5 px-4 bg-brand-cream-deep text-brand-ink-soft font-semibold rounded-xl text-center text-sm">
                                        🔒 {lang === "es"
                                            ? `${takenBy[0]} ya la está haciendo`
                                            : `${takenBy[0]} is already on it`}
                                    </div>
                                )}
                                {!hasClaim && !lockedBySibling && (
                                    <form method="POST" action={`/api/gigs/offerings/${o.id}/claim`} data-claim-form>
                                        {takenBy.length > 0 && (
                                            <p class="text-xs text-brand-ink-soft mb-2">
                                                👥 {takenBy.join(", ")} {lang === "es" ? "también la está haciendo" : "is also on it"}
                                            </p>
                                        )}
                                        <input type="hidden" name="gig_id" value={o.id} />
                                        <button
                                            type="submit"
                                            data-label={lang === "es" ? "Reclamar" : "Claim"}
                                            class="w-full py-2.5 px-4 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 active:scale-[.98] transition-all text-sm"
                                        >
                                            {lang === "es" ? "Reclamar" : "Claim"}
                                        </button>
                                    </form>
                                )}
                                {isClaimed && (
                                    <form class="space-y-3 mt-1" data-complete-form data-claim-id={claim.id}>
                                        <p class="text-xs font-semibold text-amber-700 bg-amber-50 rounded-lg px-3 py-1.5">
                                            {lang === "es" ? "Reclamada — envía tu evidencia abajo" : "Claimed — submit your proof below"}
                                        </p>
                                        <div>
                                            <label class="block text-sm font-medium text-brand-ink mb-1">
                                                {lang === "es" ? "¿Qué hiciste? (opcional)" : "What did you do? (optional)"}
                                            </label>
                                            <textarea
                                                name="proof_text"
                                                rows={3}
                                                class="w-full rounded-xl border border-brand-ink/20 bg-brand-cream-deep px-3 py-2 text-sm text-brand-ink placeholder-brand-ink-soft focus:outline-none focus:ring-2 focus:ring-violet-400"
                                                placeholder={lang === "es" ? "Describe lo que hiciste..." : "Describe what you did..."}
                                            />
                                        </div>
                                        <div>
                                            <label class="block text-sm font-medium text-brand-ink mb-1">
                                                {lang === "es" ? "Foto de evidencia (opcional)" : "Photo evidence (optional)"}
                                            </label>
                                            <input
                                                type="file"
                                                accept="image/jpeg,image/png,image/webp"
                                                name="proof_image"
                                                class="w-full text-sm text-brand-ink-soft file:mr-3 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-violet-100 file:text-violet-700 hover:file:bg-violet-200"
                                            />
                                        </div>
                                        <button
                                            type="submit"
                                            class="w-full py-2.5 px-4 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 active:scale-[.98] transition-all text-sm"
                                        >
                                            {lang === "es" ? "Enviar para aprobación" : "Submit for approval"}
                                        </button>
                                    </form>
                                )}
                                {isCompleted && (
                                    <div class="w-full py-2.5 px-4 bg-sky-100 text-sky-700 font-semibold rounded-xl text-center text-sm">
                                        {lang === "es" ? "⏳ Pendiente de aprobación" : "⏳ Awaiting approval"}
                                    </div>
                                )}
                                {isApproved && (
                                    <div class="w-full py-2.5 px-4 bg-emerald-100 text-emerald-700 font-semibold rounded-xl text-center text-sm">
                                        ✅ {lang === "es" ? `Aprobada · +$${claim.points_awarded} MXN` : `Approved · +$${claim.points_awarded} MXN`}
                                    </div>
                                )}
                            </div>
                        );
                    })}
                </div>
            )}
    <!-- Propose-a-gig modal (kid → parent review) -->
    <div id="propose-modal" class="hidden fixed inset-0 z-[60] flex items-end sm:items-center justify-center bg-black/50 backdrop-blur-sm px-4">
        <div class="bg-brand-cream rounded-t-3xl sm:rounded-3xl w-full max-w-md p-6 pb-[calc(1.5rem+env(safe-area-inset-bottom,0px))] sm:pb-6 shadow-2xl max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-lg font-bold text-brand-ink">
                    💡 {lang === "es" ? "Proponer una gig" : "Propose a gig"}
                </h2>
                <button id="propose-close" type="button" class="text-brand-ink-soft hover:text-brand-ink text-2xl leading-none">&times;</button>
            </div>
            <p class="text-xs text-brand-ink-soft mb-4">
                {lang === "es"
                    ? "Dile a tus papás qué trabajo quieres hacer y cuánto crees que vale. Ellos la revisan antes de publicarla."
                    : "Tell your parents what job you want to do and what you think it's worth. They review it before it goes live."}
            </p>
            <form id="propose-form" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-brand-ink mb-1">{lang === "es" ? "¿Qué quieres hacer? *" : "What do you want to do? *"}</label>
                    <input type="text" id="pf-title" required maxlength="200"
                        class="w-full rounded-xl border border-brand-ink/20 bg-brand-cream-deep px-3 py-2 text-sm text-brand-ink focus:outline-none focus:ring-2 focus:ring-violet-400"
                        placeholder={lang === "es" ? "Ej: Organizar el garage" : "e.g. Organize the garage"} />
                </div>
                <div>
                    <label class="block text-sm font-medium text-brand-ink mb-1">{lang === "es" ? "Detalles" : "Details"}</label>
                    <textarea id="pf-description" rows={2} maxlength="1000"
                        class="w-full rounded-xl border border-brand-ink/20 bg-brand-cream-deep px-3 py-2 text-sm text-brand-ink focus:outline-none focus:ring-2 focus:ring-violet-400"
                        placeholder={lang === "es" ? "Opcional..." : "Optional..."} />
                </div>
                <div>
                    <label class="block text-sm font-medium text-brand-ink mb-1">{lang === "es" ? "¿Cuánto crees que vale? ($MXN) *" : "What's it worth? ($MXN) *"}</label>
                    <input type="number" id="pf-points" required min="1" max="1000"
                        class="w-full rounded-xl border border-brand-ink/20 bg-brand-cream-deep px-3 py-2 text-sm text-brand-ink focus:outline-none focus:ring-2 focus:ring-violet-400"
                        placeholder="50" />
                </div>
                <div id="pf-error" class="hidden text-sm text-red-600"></div>
                <button type="submit"
                    class="w-full py-3 bg-violet-600 text-white font-bold rounded-xl hover:bg-violet-700 active:scale-[.98] transition-all"
                >
                    {lang === "es" ? "Enviar a mis papás" : "Send to my parents"}
                </button>
            </form>
        </div>
    </div>
</PageLayout>

<script>
import { mutate } from "../../lib/mutate";
import { showToast } from "../../lib/toast";

const _lang = document.cookie.split(";").find(c => c.trim().startsWith("lang="))?.split("=")[1] ?? "es";
const es = _lang === "es";
const submitLabel = es ? "Enviar para aprobación" : "Submit for approval";

// Markup for the two post-action card states — injected in place of a full
// page reload so a claimed gig immediately shows its proof form, and a
// submitted one shows the awaiting-approval pill.
function proofFormHTML(claimId: string): string {
    return `<form class="space-y-3 mt-1" data-complete-form data-claim-id="${claimId}">
        <p class="text-xs font-semibold text-amber-700 bg-amber-50 rounded-lg px-3 py-1.5">${es ? "Reclamada — envía tu evidencia abajo" : "Claimed — submit your proof below"}</p>
        <div><label class="block text-sm font-medium text-brand-ink mb-1">${es ? "¿Qué hiciste? (opcional)" : "What did you do? (optional)"}</label>
        <textarea name="proof_text" rows="3" class="w-full rounded-xl border border-brand-ink/20 bg-brand-cream-deep px-3 py-2 text-sm text-brand-ink placeholder-brand-ink-soft focus:outline-none focus:ring-2 focus:ring-violet-400" placeholder="${es ? "Describe lo que hiciste..." : "Describe what you did..."}"></textarea></div>
        <div><label class="block text-sm font-medium text-brand-ink mb-1">${es ? "Foto de evidencia (opcional)" : "Photo evidence (optional)"}</label>
        <input type="file" accept="image/jpeg,image/png,image/webp" name="proof_image" class="w-full text-sm text-brand-ink-soft file:mr-3 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-violet-100 file:text-violet-700 hover:file:bg-violet-200" /></div>
        <button type="submit" class="w-full py-2.5 px-4 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 active:scale-[.98] transition-all text-sm">${submitLabel}</button>
    </form>`;
}
function awaitingHTML(): string {
    return `<div class="w-full py-2.5 px-4 bg-sky-100 text-sky-700 font-semibold rounded-xl text-center text-sm">${es ? "⏳ Pendiente de aprobación" : "⏳ Awaiting approval"}</div>`;
}

// ── Propose-a-gig modal (W4.4) ──────────────────────────────────────
const proposeModal = document.getElementById("propose-modal");
const proposeForm = document.getElementById("propose-form") as HTMLFormElement | null;
const openPropose = () => proposeModal?.classList.remove("hidden");
const closePropose = () => {
    proposeModal?.classList.add("hidden");
    proposeForm?.reset();
    document.getElementById("pf-error")?.classList.add("hidden");
};
document.getElementById("propose-gig-btn")?.addEventListener("click", openPropose);
document.getElementById("propose-close")?.addEventListener("click", closePropose);
proposeModal?.addEventListener("click", (e) => { if (e.target === proposeModal) closePropose(); });

proposeForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const errEl = document.getElementById("pf-error");
    const btn = proposeForm.querySelector("button[type=submit]") as HTMLButtonElement;
    const title = (document.getElementById("pf-title") as HTMLInputElement).value.trim();
    const description = (document.getElementById("pf-description") as HTMLTextAreaElement).value.trim() || null;
    const points = parseInt((document.getElementById("pf-points") as HTMLInputElement).value, 10);
    if (!title || isNaN(points) || points < 1) return;
    btn.disabled = true;
    try {
        const res = await fetch("/api/gigs/offerings/propose", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ title, description, points }),
        });
        if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            if (errEl) {
                errEl.textContent = err.detail ?? (es ? "No se pudo enviar" : "Could not submit");
                errEl.classList.remove("hidden");
            }
            btn.disabled = false;
            return;
        }
        closePropose();
        showToast(es ? "¡Propuesta enviada a tus papás! 💡" : "Proposal sent to your parents! 💡", "success");
        // Reload so the new proposal shows in "Mis propuestas".
        setTimeout(() => window.location.reload(), 900);
    } catch {
        btn.disabled = false;
        showToast(es ? "Error de conexión" : "Connection error", "error");
    }
});

// Delegated so it also handles the proof form INJECTED after a claim (which
// wouldn't have a per-element listener).
document.addEventListener("submit", async (e) => {
    const target = e.target as HTMLElement;

    // ── Claim a gig → swap the button for the proof form (no reload) ──
    const claimForm = target.closest?.("[data-claim-form]") as HTMLFormElement | null;
    if (claimForm) {
        e.preventDefault();
        const gigId = (claimForm.querySelector("[name=gig_id]") as HTMLInputElement).value;
        const btn = claimForm.querySelector("button") as HTMLButtonElement;
        const label = btn.getAttribute("data-label") ?? (es ? "Reclamar" : "Claim");
        // Capture the card BEFORE the outerHTML swap detaches claimForm.
        const card = claimForm.closest<HTMLElement>(".rounded-2xl");
        btn.disabled = true; btn.textContent = "...";
        const res = await mutate(`/api/gigs/offerings/${gigId}/claim`, { errorFallback: es ? "No se pudo reclamar" : "Could not claim" });
        if (res) {
            const claim = await res.json().catch(() => null);
            if (claim && claim.id) {
                claimForm.outerHTML = proofFormHTML(claim.id);
                // Match the server-rendered claimed-card border (was grey).
                card?.classList.replace("border-brand-ink/10", "border-violet-200");
            } else {
                window.location.reload();
            }
        } else { btn.disabled = false; btn.textContent = label; }
        return;
    }

    // ── Submit proof → swap for the awaiting-approval pill (no reload) ──
    const completeForm = target.closest?.("[data-complete-form]") as HTMLFormElement | null;
    if (completeForm) {
        e.preventDefault();
        const claimId = (completeForm as HTMLElement).dataset.claimId;
        const btn = completeForm.querySelector("button[type=submit]") as HTMLButtonElement;
        btn.disabled = true; btn.textContent = "...";

        const proofText = (completeForm.querySelector("[name=proof_text]") as HTMLTextAreaElement)?.value || null;
        const fileInput = completeForm.querySelector("[name=proof_image]") as HTMLInputElement;
        let proofImageUrl: string | null = null;

        if (fileInput?.files?.length) {
            const uploadForm = new FormData();
            uploadForm.append("file", fileInput.files[0]);
            const uploadRes = await fetch("/api/assignments/proof-upload", { method: "POST", body: uploadForm });
            if (!uploadRes.ok) {
                const uploadErr = await uploadRes.json().catch(() => null);
                btn.disabled = false; btn.textContent = submitLabel;
                showToast(uploadErr?.detail ?? (es ? "No se pudo subir la foto. Inténtalo de nuevo." : "Photo upload failed. Please try again."), "error");
                return;
            }
            proofImageUrl = (await uploadRes.json()).proof_image_url;
        }

        const res = await mutate(`/api/gigs/claims/${claimId}/complete`, {
            body: { proof_text: proofText, proof_image_url: proofImageUrl },
            errorFallback: es ? "No se pudo enviar" : "Could not submit",
        });
        if (res) completeForm.outerHTML = awaitingHTML();
        else { btn.disabled = false; btn.textContent = submitLabel; }
    }
});
</script>
