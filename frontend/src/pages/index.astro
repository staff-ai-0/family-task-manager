---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/brand/Logo.astro";
import Mark from "../components/brand/Mark.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import Badge from "../components/ui/Badge.astro";
import RoleBadge from "../components/ui/RoleBadge.astro";

const lang = Astro.cookies.get("lang")?.value ?? "es";

if (Astro.cookies.has("access_token")) {
	return Astro.redirect("/dashboard");
}

const es = lang === "es";
---

<Layout title={es ? "Family Task Manager — Tareas, premios y presupuesto en familia" : "Family Task Manager — Chores, rewards, budget — together"}>

  <!-- TOP BAR -->
  <header class="sticky top-0 z-50 bg-brand-cream border-b-2 border-brand-ink px-6 py-3 flex items-center gap-4">
    <Logo size="sm" href="/" />
    <nav class="ml-auto flex gap-2 items-center">
      <form method="POST" action="/api/lang" class="inline">
        <input type="hidden" name="lang" value={es ? "en" : "es"} />
        <button type="submit" class="press inline-flex items-center gap-1 px-3 py-1.5 border-2 border-brand-ink rounded-full text-xs font-extrabold font-display bg-brand-cream shadow-[2px_2px_0_var(--color-brand-ink)]">
          {es ? "EN" : "ES"}
        </button>
      </form>
      <a href="/login" class="hidden md:inline-flex font-display font-extrabold text-sm text-brand-ink px-3 py-2 hover:text-brand-coral-deep">{es ? "Iniciar sesión" : "Sign in"}</a>
      <Button variant="primary" size="sm" href="/login">{es ? "Comenzar gratis" : "Get started"}</Button>
    </nav>
  </header>

  <!-- HERO -->
  <section class="bg-brand-sky border-b-2 border-brand-ink px-6 py-20">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <Badge tone="cream">{es ? "Bilingüe ES · EN" : "Bilingual EN · ES"}</Badge>
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl mt-4 leading-[0.95] tracking-tight">
          {es ? <>Tareas, premios<br/>y presupuesto<br/><span class="text-brand-coral">en familia.</span></> : <>Chores, rewards,<br/>budget — <br/><span class="text-brand-coral">together.</span></>}
        </h1>
        <p class="mt-5 text-lg font-sans font-medium text-brand-ink max-w-md">
          {es
            ? "App gamificada para familias con hijos de 6 a 17 años. Tareas automáticas, puntos canjeables y finanzas familiares — todo en un solo lugar."
            : "Gamified family app for parents of kids 6–17. Automated chores, redeemable points, and family budgeting — all in one place."}
        </p>
        <div class="mt-7 flex gap-3 flex-wrap">
          <Button variant="primary" size="lg" href="/login">{es ? "Comenzar ahora →" : "Start now →"}</Button>
          <Button variant="ghost" size="lg" href="#features">{es ? "Ver cómo funciona" : "See how it works"}</Button>
        </div>
      </div>
      <Card tone="cream" pop class="flex items-center justify-center p-8">
        <Mark size={240} />
      </Card>
    </div>
  </section>

  <!-- ROLES -->
  <section class="bg-brand-cream px-6 py-16">
    <div class="max-w-6xl mx-auto">
      <p class="font-sans font-extrabold text-xs tracking-[0.18em] uppercase text-brand-ink-soft">{es ? "Roles" : "Roles"}</p>
      <h2 class="font-display text-4xl mt-2">{es ? "Tres personas, una pantalla." : "Three people, one screen."}</h2>
      <div class="mt-8 grid md:grid-cols-3 gap-6">
        <Card>
          <div class="flex items-center gap-4">
            <RoleBadge role="parent" size={72} />
            <div>
              <h3 class="font-display text-xl">{es ? "Padre/Madre" : "Parent"}</h3>
              <p class="text-sm text-brand-ink-soft mt-1 font-sans">{es ? "Aprueba tareas, define premios, controla la familia." : "Approves chores, sets payouts, runs the family."}</p>
            </div>
          </div>
        </Card>
        <Card>
          <div class="flex items-center gap-4">
            <RoleBadge role="teen" size={72} />
            <div>
              <h3 class="font-display text-xl">{es ? "Adolescente" : "Teen"}</h3>
              <p class="text-sm text-brand-ink-soft mt-1 font-sans">{es ? "Toma tareas, pide premios, rastrea estadísticas." : "Claims chores, requests rewards, tracks stats."}</p>
            </div>
          </div>
        </Card>
        <Card>
          <div class="flex items-center gap-4">
            <RoleBadge role="child" size={72} />
            <div>
              <h3 class="font-display text-xl">{es ? "Niño/a" : "Child"}</h3>
              <p class="text-sm text-brand-ink-soft mt-1 font-sans">{es ? "Números grandes, taps amplios, modo tutorial." : "Big numerals, larger taps, tutorial mode."}</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="bg-brand-cream-deep px-6 py-16 border-y-2 border-brand-ink">
    <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-6">
      <Card tone="mint">
        <p class="font-sans font-extrabold text-xs tracking-[0.12em] uppercase">{es ? "Esta semana" : "This week"}</p>
        <p class="font-display text-5xl mt-2 num">+1,240 pts</p>
      </Card>
      <Card tone="sun">
        <p class="font-sans font-extrabold text-xs tracking-[0.12em] uppercase">{es ? "Cartera" : "Wallet"}</p>
        <p class="font-display text-5xl mt-2 num">$48.00</p>
      </Card>
      <Card tone="coral">
        <p class="font-sans font-extrabold text-xs tracking-[0.12em] uppercase">{es ? "Racha" : "Streak"}</p>
        <p class="font-display text-5xl mt-2 num">{es ? "3 días" : "3 days"}</p>
      </Card>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="bg-brand-cream px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <p class="font-sans font-extrabold text-xs tracking-[0.18em] uppercase text-brand-ink-soft">{es ? "Tres módulos" : "Three modules"}</p>
      <h2 class="font-display text-4xl md:text-5xl mt-2">{es ? "Todo lo que una familia necesita." : "Everything a family needs."}</h2>

      <div class="mt-12 grid md:grid-cols-3 gap-6">
        <Card>
          <Badge tone="sky">{es ? "Módulo 1" : "Module 1"}</Badge>
          <h3 class="font-display text-2xl mt-4">{es ? "Tareas automáticas" : "Automated chores"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Barajado semanal inteligente. El sistema rota tareas según frecuencia y preferencias — sin trabajo manual de los padres." : "Smart weekly shuffle. The system rotates chores based on frequency + preferences — no parent legwork."}</p>
        </Card>
        <Card>
          <Badge tone="coral">{es ? "Módulo 2" : "Module 2"}</Badge>
          <h3 class="font-display text-2xl mt-4">{es ? "Puntos y premios" : "Points & rewards"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Los hijos acumulan puntos por tareas completadas y los canjean por premios que la familia define." : "Kids earn points for completed chores and redeem them for rewards the family defines."}</p>
        </Card>
        <Card>
          <Badge tone="mint">{es ? "Módulo 3" : "Module 3"}</Badge>
          <h3 class="font-display text-2xl mt-4">{es ? "Presupuesto por sobres" : "Envelope budgeting"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Asigna dinero a categorías, controla gastos en tiempo real y enseña finanzas a tus hijos." : "Assign money to categories, track spending in real time, and teach finance to your kids."}</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="bg-brand-sun border-y-2 border-brand-ink px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <p class="font-sans font-extrabold text-xs tracking-[0.18em] uppercase text-brand-ink">{es ? "Familias reales" : "Real families"}</p>
      <h2 class="font-display text-4xl md:text-5xl mt-2 text-brand-ink">{es ? "Lo que las familias dicen." : "What families say."}</h2>

      <div class="mt-12 grid md:grid-cols-3 gap-6">
        <Card>
          <p class="text-base font-sans text-brand-ink leading-relaxed">{es ? "“El barajado automático cambió todo. Antes era una pelea cada semana. Ahora el sistema lo hace solo.”" : "“The automatic shuffle changed everything. Before it was a fight every week. Now the system does it.”"}</p>
          <div class="mt-4 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-brand-coral border-2 border-brand-ink flex items-center justify-center font-display font-extrabold text-brand-ink">S</div>
            <div>
              <p class="font-display font-extrabold text-sm">Sandra M.</p>
              <p class="text-xs text-brand-ink-soft font-sans">{es ? "Madre de 3" : "Mother of 3"}</p>
            </div>
          </div>
        </Card>
        <Card>
          <p class="text-base font-sans text-brand-ink leading-relaxed">{es ? "“Por primera vez en 10 años entiendo a dónde va el dinero familiar.”" : "“For the first time in 10 years I understand where the family money goes.”"}</p>
          <div class="mt-4 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-brand-mint border-2 border-brand-ink flex items-center justify-center font-display font-extrabold text-brand-ink">R</div>
            <div>
              <p class="font-display font-extrabold text-sm">Roberto K.</p>
              <p class="text-xs text-brand-ink-soft font-sans">{es ? "Padre, CFO familiar" : "Father, family CFO"}</p>
            </div>
          </div>
        </Card>
        <Card>
          <p class="text-base font-sans text-brand-ink leading-relaxed">{es ? "“Mis hijos compiten por quién acumula más puntos. La gamificación funciona mejor de lo que esperaba.”" : "“My kids compete over who earns more points. The gamification works better than I expected.”"}</p>
          <div class="mt-4 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-brand-sky border-2 border-brand-ink flex items-center justify-center font-display font-extrabold text-brand-ink">A</div>
            <div>
              <p class="font-display font-extrabold text-sm">Ana L.</p>
              <p class="text-xs text-brand-ink-soft font-sans">{es ? "Madre de gemelos (12)" : "Mother of twins (12)"}</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-brand-coral border-b-2 border-brand-ink px-6 py-24 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-5xl md:text-6xl text-brand-ink leading-tight tracking-tight">
        {es ? <>Empieza hoy.<br/>Tu familia lo notará.</> : <>Start today.<br/>Your family will notice.</>}
      </h2>
      <p class="mt-6 text-lg font-sans text-brand-ink font-medium">{es ? "Sin tarjeta. Sin configuraciones eternas. Listo en minutos." : "No credit card. No endless setup. Ready in minutes."}</p>
      <div class="mt-8 flex gap-3 justify-center flex-wrap">
        <Button variant="primary" size="lg" href="/login" class="bg-brand-sun">{es ? "Comenzar gratis →" : "Get started →"}</Button>
        <Button variant="ghost" size="lg" href="/login">{es ? "Iniciar sesión" : "Sign in"}</Button>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-brand-ink text-brand-cream px-6 py-10">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <Logo size="sm" tone="mono-cream" />
      <p class="font-sans text-xs text-brand-cream/70">family.agent-ia.mx · © 2026</p>
      <form method="POST" action="/api/lang" class="inline">
        <input type="hidden" name="lang" value={es ? "en" : "es"} />
        <button type="submit" class="text-xs text-brand-cream/80 hover:text-brand-sun font-sans font-bold transition">
          {es ? "Switch to English" : "Cambiar a Español"}
        </button>
      </form>
    </div>
  </footer>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (this: HTMLAnchorElement, e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href') as string);
        if (target) (target as HTMLElement).scrollIntoView({ behavior: 'smooth' });
      });
    });
  });
</script>
</Layout>
