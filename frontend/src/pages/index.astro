---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/brand/Logo.astro";
import Mark from "../components/brand/Mark.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import Badge from "../components/ui/Badge.astro";
import RoleBadge from "../components/ui/RoleBadge.astro";
import { seoFor, organizationJsonLd, softwareAppJsonLd } from "../lib/seo";

const lang = Astro.cookies.get("lang")?.value ?? "es";

if (Astro.cookies.has("access_token")) {
	return Astro.redirect("/dashboard");
}

const es = lang === "es";
const seo = seoFor("/", lang)!;
const landingJsonLd = [organizationJsonLd(), softwareAppJsonLd(lang)];
---

<Layout title={seo.title} description={seo.description} lang={lang} jsonLd={landingJsonLd}>

  <!-- TOP BAR -->
  <header class="sticky top-0 z-50 bg-brand-cream border-b-2 border-brand-ink px-6 py-3 flex items-center gap-4">
    <Logo size="sm" href="/" />
    <nav class="ml-auto flex gap-2 items-center">
      <form method="POST" action="/api/lang" class="inline">
        <input type="hidden" name="lang" value={es ? "en" : "es"} />
        <button type="submit" class="press inline-flex items-center gap-1 px-3 py-1.5 border-2 border-brand-ink rounded-full text-xs font-extrabold font-display bg-brand-cream shadow-[2px_2px_0_var(--color-brand-ink)]">
          {es ? "EN" : "ES"}
        </button>
      </form>
      <a href="/login" class="hidden md:inline-flex font-display font-extrabold text-sm text-brand-ink px-3 py-2 hover:text-brand-coral-deep">{es ? "Iniciar sesión" : "Sign in"}</a>
      <Button variant="primary" size="sm" href="/register">{es ? "Comenzar gratis" : "Get started"}</Button>
    </nav>
  </header>

  <!-- HERO -->
  <section class="bg-brand-sky border-b-2 border-brand-ink px-6 py-20">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <Badge tone="cream">{es ? "Bilingüe ES · EN · Sin tarjeta para empezar" : "Bilingual EN · ES · No card to start"}</Badge>
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl mt-4 leading-[0.95] tracking-tight">
          {es ? <>El sistema<br/>operativo de<br/><span class="text-brand-coral">tu familia.</span></> : <>Your family's<br/>operating<br/><span class="text-brand-coral">system.</span></>}
        </h1>
        <p class="mt-5 text-lg font-sans font-medium text-brand-ink max-w-md">
          {es
            ? "Tareas que se reparten solas, dos monedas (puntos y dinero real), presupuesto por sobres a la altura de las mejores apps, escáner de recibos con IA y un copiloto que responde tus preguntas de dinero. Para familias con hijos de 6 a 17."
            : "Chores that assign themselves, two currencies (points and real cash), envelope budgeting on par with the best finance apps, an AI receipt scanner, and a copilot that answers your money questions. For families with kids 6–17."}
        </p>
        <div class="mt-7 flex gap-3 flex-wrap">
          <Button variant="primary" size="lg" href="/register">{es ? "Comenzar gratis →" : "Start free →"}</Button>
          <Button variant="ghost" size="lg" href="#pricing">{es ? "Ver planes" : "See pricing"}</Button>
        </div>
      </div>
      <Card tone="cream" pop class="flex items-center justify-center p-8">
        <Mark size={240} />
      </Card>
    </div>
  </section>

  <!-- ROLES -->
  <section class="bg-brand-cream px-6 py-16">
    <div class="max-w-6xl mx-auto">
      <p class="font-sans font-extrabold text-xs tracking-[0.18em] uppercase text-brand-ink-soft">{es ? "Roles" : "Roles"}</p>
      <h2 class="font-display text-4xl mt-2">{es ? "Tres personas, una pantalla." : "Three people, one screen."}</h2>
      <div class="mt-8 grid md:grid-cols-3 gap-6">
        <Card>
          <div class="flex items-center gap-4">
            <RoleBadge role="parent" size={72} />
            <div>
              <h3 class="font-display text-xl">{es ? "Padre/Madre" : "Parent"}</h3>
              <p class="text-sm text-brand-ink-soft mt-1 font-sans">{es ? "Aprueba tareas, define premios, controla la familia." : "Approves chores, sets payouts, runs the family."}</p>
            </div>
          </div>
        </Card>
        <Card>
          <div class="flex items-center gap-4">
            <RoleBadge role="teen" size={72} />
            <div>
              <h3 class="font-display text-xl">{es ? "Adolescente" : "Teen"}</h3>
              <p class="text-sm text-brand-ink-soft mt-1 font-sans">{es ? "Toma tareas, pide premios, rastrea estadísticas." : "Claims chores, requests rewards, tracks stats."}</p>
            </div>
          </div>
        </Card>
        <Card>
          <div class="flex items-center gap-4">
            <RoleBadge role="child" size={72} />
            <div>
              <h3 class="font-display text-xl">{es ? "Niño/a" : "Child"}</h3>
              <p class="text-sm text-brand-ink-soft mt-1 font-sans">{es ? "Números grandes, taps amplios, modo tutorial." : "Big numerals, larger taps, tutorial mode."}</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="bg-brand-cream-deep px-6 py-16 border-y-2 border-brand-ink">
    <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-6">
      <Card tone="mint">
        <p class="font-sans font-extrabold text-xs tracking-[0.12em] uppercase">{es ? "Esta semana" : "This week"}</p>
        <p class="font-display text-5xl mt-2 num">+1,240 pts</p>
      </Card>
      <Card tone="sun">
        <p class="font-sans font-extrabold text-xs tracking-[0.12em] uppercase">{es ? "Cartera" : "Wallet"}</p>
        <p class="font-display text-5xl mt-2 num">$48.00</p>
      </Card>
      <Card tone="coral">
        <p class="font-sans font-extrabold text-xs tracking-[0.12em] uppercase">{es ? "Racha" : "Streak"}</p>
        <p class="font-display text-5xl mt-2 num">{es ? "3 días" : "3 days"}</p>
      </Card>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="bg-brand-cream px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <p class="font-sans font-extrabold text-xs tracking-[0.18em] uppercase text-brand-ink-soft">{es ? "Todo incluido" : "All in one"}</p>
      <h2 class="font-display text-4xl md:text-5xl mt-2">{es ? "Una app. Toda la logística familiar." : "One app. The whole family's logistics."}</h2>

      <div class="mt-12 grid md:grid-cols-3 gap-6">
        <Card>
          <Badge tone="sky">{es ? "Tareas" : "Chores"}</Badge>
          <h3 class="font-display text-2xl mt-4">{es ? "Se reparten solas" : "They assign themselves"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Barajado semanal balanceado por persona, días específicos, rotación justa y aprobación con foto. Cero pelea de quién le toca qué." : "Balanced weekly shuffle per person, specific weekdays, fair rotation and photo approval. Zero fights over whose turn it is."}</p>
        </Card>
        <Card>
          <Badge tone="coral">{es ? "Dos monedas" : "Two currencies"}</Badge>
          <h3 class="font-display text-2xl mt-4">{es ? "Puntos y dinero real" : "Points & real cash"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Las tareas dan puntos canjeables por privilegios; el tablero de 'gigs' paga dinero real. Banco familiar con mesada, interés y metas de ahorro por hijo." : "Chores earn points redeemable for privileges; the gigs board pays real cash. Family bank with allowance, interest, and per-kid savings goals."}</p>
        </Card>
        <Card>
          <Badge tone="mint">{es ? "Finanzas" : "Finance"}</Badge>
          <h3 class="font-display text-2xl mt-4">{es ? "Presupuesto pro" : "Pro-grade budget"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Sobres, conciliación bancaria, transacciones divididas, recurrentes que se registran solas, reportes y 'deshacer'. A la altura de las mejores apps de finanzas." : "Envelopes, bank reconciliation, split transactions, auto-posting recurring, reports and undo. On par with the best finance apps."}</p>
        </Card>
        <Card>
          <Badge tone="sun">{es ? "IA" : "AI"}</Badge>
          <h3 class="font-display text-2xl mt-4">{es ? "Escáner de recibos" : "Receipt scanner"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Toma foto del ticket y la IA extrae fecha, monto, comercio y cada artículo. Más un copiloto (Jarvis) que responde '¿cuánto gastamos en comida?'." : "Snap the receipt and AI pulls date, amount, merchant and every line item. Plus a copilot (Jarvis) that answers 'how much did we spend on food?'."}</p>
        </Card>
        <Card>
          <Badge tone="sky">{es ? "Hogar" : "Home"}</Badge>
          <h3 class="font-display text-2xl mt-4">{es ? "Comidas, compras, agenda" : "Meals, shopping, calendar"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Plan de comidas que arma la lista del súper, calendario familiar con escáner de imágenes, chat y mensajes directos. La familia coordinada en un lugar." : "Meal plans that build the shopping list, a family calendar with image scanning, group chat and direct messages. The family coordinated in one place."}</p>
        </Card>
        <Card>
          <Badge tone="coral">{es ? "Para niños" : "For kids"}</Badge>
          <h3 class="font-display text-2xl mt-4">{es ? "Mascota y modo kiosko" : "Pet & kiosk mode"}</h3>
          <p class="text-sm text-brand-ink-soft mt-2 font-sans">{es ? "Una mascota virtual por hijo que crece al completar tareas, rutinas tipo Skylight, y un modo kiosko para la tablet compartida del refri." : "A virtual pet per kid that grows as they complete work, Skylight-style routines, and a kiosk mode for the shared fridge tablet."}</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="bg-brand-sun border-y-2 border-brand-ink px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <p class="font-sans font-extrabold text-xs tracking-[0.18em] uppercase text-brand-ink">{es ? "Precios" : "Pricing"}</p>
      <h2 class="font-display text-4xl md:text-5xl mt-2 text-brand-ink">{es ? "Empieza gratis. Sube cuando la uses." : "Start free. Upgrade when you use it."}</h2>
      <p class="mt-3 font-sans text-brand-ink font-medium max-w-xl">{es ? "Todo el sistema de tareas, puntos y el banco familiar son gratis para siempre. Los planes de pago abren las finanzas avanzadas y la IA." : "The whole chores, points and family-bank system is free forever. Paid plans unlock advanced finance and AI."}</p>

      <div class="mt-12 grid md:grid-cols-3 gap-6 items-start">
        <!-- FREE -->
        <Card>
          <Badge tone="sky">{es ? "Gratis" : "Free"}</Badge>
          <p class="font-display text-4xl mt-4 num">$0</p>
          <p class="text-xs text-brand-ink-soft font-sans mb-4">{es ? "para siempre" : "forever"}</p>
          <ul class="space-y-2 text-sm font-sans text-brand-ink">
            <li>✓ {es ? "Tareas, barajado y rutinas" : "Chores, shuffle & routines"}</li>
            <li>✓ {es ? "Puntos, premios y tablero de gigs" : "Points, rewards & gigs board"}</li>
            <li>✓ {es ? "Banco familiar (mesada + ahorro)" : "Family bank (allowance + savings)"}</li>
            <li>✓ {es ? "Presupuesto básico (2 cuentas)" : "Basic budget (2 accounts)"}</li>
            <li>✓ {es ? "Hasta 4 miembros" : "Up to 4 members"}</li>
          </ul>
          <Button variant="ghost" size="md" href="/register" class="mt-6 w-full">{es ? "Crear cuenta" : "Create account"}</Button>
        </Card>

        <!-- PLUS (featured) -->
        <Card pop tone="cream" class="border-brand-coral">
          <div class="flex items-center gap-2">
            <Badge tone="coral">Plus</Badge>
            <span class="font-sans text-[10px] font-extrabold uppercase tracking-wide bg-brand-coral text-brand-ink px-2 py-0.5 rounded-full border border-brand-ink">{es ? "Más elegido" : "Most popular"}</span>
          </div>
          <p class="font-display text-4xl mt-4 num">$4.99<span class="text-lg text-brand-ink-soft"> {es ? "/mes" : "/mo"}</span></p>
          <p class="text-xs text-brand-ink-soft font-sans mb-4">{es ? "o $49 al año (2 meses gratis) · USD" : "or $49/yr (2 months free) · USD"}</p>
          <ul class="space-y-2 text-sm font-sans text-brand-ink">
            <li>✓ {es ? "Todo lo de Gratis, más:" : "Everything in Free, plus:"}</li>
            <li>✓ {es ? "Escáner de recibos con IA (50/mes)" : "AI receipt scanner (50/mo)"}</li>
            <li>✓ {es ? "Copiloto Jarvis + reportes + metas" : "Jarvis copilot + reports + goals"}</li>
            <li>✓ {es ? "Recurrentes, import CSV/OFX, 5 cuentas" : "Recurring, CSV/OFX import, 5 accounts"}</li>
            <li>✓ {es ? "Automatización del banco familiar" : "Family-bank automation"}</li>
            <li>✓ {es ? "Hasta 6 miembros" : "Up to 6 members"}</li>
          </ul>
          <Button variant="primary" size="md" href="/register" class="mt-6 w-full">{es ? "Empezar con Plus" : "Get Plus"}</Button>
        </Card>

        <!-- PRO -->
        <Card>
          <Badge tone="mint">Pro</Badge>
          <p class="font-display text-4xl mt-4 num">$9.99<span class="text-lg text-brand-ink-soft"> {es ? "/mes" : "/mo"}</span></p>
          <p class="text-xs text-brand-ink-soft font-sans mb-4">{es ? "o $99 al año · USD" : "or $99/yr · USD"}</p>
          <ul class="space-y-2 text-sm font-sans text-brand-ink">
            <li>✓ {es ? "Todo lo de Plus, sin límites:" : "Everything in Plus, unlimited:"}</li>
            <li>✓ {es ? "Escaneos de recibos ilimitados" : "Unlimited receipt scans"}</li>
            <li>✓ {es ? "Cuentas, transacciones y recurrentes sin tope" : "Unlimited accounts, transactions, recurring"}</li>
            <li>✓ {es ? "Comparador de precios por artículo" : "Per-item price comparison"}</li>
            <li>✓ {es ? "Miembros ilimitados" : "Unlimited members"}</li>
          </ul>
          <Button variant="ghost" size="md" href="/register" class="mt-6 w-full">{es ? "Elegir Pro" : "Go Pro"}</Button>
        </Card>
      </div>
      <p class="mt-6 text-xs text-brand-ink font-sans">{es ? "Pago con PayPal. Cancela cuando quieras. Precios en USD." : "Pay with PayPal. Cancel anytime. Prices in USD."}</p>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-brand-coral border-b-2 border-brand-ink px-6 py-24 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-5xl md:text-6xl text-brand-ink leading-tight tracking-tight">
        {es ? <>Empieza hoy.<br/>Tu familia lo notará.</> : <>Start today.<br/>Your family will notice.</>}
      </h2>
      <p class="mt-6 text-lg font-sans text-brand-ink font-medium">{es ? "Sin tarjeta. Sin configuraciones eternas. Listo en minutos." : "No credit card. No endless setup. Ready in minutes."}</p>
      <div class="mt-8 flex gap-3 justify-center flex-wrap">
        <Button variant="primary" size="lg" href="/register" class="bg-brand-sun">{es ? "Comenzar gratis →" : "Get started →"}</Button>
        <Button variant="ghost" size="lg" href="/login">{es ? "Iniciar sesión" : "Sign in"}</Button>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-brand-ink text-brand-cream px-6 py-10">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <Logo size="sm" tone="mono-cream" />
      <nav class="flex gap-4 text-xs font-sans font-bold" aria-label={es ? "Legal" : "Legal"}>
        <a href="/privacidad" class="text-brand-cream/80 hover:text-brand-sun transition">{es ? "Aviso de Privacidad" : "Privacy Notice"}</a>
        <a href="/terminos" class="text-brand-cream/80 hover:text-brand-sun transition">{es ? "Términos" : "Terms"}</a>
        <a href={es ? "/ayuda" : "/help"} class="text-brand-cream/80 hover:text-brand-sun transition">{es ? "Ayuda" : "Help"}</a>
        <a href="mailto:soporte@agent-ia.mx" class="text-brand-cream/80 hover:text-brand-sun transition">{es ? "Soporte" : "Support"}</a>
      </nav>
      <p class="font-sans text-xs text-brand-cream/70">family.agent-ia.mx · © 2026</p>
      <form method="POST" action="/api/lang" class="inline">
        <input type="hidden" name="lang" value={es ? "en" : "es"} />
        <button type="submit" class="text-xs text-brand-cream/80 hover:text-brand-sun font-sans font-bold transition">
          {es ? "Switch to English" : "Cambiar a Español"}
        </button>
      </form>
    </div>
  </footer>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (this: HTMLAnchorElement, e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href') as string);
        if (target) (target as HTMLElement).scrollIntoView({ behavior: 'smooth' });
      });
    });
  });
</script>
</Layout>
