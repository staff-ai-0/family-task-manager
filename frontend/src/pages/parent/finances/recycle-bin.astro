---
/**
 * Recycle Bin Page
 * Shows deleted transactions, accounts, and categories with restore/delete options
 */

import Layout from "@layouts/Layout.astro";
import BottomNav from "@components/BottomNav.astro";
import BudgetNav from "@components/BudgetNav.astro";
import RecycleBinTable from "@components/RecycleBinTable.astro";
import { apiFetch } from "@lib/api";
import { t } from "@lib/i18n";

// Authentication check
const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");

const lang = Astro.cookies.get("lang")?.value ?? "en";

// Get user info
const { data: user, ok: userOk } = await apiFetch<any>("/api/auth/me", { token });
if (!userOk) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}

// Only parents can view recycle bin
if (user.role !== "parent") {
    return Astro.redirect("/dashboard");
}
---

<Layout title="Recycle Bin - Budget" lang={lang}>
    <BudgetNav active="recycle-bin" />

    <main class="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto px-4 py-6 space-y-6">
        <!-- Header -->
        <div>
            <h1 class="text-3xl font-bold text-gray-900">
                {t(lang, "budget_recyclebin_title")}
            </h1>
            <p class="mt-2 text-gray-600">
                {t(lang, "budget_recyclebin_description")}
            </p>
        </div>

        <!-- Recycle Bin Table -->
        <RecycleBinTable session={{ token }} />
    </main>

    <BottomNav active="budget" lang={lang} />
</Layout>
