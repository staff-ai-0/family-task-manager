---
import PageLayout from "@components/ui/PageLayout.astro";
import { apiFetch } from "../../lib/api";
import { t } from "../../lib/i18n";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = Astro.cookies.get("lang")?.value ?? "en";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

// One queue, THREE sources: chore/bonus task proofs, gig-board claim proofs,
// and parent-approval reward redemptions.
const [taskRes, gigRes, redemptionRes] = await Promise.all([
    apiFetch<any[]>("/api/task-assignments/pending-approvals", { token }),
    apiFetch<any[]>("/api/gigs/claims/pending-approvals", { token }),
    apiFetch<any[]>("/api/rewards/redemptions/pending", { token }),
]);
const taskItems: any[] = taskRes.data ?? [];
const gigItems: any[] = gigRes.data ?? [];
const redemptionItems: any[] = redemptionRes.data ?? [];
const total = taskItems.length + gigItems.length + redemptionItems.length;

const flash = Astro.cookies.get("flash")?.value;
if (flash) Astro.cookies.delete("flash", { path: "/" });

const fmtDate = (d: string) =>
    new Date(d).toLocaleString(lang === "es" ? "es-MX" : "en-US", {
        month: "short", day: "numeric", hour: "2-digit", minute: "2-digit",
    });
---

<PageLayout
    title={lang === "es" ? "Aprobaciones" : "Approvals"}
    headerClass="bg-gradient-to-br from-amber-700 to-amber-600"
    dark
    backClass="text-amber-100 hover:text-white"
    backHref="/parent"
    backLabel={t(lang, "back_parent") as string}
    role={user.role}
    active="parent"
    lang={lang as "en" | "es"}
    mainClass="flex-1 px-4 py-6 space-y-6"
>
    <p slot="header-extra" class="text-amber-100 text-sm mt-1">
        {lang === "es"
            ? "Todo el trabajo enviado, en un solo lugar."
            : "All submitted work, in one place."}
    </p>
            {total > 1 && (
                <div id="batch-bar" class="sticky top-2 z-20 flex flex-wrap gap-2 items-center bg-brand-cream/95 backdrop-blur rounded-2xl p-3 border border-brand-ink/10 shadow-[var(--shadow-card)]">
                    <span id="batch-count" class="text-sm font-semibold text-brand-ink mr-auto">
                        {total} {lang === "es" ? "por revisar" : "to review"}
                    </span>
                    {taskItems.some((r: any) => (r.ai_validation_score ?? 0) >= 0.7) && (
                        <button type="button" id="approve-ai" data-busy={lang === "es" ? "Aprobando…" : "Approving…"}
                            class="px-3 py-2 rounded-lg bg-brand-mint/20 text-brand-mint-deep border border-brand-mint-deep/30 font-semibold text-sm hover:bg-brand-mint/30 transition-colors">
                            {lang === "es" ? "Aprobar IA ≥70%" : "Approve AI ≥70%"}
                        </button>
                    )}
                    <button type="button" id="approve-all" data-busy={lang === "es" ? "Aprobando…" : "Approving…"}
                        class="px-4 py-2 rounded-lg bg-brand-mint-deep text-white font-semibold text-sm shadow-[var(--shadow-card)] hover:opacity-90 transition-opacity">
                        {lang === "es" ? "Aprobar todo" : "Approve all"}
                    </button>
                </div>
            )}

            {total === 0 && (
                <div class="bg-brand-cream rounded-2xl p-8 text-center border border-brand-ink/10 shadow-[var(--shadow-card)]">
                    <div class="w-16 h-16 bg-brand-mint/20 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-brand-mint-deep" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                    <p class="text-brand-ink-soft text-sm">
                        {lang === "es" ? "Nada por aprobar." : "Nothing waiting for approval."}
                    </p>
                </div>
            )}

            {taskItems.length > 0 && (
                <section>
                    <h2 class="text-sm font-bold text-brand-ink-soft uppercase tracking-wide mb-3 px-1">
                        {lang === "es" ? "Tareas y bonus" : "Chores & bonus"} ({taskItems.length})
                    </h2>
                    <ul class="space-y-3 approvals-list">
                        {taskItems.map((row: any) => (
                            <li
                                class="bg-brand-cream rounded-2xl p-5 border border-brand-ink/10 shadow-[var(--shadow-card)]"
                                data-kind="task"
                                data-id={row.assignment_id}
                                data-ai-score={row.ai_validation_score ?? ""}
                            >
                                <div class="flex justify-between items-start mb-3 gap-3">
                                    <div class="min-w-0">
                                        <h3 class="font-bold text-brand-ink truncate">{row.template_title}</h3>
                                        <p class="text-sm text-brand-ink-soft mt-0.5">
                                            {row.assigned_to_name}
                                            <span class="mx-1">·</span>
                                            <span class="text-brand-sun-deep font-semibold">+{row.points} pts</span>
                                        </p>
                                    </div>
                                    {row.completed_at && (
                                        <span class="text-xs text-brand-ink-soft whitespace-nowrap">{fmtDate(row.completed_at)}</span>
                                    )}
                                </div>
                                <p class="text-sm bg-brand-cream-deep rounded-lg p-3 mb-3 whitespace-pre-wrap text-brand-ink">
                                    {row.proof_text || (lang === "es" ? "(sin texto)" : "(no proof text)")}
                                </p>
                                {row.proof_image_url && (
                                    <a href={row.proof_image_url} target="_blank" rel="noopener noreferrer" class="block mb-3">
                                        <img src={row.proof_image_url} alt={lang === "es" ? "Foto de prueba" : "Proof image"}
                                            class="max-w-full max-h-48 rounded-lg border border-brand-ink/20 object-cover" />
                                    </a>
                                )}
                                {row.ai_validation_score != null && (
                                    <div class={`mb-3 p-2 rounded-lg border text-xs ${
                                        row.ai_validation_score >= 0.7
                                            ? "bg-brand-mint/15 border-brand-mint-deep/30 text-brand-mint-deep"
                                            : row.ai_validation_score >= 0.4
                                                ? "bg-brand-sun/15 border-brand-sun-deep/30 text-brand-sun-deep"
                                                : "bg-red-50 border-red-200 text-red-700"
                                    }`}>
                                        <p class="font-semibold">🤖 AI: {Math.round(row.ai_validation_score * 100)}%
                                            {row.ai_validation_score >= 0.7 && " ✓"}
                                            {row.ai_validation_score < 0.4 && " ⚠️"}
                                        </p>
                                        {row.ai_validation_notes && (<p class="mt-1 italic">{row.ai_validation_notes}</p>)}
                                    </div>
                                )}
                                <textarea data-notes rows="2"
                                    class="w-full border border-brand-ink/20 rounded-lg p-2 mb-3 text-sm focus:ring-2 focus:ring-amber-500 outline-none bg-brand-cream"
                                    placeholder={lang === "es" ? "Notas (opcional)" : "Notes (optional)"}></textarea>
                                <div class="flex justify-end gap-2">
                                    <button type="button" data-action="reject"
                                        class="px-4 py-2 rounded-lg border border-red-300 text-red-700 font-semibold text-sm hover:bg-red-50 transition-colors">
                                        {lang === "es" ? "Rechazar" : "Reject"}
                                    </button>
                                    <button type="button" data-action="approve"
                                        class="px-4 py-2 rounded-lg bg-brand-mint-deep text-white font-semibold text-sm shadow-[var(--shadow-card)] hover:opacity-90 transition-opacity">
                                        {lang === "es" ? "Aprobar" : "Approve"}
                                    </button>
                                </div>
                            </li>
                        ))}
                    </ul>
                </section>
            )}

            {gigItems.length > 0 && (
                <section>
                    <h2 class="text-sm font-bold text-brand-ink-soft uppercase tracking-wide mb-3 px-1">
                        {lang === "es" ? "Tablero de gigs" : "Gig board"} ({gigItems.length})
                    </h2>
                    <ul class="space-y-3 approvals-list">
                        {gigItems.map((claim: any) => (
                            <li
                                class="bg-brand-cream rounded-2xl p-5 border border-brand-ink/10 shadow-[var(--shadow-card)]"
                                data-kind="gig"
                                data-id={claim.id}
                            >
                                <div class="flex justify-between items-start mb-3 gap-3">
                                    <div class="min-w-0">
                                        <h3 class="font-bold text-brand-ink truncate">{claim.gig_title ?? "—"}</h3>
                                        <p class="text-sm text-brand-ink-soft mt-0.5">
                                            {claim.claimer_name ?? claim.claimed_by}
                                            {claim.gig_points != null && (
                                                <>
                                                    <span class="mx-1">·</span>
                                                    <span class="text-emerald-600 font-semibold">+${claim.gig_points} MXN</span>
                                                </>
                                            )}
                                        </p>
                                    </div>
                                </div>
                                <p class="text-sm bg-brand-cream-deep rounded-lg p-3 mb-3 whitespace-pre-wrap text-brand-ink">
                                    {claim.proof_text || (lang === "es" ? "(sin texto)" : "(no proof text)")}
                                </p>
                                {claim.proof_image_url && (
                                    <a href={claim.proof_image_url} target="_blank" rel="noopener noreferrer" class="block mb-3">
                                        <img src={claim.proof_image_url} alt={lang === "es" ? "Foto de prueba" : "Proof image"}
                                            class="max-w-full max-h-48 rounded-lg border border-brand-ink/20 object-cover" />
                                    </a>
                                )}
                                <textarea data-notes rows="2"
                                    class="w-full border border-brand-ink/20 rounded-lg p-2 mb-3 text-sm focus:ring-2 focus:ring-amber-500 outline-none bg-brand-cream"
                                    placeholder={lang === "es" ? "Notas (opcional)" : "Notes (optional)"}></textarea>
                                <div class="flex justify-end gap-2">
                                    <button type="button" data-action="reject"
                                        class="px-4 py-2 rounded-lg border border-red-300 text-red-700 font-semibold text-sm hover:bg-red-50 transition-colors">
                                        {lang === "es" ? "Rechazar" : "Reject"}
                                    </button>
                                    <button type="button" data-action="approve"
                                        class="px-4 py-2 rounded-lg bg-brand-mint-deep text-white font-semibold text-sm shadow-[var(--shadow-card)] hover:opacity-90 transition-opacity">
                                        {lang === "es" ? "Aprobar" : "Approve"}
                                    </button>
                                </div>
                            </li>
                        ))}
                    </ul>
                </section>
            )}

            {redemptionItems.length > 0 && (
                <section>
                    <h2 class="text-sm font-bold text-brand-ink-soft uppercase tracking-wide mb-3 px-1">
                        {lang === "es" ? "Canjes de premios" : "Reward redemptions"} ({redemptionItems.length})
                    </h2>
                    <ul class="space-y-3 approvals-list">
                        {redemptionItems.map((r: any) => (
                            <li
                                class="bg-brand-cream rounded-2xl p-5 border border-brand-ink/10 shadow-[var(--shadow-card)]"
                                data-kind="redemption"
                                data-id={r.id}
                            >
                                <div class="flex justify-between items-start mb-3 gap-3">
                                    <div class="min-w-0">
                                        <h3 class="font-bold text-brand-ink truncate">🎁 {r.reward_title}</h3>
                                        <p class="text-sm text-brand-ink-soft mt-0.5">
                                            {r.user_name}
                                            <span class="mx-1">·</span>
                                            <span class="text-brand-sun-deep font-semibold">−{r.points_cost} pts</span>
                                        </p>
                                    </div>
                                    {r.created_at && (
                                        <span class="text-xs text-brand-ink-soft whitespace-nowrap">{fmtDate(r.created_at)}</span>
                                    )}
                                </div>
                                <textarea data-notes rows="2"
                                    class="w-full border border-brand-ink/20 rounded-lg p-2 mb-3 text-sm focus:ring-2 focus:ring-amber-500 outline-none bg-brand-cream"
                                    placeholder={lang === "es" ? "Notas (opcional)" : "Notes (optional)"}></textarea>
                                <div class="flex justify-end gap-2">
                                    <button type="button" data-action="reject"
                                        class="px-4 py-2 rounded-lg border border-red-300 text-red-700 font-semibold text-sm hover:bg-red-50 transition-colors">
                                        {lang === "es" ? "Rechazar" : "Reject"}
                                    </button>
                                    <button type="button" data-action="approve"
                                        class="px-4 py-2 rounded-lg bg-brand-mint-deep text-white font-semibold text-sm shadow-[var(--shadow-card)] hover:opacity-90 transition-opacity">
                                        {lang === "es" ? "Aprobar" : "Approve"}
                                    </button>
                                </div>
                            </li>
                        ))}
                    </ul>
                </section>
            )}
    <script>
        document.addEventListener("astro:page-load", () => {
            const lists = document.querySelectorAll(".approvals-list");
            if (!lists.length) return;

            const remaining = () =>
                document.querySelectorAll(".approvals-list li[data-id]").length;

            // One request per item, reused by the per-item buttons and the
            // batch buttons. Resolves true on success (li removed), false on
            // failure (li kept for manual handling).
            async function decide(li: HTMLLIElement, approve: boolean): Promise<boolean> {
                const id = li.dataset.id!;
                const kind = li.dataset.kind;
                const notes = li.querySelector<HTMLTextAreaElement>("[data-notes]");
                const noteVal = notes?.value.trim() || null;
                try {
                    let r: Response;
                    if (kind === "gig") {
                        r = await fetch(`/api/gigs/claims/${id}/approve`, {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ approved: approve, notes: noteVal }),
                        });
                    } else if (kind === "redemption") {
                        r = await fetch(`/api/rewards/redemptions/${id}/${approve ? "approve" : "reject"}`, {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ notes: noteVal }),
                        });
                    } else {
                        r = await fetch("/api/assignments/approve", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ assignment_id: id, approve, notes: noteVal }),
                        });
                    }
                    if (r.ok) {
                        li.remove();
                        return true;
                    }
                    // Surface the backend reason (e.g. "Insufficient points.
                    // Need X, have Y") instead of a blanket error.
                    const err = await r.json().catch(() => null);
                    lastError = (err && (err.detail || err.message)) || null;
                    return false;
                } catch {
                    lastError = null;
                    return false;
                }
            }
            let lastError: string | null = null;

            const countEl = document.getElementById("batch-count");
            const es = document.documentElement.lang === "es";
            const afterChange = () => {
                const n = remaining();
                if (n === 0) { window.location.reload(); return; }
                if (countEl) countEl.textContent = `${n} ${es ? "por revisar" : "to review"}`;
            };

            lists.forEach((list) => {
                list.querySelectorAll<HTMLLIElement>("li[data-id]").forEach((li) => {
                    li.querySelectorAll<HTMLButtonElement>("button[data-action]").forEach((btn) => {
                        btn.addEventListener("click", async () => {
                            btn.disabled = true;
                            const ok = await decide(li, btn.dataset.action === "approve");
                            if (ok) afterChange();
                            else { alert(lastError || (es ? "Error al procesar" : "Error processing")); btn.disabled = false; }
                        });
                    });
                });
            });

            // Batch approve — loops the same single-item request. `filter`
            // selects a subset (e.g. AI-confident task items).
            async function batchApprove(btn: HTMLButtonElement, filter: (li: HTMLLIElement) => boolean) {
                const items = Array.from(
                    document.querySelectorAll<HTMLLIElement>(".approvals-list li[data-id]")
                ).filter(filter);
                if (!items.length) return;
                // Capture the real label BEFORE swapping in the busy text, so a
                // partial-failure restore doesn't leave it stuck on "Approving…".
                const original = btn.textContent;
                btn.textContent = btn.dataset.busy || "…";
                document.querySelectorAll<HTMLButtonElement>("#batch-bar button").forEach((b) => (b.disabled = true));
                let done = 0, failed = 0;
                for (const li of items) {
                    const ok = await decide(li, true);
                    ok ? done++ : failed++;
                    if (countEl) countEl.textContent = `${remaining()} ${es ? "por revisar" : "to review"}`;
                }
                if (remaining() === 0) { window.location.reload(); return; }
                document.querySelectorAll<HTMLButtonElement>("#batch-bar button").forEach((b) => (b.disabled = false));
                btn.textContent = original;
                if (failed) alert(es ? `${failed} no se pudieron aprobar` : `${failed} could not be approved`);
            }

            const allBtn = document.getElementById("approve-all") as HTMLButtonElement | null;
            allBtn?.addEventListener("click", () => {
                if (!window.confirm(es ? "¿Aprobar todo el trabajo pendiente?" : "Approve all pending work?")) return;
                batchApprove(allBtn, () => true);
            });

            const aiBtn = document.getElementById("approve-ai") as HTMLButtonElement | null;
            aiBtn?.addEventListener("click", () => {
                // Only task items expose an AI score; gigs are excluded.
                batchApprove(aiBtn, (li) => {
                    const s = parseFloat(li.dataset.aiScore || "");
                    return !isNaN(s) && s >= 0.7;
                });
            });
        });
    </script>
</PageLayout>
