---
import PageLayout from "@components/ui/PageLayout.astro";
import EmptyState from "@components/ui/EmptyState.astro";
import Button from "@components/ui/Button.astro";
import TaskCreateModal from "../../components/TaskCreateModal.astro";
import DifficultyChip from "../../components/DifficultyChip.astro";
import { apiFetch } from "../../lib/api";
import { t } from "../../lib/i18n";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

let successMsg = "";
let errorMsg = "";

// PRG (Post-Redirect-Get): every successful POST redirects back with
// ?ok=<action> so a browser refresh can never re-execute a delete/shuffle.
if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    const action = data.get("action");

    if (action === "delete") {
        const templateId = data.get("template_id");
        const { ok, error } = await apiFetch(`/api/task-templates/${templateId}`, {
            method: "DELETE",
            token,
        });
        if (ok) return Astro.redirect(Astro.url.pathname + "?ok=deleted");
        errorMsg = error || "Error";
    }

    if (action === "toggle") {
        const templateId = data.get("template_id");
        const { ok, error } = await apiFetch(`/api/task-templates/${templateId}/toggle`, {
            method: "PATCH",
            token,
        });
        if (ok) return Astro.redirect(Astro.url.pathname + "?ok=toggled");
        errorMsg = error || "Error";
    }

    if (action === "shuffle") {
        const { ok, data: shuffleResult, error } = await apiFetch<any>("/api/task-assignments/shuffle", {
            method: "POST",
            token,
            body: JSON.stringify({}),
        });
        if (ok && shuffleResult) {
            const params = new URLSearchParams({
                ok: "shuffle",
                created: String(shuffleResult.assignments_created ?? 0),
            });
            const skipped = (Array.isArray(shuffleResult.skipped_templates) ? shuffleResult.skipped_templates : [])
                .slice(0, 20)
                .map((s: any) => ({ t: s.title, r: s.reason }));
            if (skipped.length > 0) params.set("skipped", JSON.stringify(skipped));
            return Astro.redirect(`${Astro.url.pathname}?${params.toString()}`);
        }
        errorMsg = error || t(lang, "shuffle_error");
    }
}

// Flash messages from the PRG query params
const okParam = Astro.url.searchParams.get("ok");
const shuffleDone = okParam === "shuffle";
let shuffleSkipped: Array<{ t: string; r: string }> = [];
if (okParam === "deleted") {
    successMsg = t(lang, "pt_deleted") as string;
} else if (okParam === "toggled") {
    successMsg = t(lang, "pt_toggled") as string;
} else if (shuffleDone) {
    const created = parseInt(Astro.url.searchParams.get("created") ?? "0", 10) || 0;
    successMsg = (t(lang, "shuffle_success") as Function)(created);
    try {
        const raw = JSON.parse(Astro.url.searchParams.get("skipped") ?? "[]");
        if (Array.isArray(raw)) {
            shuffleSkipped = raw.filter((s: any) => s && typeof s.t === "string" && typeof s.r === "string");
        }
    } catch (_) { /* malformed param — ignore */ }
}

// Known backend skip reasons, localized (fallback: raw reason)
function skipReasonLabel(reason: string): string {
    if (lang !== "es") return reason;
    const map: Record<string, string> = {
        "fixed template has no valid members": "asignación fija sin miembros válidos",
        "no members match allowed_roles": "ningún miembro cumple los roles permitidos",
        "no eligible members for this gig": "sin miembros elegibles para este gig",
    };
    return map[reason] ?? reason;
}

const [{ data: templates }, { data: weekAssignments }, { data: familyMembers }] = await Promise.all([
    apiFetch<any[]>("/api/task-templates/", { token }),
    apiFetch<any[]>("/api/task-assignments/week", { token }),
    apiFetch<any[]>(`/api/families/${user.family_id}/members`, { token }),
]);
// Only show mandatory tasks (is_bonus=False) — gigs live in /parent/gigs
const templateList: any[] = (Array.isArray(templates) ? templates : []).filter((t: any) => !t.is_bonus);
const assignmentList: any[] = Array.isArray(weekAssignments) ? weekAssignments : [];
const memberList: any[] = Array.isArray(familyMembers) ? familyMembers : [];

// Post-shuffle inline summary: who got how many chores/points this week.
// Computed from the freshly-fetched week assignments (post-redirect = post-shuffle state).
type ShuffleMemberStat = { name: string; count: number; points: number };
let shuffleMemberStats: ShuffleMemberStat[] = [];
if (shuffleDone) {
    const byName: Record<string, ShuffleMemberStat> = {};
    for (const a of assignmentList) {
        const name = a.assigned_user_name || a.assigned_to;
        if (!byName[name]) byName[name] = { name, count: 0, points: 0 };
        byName[name].count += 1;
        byName[name].points += a.template_points ?? 0;
    }
    shuffleMemberStats = Object.values(byName);
}

// Group assignments by user
const assignmentsByUser: Record<string, any[]> = {};
for (const a of assignmentList) {
    const name = a.assigned_user_name || a.assigned_to;
    if (!assignmentsByUser[name]) assignmentsByUser[name] = [];
    assignmentsByUser[name].push(a);
}

function freqLabel(tmpl: any): string {
    if (tmpl.recurrence_mode === "since_completion") {
        const n = tmpl.recur_every_n_days ?? 1;
        return lang === "es" ? `c/${n}d al terminar` : `every ${n}d after done`;
    }
    const interval = tmpl.interval_days;
    if (interval === 1) return t(lang, "pt_daily") as string;
    if (interval === 7) return t(lang, "pt_weekly") as string;
    return (t(lang, "pt_every_n_days") as any)(interval);
}
---

<PageLayout
    title={t(lang, "pt_title") as string}
    tone="sky"
    backHref="/parent"
    backLabel={t(lang, "back_parent") as string}
    role={user.role}
    active="parent"
    lang={lang}
    mainClass="flex-1 px-4 py-6 space-y-6"
>
    <button
        slot="actions"
        id="tcm-trigger"
        data-tour="task-fab"
        class="press h-10 w-10 rounded-full bg-brand-sky-deep border-2 border-brand-ink shadow-[var(--shadow-card)] text-white flex items-center justify-center text-xl font-bold flex-shrink-0"
        aria-label={lang === "es" ? "Nueva tarea" : "New task"}
    >+</button>
    <p slot="header-extra" class="text-brand-ink-soft text-sm mt-1 font-sans">
        {t(lang, "pt_templates_in_family")(templateList.length)}
    </p>
            {successMsg && (
                <div class="p-3 bg-brand-mint/20 border border-brand-mint text-brand-mint-deep text-sm rounded-xl">
                    {successMsg}
                </div>
            )}
            {errorMsg && (
                <div class="p-3 bg-red-100 border border-red-200 text-red-700 text-sm rounded-xl">
                    {errorMsg}
                </div>
            )}

            <!-- Post-shuffle result: per-member counts + skipped templates -->
            {shuffleDone && shuffleMemberStats.length > 0 && (
                <section class="bg-brand-cream rounded-2xl p-4 shadow-[var(--shadow-card)] border border-brand-ink/10">
                    <h2 class="text-sm font-bold text-brand-ink mb-2">
                        {lang === "es" ? "Resultado del shuffle esta semana" : "This week's shuffle result"}
                    </h2>
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
                        {shuffleMemberStats.map((m) => (
                            <div class="bg-brand-cream-deep rounded-lg p-3 border border-brand-ink/10">
                                <p class="text-sm font-semibold text-brand-ink">{m.name}</p>
                                <p class="text-xs text-brand-ink-soft">
                                    {lang === "es"
                                        ? `${m.count} ${m.count === 1 ? "tarea" : "tareas"} · ${m.points} pts`
                                        : `${m.count} ${m.count === 1 ? "chore" : "chores"} · ${m.points} pts`}
                                </p>
                            </div>
                        ))}
                    </div>
                </section>
            )}
            {shuffleDone && shuffleSkipped.length > 0 && (
                <div class="p-3 bg-amber-50 border border-amber-300 text-amber-800 text-sm rounded-xl">
                    <p class="font-semibold mb-1">
                        ⚠️ {lang === "es" ? "No se pudieron programar:" : "Could not be scheduled:"}
                    </p>
                    <ul class="list-disc list-inside space-y-0.5">
                        {shuffleSkipped.map((s) => (
                            <li>
                                <span class="font-medium">{s.t}</span> — {skipReasonLabel(s.r)}
                            </li>
                        ))}
                    </ul>
                </div>
            )}

            <!-- Shuffle Section -->
            <section class="bg-brand-sun/20 rounded-[var(--radius-card)] p-5 shadow-[var(--shadow-card)] border-2 border-brand-ink">
                <div class="flex items-center justify-between mb-2">
                    <h2 class="font-bold text-brand-ink">{t(lang, "shuffle_title")}</h2>
                </div>
                <p class="text-xs text-brand-ink-soft mb-3">{t(lang, "shuffle_desc")}</p>
                <div class="flex gap-2">
                    <button
                        type="button"
                        id="btn-shuffle-preview"
                        data-t-loading={t(lang, "shuffle_preview_loading")}
                        data-t-error={t(lang, "shuffle_preview_error")}
                        data-t-empty={t(lang, "shuffle_preview_empty")}
                        data-t-carry={t(lang, "shuffle_preview_carry")}
                        data-t-total={t(lang, "shuffle_preview_total")}
                        data-t-skipped-intro={lang === "es" ? "No se pudieron programar:" : "Could not be scheduled:"}
                        data-t-reasons={JSON.stringify(lang === "es" ? {
                            "fixed template has no valid members": "asignación fija sin miembros válidos",
                            "no members match allowed_roles": "ningún miembro cumple los roles permitidos",
                            "no eligible members for this gig": "sin miembros elegibles para este gig",
                        } : {})}
                        class="press flex-1 py-2.5 bg-brand-cream border-2 border-brand-ink hover:bg-brand-sun/30 text-brand-ink font-extrabold text-sm rounded-full transition-colors shadow-[var(--shadow-card)] flex items-center justify-center gap-2"
                    >
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                        {t(lang, "shuffle_preview_btn")}
                    </button>
                    <form method="POST" class="flex-1">
                        <input type="hidden" name="action" value="shuffle" />
                        <Button
                            variant="sun"
                            size="sm"
                            type="submit"
                            class="w-full"
                            onclick={`return confirm('${t(lang, "shuffle_confirm")}')`}
                        >
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                            </svg>
                            {t(lang, "shuffle_btn")}
                        </Button>
                    </form>
                </div>
                {assignmentList.length > 0 && (
                    <p class="text-xs text-brand-sun-deep mt-2 text-center">
                        {t(lang, "shuffle_week_of")}: {assignmentList[0]?.week_of} | {(t(lang, "shuffle_assignment_count") as Function)(assignmentList.length)}
                    </p>
                )}
            </section>

            <!-- Template List -->
            <section>
                <h2 class="font-bold text-brand-ink mb-3 px-1">{t(lang, "pt_all_templates")}</h2>
                <div id="template-list-container" class="space-y-3">
                    {templateList.length === 0 ? (
                        <EmptyState
                            icon="📋"
                            title={lang === "es" ? "Ninguna tarea todavía" : "No tasks yet"}
                            subtitle={lang === "es" ? "Crea la primera para empezar" : "Create the first one to get started"}
                            ctaLabel={lang === "es" ? "+ Crear tarea" : "+ Create task"}
                            ctaId="tcm-trigger"
                        />
                    ) : (
                        templateList.map((tmpl: any) => (
                            <div class={`bg-brand-cream rounded-2xl p-4 shadow-[var(--shadow-card)] border ${tmpl.is_active ? "border-brand-ink/10" : "border-brand-ink/10 opacity-60"}`}>
                                <div class="flex items-start justify-between gap-3">
                                    <div class="flex-1">
                                        <div class="flex items-center gap-2 flex-wrap mb-1">
                                            <h3 class="font-bold text-brand-ink text-sm">
                                                {tmpl.title}
                                                {!tmpl.title_es && (
                                                    <span class="inline-block ml-2 text-[10px] font-normal px-1.5 py-0.5 rounded bg-orange-100 text-orange-700 border border-orange-200" title={t(lang, "translation_missing")}>
                                                        {lang === "es" ? "Falta ES" : "ES missing"}
                                                    </span>
                                                )}
                                            </h3>
                                            <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${
                                                tmpl.is_bonus
                                                    ? "bg-brand-sun/20 text-brand-sun-deep"
                                                    : "bg-brand-sky/15 text-brand-sky-deep"
                                            }`}>
                                                {tmpl.is_bonus ? t(lang, "pt_bonus") : t(lang, "pt_regular")}
                                            </span>
                                            <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-brand-cream-deep text-brand-ink-soft">
                                                {freqLabel(tmpl)}
                                            </span>
                                            {tmpl.requires_proof && (
                                                <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-brand-sky/15 text-brand-sky-deep" title={lang === "es" ? "Requiere foto de evidencia" : "Requires photo proof"}>
                                                    📸 {lang === "es" ? "Foto" : "Photo"}
                                                </span>
                                            )}
                                            {tmpl.assignment_type && tmpl.assignment_type !== 'auto' && (
                                                <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${
                                                    tmpl.assignment_type === 'fixed' 
                                                        ? 'bg-brand-coral/15 text-brand-coral-deep' 
                                                        : 'bg-brand-mint/20 text-brand-mint-deep'
                                                }`}>
                                                    {tmpl.assignment_type === 'fixed'
                                                        ? (lang === "es" ? '📌 Fijo' : '📌 Fixed')
                                                        : (lang === "es" ? '🔄 Rotación' : '🔄 Rotate')}
                                                </span>
                                            )}
                                            {!tmpl.is_active && (
                                                <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-red-100 text-red-600">
                                                    {t(lang, "pt_inactive")}
                                                </span>
                                            )}
                                        </div>
                                        {tmpl.description && (
                                            <p class="text-xs text-brand-ink-soft line-clamp-1">{tmpl.description}</p>
                                        )}
                                        <div class="mt-1">
                                            <DifficultyChip level={tmpl.effort_level ?? 1} lang={lang} />
                                        </div>
                                    </div>
                                    <div class="flex gap-1.5 flex-shrink-0">
                                        <!-- Toggle active -->
                                        <form method="POST">
                                            <input type="hidden" name="action" value="toggle" />
                                            <input type="hidden" name="template_id" value={tmpl.id} />
                                            <button
                                                type="submit"
                                                title={tmpl.is_active ? (t(lang, "pm_deactivate") as string) : (t(lang, "pm_activate") as string)}
                                                class={`h-8 w-8 rounded-lg flex items-center justify-center transition-colors ${
                                                    tmpl.is_active
                                                        ? "bg-brand-mint/20 text-brand-mint-deep hover:bg-brand-mint"
                                                        : "bg-brand-cream-deep text-brand-ink-soft hover:bg-brand-mint/20 hover:text-brand-mint-deep"
                                                }`}
                                            >
                                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={tmpl.is_active ? "M5 13l4 4L19 7" : "M12 4v16m8-8H4"} />
                                                </svg>
                                            </button>
                                        </form>
                                        <!-- Edit -->
                                        <a
                                            href={`/parent/tasks/${tmpl.id}/edit`}
                                            class="h-8 w-8 rounded-lg bg-brand-cream-deep hover:bg-brand-cream-deep text-brand-ink-soft hover:text-brand-sky-deep flex items-center justify-center transition-colors"
                                        >
                                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                            </svg>
                                        </a>
                                        <!-- Delete -->
                                        <form method="POST">
                                            <input type="hidden" name="action" value="delete" />
                                            <input type="hidden" name="template_id" value={tmpl.id} />
                                            <button
                                                type="submit"
                                                onclick={`return confirm('${t(lang, "pt_delete_confirm")}')`}
                                                class="h-8 w-8 rounded-lg bg-brand-cream-deep hover:bg-red-100 text-brand-ink-soft hover:text-red-500 flex items-center justify-center transition-colors"
                                            >
                                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                </svg>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        ))
                    )}
                </div>
            </section>

    <!-- Shuffle preview modal -->
    <div id="preview-modal" class="hidden fixed inset-0 z-[60] bg-slate-900/50 backdrop-blur-sm flex items-end md:items-center justify-center p-0 md:p-4">
        <div class="bg-brand-cream w-full md:max-w-2xl max-h-[90dvh] rounded-t-[var(--radius-card)] md:rounded-[var(--radius-card)] border-2 border-brand-ink shadow-[var(--shadow-pop)] flex flex-col pb-[env(safe-area-inset-bottom,0px)] md:pb-0">
            <div class="p-5 border-b border-brand-ink/10 flex items-start justify-between gap-3">
                <div>
                    <p class="text-xs font-medium text-brand-ink-soft uppercase tracking-wider">{t(lang, "shuffle_preview_title")}</p>
                    <p id="preview-week" class="text-lg font-bold text-brand-ink"></p>
                    <p class="text-xs text-brand-ink-soft mt-0.5">{t(lang, "shuffle_preview_hint")}</p>
                </div>
                <button type="button" id="preview-close" class="text-brand-ink-soft hover:text-brand-ink">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="flex-1 overflow-y-auto p-5 space-y-4">
                <div id="preview-status" class="text-sm text-brand-ink-soft text-center py-4 hidden"></div>
                <div id="preview-skipped" class="hidden p-3 bg-amber-50 border border-amber-300 text-amber-800 text-sm rounded-xl"></div>
                <div id="preview-totals" class="grid grid-cols-2 md:grid-cols-3 gap-2"></div>
                <div id="preview-plan" class="space-y-2"></div>
            </div>
            <div class="p-4 border-t border-brand-ink/10 flex items-center gap-2">
                <button type="button" id="preview-cancel" class="flex-1 py-2.5 bg-brand-cream-deep hover:bg-brand-cream text-brand-ink font-semibold text-sm rounded-lg transition-colors">
                    {t(lang, "shuffle_preview_close")}
                </button>
                <form method="POST" class="flex-1">
                    <input type="hidden" name="action" value="shuffle" />
                    <button type="submit" class="w-full py-2.5 bg-brand-sun-deep hover:bg-brand-ink hover:text-brand-cream text-brand-ink font-semibold text-sm rounded-lg transition-colors shadow-[var(--shadow-card)]">
                        {t(lang, "shuffle_preview_apply")}
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        import { buildMission } from "../../lib/tourSteps";
        import { runMission } from "../../lib/missionRunner";

        document.addEventListener('astro:page-load', () => {
        // Resume an in-progress mission (e.g. started from the parent
        // dashboard checklist) now that this page hosts its next target.
        const lang = document.documentElement.lang === "es" ? "es" : "en";
        for (const id of ["first-task", "first-gig"] as const) {
            if (sessionStorage.getItem("ftm_mission_" + id)) runMission(buildMission(id, lang), lang);
        }

        // Mission signal: the + FAB always opens TaskCreateModal (see TaskCreateModal.astro's
        // "tcm-trigger" click listener) — dispatch alongside that real action, additive only.
        const fabTrigger = document.getElementById("tcm-trigger");
        fabTrigger?.addEventListener("click", () => {
            window.dispatchEvent(new CustomEvent("ftm:mission", { detail: { signal: "task-modal-open" } }));
        });

        // Completion chain: first-task's last step ("task-created", fired by
        // TaskCreateModal above) completes here, so this is where
        // ftm:mission-complete for it actually fires. Arm first-gig and hop
        // to the page hosting its first target — same pattern as the
        // checklist launcher in parent/index.astro — so the resume block in
        // parent/gigs.astro picks it up. Always re-arms rather than tracking
        // a separate "already done" guard (simpler; harmless since replaying
        // first-task requires the checklist CTA, which hides itself once
        // onboarding.task_created is true).
        window.addEventListener("ftm:mission-complete", (e) => {
            const detail = (e as CustomEvent).detail;
            if (detail?.id !== "first-task") return;
            sessionStorage.setItem("ftm_mission_first-gig", "0");
            window.location.href = "/parent/gigs";
        });

        const previewBtn = document.getElementById("btn-shuffle-preview");
        const modal = document.getElementById("preview-modal");
        const closeBtn = document.getElementById("preview-close");
        const cancelBtn = document.getElementById("preview-cancel");
        const weekEl = document.getElementById("preview-week");
        const statusEl = document.getElementById("preview-status");
        const skippedEl = document.getElementById("preview-skipped");
        const totalsEl = document.getElementById("preview-totals");
        const planEl = document.getElementById("preview-plan");

        if (!previewBtn || !modal) return;

        const isEs = document.documentElement.lang === "es";

        let reasonMap: Record<string, string> = {};
        try { reasonMap = JSON.parse(previewBtn.dataset.tReasons ?? "{}"); } catch (_) { /* ignore */ }

        const t = {
            loading: previewBtn.dataset.tLoading ?? "Computing...",
            error: previewBtn.dataset.tError ?? "Error loading preview.",
            empty: previewBtn.dataset.tEmpty ?? "No assignments.",
            carry: previewBtn.dataset.tCarry ?? "carry",
            total: previewBtn.dataset.tTotal ?? "this week",
            skippedIntro: previewBtn.dataset.tSkippedIntro ?? "Could not be scheduled:",
        };

        const escapeHtml = (s: unknown) => String(s ?? "")
            .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");

        const close = () => modal.classList.add("hidden");
        closeBtn?.addEventListener("click", close);
        cancelBtn?.addEventListener("click", close);
        modal.addEventListener("click", (e) => { if (e.target === modal) close(); });

        previewBtn.addEventListener("click", async () => {
            modal.classList.remove("hidden");
            if (totalsEl) totalsEl.innerHTML = "";
            if (planEl) planEl.innerHTML = "";
            if (weekEl) weekEl.textContent = "";
            if (skippedEl) { skippedEl.innerHTML = ""; skippedEl.classList.add("hidden"); }
            if (statusEl) {
                statusEl.textContent = t.loading;
                statusEl.classList.remove("hidden", "text-red-600");
                statusEl.classList.add("text-brand-ink-soft");
            }

            try {
                const res = await fetch("/api/assignments/preview");
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                const data = await res.json();
                if (statusEl) statusEl.classList.add("hidden");
                if (weekEl) weekEl.textContent = data.week_of ?? "";

                // Skipped templates — amber warning, never silent
                const skipped = data.skipped_templates || [];
                if (skippedEl && skipped.length > 0) {
                    skippedEl.innerHTML = `
                        <p class="font-semibold mb-1">⚠️ ${escapeHtml(t.skippedIntro)}</p>
                        <ul class="list-disc list-inside space-y-0.5">
                            ${skipped.map((s: any) => `
                                <li><span class="font-medium">${escapeHtml(s.title)}</span> — ${escapeHtml(reasonMap[s.reason] ?? s.reason)}</li>`).join("")}
                        </ul>`;
                    skippedEl.classList.remove("hidden");
                }

                if (totalsEl) {
                    totalsEl.innerHTML = (data.totals_by_member || [])
                        .map((m: any) => `
                            <div class="bg-brand-cream-deep rounded-lg p-3 border border-brand-ink/10">
                                <p class="text-sm font-semibold text-brand-ink">${escapeHtml(m.user_name)}</p>
                                <p class="text-xs text-brand-ink-soft">${m.points_this_week} pts ${t.total} · ${m.points_carry} ${t.carry}</p>
                            </div>`)
                        .join("");
                }

                const items = data.assignments || [];
                if (planEl) {
                    if (items.length === 0) {
                        planEl.innerHTML = `<p class="text-sm text-brand-ink-soft text-center py-4">${t.empty}</p>`;
                    } else {
                        // Group by user
                        const byUser: Record<string, any[]> = {};
                        for (const a of items) {
                            const k = a.assigned_user_name || a.assigned_to;
                            if (!byUser[k]) byUser[k] = [];
                            byUser[k].push(a);
                        }
                        planEl.innerHTML = Object.entries(byUser).map(([name, list]) => `
                            <div class="bg-brand-cream border border-brand-ink/10 rounded-lg p-3">
                                <p class="text-sm font-bold text-brand-ink mb-2">${escapeHtml(name)}</p>
                                <ul class="space-y-1">
                                    ${list.map((a: any) => `
                                        <li class="flex justify-between text-xs">
                                            <span class="text-brand-ink truncate">${a.assigned_date} · ${escapeHtml((isEs && a.template_title_es) ? a.template_title_es : a.template_title)}${a.template_is_bonus ? " ⭐" : ""}</span>
                                            <span class="text-brand-sun-deep font-semibold ml-2 flex-shrink-0">+${a.template_points}</span>
                                        </li>`).join("")}
                                </ul>
                            </div>`).join("");
                    }
                }
            } catch (err) {
                console.error("preview error", err);
                if (statusEl) {
                    statusEl.textContent = t.error;
                    statusEl.classList.remove("text-brand-ink-soft");
                    statusEl.classList.add("text-red-600");
                }
            }
        });
        });
    </script>
    <TaskCreateModal lang={lang} token={token} memberList={memberList} />
</PageLayout>
