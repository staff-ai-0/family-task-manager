---
import PageLayout from "@components/ui/PageLayout.astro";
import { apiFetch } from "../../lib/api";
import { SITE_URL } from "../../lib/seo";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

let errorMsg = "";
let createdToken = "";

if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    const action = data.get("action");
    if (action === "create") {
        const name = String(data.get("name") || "").trim();
        if (name) {
            const { ok, error, data: dev } = await apiFetch<any>(
                "/api/kiosk/devices",
                { method: "POST", token, body: JSON.stringify({ name }) },
            );
            if (ok && dev) {
                createdToken = dev.token;
            } else {
                errorMsg = error || "Error";
            }
        }
    } else if (action === "delete") {
        const id = data.get("device_id");
        if (id) {
            await apiFetch(`/api/kiosk/devices/${id}`, {
                method: "DELETE",
                token,
            });
            return Astro.redirect("/parent/kiosk");
        }
    }
}

const [{ data: devicesRaw }, { data: prefsRaw }] = await Promise.all([
    apiFetch<any[]>("/api/kiosk/devices", { token }),
    apiFetch<any[]>("/api/kiosk/member-prefs", { token }),
]);
const devices: any[] = Array.isArray(devicesRaw) ? devicesRaw : [];
const memberPrefs: any[] = Array.isArray(prefsRaw) ? prefsRaw : [];

// Brand palette (docs/design-tokens.md) — names must match the backend's
// MEMBER_COLORS in app/services/member_prefs_service.py.
const PALETTE: { name: string; hex: string }[] = [
    { name: "sky", hex: "#4FB8E6" },
    { name: "coral", hex: "#FF8A65" },
    { name: "mint", hex: "#5DD4A8" },
    { name: "sun", hex: "#FFC857" },
    { name: "sky-deep", hex: "#2E9BCC" },
    { name: "coral-deep", hex: "#E96A45" },
    { name: "mint-deep", hex: "#3DB689" },
    { name: "sun-deep", hex: "#E5A91F" },
];

// The kiosk URL is opened on external wall devices (Echo Show, Fire TV, an old
// iPad), so it MUST be the public origin. Behind the Cloudflare tunnel
// Astro.url.origin resolves to http(s)://localhost — useless on a device — so
// prefer the canonical SITE_URL, falling back to the request origin only when
// it isn't localhost (e.g. a custom self-host).
const _origin = typeof Astro.url.origin === "string" ? Astro.url.origin : "";
const baseUrl =
    _origin && !/localhost|127\.0\.0\.1/.test(_origin) ? _origin : SITE_URL;

const labels = {
    title: lang === "es" ? "Pantallas de pared" : "Wall displays",
    subtitle:
        lang === "es"
            ? "Echo Show, iPad viejo, Fire TV, etc."
            : "Echo Show, old iPad, Fire TV, etc.",
    name_ph: lang === "es" ? "Nombre (Cocina, Sala…)" : "Name (Kitchen, Living…)",
    create: lang === "es" ? "Crear" : "Create",
    last_seen: lang === "es" ? "Visto:" : "Seen:",
    never: lang === "es" ? "Nunca" : "Never",
    revoke: lang === "es" ? "Revocar" : "Revoke",
    confirm: lang === "es" ? "¿Revocar este dispositivo?" : "Revoke this device?",
    url_label:
        lang === "es"
            ? "Abre esta URL en el dispositivo:"
            : "Open this URL on the device:",
    copy: lang === "es" ? "Copiar" : "Copy",
    save_token: lang === "es"
        ? "⚠️ Guarda esta URL ahora — no se vuelve a mostrar."
        : "⚠️ Save this URL now — it won't be shown again.",
    members_title: lang === "es" ? "Miembros en el kiosko" : "Members on the kiosk",
    members_hint:
        lang === "es"
            ? "Elige un color para cada quien y un PIN de 4 dígitos para que vean sus tareas y puntos en la pantalla."
            : "Pick a color for each member and a 4-digit PIN so they can open their own chores and points on the display.",
    pin_ph: lang === "es" ? "PIN (4 dígitos)" : "PIN (4 digits)",
    pin_save: lang === "es" ? "Guardar PIN" : "Save PIN",
    pin_remove: lang === "es" ? "Quitar PIN" : "Remove PIN",
    pin_set: lang === "es" ? "PIN configurado" : "PIN set",
    pin_unset: lang === "es" ? "Sin PIN" : "No PIN",
    saved: lang === "es" ? "Guardado ✓" : "Saved ✓",
    save_error: lang === "es" ? "Error al guardar" : "Save failed",
    pin_invalid: lang === "es" ? "El PIN debe tener 4 dígitos" : "PIN must be 4 digits",
};

function timeAgo(iso: string | null): string {
    if (!iso) return labels.never;
    const ms = Date.now() - new Date(iso).getTime();
    const mins = Math.floor(ms / 60000);
    if (mins < 1) return lang === "es" ? "ahora" : "now";
    if (mins < 60) return `${mins}m`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `${hrs}h`;
    return `${Math.floor(hrs / 24)}d`;
}
---

<PageLayout
    title={`📺 ${labels.title}`}
    headerClass="bg-gradient-to-br from-slate-700 to-slate-900"
    dark
    role={user.role}
    active="parent"
    lang={lang}
    mainClass="flex-1 px-4 py-6 space-y-4"
    containerClass="w-full max-w-md md:max-w-4xl mx-auto bg-brand-cream-deep"
>
    <p slot="header-extra" class="text-slate-300 text-sm mt-1">{labels.subtitle}</p>
            {errorMsg && (
                <div class="p-3 bg-red-100 border border-red-200 text-red-700 text-sm rounded-xl">
                    {errorMsg}
                </div>
            )}

            {createdToken && (
                <div class="p-4 bg-brand-mint/15 border-2 border-brand-mint-deep rounded-xl space-y-2">
                    <p class="text-sm font-bold text-brand-mint-deep">
                        {labels.save_token}
                    </p>
                    <p class="text-xs text-brand-ink">{labels.url_label}</p>
                    <code class="block bg-brand-cream p-2 rounded text-xs break-all">
                        {baseUrl}/kiosk?token={createdToken}
                    </code>
                </div>
            )}

            <form method="POST" class="bg-brand-cream rounded-2xl p-3 border border-brand-ink/10 shadow-[var(--shadow-card)] flex gap-2">
                <input type="hidden" name="action" value="create" />
                <input
                    type="text"
                    name="name"
                    required
                    maxlength="120"
                    placeholder={labels.name_ph}
                    class="flex-1 px-3 py-2 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none"
                />
                <button
                    type="submit"
                    class="px-4 py-2 rounded-lg bg-brand-ink text-brand-cream text-sm font-semibold hover:bg-brand-ink-soft active:scale-95"
                >
                    {labels.create}
                </button>
            </form>

            <section class="bg-brand-cream rounded-2xl p-4 border border-brand-ink/10 shadow-[var(--shadow-card)] space-y-4">
                <div>
                    <h2 class="font-bold text-brand-ink text-sm">🎨 {labels.members_title}</h2>
                    <p class="text-xs text-brand-ink-soft mt-1">{labels.members_hint}</p>
                </div>
                {memberPrefs.map((m: any) => (
                    <div class="border-t border-brand-ink/10 pt-3" data-member-row={m.user_id}>
                        <div class="flex items-center gap-3 mb-2">
                            <span
                                data-member-avatar
                                class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold text-brand-ink flex-shrink-0"
                                style={`background-color: ${m.color_hex};`}
                            >
                                {m.name.charAt(0).toUpperCase()}
                            </span>
                            <div class="flex-1 min-w-0">
                                <p class="font-semibold text-brand-ink text-sm truncate">{m.name}</p>
                                <p data-pin-state class="text-[11px] text-brand-ink-soft">
                                    {m.has_pin ? `🔒 ${labels.pin_set}` : labels.pin_unset}
                                </p>
                            </div>
                            <span data-save-status class="text-[11px] font-semibold text-brand-mint-deep"></span>
                        </div>
                        <div class="flex flex-wrap items-center gap-1.5 mb-2">
                            {PALETTE.map((c) => (
                                <button
                                    type="button"
                                    data-color-swatch
                                    data-user-id={m.user_id}
                                    data-color-name={c.name}
                                    data-color-hex={c.hex}
                                    aria-label={c.name}
                                    class={`w-7 h-7 rounded-full border-2 transition-transform hover:scale-110 ${m.color === c.name ? "border-brand-ink ring-2 ring-brand-ink/30" : "border-brand-ink/15"}`}
                                    style={`background-color: ${c.hex};`}
                                ></button>
                            ))}
                        </div>
                        <div class="flex gap-2 items-center">
                            <input
                                type="password"
                                inputmode="numeric"
                                pattern="[0-9]*"
                                maxlength="4"
                                autocomplete="off"
                                data-pin-input
                                data-user-id={m.user_id}
                                placeholder={labels.pin_ph}
                                class="w-32 px-2.5 py-1.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none"
                            />
                            <button
                                type="button"
                                data-pin-save
                                data-user-id={m.user_id}
                                class="px-3 py-1.5 rounded-lg bg-brand-ink text-brand-cream text-xs font-semibold hover:bg-brand-ink-soft active:scale-95"
                            >
                                {labels.pin_save}
                            </button>
                            <button
                                type="button"
                                data-pin-remove
                                data-user-id={m.user_id}
                                class={`px-3 py-1.5 rounded-lg text-xs font-semibold bg-red-100 text-red-700 hover:bg-red-200 ${m.has_pin ? "" : "hidden"}`}
                            >
                                {labels.pin_remove}
                            </button>
                        </div>
                    </div>
                ))}
            </section>

            <ul class="space-y-2">
                {devices.map((d: any) => (
                    <li class="bg-brand-cream rounded-2xl p-4 border border-brand-ink/10 shadow-[var(--shadow-card)] flex items-start justify-between gap-3">
                        <div class="flex-1 min-w-0">
                            <p class="font-semibold text-brand-ink text-sm">📺 {d.name}</p>
                            <p class="text-xs text-brand-ink-soft mt-1">
                                {labels.last_seen} {timeAgo(d.last_seen)}
                            </p>
                            <code class="block mt-2 text-[10px] text-brand-ink-soft truncate" title={d.token}>
                                {baseUrl}/kiosk?token={d.token.slice(0, 12)}…
                            </code>
                        </div>
                        <form method="POST" onsubmit={`return confirm('${labels.confirm}')`}>
                            <input type="hidden" name="action" value="delete" />
                            <input type="hidden" name="device_id" value={d.id} />
                            <button
                                type="submit"
                                class="px-2.5 py-1.5 rounded-lg text-xs font-semibold bg-red-100 text-red-700 hover:bg-red-200"
                            >
                                {labels.revoke}
                            </button>
                        </form>
                    </li>
                ))}
            </ul>

    <script define:vars={{ jsLabels: { saved: labels.saved, save_error: labels.save_error, pin_invalid: labels.pin_invalid, pin_set: labels.pin_set, pin_unset: labels.pin_unset } }}>
        document.addEventListener("astro:page-load", () => {
            async function updatePrefs(userId, body) {
                const res = await fetch(`/api/kiosk/member-prefs/${userId}`, {
                    method: "PUT",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify(body),
                });
                if (!res.ok) throw new Error(String(res.status));
                return res.json();
            }

            function flash(row, text, isError) {
                const el = row?.querySelector("[data-save-status]");
                if (!el) return;
                el.textContent = text;
                el.classList.toggle("text-red-600", !!isError);
                el.classList.toggle("text-brand-mint-deep", !isError);
                setTimeout(() => { el.textContent = ""; }, 2500);
            }

            // Color swatches
            document.querySelectorAll("[data-color-swatch]").forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const userId = btn.dataset.userId;
                    const row = document.querySelector(`[data-member-row="${userId}"]`);
                    try {
                        const out = await updatePrefs(userId, { color: btn.dataset.colorName });
                        row?.querySelectorAll("[data-color-swatch]").forEach((b) => {
                            b.classList.remove("border-brand-ink", "ring-2", "ring-brand-ink/30");
                            b.classList.add("border-brand-ink/15");
                        });
                        btn.classList.remove("border-brand-ink/15");
                        btn.classList.add("border-brand-ink", "ring-2", "ring-brand-ink/30");
                        const avatar = row?.querySelector("[data-member-avatar]");
                        if (avatar) avatar.style.backgroundColor = out.color_hex || btn.dataset.colorHex;
                        flash(row, jsLabels.saved, false);
                    } catch {
                        flash(row, jsLabels.save_error, true);
                    }
                });
            });

            // Save PIN
            document.querySelectorAll("[data-pin-save]").forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const userId = btn.dataset.userId;
                    const row = document.querySelector(`[data-member-row="${userId}"]`);
                    const input = row?.querySelector("[data-pin-input]");
                    const pin = (input?.value || "").trim();
                    if (!/^\d{4}$/.test(pin)) {
                        flash(row, jsLabels.pin_invalid, true);
                        return;
                    }
                    try {
                        await updatePrefs(userId, { pin });
                        if (input) input.value = "";
                        const state = row?.querySelector("[data-pin-state]");
                        if (state) state.textContent = `🔒 ${jsLabels.pin_set}`;
                        row?.querySelector("[data-pin-remove]")?.classList.remove("hidden");
                        flash(row, jsLabels.saved, false);
                    } catch {
                        flash(row, jsLabels.save_error, true);
                    }
                });
            });

            // Remove PIN
            document.querySelectorAll("[data-pin-remove]").forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const userId = btn.dataset.userId;
                    const row = document.querySelector(`[data-member-row="${userId}"]`);
                    try {
                        await updatePrefs(userId, { pin: "" });
                        const state = row?.querySelector("[data-pin-state]");
                        if (state) state.textContent = jsLabels.pin_unset;
                        btn.classList.add("hidden");
                        flash(row, jsLabels.saved, false);
                    } catch {
                        flash(row, jsLabels.save_error, true);
                    }
                });
            });
        });
    </script>
</PageLayout>
