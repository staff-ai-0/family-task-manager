---
import PageLayout from "@components/ui/PageLayout.astro";
import { apiFetch } from "../../../lib/api";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";
const es = lang === "es";

const { data: user, ok: userOk } = await apiFetch<any>("/api/auth/me", { token });
if (!userOk) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

const { data: rowsRaw } = await apiFetch<any[]>("/api/bank/envelopes/family", { token });
const kids: any[] = Array.isArray(rowsRaw) ? rowsRaw : [];

const fmt = (cents: number) => `$${(cents / 100).toFixed(2)}`;

const META: Record<string, { emoji: string; label: string; accent: string; bg: string; bar: string }> = {
    spend: { emoji: "🛍️", label: es ? "Gastar" : "Spend", accent: "text-brand-coral-deep", bg: "bg-brand-coral/15", bar: "bg-brand-coral" },
    save: { emoji: "🐷", label: es ? "Ahorrar" : "Save", accent: "text-brand-mint-deep", bg: "bg-brand-mint/20", bar: "bg-brand-mint-deep" },
    share: { emoji: "💝", label: es ? "Compartir" : "Share", accent: "text-brand-sun-deep", bg: "bg-brand-sun/25", bar: "bg-brand-sun-deep" },
};
const ORDER = ["spend", "save", "share"];
const byKey = (row: any): Record<string, any> => {
    const m: Record<string, any> = {};
    (row.envelopes ?? []).forEach((e: any) => { m[e.key] = e; });
    return m;
};
---

<PageLayout
    title={es ? "Sobres de mis hijos" : "Kids' envelopes"}
    headerClass="bg-gradient-to-br from-brand-mint-deep to-brand-mint"
    dark
    backClass="text-white/80 hover:text-white"
    backHref="/parent/settings"
    backLabel={es ? "Volver" : "Back"}
    role={user.role}
    active="parent"
    lang={lang}
>
    <p class="text-sm text-brand-ink-soft px-1 mb-5">
        {es
            ? "Cada hijo tiene sus propios sobres (Gastar / Ahorrar / Compartir), llenados con el dinero que gana en chambas y gigs. Para configurar mesada, interés o match, ve al Banco Familiar."
            : "Each kid has their own envelopes (Spend / Save / Share), filled with the money they earn from chores and gigs. To set allowance, interest or match, go to the Family Bank."}
    </p>

    {kids.length === 0 ? (
        <div class="bg-brand-cream rounded-2xl p-8 text-center border border-brand-ink/10 shadow-[var(--shadow-card)]">
            <div class="text-4xl mb-3">✉️</div>
            <h3 class="font-bold text-brand-ink mb-1">{es ? "Aún no hay hijos en la familia" : "No kids in the family yet"}</h3>
            <p class="text-brand-ink-soft text-sm mb-4">
                {es ? "Invita a tus hijos para darles sus sobres." : "Invite your kids to give them their envelopes."}
            </p>
            <a href="/parent/members#invite" class="inline-block bg-brand-mint-deep text-white px-5 py-2 rounded-xl font-semibold text-sm shadow-[var(--shadow-card)]">
                {es ? "Invitar a un hijo" : "Invite a kid"}
            </a>
        </div>
    ) : (
        <div class="space-y-6">
            {kids.map((row: any) => {
                const envs = byKey(row);
                const total = row.total_cents ?? 0;
                const goal = envs.save?.goal;
                return (
                    <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink shadow-[var(--shadow-card)] overflow-hidden">
                        <div class="bg-brand-cream-deep px-5 py-4 border-b-2 border-brand-ink flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-brand-mint-deep text-white flex items-center justify-center font-bold">
                                    {(row.name ?? "?").charAt(0).toUpperCase()}
                                </div>
                                <div>
                                    <p class="font-bold text-brand-ink">{row.name}</p>
                                    <p class="text-xs text-brand-ink-soft">{es ? "Total: " : "Total: "}{fmt(total)}</p>
                                </div>
                            </div>
                        </div>

                        <div class="p-5 space-y-3">
                            {ORDER.filter((k) => envs[k]).map((k) => {
                                const env = envs[k];
                                const m = META[k];
                                return (
                                    <div class={`${m.bg} rounded-xl px-4 py-3`}>
                                        <div class="flex items-center justify-between mb-1.5">
                                            <p class={`text-sm font-bold ${m.accent}`}>{m.emoji} {m.label}</p>
                                            <p class="font-extrabold text-brand-ink text-sm">
                                                {fmt(env.balance_cents)}
                                                <span class="text-xs font-semibold text-brand-ink-soft ml-1">· {env.pct_of_total}%</span>
                                            </p>
                                        </div>
                                        <div class="flex h-2 rounded-full overflow-hidden bg-white/60 border border-brand-ink/10">
                                            <div class={`${m.bar} h-full`} style={`width:${env.pct_of_total}%`}></div>
                                        </div>
                                    </div>
                                );
                            })}

                            {goal && (
                                <div class="bg-white/70 border border-brand-ink/10 rounded-xl px-4 py-3">
                                    <div class="flex items-center justify-between mb-1">
                                        <p class="text-sm font-bold text-brand-ink">🎯 {goal.emoji || ""} {goal.name}</p>
                                        {goal.pending_approval && (
                                            <span class="text-xs bg-brand-sun/25 text-brand-sun-deep font-semibold rounded-lg px-2 py-0.5">
                                                ⏳ {es ? "pendiente" : "pending"}
                                            </span>
                                        )}
                                    </div>
                                    <div class="flex h-2.5 rounded-full overflow-hidden bg-brand-cream-deep border border-brand-ink/10 mb-1">
                                        <div class="bg-brand-mint-deep h-full" style={`width:${goal.progress_pct}%`}></div>
                                    </div>
                                    <p class="text-xs text-brand-ink-soft">
                                        {fmt(goal.saved_cents)} / {fmt(goal.target_cents)} ·{" "}
                                        {goal.reached
                                            ? (es ? "¡lograda! 🎉" : "reached! 🎉")
                                            : (es ? `faltan ${fmt(goal.remaining_cents)}` : `${fmt(goal.remaining_cents)} to go`)}
                                    </p>
                                </div>
                            )}
                        </div>

                        <div class="px-5 pb-5">
                            <a href="/parent/settings/family-bank"
                               class="inline-flex items-center gap-2 text-sm font-semibold text-brand-mint-deep hover:text-brand-ink transition-colors">
                                🏦 {es ? "Configurar en el Banco Familiar" : "Configure in the Family Bank"}
                            </a>
                        </div>
                    </div>
                );
            })}
        </div>
    )}
</PageLayout>
