---
import PageLayout from "@components/ui/PageLayout.astro";
import { apiFetch } from "../../../lib/api";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

// Fetch subscription data in parallel
const [plansRes, currentRes, usageRes] = await Promise.all([
    apiFetch<any[]>("/api/subscriptions/plans", { token }),
    apiFetch<any>("/api/subscriptions/current", { token }),
    apiFetch<any>("/api/subscriptions/usage", { token }),
]);

const plans = plansRes.data ?? [];
const current = currentRes.data;
const usage = usageRes.data;

const currentPlanName = (current?.plan?.name ?? current?.plan_name ?? "free").toLowerCase();
const isActive = current?.status === "active";
const isCancelled = current?.status === "cancelled";
const isPaid = currentPlanName !== "free";
const cancelAtPeriodEnd = Boolean(current?.cancel_at_period_end);
const periodEndIso = current?.current_period_end ?? null;
const periodEndLabel = periodEndIso
    ? new Date(periodEndIso).toLocaleDateString(lang === "es" ? "es-MX" : "en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
    })
    : "";

const i18n = {
    en: {
        title: "Subscription",
        back: "Settings",
        current_plan: "Current Plan",
        active: "Active",
        cancelled: "Cancelled",
        cancel_scheduled: "Cancellation scheduled",
        access_until: "You keep your current plan benefits until",
        usage_title: "Current Usage",
        of: "of",
        unlimited: "Unlimited",
        this_month: "this month",
        plan_comparison: "Plan Comparison",
        feature: "Feature",
        free: "Free",
        plus: "Plus",
        pro: "Pro",
        month: "/mo",
        year: "/yr",
        upgrade: "Upgrade",
        coming_soon: "Coming soon — PayPal integration pending",
        cancel: "Cancel Subscription",
        cancel_confirm: "Are you sure you want to cancel your subscription?",
        support_prompt: "Questions about your plan or billing? Email us at",
        features: {
            tasks_rewards: "Tasks & Rewards",
            family_members: "Family Members",
            budget_accounts: "Budget Accounts",
            transactions_month: "Transactions / month",
            reports_goals: "Reports & Goals",
            recurring_transactions: "Recurring Transactions",
            csv_import: "CSV Import",
            ai_receipt_scan: "AI Receipt Scanning",
            future_ai: "Future AI Features",
        },
    },
    es: {
        title: "Suscripci\u00f3n",
        back: "Configuraci\u00f3n",
        current_plan: "Plan Actual",
        active: "Activo",
        cancelled: "Cancelado",
        cancel_scheduled: "Cancelación programada",
        access_until: "Conservas los beneficios del plan actual hasta",
        usage_title: "Uso Actual",
        of: "de",
        unlimited: "Ilimitado",
        this_month: "este mes",
        plan_comparison: "Comparaci\u00f3n de Planes",
        feature: "Caracter\u00edstica",
        free: "Gratis",
        plus: "Plus",
        pro: "Pro",
        month: "/mes",
        year: "/a\u00f1o",
        upgrade: "Mejorar Plan",
        coming_soon: "Pr\u00f3ximamente \u2014 integraci\u00f3n con PayPal pendiente",
        cancel: "Cancelar Suscripci\u00f3n",
        cancel_confirm: "\u00bfEst\u00e1s seguro de que quieres cancelar tu suscripci\u00f3n?",
        support_prompt: "\u00bfDudas sobre tu plan o facturaci\u00f3n? Escr\u00edbenos a",
        features: {
            tasks_rewards: "Tareas y Recompensas",
            family_members: "Miembros de Familia",
            budget_accounts: "Cuentas de Presupuesto",
            transactions_month: "Transacciones / mes",
            reports_goals: "Reportes y Metas",
            recurring_transactions: "Transacciones Recurrentes",
            csv_import: "Importar CSV",
            ai_receipt_scan: "Escaneo de Recibos con IA",
            future_ai: "Futuras Funciones IA",
        },
    },
};

const l = i18n[lang] ?? i18n.en;

// Feature comparison table data
const featureRows = [
    { label: l.features.tasks_rewards, free: { en: "Full", es: "Completo" }[lang], plus: { en: "Full", es: "Completo" }[lang], pro: { en: "Full", es: "Completo" }[lang] },
    { label: l.features.family_members, free: "4", plus: "8", pro: l.unlimited },
    { label: l.features.budget_accounts, free: "2", plus: "5", pro: l.unlimited },
    { label: l.features.transactions_month, free: "30", plus: "200", pro: l.unlimited },
    { label: l.features.reports_goals, free: null, plus: true, pro: true },
    { label: l.features.recurring_transactions, free: null, plus: "5", pro: l.unlimited },
    { label: l.features.csv_import, free: null, plus: true, pro: true },
    { label: l.features.ai_receipt_scan, free: null, plus: `15/${lang === "es" ? "mes" : "mo"}`, pro: l.unlimited },
    { label: l.features.future_ai, free: null, plus: { en: "Limited", es: "Limitado" }[lang], pro: { en: "Full", es: "Completo" }[lang] },
];

// Usage meters
const usageMeters: Array<{ label: string; current: number; limit: number | null }> = [];
if (usage) {
    if (usage.family_members !== undefined) {
        usageMeters.push({
            label: l.features.family_members,
            current: usage.family_members?.current ?? 0,
            limit: usage.family_members?.limit,
        });
    }
    if (usage.budget_accounts !== undefined) {
        usageMeters.push({
            label: l.features.budget_accounts,
            current: usage.budget_accounts?.current ?? 0,
            limit: usage.budget_accounts?.limit,
        });
    }
    if (usage.monthly_transactions !== undefined) {
        usageMeters.push({
            label: l.features.transactions_month,
            current: usage.monthly_transactions?.current ?? 0,
            limit: usage.monthly_transactions?.limit,
        });
    }
    if (usage.recurring_transactions !== undefined) {
        usageMeters.push({
            label: l.features.recurring_transactions,
            current: usage.recurring_transactions?.current ?? 0,
            limit: usage.recurring_transactions?.limit,
        });
    }
}

function renderCell(value: any): string {
    if (value === true) return "\u2713";
    if (value === null || value === false) return "\u2717";
    return String(value);
}

function cellClass(value: any): string {
    if (value === true) return "text-brand-mint-deep font-bold";
    if (value === null || value === false) return "text-brand-ink-soft";
    return "text-brand-ink font-medium";
}
---

<PageLayout
    title={l.title}
    headerClass="bg-gradient-to-br from-amber-600 to-orange-600"
    dark
    backClass="text-amber-200 hover:text-white"
    backHref="/parent/settings"
    backLabel={l.back}
    role={user.role}
    active="parent"
    lang={lang}
    mainClass="flex-1 px-4 py-6 space-y-6"
>
            <!-- Current Plan -->
            <section class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-brand-ink-soft">{l.current_plan}</p>
                        <h2 class="text-xl font-bold text-brand-ink capitalize">{currentPlanName}</h2>
                    </div>
                    {isActive && !cancelAtPeriodEnd && (
                        <span class="px-3 py-1 text-xs font-semibold rounded-full bg-brand-mint/20 text-brand-mint-deep border border-brand-mint">
                            {l.active}
                        </span>
                    )}
                    {isActive && cancelAtPeriodEnd && (
                        <span class="px-3 py-1 text-xs font-semibold rounded-full bg-brand-sun/20 text-brand-sun-deep border border-brand-sun">
                            {l.cancel_scheduled}
                        </span>
                    )}
                    {isCancelled && (
                        <span class="px-3 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-700 border border-red-200">
                            {l.cancelled}
                        </span>
                    )}
                </div>
                {cancelAtPeriodEnd && periodEndLabel && (
                    <p class="mt-3 text-sm text-brand-sun-deep bg-brand-sun/20 border border-brand-sun rounded-lg p-3">
                        {l.access_until} <strong>{periodEndLabel}</strong>.
                    </p>
                )}
            </section>

            <!-- Usage Meters -->
            {usageMeters.length > 0 && (
                <section class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10">
                    <h2 class="text-lg font-bold text-brand-ink mb-4">{l.usage_title}</h2>
                    <div class="space-y-4">
                        {usageMeters.map((meter) => {
                            const isUnlimited = meter.limit === null || meter.limit === -1;
                            const pct = isUnlimited ? 0 : Math.min(100, Math.round((meter.current / meter.limit!) * 100));
                            const barColor = pct >= 90 ? "bg-red-500" : pct >= 70 ? "bg-brand-sun-deep" : "bg-brand-sky-deep";
                            return (
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="text-brand-ink-soft">{meter.label}</span>
                                        <span class="font-medium text-brand-ink">
                                            {meter.current} {l.of} {isUnlimited ? l.unlimited : meter.limit}
                                            {" "}<span class="text-brand-ink-soft text-xs">{l.this_month}</span>
                                        </span>
                                    </div>
                                    <div class="w-full bg-brand-cream-deep rounded-full h-2.5">
                                        <div
                                            class={`h-2.5 rounded-full transition-all ${barColor}`}
                                            style={`width: ${isUnlimited ? 5 : pct}%`}
                                        />
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                </section>
            )}

            <!-- Plan Comparison Table -->
            <section class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 overflow-x-auto">
                <h2 class="text-lg font-bold text-brand-ink mb-4">{l.plan_comparison}</h2>
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-brand-ink/10">
                            <th class="text-left py-3 px-2 text-brand-ink-soft font-medium">{l.feature}</th>
                            <th class={`text-center py-3 px-2 ${currentPlanName === "free" ? "bg-brand-sky/15 rounded-t-xl" : ""}`}>
                                <div class="font-bold text-brand-ink">{l.free}</div>
                                <div class="text-xs text-brand-ink-soft">{l.free}</div>
                                {currentPlanName === "free" && (
                                    <span class="inline-block mt-1 px-2 py-0.5 text-[10px] font-semibold rounded-full bg-brand-sky/15 text-brand-sky-deep">
                                        {l.current_plan}
                                    </span>
                                )}
                            </th>
                            <th class={`text-center py-3 px-2 ${currentPlanName === "plus" ? "bg-brand-sky/15 rounded-t-xl" : ""}`}>
                                <div class="font-bold text-brand-ink">{l.plus}</div>
                                <div class="text-xs text-brand-ink-soft">$5{l.month} ($50{l.year})</div>
                                {currentPlanName === "plus" && (
                                    <span class="inline-block mt-1 px-2 py-0.5 text-[10px] font-semibold rounded-full bg-brand-sky/15 text-brand-sky-deep">
                                        {l.current_plan}
                                    </span>
                                )}
                            </th>
                            <th class={`text-center py-3 px-2 ${currentPlanName === "pro" ? "bg-brand-sky/15 rounded-t-xl" : ""}`}>
                                <div class="font-bold text-brand-ink">{l.pro}</div>
                                <div class="text-xs text-brand-ink-soft">$15{l.month} ($150{l.year})</div>
                                {currentPlanName === "pro" && (
                                    <span class="inline-block mt-1 px-2 py-0.5 text-[10px] font-semibold rounded-full bg-brand-sky/15 text-brand-sky-deep">
                                        {l.current_plan}
                                    </span>
                                )}
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        {featureRows.map((row, i) => (
                            <tr class={`border-b border-brand-ink/10 ${i % 2 === 0 ? "bg-brand-cream-deep/50" : ""}`}>
                                <td class="py-3 px-2 text-brand-ink">{row.label}</td>
                                <td class={`py-3 px-2 text-center ${cellClass(row.free)} ${currentPlanName === "free" ? "bg-brand-sky/15/50" : ""}`}>
                                    {renderCell(row.free)}
                                </td>
                                <td class={`py-3 px-2 text-center ${cellClass(row.plus)} ${currentPlanName === "plus" ? "bg-brand-sky/15/50" : ""}`}>
                                    {renderCell(row.plus)}
                                </td>
                                <td class={`py-3 px-2 text-center ${cellClass(row.pro)} ${currentPlanName === "pro" ? "bg-brand-sky/15/50" : ""}`}>
                                    {renderCell(row.pro)}
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>

                <!-- Upgrade / Cancel Buttons -->
                <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
                    {currentPlanName === "free" && (
                        <button
                            class="upgrade-btn px-6 py-2.5 bg-brand-sky-deep text-white text-sm font-semibold rounded-lg hover:bg-brand-sky-deep transition-colors"
                            data-plan="plus"
                            data-cycle="monthly"
                        >
                            {l.upgrade} → {l.plus}
                        </button>
                    )}
                    {currentPlanName !== "pro" && (
                        <button
                            class="upgrade-btn px-6 py-2.5 bg-brand-coral-deep text-white text-sm font-semibold rounded-lg hover:bg-brand-coral-deep transition-colors"
                            data-plan="pro"
                            data-cycle="monthly"
                        >
                            {l.upgrade} → {l.pro}
                        </button>
                    )}
                    {isPaid && isActive && !cancelAtPeriodEnd && (
                        <button
                            id="cancel-sub-btn"
                            class="px-6 py-2.5 bg-brand-cream border border-red-200 text-red-600 text-sm font-semibold rounded-lg hover:bg-red-100 transition-colors"
                        >
                            {l.cancel}
                        </button>
                    )}
                </div>
            </section>

            <!-- Support contact -->
            <p class="mt-6 text-center text-sm text-brand-ink-soft font-sans">
                {l.support_prompt}
                <a href="mailto:soporte@agent-ia.mx" class="font-semibold underline hover:text-brand-coral-deep">soporte@agent-ia.mx</a>
            </p>
</PageLayout>

<script define:vars={{ cancelConfirm: l.cancel_confirm }}>
    document.addEventListener('astro:page-load', () => {
        const cancelBtn = document.getElementById('cancel-sub-btn');
        if (cancelBtn) {
            cancelBtn.addEventListener('click', async () => {
                if (!confirm(cancelConfirm)) return;
                try {
                    const res = await fetch('/api/subscriptions/cancel', { method: 'POST' });
                    if (res.ok) {
                        window.location.reload();
                    }
                } catch {
                    // silently fail
                }
            });
        }

        document.querySelectorAll('.upgrade-btn').forEach((btn) => {
            btn.addEventListener('click', async (evt) => {
                const target = evt.currentTarget;
                const plan = target.dataset.plan;
                const cycle = target.dataset.cycle || 'monthly';
                const originalText = target.textContent;
                target.disabled = true;
                target.textContent = '...';
                try {
                    const resp = await fetch('/api/subscriptions/checkout', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ plan_name: plan, billing_cycle: cycle }),
                    });
                    if (!resp.ok) {
                        const err = await resp.json().catch(() => ({ detail: 'Error' }));
                        alert('Upgrade failed: ' + (err.detail || resp.statusText));
                        target.disabled = false;
                        target.textContent = originalText;
                        return;
                    }
                    const data = await resp.json();
                    window.location.href = data.approval_url;
                } catch (e) {
                    alert('Network error: ' + e);
                    target.disabled = false;
                    target.textContent = originalText;
                }
            });
        });
    });
</script>
