---
import PageLayout from "@components/ui/PageLayout.astro";
import InvitationModal from "../../components/InvitationModal.astro";
import EditMemberModal from "../../components/EditMemberModal.astro";
import { apiFetch } from "../../lib/api";
import { t } from "../../lib/i18n";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "en") as "en" | "es";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
  Astro.cookies.delete("access_token", { path: "/" });
  return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

let successMsg = "";
let errorMsg = "";

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const action = data.get("action");

  if (action === "toggle_active") {
    const memberId = data.get("member_id");
    const isActive = data.get("is_active") === "true";
    const endpoint = isActive ? "deactivate" : "activate";
    const { ok, error } = await apiFetch(`/api/users/${memberId}/${endpoint}`, {
      method: "PUT",
      token,
    });
    if (!ok) errorMsg = error || "Error";
  }
  if (action === "delete") {
    const memberId = data.get("member_id");
    const { ok, error } = await apiFetch(`/api/users/${memberId}`, {
      method: "DELETE",
      token,
    });
    if (ok) {
      successMsg = t(lang, "pm_deleted");
    } else {
      errorMsg = error || "Error";
    }
  }
  if (action === "adjust_points") {
    const memberId = data.get("member_id");
    const points = Number(data.get("points"));
    const reason = data.get("reason")?.toString();
    
    // Validate required fields
    if (!reason || reason.trim() === "") {
      errorMsg = "Reason is required for point adjustment";
    } else {
      const { ok, error } = await apiFetch(`/api/users/points/adjust`, {
        method: "POST",
        token,
        body: JSON.stringify({ 
          user_id: memberId, 
          points, 
          reason 
        }),
      });
      if (ok) {
        successMsg = t(lang, "pm_points_adjusted");
      } else {
        errorMsg = error || "Error";
      }
    }
  }
  if (action === "register") {
    const role = data.get("role")?.toString() || "child";
    const payload = {
      name: data.get("name"),
      email: data.get("email"),
      password: data.get("password"),
      role: role,
      family_id: user.family_id, // Use the current user's family_id
    };
    const { ok, error } = await apiFetch("/api/auth/register", {
      method: "POST",
      token,
      body: JSON.stringify(payload),
    });
    if (ok) {
      successMsg = t(lang, "pm_registered");
    } else {
      // Handle Pydantic validation errors (array of objects) or simple string errors
      if (typeof error === 'string') {
        errorMsg = error;
      } else {
        errorMsg = "Registration failed. Please check all fields.";
      }
    }
  }
  if (action === "generate_join_code") {
    const { ok, data: codeData, error } = await apiFetch<any>("/api/families/join-code/generate", {
      method: "POST",
      token,
    });
    if (ok && codeData) {
      successMsg = lang === "es" 
        ? `Codigo de familia generado: ${codeData.join_code}` 
        : `Family code generated: ${codeData.join_code}`;
    } else {
      errorMsg = error || "Error generating join code";
    }
  }
}

const { data: family } = await apiFetch<any>("/api/families/me", { token });
const members: any[] = family?.members ?? [];

// Fetch pending invitations server-side.
// Backend route is path-param (/{family_id}/pending) and returns a plain list.
const { data: pendingInvitationsResult, ok: pendingInvOk, error: pendingInvError } = await apiFetch<any>(
  `/api/invitations/${user.family_id}/pending`,
  { token }
);
const pendingInvitations: any[] = pendingInvOk && Array.isArray(pendingInvitationsResult)
  ? pendingInvitationsResult
  : [];
if (!pendingInvOk && pendingInvError) {
  console.error("Error fetching pending invitations:", pendingInvError);
}

// Fetch join code via proxy endpoint to ensure auth is applied correctly
const { data: joinCodeResult, ok: joinCodeOk, error: joinCodeError } = await apiFetch<any>("/api/families/join-code/current", { token });
const joinCode: string | null = joinCodeOk ? joinCodeResult?.join_code ?? null : null;
if (!joinCodeOk && joinCodeError) {
  errorMsg = joinCodeError || errorMsg;
}
---

<PageLayout
  title={t(lang, "pm_title") as string}
  tone="coral"
  backHref="/parent"
  backLabel={t(lang, "back_parent") as string}
  role={user.role}
  active="parent"
  lang={lang}
  mainClass="flex-1 px-4 py-6 space-y-5"
>
  <p slot="header-extra" class="text-brand-coral-deep text-sm mt-1">
    {t(lang, "parent_members_count")(members.length)}
  </p>
      {
        successMsg && (
          <div class="p-3 bg-brand-mint/20 border border-brand-mint text-brand-mint-deep text-sm rounded-xl">
            {successMsg}
          </div>
        )
      }
      {
        errorMsg && (
          <div class="p-3 bg-red-100 border border-red-200 text-red-700 text-sm rounded-xl">
            {errorMsg}
          </div>
        )
      }

      <!-- Family Join Code Section -->
      <section class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-coral">
        <div class="flex items-center gap-2 mb-3">
          <svg class="h-5 w-5 text-brand-coral-deep" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
          </svg>
          <h2 class="font-bold text-brand-ink">
            {lang === "es" ? "Codigo de Familia" : "Family Join Code"}
          </h2>
        </div>
        <p class="text-xs text-brand-ink-soft mb-3">
          {lang === "es" 
            ? "Comparte este codigo con miembros de tu familia para que se unan usando Google Sign-In." 
            : "Share this code with family members so they can join using Google Sign-In."}
        </p>
        {joinCode ? (
          <div class="flex items-center gap-3">
            <div class="flex-1 bg-indigo-50 border border-brand-coral rounded-lg px-4 py-3 text-center">
              <span id="join-code-display" class="font-mono text-2xl font-bold tracking-[0.3em] text-brand-coral-deep">{joinCode}</span>
            </div>
            <button 
              id="copy-code-btn"
              type="button"
              class="px-3 py-3 rounded-lg bg-indigo-100 text-brand-coral-deep hover:bg-brand-coral-deep transition-colors"
              title={lang === "es" ? "Copiar" : "Copy"}
            >
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
            </button>
            <form method="POST" class="inline-flex">
              <input type="hidden" name="action" value="generate_join_code" />
              <button 
                type="submit"
                class="px-3 py-3 rounded-lg bg-brand-cream-deep text-brand-ink-soft hover:bg-brand-cream-deep transition-colors"
                title={lang === "es" ? "Regenerar" : "Regenerate"}
              >
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
              </button>
            </form>
          </div>
        ) : (
          <form method="POST">
            <input type="hidden" name="action" value="generate_join_code" />
            <button 
              type="submit"
              class="w-full py-2.5 bg-brand-coral-deep hover:bg-brand-ink text-white font-semibold text-sm rounded-lg transition-colors shadow-[var(--shadow-card)]"
            >
              {lang === "es" ? "Generar Codigo de Familia" : "Generate Family Code"}
            </button>
          </form>
        )}
      </section>

      <!-- Invite Family Members Section -->
      <section class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-cyan-100">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2 flex-1">
            <svg class="h-5 w-5 text-brand-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            <div>
              <h2 class="font-bold text-brand-ink">
                {lang === "es" ? "Invitar Miembros" : "Invite Members"}
              </h2>
              <p class="text-xs text-brand-ink-soft mt-1">
                {lang === "es" 
                  ? "Envía una invitación por correo electrónico para que otros se unan a tu familia." 
                  : "Send email invitations for others to join your family."}
              </p>
            </div>
          </div>
          <button 
            id="open-invitation-modal"
            type="button"
            class="px-4 py-2 rounded-lg bg-brand-sky text-brand-ink font-semibold text-sm transition-all transform hover:scale-105 active:scale-95 whitespace-nowrap"
          >
            {lang === "es" ? "Invitar" : "Invite"}
          </button>
        </div>
      </section>

      <!-- Pending Invitations Section -->
      {
        pendingInvitations.length > 0 && (
          <section data-pending-section class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-sun">
            <div class="flex items-center gap-2 mb-4">
              <svg class="h-5 w-5 text-brand-sun-deep animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <h2 class="font-bold text-brand-ink">
                {lang === "es" ? "Invitaciones Pendientes" : "Pending Invitations"}
              </h2>
              <span data-inv-count class="ml-auto text-xs bg-brand-sun/20 text-brand-sun-deep px-2 py-1 rounded-full font-semibold">
                {pendingInvitations.length}
              </span>
            </div>
            <div class="space-y-3">
              {
                pendingInvitations.map((inv: any) => (
                  <div data-inv-row class="flex items-center justify-between p-4 bg-gradient-to-r from-amber-50 to-orange-50 rounded-xl border border-brand-sun hover:border-brand-sun transition-colors">
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-brand-ink break-all">
                        {inv.invited_email}
                      </p>
                      <div class="flex gap-4 mt-2 text-xs text-brand-ink-soft">
                        <span>
                          {lang === "es" ? "Rol: " : "Role: "}
                          <span class="font-semibold text-brand-sun-deep capitalize">
                            {inv.role}
                          </span>
                        </span>
                        <span>
                          {lang === "es" ? "Por: " : "By: "}
                          <span class="font-semibold text-brand-ink">
                            {inv.invited_by_user_name}
                          </span>
                        </span>
                      </div>
                    </div>
                    <div class="ml-3 flex-shrink-0 flex items-center gap-1">
                      <button
                        onclick={`resendInvitation('${inv.id}', '${user.family_id}', '${lang}', this)`}
                        class="px-3 py-1.5 text-xs font-semibold text-brand-sky-deep bg-brand-sky/15 hover:bg-brand-sky/30 rounded-lg transition-colors whitespace-nowrap"
                        title={lang === "es" ? "Reenviar invitación" : "Resend invitation"}
                      >
                        {lang === "es" ? "Reenviar" : "Resend"}
                      </button>
                      <button
                        onclick={`cancelInvitation('${inv.id}', '${user.family_id}', '${lang}', this)`}
                        class="p-2 text-red-600 hover:bg-red-100 rounded-lg transition-colors"
                        title={lang === "es" ? "Cancelar invitación" : "Cancel invitation"}
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                      </button>
                    </div>
                  </div>
                ))
              }
            </div>
          </section>
        )
      }

      {
        members.map((m: any) => (
          <div
            class={`bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border ${m.is_active === false ? "opacity-50 border-brand-ink/10" : "border-brand-ink/10"}`}
          >
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-full bg-brand-coral/15 flex items-center justify-center text-brand-coral-deep font-bold">
                {m.name.charAt(0).toUpperCase()}
              </div>
              <div class="flex-1">
                <p class="font-bold text-brand-ink text-sm">{m.name}</p>
                <p class="text-xs text-brand-ink-soft">
                  {m.role} · {m.email}
                </p>
              </div>
              <span class="text-sm font-bold text-brand-sun-deep">
                {m.points ?? 0} pts
              </span>
            </div>

            <div class="flex gap-2 flex-wrap">
              <form method="POST" class="inline-flex">
                <input type="hidden" name="action" value="toggle_active" />
                <input type="hidden" name="member_id" value={m.id} />
                <input
                  type="hidden"
                  name="is_active"
                  value={String(m.is_active !== false)}
                />
                <button
                  type="submit"
                  class={`px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors ${m.is_active === false ? "bg-brand-mint/20 text-brand-mint-deep hover:bg-brand-mint" : "bg-rose-100 text-rose-700 hover:bg-rose-200"}`}
                >
                  {m.is_active === false
                    ? t(lang, "pm_activate")
                    : t(lang, "pm_deactivate")}
                </button>
              </form>

              <button
                type="button"
                onclick={`openEditMemberModal('${m.id}', '${m.name}', '${m.role}')`}
                class="px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors bg-brand-coral/15 text-brand-coral-deep hover:bg-brand-coral-deep"
              >
                {lang === "es" ? "Editar" : "Edit"}
              </button>
               
              <form method="POST" class="inline-flex" onsubmit="return confirm('¿Estás seguro de que quieres eliminar permanentemente a este miembro? Esta acción NO se puede deshacer y eliminará todas sus tareas, puntos e historial.');">
                <input type="hidden" name="action" value="delete" />
                <input type="hidden" name="member_id" value={m.id} />
                <button
                  type="submit"
                  class="px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors bg-red-600 text-white hover:bg-red-700"
                >
                  {t(lang, "pm_delete")}
                </button>
              </form>
            </div>

            <form method="POST" class="mt-3 flex gap-2">
              <input type="hidden" name="action" value="adjust_points" />
              <input type="hidden" name="member_id" value={m.id} />
              <div class="flex-1 flex gap-2">
                <input
                  type="number"
                  name="points"
                  placeholder={t(lang, "pm_pts_placeholder")}
                  required
                  class="w-20 px-2 py-1.5 rounded-lg border border-brand-ink/20 text-xs focus:ring-1 focus:ring-brand-coral outline-none"
                />
                <input
                  name="reason"
                  placeholder={t(lang, "pm_reason_placeholder")}
                  required
                  class="flex-1 px-2 py-1.5 rounded-lg border border-brand-ink/20 text-xs focus:ring-1 focus:ring-brand-coral outline-none"
                />
                <button
                  type="submit"
                  class="px-3 py-1.5 rounded-lg bg-brand-coral/15 text-brand-coral-deep hover:bg-brand-coral-deep text-xs font-semibold transition-colors"
                >
                  {t(lang, "pm_apply")}
                </button>
              </div>
            </form>
          </div>
        ))
      }

      <section
        class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10"
      >
        <h2 class="font-bold text-brand-ink mb-4">
          {t(lang, "pm_register_title")}
        </h2>
        <form method="POST" class="space-y-3">
          <input type="hidden" name="action" value="register" />
          <input
            name="name"
            required
            placeholder={t(lang, "pm_name")}
            class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-coral outline-none"
          />
          <input
            type="email"
            name="email"
            required
            placeholder={t(lang, "pm_email")}
            class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-coral outline-none"
          />
          <input
            type="password"
            name="password"
            required
            minlength={8}
            placeholder={t(lang, "pm_password")}
            class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-coral outline-none"
          />
          <select
            name="role"
            required
            class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-coral outline-none bg-brand-cream"
          >
            <option value="child">{t(lang, "pm_role_child")}</option>
            <option value="teen">{t(lang, "pm_role_teen")}</option>
            <option value="parent">{t(lang, "pm_role_parent")}</option>
          </select>
          <button
            type="submit"
            class="w-full py-2.5 bg-brand-coral-deep hover:bg-brand-ink text-white font-semibold text-sm rounded-lg transition-colors shadow-[var(--shadow-card)]"
          >
            {t(lang, "pm_register_btn")}
          </button>
        </form>
      </section>

  <!-- Invitation Modal -->
  <InvitationModal familyId={user.family_id} familyName={user.family?.name || "Family"} lang={lang} />

  <script>
    import { showToast } from '../../lib/toast';

    document.addEventListener('astro:page-load', () => {
    // Open invitation modal
    document.getElementById('open-invitation-modal')?.addEventListener('click', () => {
      const modal = document.getElementById('invitation-modal');
      if (modal) {
        modal.classList.remove('hidden');
      }
    });

    document.getElementById('copy-code-btn')?.addEventListener('click', () => {
      const code = document.getElementById('join-code-display')?.textContent?.trim();
      if (code) {
        navigator.clipboard.writeText(code).then(() => {
          const btn = document.getElementById('copy-code-btn');
          if (btn) {
            btn.innerHTML = '<svg class="h-5 w-5 text-brand-mint-deep" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
            setTimeout(() => {
              btn.innerHTML = '<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>';
            }, 2000);
          }
        });
      }
    });

    // Cancel pending invitation. Auth rides the httpOnly cookie via
    // credentials:'include' — the proxy reads it server-side (locals.token),
    // so we must NOT try to read access_token from document.cookie here.
    (window as any).cancelInvitation = async (invitationId: string, familyId: string, lang = 'en', btn?: HTMLButtonElement) => {
      if (!confirm(lang === "es" ? "¿Cancelar esta invitación?" : "Cancel this invitation?")) {
        return;
      }
      try {
        const response = await fetch(
          `/api/invitations/${familyId}/${invitationId}`,
          { method: "DELETE", headers: { "Content-Type": "application/json" }, credentials: 'include' }
        );
        if (response.ok || response.status === 204) {
          // In-place: drop the row, decrement the count, and remove the whole
          // section once the last pending invitation is gone.
          const row = btn?.closest('[data-inv-row]');
          const section = btn?.closest('[data-pending-section]') as HTMLElement | null;
          row?.remove();
          const remaining = section?.querySelectorAll('[data-inv-row]').length ?? 0;
          if (section && remaining === 0) {
            section.remove();
          } else {
            const countEl = section?.querySelector('[data-inv-count]');
            if (countEl) countEl.textContent = String(remaining);
          }
          showToast(lang === "es" ? "Invitación cancelada" : "Invitation canceled", 'success');
        } else {
          const data = await response.json().catch(() => ({}));
          showToast(data.error || (lang === "es" ? "Error al cancelar la invitación" : "Error canceling invitation"), 'error');
        }
      } catch (error) {
        console.error("Error canceling invitation:", error);
        showToast(lang === "es" ? "Error de conexión" : "Connection error", 'error');
      }
    };

    // Resend pending invitation (refreshes expiry + re-sends the email).
    (window as any).resendInvitation = async (invitationId: string, familyId: string, lang = 'en', btn?: HTMLButtonElement) => {
      const original = btn?.textContent;
      if (btn) { btn.disabled = true; btn.textContent = lang === "es" ? "Enviando…" : "Sending…"; }
      try {
        const response = await fetch(
          `/api/invitations/${familyId}/${invitationId}/resend`,
          { method: "POST", headers: { "Content-Type": "application/json" }, credentials: 'include' }
        );
        const data = await response.json().catch(() => ({}));
        if (response.ok && data.success !== false) {
          showToast(lang === "es" ? "Invitación reenviada" : "Invitation resent", 'success');
        } else {
          showToast(data.error || (lang === "es" ? "Error al reenviar la invitación" : "Error resending invitation"), 'error');
        }
      } catch (error) {
        console.error("Error resending invitation:", error);
        showToast(lang === "es" ? "Error de conexión" : "Connection error", 'error');
      } finally {
        if (btn) { btn.disabled = false; if (original) btn.textContent = original; }
      }
    };
    });
  </script>

  <EditMemberModal lang={lang} />
</PageLayout>
