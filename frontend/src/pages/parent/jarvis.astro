---
import ChatShell from "@components/ui/ChatShell.astro";
import { apiFetch } from "../../lib/api";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "en") as "en" | "es";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    const action = data.get("action");
    if (action === "clear") {
        await apiFetch("/api/jarvis/history", { method: "DELETE", token });
    }
    return Astro.redirect("/parent/jarvis");
}

const { data: historyRaw } = await apiFetch<any[]>("/api/jarvis/history", {
    token,
});
const history: any[] = Array.isArray(historyRaw) ? historyRaw : [];

const labels = {
    title: lang === "es" ? "Jarvis" : "Jarvis",
    subtitle:
        lang === "es"
            ? "Copiloto familiar — pregunta lo que sea"
            : "Family copilot — ask anything",
    placeholder: lang === "es"
        ? "¿Cómo balanceo la semana? ¿Qué le digo a Emma?"
        : "How do I balance this week? What do I say to Emma?",
    send: lang === "es" ? "Enviar" : "Send",
    clear: lang === "es" ? "Limpiar historial" : "Clear history",
    empty: lang === "es"
        ? "Sin mensajes aún. Pregúntale algo a Jarvis."
        : "No messages yet. Ask Jarvis something.",
    thinking: lang === "es" ? "Pensando…" : "Thinking…",
};
---

<ChatShell
    title={`${labels.title} - Family Task Manager`}
    headerClass="bg-gradient-to-br from-violet-600 to-fuchsia-500"
    feedId="chat-scroll"
    feedClass="flex-1 px-4 py-4 space-y-3 overflow-y-auto"
    active="parent"
    role={user.role}
    lang={lang}
>
    <Fragment slot="header">
            <div class="flex items-baseline justify-between">
                <div>
                    <h1 class="text-2xl font-bold">🤖 {labels.title}</h1>
                    <p class="text-violet-100 text-xs mt-1">{labels.subtitle}</p>
                </div>
                <div class="flex gap-2 items-center">
                    <a href="/parent/jarvis-schedules" class="text-xs underline text-violet-200 hover:text-white">
                        ⏰ {lang === "es" ? "Programaciones" : "Schedules"}
                    </a>
                    {history.length > 0 && (
                        <form method="POST">
                            <input type="hidden" name="action" value="clear" />
                            <button
                                type="submit"
                                class="text-xs underline text-violet-200 hover:text-white"
                            >
                                {labels.clear}
                            </button>
                        </form>
                    )}
                </div>
            </div>
            <div class="mt-3">
                <select
                    id="model-select"
                    class="w-full bg-white/15 text-white text-xs font-semibold rounded-xl px-3 py-2 border border-white/30 focus:outline-none focus:ring-2 focus:ring-white/50 appearance-none cursor-pointer"
                >
                    <!-- gemini-2.5-flash is the only model the LiteLLM key
                         currently reaches end-to-end (see jctux/platform#86);
                         re-add others once their upstreams are fixed. -->
                    <option value="gemini-2.5-flash">💎 Gemini 2.5 Flash</option>
                </select>
            </div>
    </Fragment>
            {history.length === 0 ? (
                <div class="bg-brand-cream rounded-2xl p-8 text-center border border-brand-ink/10">
                    <p class="text-4xl mb-2">🤖</p>
                    <p class="text-brand-ink-soft text-sm">{labels.empty}</p>
                </div>
            ) : (
                history.map((m: any) => (
                    <div class={`flex ${m.role === "user" ? "justify-end" : "justify-start"}`}>
                        <div class={`max-w-[80%] rounded-2xl px-4 py-2.5 text-sm ${
                            m.role === "user"
                                ? "bg-brand-ink text-brand-cream"
                                : "bg-brand-cream border border-brand-ink/10 text-brand-ink"
                        }`}>
                            <p class="whitespace-pre-wrap">{m.content}</p>
                        </div>
                    </div>
                ))
            )}
            <div id="pending" class="hidden flex justify-start">
                <div class="bg-brand-cream border border-brand-ink/10 text-brand-ink-soft rounded-2xl px-4 py-2.5 text-sm italic">
                    {labels.thinking}
                </div>
            </div>
    <form slot="composer" id="chat-form" class="p-3 border-t border-brand-ink/10 bg-brand-cream flex-shrink-0 flex gap-2">
            <input
                type="text"
                id="message-input"
                required
                maxlength="2000"
                placeholder={labels.placeholder}
                class="flex-1 px-3 py-2.5 rounded-xl border border-brand-ink/20 text-sm focus:ring-2 focus:ring-violet-500 outline-none"
            />
            <button
                type="submit"
                class="px-4 py-2.5 rounded-xl bg-violet-600 text-white text-sm font-bold hover:bg-violet-700 active:scale-95"
            >
                {labels.send}
            </button>
    </form>
</ChatShell>

<script>
    document.addEventListener("astro:page-load", () => {
        const form = document.getElementById("chat-form") as HTMLFormElement | null;
        const input = document.getElementById("message-input") as HTMLInputElement | null;
        const modelSelect = document.getElementById("model-select") as HTMLSelectElement | null;
        const pending = document.getElementById("pending");
        const scroll = document.getElementById("chat-scroll");
        if (!form || !input) return;

        // gemini-2.5-flash is the only model the LiteLLM key reaches today, so
        // pin to it and migrate any stale persisted choice (platform#86).
        const WORKING_MODEL = "gemini-2.5-flash";
        let savedModel = localStorage.getItem("jarvis-model");
        if (savedModel !== WORKING_MODEL) {
            savedModel = WORKING_MODEL;
            localStorage.setItem("jarvis-model", savedModel);
        }
        if (modelSelect) {
            modelSelect.value = savedModel;
            modelSelect.addEventListener("change", () => {
                localStorage.setItem("jarvis-model", modelSelect.value);
            });
        }

        scroll?.scrollTo({ top: scroll.scrollHeight });

        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            const message = input.value.trim();
            if (!message) return;
            input.value = "";
            input.disabled = true;
            const selectedModel = modelSelect?.value || "gemini-2.5-flash";

            // Optimistic user bubble
            if (scroll) {
                const userBubble = document.createElement("div");
                userBubble.className = "flex justify-end";
                userBubble.innerHTML = `<div class="max-w-[80%] rounded-2xl px-4 py-2.5 text-sm bg-brand-ink text-brand-cream"><p class="whitespace-pre-wrap"></p></div>`;
                (userBubble.querySelector("p") as HTMLElement).textContent = message;
                scroll.insertBefore(userBubble, pending);
            }
            pending?.classList.remove("hidden");
            scroll?.scrollTo({ top: scroll.scrollHeight, behavior: "smooth" });

            const liveActions: string[] = [];
            try {
                const resp = await fetch("/api/jarvis/chat-stream", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ message, model: selectedModel }),
                });
                if (!resp.ok || !resp.body) {
                    pending?.classList.add("hidden");
                    let txt = "Error";
                    try { txt = (await resp.json()).detail || txt; } catch {}
                    alert(txt);
                    return;
                }

                const reader = resp.body.getReader();
                const decoder = new TextDecoder();
                let buf = "";
                let event = "message";
                let dataStr = "";

                while (true) {
                    const { value, done } = await reader.read();
                    if (done) break;
                    buf += decoder.decode(value, { stream: true });

                    let idx;
                    while ((idx = buf.indexOf("\n\n")) >= 0) {
                        const chunk = buf.slice(0, idx);
                        buf = buf.slice(idx + 2);
                        event = "message";
                        dataStr = "";
                        for (const line of chunk.split("\n")) {
                            if (line.startsWith("event: ")) event = line.slice(7).trim();
                            else if (line.startsWith("data: ")) dataStr += line.slice(6);
                        }
                        let payload: any = {};
                        try { payload = dataStr ? JSON.parse(dataStr) : {}; } catch {}

                        if (event === "tool") {
                            liveActions.push(`${payload.name}(${payload.ok ? "ok" : "err"})`);
                            if (pending) {
                                pending.querySelector("div")!.textContent =
                                    `⚡ ${payload.name} · ${liveActions.length} action(s) so far…`;
                            }
                        } else if (event === "confirm") {
                            pending?.classList.add("hidden");
                            if (scroll) {
                                const actionId: string = payload.action_id ?? "";
                                const card = document.createElement("div");
                                card.className = "flex justify-start";
                                card.dataset.confirmId = actionId;
                                card.innerHTML = `<div class="max-w-[90%] rounded-2xl px-4 py-3 text-sm bg-amber-50 border border-amber-300 text-brand-ink space-y-2">
  <p class="font-semibold text-amber-700">⚠️ Confirm action: <code class="font-mono text-xs bg-amber-100 px-1 rounded"></code></p>
  <p class="text-xs text-brand-ink-soft confirm-summary"></p>
  <pre class="text-xs bg-white border border-amber-200 rounded p-2 overflow-x-auto whitespace-pre-wrap break-all"></pre>
  <div class="flex gap-2 pt-1">
    <button class="btn-approve px-3 py-1.5 rounded-lg bg-violet-600 text-white text-xs font-bold hover:bg-violet-700 active:scale-95">Approve</button>
    <button class="btn-cancel px-3 py-1.5 rounded-lg bg-gray-200 text-gray-700 text-xs font-bold hover:bg-gray-300 active:scale-95">Cancel</button>
  </div>
</div>`;
                                (card.querySelector("code") as HTMLElement).textContent = payload.tool ?? actionId;
                                (card.querySelector(".confirm-summary") as HTMLElement).textContent = payload.summary ?? "";
                                (card.querySelector("pre") as HTMLElement).textContent = JSON.stringify(payload.params ?? {}, null, 2);
                                const btnApprove = card.querySelector(".btn-approve") as HTMLButtonElement;
                                const btnCancel = card.querySelector(".btn-cancel") as HTMLButtonElement;
                                const disableButtons = () => {
                                    btnApprove.disabled = true;
                                    btnCancel.disabled = true;
                                    btnApprove.classList.add("opacity-50");
                                    btnCancel.classList.add("opacity-50");
                                };
                                const renderResult = (ok: boolean, detail: string) => {
                                    card.innerHTML = `<div class="max-w-[90%] rounded-2xl px-4 py-2.5 text-sm ${ok ? "bg-green-50 border border-green-300 text-green-800" : "bg-red-50 border border-red-300 text-red-800"}"><p class="text-xs font-semibold"></p></div>`;
                                    (card.querySelector("p") as HTMLElement).textContent = detail;
                                };
                                btnApprove.addEventListener("click", async () => {
                                    disableButtons();
                                    try {
                                        const r = await fetch(`/api/jarvis/actions/${actionId}/approve`, { method: "POST" });
                                        const result = await r.json().catch(() => ({}));
                                        if (r.ok) {
                                            renderResult(true, `✅ Approved — ${result.data ? JSON.stringify(result.data) : "done"}`);
                                        } else {
                                            renderResult(false, `❌ Approval failed: ${result.detail ?? r.statusText}`);
                                        }
                                    } catch (err) {
                                        renderResult(false, `❌ Network error: ${String(err)}`);
                                    }
                                    scroll?.scrollTo({ top: scroll.scrollHeight, behavior: "smooth" });
                                });
                                btnCancel.addEventListener("click", async () => {
                                    disableButtons();
                                    try {
                                        await fetch(`/api/jarvis/actions/${actionId}/reject`, { method: "POST" });
                                    } catch {}
                                    renderResult(false, "🚫 Cancelled");
                                    scroll?.scrollTo({ top: scroll.scrollHeight, behavior: "smooth" });
                                });
                                scroll.insertBefore(card, pending);
                                scroll.scrollTo({ top: scroll.scrollHeight, behavior: "smooth" });
                            }
                        } else if (event === "reply") {
                            pending?.classList.add("hidden");
                            if (scroll) {
                                const MODEL_META: Record<string, {label: string; icon: string; color: string}> = {
                                    "claude-haiku":     { label: "Claude Haiku",       icon: "⚡", color: "bg-orange-100 text-orange-700" },
                                    "claude-sonnet":    { label: "Claude Sonnet",      icon: "🧠", color: "bg-violet-100 text-violet-700" },
                                    "gpt-4o":           { label: "GPT-4o",             icon: "🟢", color: "bg-green-100 text-green-700" },
                                    "gemini-2.5-flash": { label: "Gemini 2.5 Flash",   icon: "💎", color: "bg-sky-100 text-sky-700" },
                                    "qwen3":            { label: "Qwen 2.5 3B · GPU",  icon: "🖥️", color: "bg-gray-100 text-gray-600" },
                                };
                                const bot = document.createElement("div");
                                bot.className = "flex justify-start flex-col gap-1";
                                const actions: string[] = Array.isArray(payload.actions) ? payload.actions : liveActions;
                                const actionBadges = actions.length
                                    ? `<div class="mt-2 flex flex-wrap gap-1">${actions.map(() => `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-violet-100 text-violet-700"></span>`).join("")}</div>`
                                    : "";
                                const modelKey = payload.model ?? selectedModel;
                                const meta = MODEL_META[modelKey] ?? { label: modelKey, icon: "🤖", color: "bg-gray-100 text-gray-600" };
                                const modelCard = `<div class="flex items-center gap-1 pl-1"><span class="text-[10px] font-semibold px-2 py-0.5 rounded-full ${meta.color}">${meta.icon} ${meta.label}</span></div>`;
                                bot.innerHTML = `<div class="max-w-[80%] rounded-2xl px-4 py-2.5 text-sm bg-brand-cream border border-brand-ink/10 text-brand-ink"><p class="whitespace-pre-wrap"></p>${actionBadges}</div>${modelCard}`;
                                (bot.querySelector("p") as HTMLElement).textContent = payload.reply ?? "";
                                bot.querySelectorAll("span.bg-violet-100").forEach((el, i) => {
                                    (el as HTMLElement).textContent = "⚡ " + actions[i];
                                });
                                scroll.insertBefore(bot, pending);
                                scroll.scrollTo({ top: scroll.scrollHeight, behavior: "smooth" });
                            }
                        } else if (event === "error") {
                            pending?.classList.add("hidden");
                            alert(payload.detail || "Error");
                        }
                    }
                }
            } catch (err) {
                pending?.classList.add("hidden");
                alert(String(err));
            } finally {
                input.disabled = false;
                input.focus();
            }
        });
    });
</script>
