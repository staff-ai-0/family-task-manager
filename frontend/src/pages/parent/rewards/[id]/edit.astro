---
import PageLayout from "@components/ui/PageLayout.astro";
import { apiFetch } from "../../../../lib/api";
import { t } from "../../../../lib/i18n";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "en") as "en" | "es";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

const { id } = Astro.params;
let errorMsg = "";

if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    const payload: any = {
        name: data.get("name"),
        description: data.get("description") || null,
        points_cost: Number(data.get("points_cost")) || 50,
    };
    const category = data.get("category");
    if (category) payload.category = category;
    const { ok, error } = await apiFetch(`/api/rewards/${id}`, {
        method: "PUT",
        token,
        body: JSON.stringify(payload),
    });
    if (ok) {
        return Astro.redirect("/parent/rewards");
    } else {
        errorMsg = error || "Error";
    }
}

const { data: reward } = await apiFetch<any>(`/api/rewards/${id}`, { token });
if (!reward) return Astro.redirect("/parent/rewards");
---

<PageLayout
    title={t(lang, "pr_edit_title") as string}
    headerClass="bg-gradient-to-br from-amber-600 to-orange-500"
    dark
    backClass="text-amber-200"
    backHref="/parent/rewards"
    backLabel={t(lang, "back_all_rewards") as string}
    role={user.role}
    active="parent"
    lang={lang}
>
    {
        errorMsg && (
            <div class="mb-4 p-3 bg-red-100 border border-red-200 text-red-700 text-sm rounded-xl">
                {errorMsg}
            </div>
        )
    }
    <form
        method="POST"
        class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 space-y-4"
    >
        <div>
            <label class="text-sm font-medium text-brand-ink mb-1 block"
                >{t(lang, "pr_name")}</label
            >
            <input
                name="name"
                required
                value={reward.name}
                class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-amber-500 outline-none"
            />
        </div>
        <div>
            <label class="text-sm font-medium text-brand-ink mb-1 block"
                >{t(lang, "pt_description")}</label
            >
            <textarea
                name="description"
                rows={3}
                class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-amber-500 outline-none resize-none"
                >{reward.description}</textarea
            >
        </div>
        <div class="grid grid-cols-2 gap-3">
            <div>
                <label
                    class="text-sm font-medium text-brand-ink mb-1 block"
                    >{t(lang, "pr_point_cost")}</label
                >
                <input
                    type="number"
                    name="points_cost"
                    min={1}
                    value={reward.points_cost}
                    class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-amber-500 outline-none"
                />
            </div>
            <div>
                <label
                    class="text-sm font-medium text-brand-ink mb-1 block"
                    >{t(lang, "pr_category")}</label
                >
                <select
                    name="category"
                    class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-amber-500 outline-none bg-brand-cream"
                >
                    <option value="">{t(lang, "pr_none_cat")}</option>
                    <option
                        value="screen_time"
                        selected={reward.category === "screen_time"}
                        >{t(lang, "pr_cat_screen_time")}</option
                    >
                    <option
                        value="treats"
                        selected={reward.category === "treats"}
                        >{t(lang, "pr_cat_food")}</option
                    >
                    <option
                        value="activities"
                        selected={reward.category === "activities"}
                        >{t(lang, "pr_cat_activity")}</option
                    >
                    <option
                        value="privileges"
                        selected={reward.category === "privileges"}
                        >{t(lang, "pr_cat_privilege")}</option
                    >
                    <option
                        value="money"
                        selected={reward.category === "money"}
                        >{t(lang, "pr_cat_money")}</option
                    >
                    <option
                        value="toys"
                        selected={reward.category === "toys"}
                        >{t(lang, "pr_cat_item")}</option
                    >
                </select>
            </div>
        </div>
        <button
            type="submit"
            class="w-full py-2.5 bg-brand-sun-deep hover:bg-brand-ink text-brand-ink font-semibold text-sm rounded-lg transition-colors shadow-[var(--shadow-card)]"
        >
            {t(lang, "pt_save")}
        </button>
    </form>
</PageLayout>
