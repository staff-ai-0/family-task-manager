---
import PageLayout from "@components/ui/PageLayout.astro";
import DifficultyChip from "../../components/DifficultyChip.astro";
import { apiFetch } from "../../lib/api";
import { gigTerm } from "../../lib/gigTerm";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/gigs");

const [offeringsRes, pendingRes, proposalsRes, claimsRes, familyRes] = await Promise.all([
    apiFetch<any[]>("/api/gigs/offerings?include_inactive=false", { token }),
    apiFetch<any[]>("/api/gigs/claims/pending-approvals", { token }),
    apiFetch<any[]>("/api/gigs/offerings/proposals/pending", { token }),
    apiFetch<any[]>("/api/gigs/claims/family", { token }),
    apiFetch<any>("/api/families/me", { token }),
]);
const offerings: any[] = offeringsRes.data ?? [];
const gt = gigTerm(familyRes.data?.gig_term ?? "gig", lang);
// Claim approvals now live in the unified /parent/approvals queue — keep only the
// pending count here for the "review" link so there is a single approval surface.
const pendingCount = Array.isArray(pendingRes.data) ? pendingRes.data.length : 0;
// Kid-proposed gigs awaiting review (W4.4).
const proposals: any[] = Array.isArray(proposalsRes.data) ? proposalsRes.data : [];

// History: every claim that made it past "claimed" — what got done, when,
// and the kid's proof/learning text. Newest meaningful timestamp first.
const claimStamp = (c: any) => c.approved_at ?? c.completed_at ?? c.created_at ?? "";
const history: any[] = (Array.isArray(claimsRes.data) ? claimsRes.data : [])
    .filter((c: any) => c.status !== "claimed")
    .sort((a: any, b: any) => String(claimStamp(b)).localeCompare(String(claimStamp(a))));
const historyKids = [...new Set(history.map((c: any) => c.claimer_name).filter(Boolean))] as string[];
const fmtDay = (iso: string | null) =>
    iso
        ? new Date(iso).toLocaleDateString(lang === "es" ? "es-MX" : "en-US", {
              month: "short",
              day: "numeric",
          })
        : "—";

// "Ask about this gig" → find/create the 1:1 DM thread with the kid and
// jump into it with a prefilled question quoting the gig.
if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    if (data.get("action") === "dm-kid") {
        const kidId = String(data.get("kid_id") || "");
        const gigTitle = String(data.get("gig_title") || "");
        if (kidId) {
            const { ok, data: thread } = await apiFetch<any>("/api/dm/threads", {
                method: "POST",
                token,
                body: JSON.stringify({ participant_ids: [kidId] }),
            });
            if (ok && thread?.id) {
                const prefill = encodeURIComponent(
                    lang === "es"
                        ? `Sobre tu ${gt.one} "${gigTitle}": `
                        : `About your ${gt.one} "${gigTitle}": `,
                );
                return Astro.redirect(`/dm/${thread.id}?prefill=${prefill}`);
            }
        }
        return Astro.redirect("/parent/gigs#historial");
    }
}

const flash = Astro.cookies.get("flash")?.value;
if (flash) Astro.cookies.delete("flash", { path: "/" });
const flashError = Astro.cookies.get("flash_error")?.value;
if (flashError) Astro.cookies.delete("flash_error", { path: "/" });
---

<PageLayout
    title={gt.Many}
    headerClass="bg-gradient-to-br from-violet-800 to-violet-600"
    dark
    role="parent"
    active="gigs"
    lang={lang}
    gigTerm={gt.Many}
>
    <button
        slot="actions"
        id="new-gig-btn"
        data-tour="gig-fab"
        class="bg-white text-violet-700 font-bold text-sm px-4 py-2 rounded-xl shadow hover:bg-violet-50 transition-colors"
    >
        + {lang === "es" ? `Nueva ${gt.One}` : `New ${gt.One}`}
    </button>
    <div slot="header-extra">
        <p class="text-violet-200 text-sm mt-0.5 mb-4">
            {lang === "es" ? "Publica tareas extras con recompensa" : "Post extra tasks with rewards"}
        </p>
        <!-- Claim approvals live in the unified /parent/approvals queue. -->
        <a
            href="/parent/approvals"
            class="flex items-center justify-center gap-2 py-2 text-sm font-semibold rounded-xl bg-white/15 text-white hover:bg-white/25 transition-colors"
        >
            {lang === "es" ? "Revisar trabajo enviado" : "Review submitted work"}
            {pendingCount > 0 && (
                <span class="bg-red-500 text-white text-xs rounded-full px-1.5 py-0.5">{pendingCount}</span>
            )}
        </a>
        <a
            href="/parent/payouts"
            class="flex items-center justify-center gap-2 py-2 mt-2 text-sm font-semibold rounded-xl bg-white/15 text-white hover:bg-white/25 transition-colors"
        >
            💵 {lang === "es" ? "Pagar dinero ganado" : "Pay out earned cash"}
        </a>
        <a
            href="#historial"
            class="flex items-center justify-center gap-2 py-2 mt-2 text-sm font-semibold rounded-xl bg-white/15 text-white hover:bg-white/25 transition-colors"
        >
            📜 {lang === "es" ? `Historial de ${gt.many} completadas` : `Completed-${gt.one} history`}
        </a>
    </div>

    {flash && (
                <div class="mb-4 p-3 bg-brand-mint/20 border border-brand-mint text-brand-mint-deep text-sm rounded-xl">
                    {flash}
                </div>
            )}
            {flashError && (
                <div class="mb-4 p-3 bg-red-100 border border-red-200 text-red-700 text-sm rounded-xl">
                    {flashError}
                </div>
            )}

            <!-- Kid proposals awaiting review (W4.4) -->
            {proposals.length > 0 && (
                <section class="mb-6">
                    <h2 class="text-sm font-bold text-brand-ink-soft uppercase tracking-wide mb-3 px-1">
                        💡 {lang === "es" ? "Propuestas de tus hijos" : "Kid proposals"} ({proposals.length})
                    </h2>
                    <div class="space-y-3">
                        {proposals.map((row: any) => {
                            const o = row.offering;
                            return (
                                <div data-proposal-card data-id={o.id} class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-amber-300">
                                    <div class="flex justify-between items-start gap-3">
                                        <div class="min-w-0 flex-1">
                                            <h3 class="font-bold text-brand-ink">{o.title}</h3>
                                            {o.description && (
                                                <p class="text-brand-ink-soft text-sm mt-0.5 line-clamp-2">{o.description}</p>
                                            )}
                                            <p class="text-xs text-brand-ink-soft mt-1">
                                                {lang === "es" ? "Propuesta por" : "Proposed by"} <span class="font-semibold">{row.proposer_name}</span>
                                            </p>
                                        </div>
                                        <label class="text-right flex-shrink-0">
                                            <span class="block text-[10px] text-brand-ink-soft font-medium mb-1">$MXN</span>
                                            <input
                                                type="number"
                                                min="1"
                                                max="1000"
                                                value={o.points}
                                                data-proposal-points
                                                class="w-20 px-2 py-1.5 rounded-lg border border-brand-ink/20 text-sm font-bold text-emerald-700 text-right focus:ring-2 focus:ring-violet-400 outline-none bg-brand-cream-deep"
                                            />
                                        </label>
                                    </div>
                                    <input
                                        data-proposal-notes
                                        placeholder={lang === "es" ? "Nota para tu hijo/a (opcional)" : "Note for your kid (optional)"}
                                        class="mt-3 w-full px-3 py-2 rounded-lg border border-brand-ink/20 text-sm bg-brand-cream focus:ring-2 focus:ring-violet-400 outline-none"
                                    />
                                    <div class="flex gap-2 mt-3">
                                        <button
                                            data-proposal-action="reject"
                                            class="flex-1 py-2 text-sm font-semibold text-red-700 border border-red-300 rounded-xl hover:bg-red-50 transition-colors"
                                        >
                                            {lang === "es" ? "Rechazar" : "Reject"}
                                        </button>
                                        <button
                                            data-proposal-action="approve"
                                            class="flex-1 py-2 text-sm font-semibold text-white bg-violet-600 rounded-xl hover:bg-violet-700 transition-colors"
                                        >
                                            {lang === "es" ? "Aprobar y publicar" : "Approve & publish"}
                                        </button>
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                </section>
            )}

            <!-- Gig offerings -->
            <div class="space-y-3">
                {offerings.length === 0 && (
                    <div class="bg-brand-cream rounded-2xl p-8 text-center border border-brand-ink/10 shadow-[var(--shadow-card)]">
                        <p class="text-brand-ink-soft text-sm">
                            {lang === "es" ? `No has publicado ninguna ${gt.one} aún. ¡Crea la primera!` : `No ${gt.many} posted yet. Create the first one!`}
                        </p>
                    </div>
                )}
                {offerings.map((item: any) => {
                    const o = item.offering ?? item;
                    return (
                        <div data-gig-card class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10">
                            <div class="flex justify-between items-start">
                                <div class="flex-1 pr-4">
                                    <h3 class="font-bold text-brand-ink">{o.title}</h3>
                                    {o.description && <p class="text-brand-ink-soft text-sm mt-0.5 line-clamp-2">{o.description}</p>}
                                    <div class="flex items-center gap-2 mt-2 flex-wrap">
                                        <DifficultyChip level={o.difficulty ?? 1} lang={lang} />
                                    </div>
                                </div>
                                <div class="text-right flex-shrink-0">
                                    <p class="text-xl font-extrabold text-emerald-600">${o.points} <span class="text-xs font-semibold text-brand-ink-soft">MXN</span></p>
                                </div>
                            </div>
                            <div class="flex gap-2 mt-4">
                                <button
                                    class="edit-gig-btn flex-1 py-2 text-sm font-semibold text-violet-700 bg-violet-100 rounded-xl hover:bg-violet-200 transition-colors"
                                    data-id={o.id}
                                    data-title={o.title}
                                    data-description={o.description ?? ""}
                                    data-points={o.points}
                                    data-difficulty={o.difficulty ?? 1}
                                    data-category={o.category ?? "other"}
                                    data-allow-multiple={o.allow_multiple ? "1" : "0"}
                                    data-payout-cadence={o.payout_cadence ?? "immediate"}
                                >
                                    {lang === "es" ? "Editar" : "Edit"}
                                </button>
                                <button
                                    class="archive-gig-btn flex-1 py-2 text-sm font-semibold text-brand-ink-soft bg-brand-cream-deep rounded-xl hover:bg-red-100 hover:text-red-700 transition-colors"
                                    data-id={o.id}
                                >
                                    {lang === "es" ? "Archivar" : "Archive"}
                                </button>
                            </div>
                        </div>
                    );
                })}
            </div>

            <!-- Completed-gig history: when it was done and what the kid
                 did/learned (proof_text). Data lives in gig_claims; the day
                 view (/parent/day) only shows one date at a time. -->
            <section id="historial" class="mt-8 scroll-mt-4">
                <div class="flex items-center justify-between mb-3 px-1">
                    <h2 class="text-sm font-bold text-brand-ink-soft uppercase tracking-wide">
                        📜 {lang === "es" ? "Historial" : "History"}
                    </h2>
                    {historyKids.length > 1 && (
                        <select id="history-kid-filter" class="text-xs border border-brand-ink/20 rounded-lg px-2 py-1 bg-brand-cream">
                            <option value="">{lang === "es" ? "Todos" : "All kids"}</option>
                            {historyKids.map((k) => <option value={k}>{k}</option>)}
                        </select>
                    )}
                </div>
                {history.length === 0 ? (
                    <div class="bg-brand-cream rounded-2xl p-6 text-center border border-brand-ink/10">
                        <p class="text-brand-ink-soft text-sm">
                            {lang === "es" ? `Aún no hay ${gt.many} completadas.` : `No completed ${gt.many} yet.`}
                        </p>
                    </div>
                ) : (
                    <div class="space-y-2">
                        {history.map((c: any) => (
                            <div data-history-card data-claimer={c.claimer_name ?? ""}
                                class={`bg-brand-cream rounded-2xl p-4 border shadow-[var(--shadow-card)] ${
                                    c.status === "approved" ? "border-emerald-200"
                                    : c.status === "rejected" ? "border-red-200 opacity-70"
                                    : "border-sky-200"
                                }`}>
                                <div class="flex items-baseline justify-between gap-2">
                                    <p class="font-bold text-brand-ink text-sm">
                                        {c.claimer_name} · {c.gig_title}
                                    </p>
                                    <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full whitespace-nowrap ${
                                        c.status === "approved" ? "bg-emerald-100 text-emerald-700"
                                        : c.status === "rejected" ? "bg-red-100 text-red-700"
                                        : "bg-sky-100 text-sky-700"
                                    }`}>
                                        {c.status === "approved"
                                            ? `✓ ${lang === "es" ? "Aprobada" : "Approved"}`
                                            : c.status === "rejected"
                                            ? (lang === "es" ? "Rechazada" : "Rejected")
                                            : (lang === "es" ? "Por aprobar" : "Awaiting approval")}
                                    </span>
                                </div>
                                <p class="text-[11px] text-brand-ink-soft mt-1">
                                    {lang === "es" ? "Completada" : "Completed"}: {fmtDay(c.completed_at)}
                                    {c.approved_at && ` · ${lang === "es" ? "aprobada" : "approved"} ${fmtDay(c.approved_at)}`}
                                    {" · "}
                                    <span class="font-bold text-emerald-700">
                                        ${c.points_awarded ?? c.gig_points} MXN
                                    </span>
                                </p>
                                {c.proof_text && (
                                    <p class="text-xs text-brand-ink mt-2 bg-brand-cream-deep rounded-lg p-2 whitespace-pre-wrap">
                                        📝 {c.proof_text}
                                    </p>
                                )}
                                {c.proof_image_url && (
                                    <a href={c.proof_image_url} target="_blank"
                                       class="inline-block text-xs text-violet-700 underline mt-2">
                                        📷 {lang === "es" ? "Ver foto" : "View photo"}
                                    </a>
                                )}
                                {c.approval_notes && (
                                    <p class="text-[11px] text-brand-ink-soft italic mt-1.5">
                                        💬 {c.approval_notes}
                                    </p>
                                )}
                                <div class="flex items-center gap-3 mt-2">
                                    <details class="flex-1" data-comments data-claim-id={c.id}>
                                        <summary class="cursor-pointer text-xs font-semibold text-violet-700 select-none">
                                            💬 {lang === "es" ? "Comentarios" : "Comments"}{c.comment_count ? ` (${c.comment_count})` : ""}
                                        </summary>
                                        <div data-comments-list class="mt-2 space-y-1.5"></div>
                                        <form data-comment-form class="mt-2 flex gap-2">
                                            <input name="body" required maxlength="1000"
                                                placeholder={lang === "es" ? "Pregúntale o felicítalo…" : "Ask or congratulate…"}
                                                class="flex-1 px-3 py-2 rounded-xl border border-brand-ink/20 text-sm bg-brand-cream-deep focus:ring-2 focus:ring-violet-400 outline-none" />
                                            <button type="submit" class="px-3 py-2 rounded-xl bg-violet-600 text-white text-xs font-bold hover:bg-violet-700">
                                                {lang === "es" ? "Enviar" : "Send"}
                                            </button>
                                        </form>
                                    </details>
                                    <form method="POST" class="flex-shrink-0">
                                        <input type="hidden" name="action" value="dm-kid" />
                                        <input type="hidden" name="kid_id" value={c.claimed_by} />
                                        <input type="hidden" name="gig_title" value={c.gig_title} />
                                        <button type="submit" class="text-xs font-semibold text-indigo-700 underline">
                                            {lang === "es" ? "Preguntar por DM" : "Ask via DM"}
                                        </button>
                                    </form>
                                </div>
                            </div>
                        ))}
                    </div>
                )}
            </section>
</PageLayout>

<!-- Create/Edit Gig Modal -->
<div id="gig-modal" data-term-one={gt.One} class="hidden fixed inset-0 z-[60] flex items-end sm:items-center justify-center bg-black/50 backdrop-blur-sm px-4">
    <div class="bg-white rounded-t-3xl sm:rounded-3xl w-full max-w-md p-6 pb-[calc(1.5rem+env(safe-area-inset-bottom,0px))] sm:pb-6 shadow-2xl max-h-[90vh] overflow-y-auto">
        <div class="flex justify-between items-center mb-5">
            <h2 id="modal-title" class="text-lg font-bold text-brand-ink"></h2>
            <button id="close-modal" class="text-brand-ink-soft hover:text-brand-ink text-2xl leading-none">&times;</button>
        </div>
        <form id="gig-form" class="space-y-4">
            <input type="hidden" id="edit-gig-id" name="gig_id" value="" />
            <div>
                <label class="block text-sm font-medium text-brand-ink mb-1">{lang === "es" ? "Título *" : "Title *"}</label>
                <input type="text" id="f-title" name="title" required maxlength="200"
                    class="w-full rounded-xl border border-brand-ink/20 bg-brand-cream-deep px-3 py-2 text-sm text-brand-ink focus:outline-none focus:ring-2 focus:ring-violet-400"
                    placeholder={lang === "es" ? "Ej: Lavar el carro" : "e.g. Wash the car"} />
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink mb-1">{lang === "es" ? "Descripción" : "Description"}</label>
                <textarea id="f-description" name="description" rows={2}
                    class="w-full rounded-xl border border-brand-ink/20 bg-brand-cream-deep px-3 py-2 text-sm text-brand-ink focus:outline-none focus:ring-2 focus:ring-violet-400"
                    placeholder={lang === "es" ? "Detalles opcionales..." : "Optional details..."} />
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-brand-ink mb-1">{lang === "es" ? "Pago ($MXN) *" : "Pay ($MXN) *"}</label>
                    <input type="number" id="f-points" name="points" required min="1"
                        class="w-full rounded-xl border border-brand-ink/20 bg-brand-cream-deep px-3 py-2 text-sm text-brand-ink focus:outline-none focus:ring-2 focus:ring-violet-400"
                        placeholder="50" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-brand-ink mb-1">{lang === "es" ? "Dificultad" : "Difficulty"}</label>
                    <select id="f-difficulty" name="difficulty"
                        class="w-full rounded-xl border border-brand-ink/20 bg-brand-cream-deep px-3 py-2 text-sm text-brand-ink focus:outline-none focus:ring-2 focus:ring-violet-400"
                    >
                        <option value="1">{lang === "es" ? "Fácil" : "Easy"}</option>
                        <option value="2">{lang === "es" ? "Medio" : "Medium"}</option>
                        <option value="3">{lang === "es" ? "Difícil" : "Hard"}</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink mb-1">{lang === "es" ? "Frecuencia de pago" : "Payout cadence"}</label>
                <select id="f-cadence" name="payout_cadence" data-tour="gig-cadence"
                    class="w-full rounded-xl border border-brand-ink/20 bg-brand-cream-deep px-3 py-2 text-sm text-brand-ink focus:outline-none focus:ring-2 focus:ring-violet-400"
                >
                    <option value="immediate">{lang === "es" ? "Inmediato" : "Immediate"}</option>
                    <option value="weekly">{lang === "es" ? "Semanal" : "Weekly"}</option>
                    <option value="biweekly">{lang === "es" ? "Quincenal" : "Biweekly"}</option>
                    <option value="monthly">{lang === "es" ? "Mensual" : "Monthly"}</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-brand-ink mb-1">{lang === "es" ? "Categoría" : "Category"}</label>
                <select id="f-category" name="category"
                    class="w-full rounded-xl border border-brand-ink/20 bg-brand-cream-deep px-3 py-2 text-sm text-brand-ink focus:outline-none focus:ring-2 focus:ring-violet-400"
                >
                    <option value="chores">{lang === "es" ? "Quehaceres" : "Chores"}</option>
                    <option value="errands">{lang === "es" ? "Mandados" : "Errands"}</option>
                    <option value="creative">{lang === "es" ? "Creativo" : "Creative"}</option>
                    <option value="learning">{lang === "es" ? "Aprendizaje" : "Learning"}</option>
                    <option value="outdoor">{lang === "es" ? "Al Aire Libre" : "Outdoor"}</option>
                    <option value="other">{lang === "es" ? "Otro" : "Other"}</option>
                </select>
            </div>
            <label class="flex items-start gap-3 rounded-xl bg-brand-cream-deep/60 px-3 py-2.5 cursor-pointer">
                <input type="checkbox" id="f-allow-multiple" name="allow_multiple"
                    class="mt-0.5 h-4 w-4 rounded border-brand-ink/30 text-violet-600 focus:ring-violet-400" />
                <span class="text-sm text-brand-ink">
                    <span class="font-medium">{lang === "es" ? "Varios niños pueden hacerla" : "Multiple kids can do it"}</span>
                    <span class="block text-xs text-brand-ink-soft mt-0.5">
                        {lang === "es"
                            ? `Si está apagado, la ${gt.one} se cierra al aprobar la primera entrega (nadie cobra doble).`
                            : `If off, the ${gt.one} closes once the first submission is approved (no double pay).`}
                    </span>
                </span>
            </label>
            <button type="submit"
                data-tour="gig-submit"
                class="w-full py-3 bg-violet-600 text-white font-bold rounded-xl hover:bg-violet-700 active:scale-[.98] transition-all"
            >
                {lang === "es" ? "Guardar" : "Save"}
            </button>
        </form>
    </div>
</div>

<script>
const lang = document.cookie.split(";").find(c => c.trim().startsWith("lang="))?.split("=")[1] ?? "es";
const modal = document.getElementById("gig-modal")!;
const modalTitle = document.getElementById("modal-title")!;
const form = document.getElementById("gig-form") as HTMLFormElement;
const editIdInput = document.getElementById("edit-gig-id") as HTMLInputElement;
// Resolved gig-term ("Gig"/"Chamba"), threaded from the Astro frontmatter via
// a data attribute since this hoisted script has no access to gigTerm().
const termOne = modal.dataset.termOne || "Gig";

const openModal = (title: string) => {
    modalTitle.textContent = title;
    modal.classList.remove("hidden");
};
const closeModal = () => {
    modal.classList.add("hidden");
    form.reset();
    editIdInput.value = "";
};

document.getElementById("new-gig-btn")!.addEventListener("click", () => {
    openModal(lang === "es" ? `Nueva ${termOne}` : `New ${termOne}`);
    // The FAB always opens this modal — dispatch alongside the real action,
    // additive only (mirrors TaskCreateModal's task-modal-open pattern).
    window.dispatchEvent(new CustomEvent("ftm:mission", { detail: { signal: "gig-modal-open" } }));
});
document.getElementById("close-modal")!.addEventListener("click", closeModal);
modal.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });

const cadenceSelect = document.getElementById("f-cadence") as HTMLSelectElement;
cadenceSelect?.addEventListener("change", () => {
    window.dispatchEvent(new CustomEvent("ftm:mission", { detail: { signal: "gig-cadence-set" } }));
});

document.querySelectorAll(".edit-gig-btn").forEach(btn => {
    btn.addEventListener("click", () => {
        const b = btn as HTMLElement;
        editIdInput.value = b.dataset.id!;
        (document.getElementById("f-title") as HTMLInputElement).value = b.dataset.title!;
        (document.getElementById("f-description") as HTMLTextAreaElement).value = b.dataset.description!;
        (document.getElementById("f-points") as HTMLInputElement).value = b.dataset.points!;
        (document.getElementById("f-difficulty") as HTMLSelectElement).value = b.dataset.difficulty!;
        (document.getElementById("f-category") as HTMLSelectElement).value = b.dataset.category!;
        (document.getElementById("f-allow-multiple") as HTMLInputElement).checked = b.dataset.allowMultiple === "1";
        (document.getElementById("f-cadence") as HTMLSelectElement).value = b.dataset.payoutCadence || "immediate";
        openModal(lang === "es" ? `Editar ${termOne}` : `Edit ${termOne}`);
    });
});

form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const gigId = editIdInput.value;
    const payload = {
        title: (document.getElementById("f-title") as HTMLInputElement).value,
        description: (document.getElementById("f-description") as HTMLTextAreaElement).value || null,
        points: parseInt((document.getElementById("f-points") as HTMLInputElement).value),
        difficulty: parseInt((document.getElementById("f-difficulty") as HTMLSelectElement).value),
        category: (document.getElementById("f-category") as HTMLSelectElement).value,
        allow_multiple: (document.getElementById("f-allow-multiple") as HTMLInputElement).checked,
        payout_cadence: (document.getElementById("f-cadence") as HTMLSelectElement).value,
    };
    const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
    btn.disabled = true;

    const res = gigId
        ? await fetch(`/api/gigs/offerings/${gigId}`, { method: "PUT", headers: {"Content-Type":"application/json"}, body: JSON.stringify(payload) })
        : await fetch("/api/gigs/offerings", { method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify(payload) });

    if (res.ok) {
        // Success-gated: only a real CREATE (not an edit save) satisfies the
        // "create your first gig" mission's final step.
        if (!gigId) {
            window.dispatchEvent(new CustomEvent("ftm:mission", { detail: { signal: "gig-created" } }));
        }
        closeModal();
        window.location.reload();
    } else {
        const err = await res.json().catch(() => ({ detail: "Error" }));
        btn.disabled = false;
        alert(err.detail ?? "Error");
    }
});

// ── Kid proposals: approve (with optional price edit) / reject ──────
document.querySelectorAll<HTMLElement>("[data-proposal-card]").forEach(card => {
    card.querySelectorAll<HTMLButtonElement>("[data-proposal-action]").forEach(btn => {
        btn.addEventListener("click", async () => {
            const approve = btn.dataset.proposalAction === "approve";
            if (!approve && !confirm(lang === "es" ? "¿Rechazar esta propuesta?" : "Reject this proposal?")) return;
            const id = card.dataset.id;
            const pointsInput = card.querySelector<HTMLInputElement>("[data-proposal-points]");
            const notesInput = card.querySelector<HTMLInputElement>("[data-proposal-notes]");
            const points = pointsInput ? parseInt(pointsInput.value, 10) : NaN;
            btn.disabled = true;
            const res = await fetch(`/api/gigs/offerings/${id}/review`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    approve,
                    points: approve && !isNaN(points) && points > 0 ? points : null,
                    notes: notesInput?.value.trim() || null,
                }),
            });
            if (res.ok) {
                // Approved gigs join the live board — reload so they render there.
                window.location.reload();
            } else {
                const err = await res.json().catch(() => ({ detail: "Error" }));
                btn.disabled = false;
                alert(err.detail ?? "Error");
            }
        });
    });
});

document.querySelectorAll(".archive-gig-btn").forEach(btn => {
    btn.addEventListener("click", async () => {
        if (!confirm(lang === "es" ? `¿Archivar esta ${termOne.toLowerCase()}?` : `Archive this ${termOne.toLowerCase()}?`)) return;
        const b = btn as HTMLElement;
        const res = await fetch(`/api/gigs/offerings/${b.dataset.id}`, { method: "DELETE" });
        if (res.ok) {
            // Drop the card in place. If it was the last one, reload so the
            // server-rendered empty state shows cleanly.
            b.closest("[data-gig-card]")?.remove();
            if (document.querySelectorAll("[data-gig-card]").length === 0) {
                window.location.reload();
            }
        } else {
            const err = await res.json().catch(() => ({ detail: "Error" }));
            alert(err.detail ?? "Error");
        }
    });
});

// History: filter cards by kid.
const kidFilter = document.getElementById("history-kid-filter") as HTMLSelectElement | null;
kidFilter?.addEventListener("change", () => {
    const who = kidFilter.value;
    document.querySelectorAll<HTMLElement>("[data-history-card]").forEach((card) => {
        card.classList.toggle("hidden", Boolean(who) && card.dataset.claimer !== who);
    });
});

// ---- History comment threads (load on expand, post inline) ----
const dlang = document.documentElement.lang === "es" ? "es-MX" : "en-US";
function commentRow(c: any): string {
    const when = new Date(c.created_at).toLocaleDateString(dlang, { month: "short", day: "numeric" });
    const div = document.createElement("div");
    div.className = "text-xs bg-brand-cream-deep rounded-lg px-2.5 py-1.5";
    div.innerHTML = `<strong></strong> <span class="text-brand-ink-soft"></span><br/>`;
    (div.querySelector("strong") as HTMLElement).textContent = c.author_name;
    (div.querySelector("span") as HTMLElement).textContent = when;
    div.appendChild(document.createTextNode(c.body));
    return div.outerHTML;
}
document.querySelectorAll<HTMLDetailsElement>("[data-comments]").forEach((box) => {
    const claimId = box.dataset.claimId;
    const list = box.querySelector("[data-comments-list]") as HTMLElement;
    let loaded = false;
    box.addEventListener("toggle", async () => {
        if (!box.open || loaded) return;
        loaded = true;
        const r = await fetch(`/api/gigs/claims/${claimId}/comments`);
        if (r.ok) list.innerHTML = ((await r.json()) as any[]).map(commentRow).join("");
    });
    box.querySelector("[data-comment-form]")?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const input = (e.target as HTMLFormElement).querySelector("input[name=body]") as HTMLInputElement;
        const body = input.value.trim();
        if (!body) return;
        const r = await fetch(`/api/gigs/claims/${claimId}/comments`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ body }),
        });
        if (r.ok) {
            list.insertAdjacentHTML("beforeend", commentRow(await r.json()));
            input.value = "";
        }
    });
});
</script>

<script>
    import { buildMission } from "../../lib/tourSteps";
    import { runMission } from "../../lib/missionRunner";

    function resumeMissions() {
        if ((window as any).__ftmMissionInit) return;
        (window as any).__ftmMissionInit = true;
        const lang = document.documentElement.lang === "es" ? "es" : "en";
        // Resume an in-progress mission (e.g. "first-gig", once wired) now
        // that this page hosts its next target. Degrades gracefully — if the
        // step's element isn't here, the runner just ends the mission.
        for (const id of ["first-task", "first-gig"] as const) {
            if (sessionStorage.getItem("ftm_mission_" + id)) runMission(buildMission(id, lang), lang);
        }
    }

    document.addEventListener("astro:page-load", resumeMissions);
    // The one-shot astro:page-load fires on DOMContentLoaded; a module that
    // executes after that would miss it (see WelcomeTour.astro). Self-trigger
    // if the DOM is already ready — __ftmMissionInit keeps this idempotent.
    if (document.readyState !== "loading") resumeMissions();
</script>
