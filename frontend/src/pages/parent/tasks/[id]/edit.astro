                                {t(lang, "pt_interval_daily")}
                            </option>
                            <option value="3" selected={tmpl.interval_days === 3}>
                                {t(lang, "pt_interval_every3")}
                            </option>
                            <option value="7" selected={tmpl.interval_days === 7}>
                                {t(lang, "pt_interval_weekly")}
                            </option>
                        </select>
                    </div>
                </div>
                
                <div class="pt-2 border-t border-brand-ink/10">
                    <label class="text-sm font-medium text-brand-ink mb-1 block">
                        {t(lang, "pt_assignment_type")}
                    </label>
                    <select
