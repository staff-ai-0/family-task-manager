---
import PageLayout from "@components/ui/PageLayout.astro";
import { apiFetch } from "../../../../lib/api";
import { t } from "../../../../lib/i18n";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = Astro.cookies.get("lang")?.value ?? "es";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

const { id } = Astro.params;
let errorMsg = "";

if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    const assignmentType = data.get("assignment_type") || "auto";
    const assignedUserIds = data.getAll("assigned_user_ids[]").filter(id => id);
    const allowedRoles = data.getAll("allowed_roles[]").filter(r => r);

    const payload: any = {
        title: data.get("title"),
        description: data.get("description") || null,
        title_es: data.get("title_es") || null,
        description_es: data.get("description_es") || null,
        points: Number(data.get("points")) || 10,
        effort_level: Number(data.get("effort_level")) || 1,
        interval_days: Number(data.get("interval_days")) || 1,
        is_bonus: data.get("is_bonus") === "on",
        blocks_rewards: data.get("blocks_rewards") === "on",
        gig_mode: data.get("gig_mode") || "claim",
        collaboration_min_count: Number(data.get("collaboration_min_count")) || 2,
        auto_late_penalty: data.get("auto_late_penalty") === "on",
        late_restriction_type: data.get("late_restriction_type") || null,
        late_severity: data.get("late_severity") || null,
        late_duration_days: Number(data.get("late_duration_days")) || 1,
        assignment_type: assignmentType,
        assigned_user_ids: assignedUserIds.length > 0 ? assignedUserIds : null,
        allowed_roles: allowedRoles.length > 0 ? allowedRoles : null,
    };

    const { ok, error } = await apiFetch(`/api/task-templates/${id}`, {
        method: "PUT",
        token,
        body: JSON.stringify(payload),
    });
    if (ok) {
        return Astro.redirect("/parent/tasks");
    } else {
        errorMsg = error || "Error";
    }
}

const [{ data: tmpl }, { data: familyMembers }] = await Promise.all([
    apiFetch<any>(`/api/task-templates/${id}`, { token }),
    apiFetch<any[]>(`/api/families/${user.family_id}/members`, { token }),
]);
if (!tmpl) return Astro.redirect("/parent/tasks");
const memberList: any[] = Array.isArray(familyMembers) ? familyMembers : [];
---

<PageLayout
    title={t(lang, "pt_edit_title") as string}
    tone="sky"
    backHref="/parent/tasks"
    backLabel={t(lang, "back_all_tasks") as string}
    role={user.role}
    active="parent"
    lang={lang as "en" | "es"}
>
            {errorMsg && (
                <div class="mb-4 p-3 bg-red-100 border border-red-200 text-red-700 text-sm rounded-xl">
                    {errorMsg}
                </div>
            )}
            <form
                method="POST"
                class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 space-y-4"
            >
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-3">
                        <h3 class="text-xs font-semibold text-brand-ink-soft uppercase tracking-wider">English</h3>
                        <div>
                            <label class="text-xs font-medium text-brand-ink mb-1 block">
                                {t(lang, "pt_task_title")}
                            </label>
                            <input
                                name="title"
                                required
                                value={tmpl.title}
                                class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none"
                            />
                        </div>
                        <div>
                            <label class="text-xs font-medium text-brand-ink mb-1 block">
                                {t(lang, "pt_description")}
                            </label>
                            <textarea
                                name="description"
                                rows={3}
                                class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none resize-none"
                            >{tmpl.description}</textarea>
                        </div>
                    </div>
                    
                    <div class="space-y-3 relative">
                        <div class="flex items-center justify-between">
                            <h3 class="text-xs font-semibold text-brand-ink-soft uppercase tracking-wider">Español</h3>
                            <button
                                type="button"
                                id="btn-translate"
                                data-id={id}
                                data-token={token}
                                class="text-xs bg-indigo-50 text-brand-coral-deep px-2 py-1 rounded hover:bg-brand-coral-deep transition-colors flex items-center gap-1"
                            >
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path></svg>
                                {t(lang, "translation_auto_translate")}
                            </button>
                        </div>
                        <div>
                            <label class="text-xs font-medium text-brand-ink mb-1 block">
                                {t(lang, "translation_title_es")}
                            </label>
                            <input
                                name="title_es"
                                id="input-title-es"
                                value={tmpl.title_es || ""}
                                placeholder={t(lang, "translation_title_es")}
                                class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none"
                            />
                        </div>
                        <div>
                            <label class="text-xs font-medium text-brand-ink mb-1 block">
                                {t(lang, "translation_desc_es")}
                            </label>
                            <textarea
                                name="description_es"
                                id="input-desc-es"
                                rows={3}
                                placeholder={t(lang, "translation_desc_es")}
                                class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none resize-none"
                            >{tmpl.description_es || ""}</textarea>
                        </div>
                        <div id="translate-status" class="text-xs text-center hidden"></div>
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-3 pt-2 border-t border-brand-ink/10">
                    <div>
                        <label class="text-sm font-medium text-brand-ink mb-1 block">
                            {t(lang, "pt_points")}
                        </label>
                        <input
                            type="number"
                            name="points"
                            min={1}
                            max={1000}
                            value={tmpl.points}
                            class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none"
                        />
                    </div>
                    <div>
                        <label class="text-sm font-medium text-brand-ink mb-1 block">
                            {lang === "es" ? "Dificultad" : "Difficulty"}
                        </label>
                        <select
                            name="effort_level"
                            class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none bg-brand-cream"
                            title={lang === "es" ? "Multiplica los puntos al aprobar" : "Multiplies points on approval"}
                        >
                            <option value="1" selected={(tmpl.effort_level ?? 1) === 1}>{lang === "es" ? "Fácil ×1" : "Easy ×1"}</option>
                            <option value="2" selected={tmpl.effort_level === 2}>{lang === "es" ? "Medio ×1.5" : "Medium ×1.5"}</option>
                            <option value="3" selected={tmpl.effort_level === 3}>{lang === "es" ? "Difícil ×2" : "Hard ×2"}</option>
                        </select>
                    </div>
                    <div>
                        <label class="text-sm font-medium text-brand-ink mb-1 block">
                            {t(lang, "pt_interval")}
                        </label>
                        <select
                            name="interval_days"
                            class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none bg-brand-cream"
                        >
                            <option value="1" selected={tmpl.interval_days === 1}>
                                {t(lang, "pt_interval_daily")}
                            </option>
                            <option value="3" selected={tmpl.interval_days === 3}>
                                {t(lang, "pt_interval_every3")}
                            </option>
                            <option value="7" selected={tmpl.interval_days === 7}>
                                {t(lang, "pt_interval_weekly")}
                            </option>
                        </select>
                    </div>
                </div>
                
                <div class="pt-2 border-t border-brand-ink/10">
                    <label class="text-sm font-medium text-brand-ink mb-1 block">
                        {t(lang, "pt_assignment_type")}
                    </label>
                    <select
                        id="assignment_type"
                        name="assignment_type"
                        class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none bg-brand-cream"
                        onchange="toggleUserSelection(this.value)"
                    >
                        <option value="auto" selected={!tmpl.assignment_type || tmpl.assignment_type === 'auto'}>
                            {t(lang, "pt_assignment_auto")}
                        </option>
                        <option value="fixed" selected={tmpl.assignment_type === 'fixed'}>
                            {t(lang, "pt_assignment_fixed")}
                        </option>
                        <option value="rotate" selected={tmpl.assignment_type === 'rotate'}>
                            {t(lang, "pt_assignment_rotate")}
                        </option>
                    </select>
                </div>

                <div id="user_selection_container" class={(!tmpl.assignment_type || tmpl.assignment_type === 'auto') ? 'hidden' : ''}>
                    <label class="text-sm font-medium text-brand-ink mb-1 block">
                        {t(lang, "pt_assign_to")}
                    </label>
                    <div class="space-y-2 p-3 bg-brand-cream-deep rounded-lg border border-brand-ink/10">
                        {memberList.map((member: any) => {
                            const isChecked = tmpl.assigned_user_ids && Array.isArray(tmpl.assigned_user_ids)
                                ? tmpl.assigned_user_ids.includes(member.id)
                                : false;
                            return (
                                <label class="flex items-center gap-2 cursor-pointer hover:bg-brand-cream px-2 py-1.5 rounded transition-colors">
                                    <input
                                        type="checkbox"
                                        name="assigned_user_ids[]"
                                        value={member.id}
                                        checked={isChecked}
                                        class="w-4 h-4 text-brand-sky-deep border-brand-ink/20 rounded focus:ring-2 focus:ring-brand-sky-deep"
                                    />
                                    <span class="text-sm text-brand-ink">{member.name}</span>
                                    <span class="text-xs text-brand-ink-soft ml-auto">{member.role.toLowerCase()}</span>
                                </label>
                            );
                        })}
                    </div>
                    <p class="text-xs text-brand-ink-soft mt-1">
                        {t(lang, "pt_assign_hint_fixed")} {t(lang, "pt_assign_hint_rotate")}
                    </p>
                </div>

                <div class="pt-2 border-t border-brand-ink/10">
                    <label class="text-sm font-medium text-brand-ink mb-1 block">
                        {t(lang, "pt_allowed_roles")}
                    </label>
                    <div class="flex gap-3 flex-wrap p-3 bg-brand-cream-deep rounded-lg border border-brand-ink/10">
                        {["parent", "teen", "child"].map((role) => {
                            const checked = Array.isArray(tmpl.allowed_roles) && tmpl.allowed_roles.includes(role);
                            const labelKey = role === "parent" ? "pt_role_parent" : role === "teen" ? "pt_role_teen" : "pt_role_child";
                            return (
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" name="allowed_roles[]" value={role} checked={checked} class="w-4 h-4 text-brand-sky-deep border-brand-ink/20 rounded focus:ring-2 focus:ring-brand-sky-deep" />
                                    <span class="text-sm text-brand-ink">{t(lang, labelKey)}</span>
                                </label>
                            );
                        })}
                    </div>
                    <p class="text-xs text-brand-ink-soft mt-1">{t(lang, "pt_allowed_roles_hint")}</p>
                </div>
                
                <div class="flex items-center gap-3 py-1">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input
                            type="checkbox"
                            name="is_bonus"
                            class="sr-only peer"
                            checked={tmpl.is_bonus}
                        />
                        <div class="w-9 h-5 bg-brand-cream-deep rounded-full peer peer-checked:bg-brand-sun-deep peer-focus:ring-2 peer-focus:ring-amber-300 transition-colors after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-brand-cream after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-full"></div>
                    </label>
                    <div>
                        <span class="text-sm font-medium text-brand-ink">{t(lang, "pt_is_bonus")}</span>
                        <p class="text-xs text-brand-ink-soft">{t(lang, "pt_is_bonus_hint")}</p>
                    </div>
                </div>

                <div>
                    <label class="text-sm font-medium text-brand-ink mb-1 block">
                        {lang === "es" ? "Modo de gig" : "Gig mode"}
                    </label>
                    <select
                        name="gig_mode"
                        class="w-full px-3 py-2 rounded-lg border border-brand-ink/20 text-sm bg-brand-cream"
                    >
                        <option value="claim" selected={!tmpl.gig_mode || tmpl.gig_mode === "claim"}>
                            {lang === "es" ? "Reservar (default)" : "Claim (default)"}
                        </option>
                        <option value="competition" selected={tmpl.gig_mode === "competition"}>
                            {lang === "es" ? "🏆 Competencia (primero gana)" : "🏆 Competition (first wins)"}
                        </option>
                        <option value="rotation" selected={tmpl.gig_mode === "rotation"}>
                            {lang === "es" ? "🔄 Rotación" : "🔄 Rotation"}
                        </option>
                        <option value="collaboration" selected={tmpl.gig_mode === "collaboration"}>
                            {lang === "es" ? "🤝 Colaboración" : "🤝 Collaboration"}
                        </option>
                    </select>
                </div>

                <div class="flex items-center gap-3 py-1">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input
                            type="checkbox"
                            name="blocks_rewards"
                            class="sr-only peer"
                            checked={tmpl.blocks_rewards}
                        />
                        <div class="w-9 h-5 bg-brand-cream-deep rounded-full peer peer-checked:bg-brand-coral-deep peer-focus:ring-2 peer-focus:ring-red-300 transition-colors after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-brand-cream after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-full"></div>
                    </label>
                    <div>
                        <span class="text-sm font-medium text-brand-ink">🔒 {lang === "es" ? "Bloquea recompensas" : "Blocks rewards"}</span>
                        <p class="text-xs text-brand-ink-soft">
                            {lang === "es"
                                ? "Si esta tarea está pendiente, el niño no puede canjear recompensas."
                                : "Child can't redeem rewards while this task is open."}
                        </p>
                    </div>
                </div>

                <details class="bg-brand-cream-deep/50 rounded-lg p-3 border border-brand-ink/10" open={tmpl.auto_late_penalty}>
                    <summary class="text-sm font-medium text-brand-ink cursor-pointer">
                        ⏰ {lang === "es" ? "Penalización por retraso (opcional)" : "Late penalty (optional)"}
                    </summary>
                    <div class="mt-3 space-y-2">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox" name="auto_late_penalty" checked={tmpl.auto_late_penalty} class="w-4 h-4 text-brand-coral-deep border-brand-ink/20 rounded focus:ring-2" />
                            <span class="text-sm text-brand-ink">{lang === "es" ? "Aplicar penalización si vence" : "Apply penalty when overdue"}</span>
                        </label>
                        <div class="grid grid-cols-3 gap-2">
                            <select name="late_restriction_type" class="px-2 py-1.5 rounded-lg border border-brand-ink/20 text-xs bg-brand-cream">
                                <option value="" selected={!tmpl.late_restriction_type}>{lang === "es" ? "Tipo…" : "Type…"}</option>
                                <option value="screen_time" selected={tmpl.late_restriction_type === "screen_time"}>{lang === "es" ? "Pantalla" : "Screen"}</option>
                                <option value="rewards" selected={tmpl.late_restriction_type === "rewards"}>{lang === "es" ? "Recompensas" : "Rewards"}</option>
                                <option value="activities" selected={tmpl.late_restriction_type === "activities"}>{lang === "es" ? "Actividades" : "Activities"}</option>
                                <option value="allowance" selected={tmpl.late_restriction_type === "allowance"}>{lang === "es" ? "Mesada" : "Allowance"}</option>
                                <option value="extra_tasks" selected={tmpl.late_restriction_type === "extra_tasks"}>{lang === "es" ? "Tareas extra" : "Extra tasks"}</option>
                            </select>
                            <select name="late_severity" class="px-2 py-1.5 rounded-lg border border-brand-ink/20 text-xs bg-brand-cream">
                                <option value="low" selected={!tmpl.late_severity || tmpl.late_severity === "low"}>{lang === "es" ? "Leve" : "Low"}</option>
                                <option value="medium" selected={tmpl.late_severity === "medium"}>{lang === "es" ? "Media" : "Medium"}</option>
                                <option value="high" selected={tmpl.late_severity === "high"}>{lang === "es" ? "Alta" : "High"}</option>
                            </select>
                            <input
                                type="number"
                                name="late_duration_days"
                                min="1"
                                max="30"
                                value={tmpl.late_duration_days ?? 1}
                                class="px-2 py-1.5 rounded-lg border border-brand-ink/20 text-xs bg-brand-cream"
                                title={lang === "es" ? "Días" : "Days"}
                            />
                        </div>
                    </div>
                </details>

                <button
                    type="submit"
                    class="w-full py-2.5 bg-brand-sky-deep hover:bg-brand-ink text-white font-semibold text-sm rounded-lg transition-colors shadow-[var(--shadow-card)]"
                >
                    {t(lang, "pt_save")}
                </button>
            </form>
</PageLayout>

<script>
    document.addEventListener('astro:page-load', () => {
    (window as any).toggleUserSelection = function(assignmentType: string) {
        const container = document.getElementById('user_selection_container');
        if (container) {
            if (assignmentType === 'fixed' || assignmentType === 'rotate') {
                container.classList.remove('hidden');
            } else {
                container.classList.add('hidden');
            }
        }
    };

    const btnTranslate = document.getElementById("btn-translate");
    const statusDiv = document.getElementById("translate-status");
    const titleInput = document.getElementById("input-title-es") as HTMLInputElement;
    const descInput = document.getElementById("input-desc-es") as HTMLTextAreaElement;

    if (btnTranslate) {
        btnTranslate.addEventListener("click", async () => {
            const id = btnTranslate.dataset.id;
            if (!id) return;

            // Show loading
            if (statusDiv) {
                statusDiv.textContent = "Translating...";
                statusDiv.classList.remove("hidden", "text-brand-mint-deep", "text-red-600");
                statusDiv.classList.add("text-brand-ink-soft");
            }
            btnTranslate.setAttribute("disabled", "true");
            btnTranslate.classList.add("opacity-50", "cursor-not-allowed");

            try {
                const res = await fetch(`/api/translate/${id}`, {
                    method: "POST",
                });
                
                if (!res.ok) throw new Error("Translation failed");
                
                const data = await res.json();
                
                if (data.title_es) titleInput.value = data.title_es;
                if (data.description_es) descInput.value = data.description_es;

                if (statusDiv) {
                    statusDiv.textContent = "Translation complete!";
                    statusDiv.classList.remove("text-brand-ink-soft");
                    statusDiv.classList.add("text-brand-mint-deep");
                }
            } catch (err) {
                console.error(err);
                if (statusDiv) {
                    statusDiv.textContent = "Error translating. Please try again.";
                    statusDiv.classList.remove("text-brand-ink-soft");
                    statusDiv.classList.add("text-red-600");
                }
            } finally {
                btnTranslate.removeAttribute("disabled");
                btnTranslate.classList.remove("opacity-50", "cursor-not-allowed");
                
                // Clear status after 3s
                setTimeout(() => {
                    if (statusDiv) statusDiv.classList.add("hidden");
                }, 3000);
            }
        });
    }
    });
</script>
