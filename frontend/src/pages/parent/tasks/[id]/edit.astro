                </div>

                <div class="grid grid-cols-3 gap-3 pt-2 border-t border-brand-ink/10">
                    <div>
                        <label class="text-sm font-medium text-brand-ink mb-1 block">
                            {t(lang, "pt_points")}
                        </label>
                        <input
                            type="number"
                            name="points"
                            min={1}
                            max={1000}
