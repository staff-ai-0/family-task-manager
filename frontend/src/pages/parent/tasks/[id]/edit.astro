---
import PageLayout from "@components/ui/PageLayout.astro";
import { apiFetch } from "../../../../lib/api";
import { t } from "../../../../lib/i18n";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "en") as "en" | "es";
const otherLang = lang === "es" ? "en" : "es";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

const { id } = Astro.params;
let errorMsg = "";

// Translate arbitrary text via the stateless backend endpoint (server-side, non-fatal).
// Returns null on failure so callers fall back gracefully.
async function translateText(
    title: string,
    description: string | null,
    source: string,
    target: string,
): Promise<{ title: string; description: string | null } | null> {
    if (!title || source === target) return { title, description };
    const { ok, data } = await apiFetch<any>("/api/task-templates/translate-text", {
        method: "POST",
        token,
        body: JSON.stringify({
            title,
            description: description || null,
            source_lang: source,
            target_lang: target,
        }),
    });
    return ok && data ? { title: data.title, description: data.description ?? null } : null;
}

if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    const assignmentType = data.get("assignment_type") || "auto";
    const assignedUserIds = data.getAll("assigned_user_ids[]").filter((v) => v);
    const allowedRoles = data.getAll("allowed_roles[]").filter((r) => r);

    // The single visible field pair holds the UI-language text (primary); the
    // collapsed "View translation" panel holds the other language (secondary).
    const primaryTitle = ((data.get("title") as string) || "").trim();
    const primaryDesc = ((data.get("description") as string) || "").trim() || null;
    let altTitle = ((data.get("title_alt") as string) || "").trim();
    let altDesc = ((data.get("description_alt") as string) || "").trim() || null;

    // Originals (hidden fields) let us tell an untouched translation from a hand-edited one.
    const origPrimaryTitle = ((data.get("title_orig") as string) || "").trim();
    const origPrimaryDesc = ((data.get("desc_orig") as string) || "").trim();
    const origAltTitle = ((data.get("alt_title_orig") as string) || "").trim();
    const origAltDesc = ((data.get("alt_desc_orig") as string) || "").trim();
    const primaryChanged =
        primaryTitle !== origPrimaryTitle || (primaryDesc || "") !== origPrimaryDesc;
    const altHandEdited =
        altTitle !== origAltTitle || (altDesc || "") !== origAltDesc;

    // Refresh the other language when it is blank, or when the parent changed the primary
    // text but left the (auto-filled) translation untouched. A hand-edited translation is kept.
    if (primaryTitle && (!altTitle || (primaryChanged && !altHandEdited))) {
        const tr = await translateText(primaryTitle, primaryDesc, lang, otherLang);
        if (tr) {
            altTitle = (tr.title || "").trim();
            altDesc = tr.description ?? null;
        }
    }

    // Normalize primary/secondary back onto the canonical columns.
    // Invariant: title/description = English (non-null base), *_es = Spanish.
    let titleEn: string, descEn: string | null, titleEs: string | null, descEs: string | null;
    if (lang === "es") {
        titleEs = primaryTitle;
        descEs = primaryDesc;
        titleEn = altTitle || primaryTitle; // never null; degrade to ES if translation failed
        descEn = altDesc ?? primaryDesc;
    } else {
        titleEn = primaryTitle;
        descEn = primaryDesc;
        titleEs = altTitle || null;
        descEs = altDesc ?? null;
    }

    const payload: any = {
        title: titleEn,
        description: descEn || null,
        title_es: titleEs || null,
        description_es: descEs || null,
        points: Number(data.get("points")) || 10,
        effort_level: Number(data.get("effort_level")) || 1,
        interval_days: Number(data.get("interval_days")) || 1,
        is_bonus: data.get("is_bonus") === "on",
        blocks_rewards: data.get("blocks_rewards") === "on",
        gig_mode: data.get("gig_mode") || "claim",
        collaboration_min_count: Number(data.get("collaboration_min_count")) || 2,
        auto_late_penalty: data.get("auto_late_penalty") === "on",
        late_restriction_type: data.get("late_restriction_type") || null,
        late_severity: data.get("late_severity") || null,
        late_duration_days: Number(data.get("late_duration_days")) || 1,
        assignment_type: assignmentType,
        assigned_user_ids: assignedUserIds.length > 0 ? assignedUserIds : null,
        allowed_roles: allowedRoles.length > 0 ? allowedRoles : null,
    };

    const { ok, error } = await apiFetch(`/api/task-templates/${id}`, {
        method: "PUT",
        token,
        body: JSON.stringify(payload),
    });
    if (ok) {
        return Astro.redirect("/parent/tasks");
    } else {
        errorMsg = error || "Error";
    }
}

const [{ data: tmpl }, { data: familyMembers }] = await Promise.all([
    apiFetch<any>(`/api/task-templates/${id}`, { token }),
    apiFetch<any[]>(`/api/families/${user.family_id}/members`, { token }),
]);
if (!tmpl) return Astro.redirect("/parent/tasks");
const memberList: any[] = Array.isArray(familyMembers) ? familyMembers : [];

// Values for the single primary field (UI language) and the translation panel (other language).
let primaryTitleVal = (lang === "es" ? tmpl.title_es : tmpl.title) || "";
let primaryDescVal = (lang === "es" ? tmpl.description_es : tmpl.description) || "";
const altTitleVal = (lang === "es" ? tmpl.title : tmpl.title_es) || "";
const altDescVal = (lang === "es" ? tmpl.description : tmpl.description_es) || "";

// Legacy rows created before this redesign may lack the UI-language text. Translate once
// on open so the parent edits in their own language instead of the other one / a blank.
if (!primaryTitleVal && altTitleVal) {
    const tr = await translateText(altTitleVal, altDescVal || null, otherLang, lang);
    if (tr) {
        primaryTitleVal = tr.title || "";
        primaryDescVal = tr.description || "";
    } else {
        primaryTitleVal = altTitleVal;
        primaryDescVal = altDescVal;
    }
}

const primaryLangName = lang === "es" ? "Español" : "English";
const otherLangName = lang === "es" ? "English" : "Español";
---

<PageLayout
    title={t(lang, "pt_edit_title") as string}
    tone="sky"
    backHref="/parent/tasks"
    backLabel={t(lang, "back_all_tasks") as string}
    role={user.role}
    active="parent"
    lang={lang as "en" | "es"}
>
            {errorMsg && (
                <div class="mb-4 p-3 bg-red-100 border border-red-200 text-red-700 text-sm rounded-xl">
                    {errorMsg}
                </div>
            )}
            <form
                method="POST"
                class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 space-y-4"
            >
                <div class="space-y-3">
                    <h3 class="text-xs font-semibold text-brand-ink-soft uppercase tracking-wider">{primaryLangName}</h3>
                    <input type="hidden" name="title_orig" value={primaryTitleVal} />
                    <input type="hidden" name="desc_orig" value={primaryDescVal} />
                    <input type="hidden" name="alt_title_orig" value={altTitleVal} />
                    <input type="hidden" name="alt_desc_orig" value={altDescVal} />
                    <div>
                        <label class="text-xs font-medium text-brand-ink mb-1 block">
                            {t(lang, "pt_task_title")}
                        </label>
                        <input
                            name="title"
                            required
                            value={primaryTitleVal}
                            class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none"
                        />
                    </div>
                    <div>
                        <label class="text-xs font-medium text-brand-ink mb-1 block">
                            {t(lang, "pt_description")}
                        </label>
                        <textarea
                            name="description"
                            rows={3}
                            class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none resize-none"
                        >{primaryDescVal}</textarea>
                    </div>

                    <details class="bg-brand-cream-deep/40 rounded-lg border border-brand-ink/10">
                        <summary class="px-3 py-2 text-xs font-medium text-brand-ink-soft cursor-pointer select-none">
                            {t(lang, "pt_view_translation")} ({otherLangName})
                        </summary>
                        <div class="px-3 pb-3 pt-1 space-y-2">
                            <div class="flex items-center justify-between gap-2">
                                <p class="text-[11px] text-brand-ink-soft">{t(lang, "pt_translation_hint")}</p>
                                <button
                                    type="button"
                                    id="btn-translate"
                                    class="flex-shrink-0 text-xs bg-indigo-50 text-brand-coral-deep px-2 py-1 rounded hover:bg-brand-coral-deep hover:text-white transition-colors flex items-center gap-1"
                                >
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path></svg>
                                    {t(lang, "translation_auto_translate")}
                                </button>
                            </div>
                            <div>
                                <label class="text-xs font-medium text-brand-ink mb-1 block">
                                    {t(lang, "pt_task_title")} ({otherLangName})
                                </label>
                                <input
                                    name="title_alt"
                                    id="input-title-alt"
                                    value={altTitleVal}
                                    class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none"
                                />
                            </div>
                            <div>
                                <label class="text-xs font-medium text-brand-ink mb-1 block">
                                    {t(lang, "pt_description")} ({otherLangName})
                                </label>
                                <textarea
                                    name="description_alt"
                                    id="input-desc-alt"
                                    rows={3}
                                    class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none resize-none"
                                >{altDescVal}</textarea>
                            </div>
                            <div id="translate-status" class="text-xs text-center hidden"></div>
                        </div>
