                </div>

                <div id="user_selection_container" class={(!tmpl.assignment_type || tmpl.assignment_type === 'auto') ? 'hidden' : ''}>
                    <label class="text-sm font-medium text-brand-ink mb-1 block">
                        {t(lang, "pt_assign_to")}
                    </label>
                    <div class="space-y-2 p-3 bg-brand-cream-deep rounded-lg border border-brand-ink/10">
                        {memberList.map((member: any) => {
                            const isChecked = tmpl.assigned_user_ids && Array.isArray(tmpl.assigned_user_ids)
                                ? tmpl.assigned_user_ids.includes(member.id)
                                : false;
                            return (
                                <label class="flex items-center gap-2 cursor-pointer hover:bg-brand-cream px-2 py-1.5 rounded transition-colors">
                                    <input
                                        type="checkbox"
                                        name="assigned_user_ids[]"
                                        value={member.id}
                                        checked={isChecked}
                                        class="w-4 h-4 text-brand-sky-deep border-brand-ink/20 rounded focus:ring-2 focus:ring-brand-sky-deep"
                                    />
                                    <span class="text-sm text-brand-ink">{member.name}</span>
                                    <span class="text-xs text-brand-ink-soft ml-auto">{member.role.toLowerCase()}</span>
                                </label>
                            );
                        })}
                    </div>
                    <p class="text-xs text-brand-ink-soft mt-1">
                        {t(lang, "pt_assign_hint_fixed")} {t(lang, "pt_assign_hint_rotate")}
                    </p>
                </div>

                <div class="pt-2 border-t border-brand-ink/10">
                    <label class="text-sm font-medium text-brand-ink mb-1 block">
                        {t(lang, "pt_allowed_roles")}
                    </label>
                    <div class="flex gap-3 flex-wrap p-3 bg-brand-cream-deep rounded-lg border border-brand-ink/10">
                        {["parent", "teen", "child"].map((role) => {
                            const checked = Array.isArray(tmpl.allowed_roles) && tmpl.allowed_roles.includes(role);
                            const labelKey = role === "parent" ? "pt_role_parent" : role === "teen" ? "pt_role_teen" : "pt_role_child";
                            return (
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" name="allowed_roles[]" value={role} checked={checked} class="w-4 h-4 text-brand-sky-deep border-brand-ink/20 rounded focus:ring-2 focus:ring-brand-sky-deep" />
                                    <span class="text-sm text-brand-ink">{t(lang, labelKey)}</span>
                                </label>
                            );
                        })}
                    </div>
                    <p class="text-xs text-brand-ink-soft mt-1">{t(lang, "pt_allowed_roles_hint")}</p>
                </div>
                
                <div class="flex items-center gap-3 py-1">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input
                            type="checkbox"
                            name="is_bonus"
                            class="sr-only peer"
                            checked={tmpl.is_bonus}
                        />
                        <div class="w-9 h-5 bg-brand-cream-deep rounded-full peer peer-checked:bg-brand-sun-deep peer-focus:ring-2 peer-focus:ring-amber-300 transition-colors after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-brand-cream after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-full"></div>
                    </label>
                    <div>
                        <span class="text-sm font-medium text-brand-ink">{t(lang, "pt_is_bonus")}</span>
                        <p class="text-xs text-brand-ink-soft">{t(lang, "pt_is_bonus_hint")}</p>
                    </div>
                </div>

                <div>
                    <label class="text-sm font-medium text-brand-ink mb-1 block">
                        {lang === "es" ? "Modo de gig" : "Gig mode"}
                    </label>
                    <select
                        name="gig_mode"
                        class="w-full px-3 py-2 rounded-lg border border-brand-ink/20 text-sm bg-brand-cream"
                    >
                        <option value="claim" selected={!tmpl.gig_mode || tmpl.gig_mode === "claim"}>
                            {lang === "es" ? "Reservar (default)" : "Claim (default)"}
                        </option>
                        <option value="competition" selected={tmpl.gig_mode === "competition"}>
                            {lang === "es" ? "🏆 Competencia (primero gana)" : "🏆 Competition (first wins)"}
                        </option>
                        <option value="rotation" selected={tmpl.gig_mode === "rotation"}>
                            {lang === "es" ? "🔄 Rotación" : "🔄 Rotation"}
                        </option>
                        <option value="collaboration" selected={tmpl.gig_mode === "collaboration"}>
                            {lang === "es" ? "🤝 Colaboración" : "🤝 Collaboration"}
                        </option>
                    </select>
                </div>

                <div class="flex items-center gap-3 py-1">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input
                            type="checkbox"
                            name="blocks_rewards"
                            class="sr-only peer"
                            checked={tmpl.blocks_rewards}
                        />
                        <div class="w-9 h-5 bg-brand-cream-deep rounded-full peer peer-checked:bg-brand-coral-deep peer-focus:ring-2 peer-focus:ring-red-300 transition-colors after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-brand-cream after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-full"></div>
                    </label>
                    <div>
                        <span class="text-sm font-medium text-brand-ink">🔒 {lang === "es" ? "Bloquea recompensas" : "Blocks rewards"}</span>
                        <p class="text-xs text-brand-ink-soft">
                            {lang === "es"
                                ? "Si esta tarea está pendiente, el niño no puede canjear recompensas."
                                : "Child can't redeem rewards while this task is open."}
                        </p>
                    </div>
                </div>

                <details class="bg-brand-cream-deep/50 rounded-lg p-3 border border-brand-ink/10" open={tmpl.auto_late_penalty}>
                    <summary class="text-sm font-medium text-brand-ink cursor-pointer">
                        ⏰ {lang === "es" ? "Penalización por retraso (opcional)" : "Late penalty (optional)"}
                    </summary>
                    <div class="mt-3 space-y-2">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox" name="auto_late_penalty" checked={tmpl.auto_late_penalty} class="w-4 h-4 text-brand-coral-deep border-brand-ink/20 rounded focus:ring-2" />
                            <span class="text-sm text-brand-ink">{lang === "es" ? "Aplicar penalización si vence" : "Apply penalty when overdue"}</span>
                        </label>
                        <div class="grid grid-cols-3 gap-2">
                            <select name="late_restriction_type" class="px-2 py-1.5 rounded-lg border border-brand-ink/20 text-xs bg-brand-cream">
                                <option value="" selected={!tmpl.late_restriction_type}>{lang === "es" ? "Tipo…" : "Type…"}</option>
                                <option value="screen_time" selected={tmpl.late_restriction_type === "screen_time"}>{lang === "es" ? "Pantalla" : "Screen"}</option>
                                <option value="rewards" selected={tmpl.late_restriction_type === "rewards"}>{lang === "es" ? "Recompensas" : "Rewards"}</option>
                                <option value="activities" selected={tmpl.late_restriction_type === "activities"}>{lang === "es" ? "Actividades" : "Activities"}</option>
                                <option value="allowance" selected={tmpl.late_restriction_type === "allowance"}>{lang === "es" ? "Mesada" : "Allowance"}</option>
                                <option value="extra_tasks" selected={tmpl.late_restriction_type === "extra_tasks"}>{lang === "es" ? "Tareas extra" : "Extra tasks"}</option>
                            </select>
                            <select name="late_severity" class="px-2 py-1.5 rounded-lg border border-brand-ink/20 text-xs bg-brand-cream">
                                <option value="low" selected={!tmpl.late_severity || tmpl.late_severity === "low"}>{lang === "es" ? "Leve" : "Low"}</option>
                                <option value="medium" selected={tmpl.late_severity === "medium"}>{lang === "es" ? "Media" : "Medium"}</option>
                                <option value="high" selected={tmpl.late_severity === "high"}>{lang === "es" ? "Alta" : "High"}</option>
                            </select>
                            <input
                                type="number"
                                name="late_duration_days"
                                min="1"
                                max="30"
                                value={tmpl.late_duration_days ?? 1}
                                class="px-2 py-1.5 rounded-lg border border-brand-ink/20 text-xs bg-brand-cream"
                                title={lang === "es" ? "Días" : "Days"}
                            />
                        </div>
                    </div>
                </details>

                <button
                    type="submit"
                    class="w-full py-2.5 bg-brand-sky-deep hover:bg-brand-ink text-white font-semibold text-sm rounded-lg transition-colors shadow-[var(--shadow-card)]"
                >
                    {t(lang, "pt_save")}
                </button>
            </form>
</PageLayout>

<script>
    document.addEventListener('astro:page-load', () => {
    (window as any).toggleUserSelection = function(assignmentType: string) {
        const container = document.getElementById('user_selection_container');
        if (container) {
            if (assignmentType === 'fixed' || assignmentType === 'rotate') {
                container.classList.remove('hidden');
            } else {
                container.classList.add('hidden');
            }
        }
    };

    const btnTranslate = document.getElementById("btn-translate");
    const statusDiv = document.getElementById("translate-status");
    const primaryTitle = document.querySelector('input[name="title"]') as HTMLInputElement | null;
    const primaryDesc = document.querySelector('textarea[name="description"]') as HTMLTextAreaElement | null;
    const altTitle = document.getElementById("input-title-alt") as HTMLInputElement | null;
    const altDesc = document.getElementById("input-desc-alt") as HTMLTextAreaElement | null;
    const uiLang = document.documentElement.lang === "es" ? "es" : "en";
    const tgtLang = uiLang === "es" ? "en" : "es";
    const isEs = uiLang === "es";

    if (btnTranslate) {
        btnTranslate.addEventListener("click", async () => {
            // Translate the visible (UI-language) title/description into the other language.
            const title = (primaryTitle?.value || "").trim();
            if (!title) return;

            if (statusDiv) {
                statusDiv.textContent = isEs ? "Traduciendo…" : "Translating…";
                statusDiv.classList.remove("hidden", "text-brand-mint-deep", "text-red-600");
                statusDiv.classList.add("text-brand-ink-soft");
            }
            btnTranslate.setAttribute("disabled", "true");
            btnTranslate.classList.add("opacity-50", "cursor-not-allowed");

            try {
                // Proxied through /api/task-templates/[...path] — the httpOnly cookie is
                // injected server-side as a Bearer token, so no auth header is needed here.
                const res = await fetch("/api/task-templates/translate-text", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        title,
                        description: (primaryDesc?.value || "").trim() || null,
                        source_lang: uiLang,
                        target_lang: tgtLang,
                    }),
                });

                if (!res.ok) throw new Error("Translation failed");

                const data = await res.json();

                if (altTitle) altTitle.value = data.title || "";
                if (altDesc) altDesc.value = data.description || "";

                if (statusDiv) {
                    statusDiv.textContent = isEs ? "¡Listo!" : "Done!";
                    statusDiv.classList.remove("text-brand-ink-soft");
                    statusDiv.classList.add("text-brand-mint-deep");
                }
            } catch (err) {
                console.error(err);
                if (statusDiv) {
                    statusDiv.textContent = isEs ? "Error al traducir." : "Error translating.";
                    statusDiv.classList.remove("text-brand-ink-soft");
                    statusDiv.classList.add("text-red-600");
                }
            } finally {
                btnTranslate.removeAttribute("disabled");
                btnTranslate.classList.remove("opacity-50", "cursor-not-allowed");

                // Clear status after 3s
                setTimeout(() => {
                    if (statusDiv) statusDiv.classList.add("hidden");
                }, 3000);
            }
        });
    }
    });
</script>
