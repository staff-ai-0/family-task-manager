                            {lang === "es" ? "Dificultad" : "Difficulty"}
                        </label>
                        <select
                            name="effort_level"
                            class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-brand-sky-deep outline-none bg-brand-cream"
