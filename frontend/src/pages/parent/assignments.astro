---
import PageLayout from "@components/ui/PageLayout.astro";
import { apiFetch } from "../../lib/api";
import { t } from "../../lib/i18n";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "en") as "en" | "es";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

// Week navigation via query param
const url = new URL(Astro.request.url);
const weekParam = url.searchParams.get("week");

// Calculate Monday of the target week
function getMonday(d: Date): Date {
    const day = d.getDay();
    const diff = d.getDate() - day + (day === 0 ? -6 : 1);
    return new Date(d.getFullYear(), d.getMonth(), diff);
}

function formatDateISO(d: Date): string {
    return d.toISOString().split("T")[0];
}

function addDays(d: Date, n: number): Date {
    const result = new Date(d);
    result.setDate(result.getDate() + n);
    return result;
}

const today = new Date();
let weekMonday: Date;
if (weekParam) {
    weekMonday = getMonday(new Date(weekParam + "T12:00:00"));
} else {
    weekMonday = getMonday(today);
}

const prevWeek = formatDateISO(addDays(weekMonday, -7));
const nextWeek = formatDateISO(addDays(weekMonday, 7));

// Build array of 7 days (Mon-Sun)
const weekDays = Array.from({ length: 7 }, (_, i) => addDays(weekMonday, i));
const dayKeys = ["pac_day_mon", "pac_day_tue", "pac_day_wed", "pac_day_thu", "pac_day_fri", "pac_day_sat", "pac_day_sun"] as const;

// Fetch family members
const { data: family } = await apiFetch<any>("/api/families/me", { token });
const members: any[] = family?.members ?? [];

// Member filter
const memberFilter = url.searchParams.get("member") ?? "all";

// Fetch assignments for the week
let apiUrl = `/api/task-assignments/week?week_of=${formatDateISO(weekMonday)}`;
if (memberFilter !== "all") {
    apiUrl += `&user_id=${memberFilter}`;
}
const { data: assignments } = await apiFetch<any[]>(apiUrl, { token });
const allAssignments: any[] = assignments ?? [];

// Group assignments by member -> date
type AssignmentMap = Record<string, Record<string, any[]>>;
const byMember: AssignmentMap = {};

for (const a of allAssignments) {
    const memberId = a.assigned_to;
    const dateStr = a.assigned_date;
    if (!byMember[memberId]) byMember[memberId] = {};
    if (!byMember[memberId][dateStr]) byMember[memberId][dateStr] = [];
    byMember[memberId][dateStr].push(a);
}

// Get unique member IDs from assignments (preserve order from family members list)
const activeMemberIds = memberFilter !== "all"
    ? [memberFilter]
    : members.map((m: any) => m.id).filter((id: string) => byMember[id]);

// Helper: member name by ID
const memberNameMap: Record<string, string> = {};
for (const m of members) {
    memberNameMap[m.id] = m.name;
}

// Stats
const totalTasks = allAssignments.length;
const completedTasks = allAssignments.filter((a: any) => a.status === "completed").length;

// Format week range for display
const weekSunday = addDays(weekMonday, 6);
const monthNames = [
    t(lang, "month_jan"), t(lang, "month_feb"), t(lang, "month_mar"),
    t(lang, "month_apr"), t(lang, "month_may"), t(lang, "month_jun"),
    t(lang, "month_jul"), t(lang, "month_aug"), t(lang, "month_sep"),
    t(lang, "month_oct"), t(lang, "month_nov"), t(lang, "month_dec"),
];

function formatShortDate(d: Date): string {
    return `${monthNames[d.getMonth()]} ${d.getDate()}`;
}

const weekRange = `${formatShortDate(weekMonday)} - ${formatShortDate(weekSunday)}`;

// Check if a day is today
function isToday(d: Date): boolean {
    return formatDateISO(d) === formatDateISO(today);
}
---

<PageLayout
    title={t(lang, "pac_title") as string}
    role={user.role}
    active="parent"
    lang={lang}
>
    <!-- Header (week-navigator widget — page-owned via header slot) -->
    <header slot="header" class="bg-gradient-to-br from-sky-700 to-sky-600 text-white pt-12 pb-6 px-6 rounded-b-[var(--radius-tile)] shadow-[var(--shadow-card)]">
            <div class="flex items-center gap-3 mb-4">
                <a href="/parent" class="text-sky-200 hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <span class="text-sky-200 text-sm">{t(lang, "back_parent")}</span>
            </div>
            <h1 class="text-2xl font-bold">{t(lang, "pac_title")}</h1>
            <p class="text-sky-200 text-sm mt-1">{t(lang, "pac_subtitle")}</p>

            <!-- Week navigator -->
            <div class="flex items-center justify-between mt-4 bg-brand-cream/15 backdrop-blur-md rounded-xl px-4 py-3 border border-white/20">
                <a
                    href={`/parent/assignments?week=${prevWeek}${memberFilter !== "all" ? `&member=${memberFilter}` : ""}`}
                    class="text-white hover:text-sky-200 transition-colors p-1"
                    title={t(lang, "pac_prev_week")}
                >
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <div class="text-center">
                    <p class="text-xs text-sky-200 font-medium uppercase tracking-wider">{t(lang, "pac_week_of")}</p>
                    <p class="text-lg font-bold">{weekRange}</p>
                </div>
                <a
                    href={`/parent/assignments?week=${nextWeek}${memberFilter !== "all" ? `&member=${memberFilter}` : ""}`}
                    class="text-white hover:text-sky-200 transition-colors p-1"
                    title={t(lang, "pac_next_week")}
                >
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
            </div>
        </header>
            <!-- Member filter -->
            <div class="mb-4">
                <div class="flex gap-2 overflow-x-auto pb-2 -mx-1 px-1">
                    <a
                        href={`/parent/assignments?week=${formatDateISO(weekMonday)}`}
                        class:list={[
                            "px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap transition-colors",
                            memberFilter === "all"
                                ? "bg-sky-600 text-white shadow-[var(--shadow-card)]"
                                : "bg-brand-cream text-brand-ink-soft border border-brand-ink/10 hover:border-sky-300",
                        ]}
                    >
                        {t(lang, "pac_all_members")}
                    </a>
                    {members.map((m: any) => (
                        <a
                            href={`/parent/assignments?week=${formatDateISO(weekMonday)}&member=${m.id}`}
                            class:list={[
                                "px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap transition-colors",
                                memberFilter === m.id
                                    ? "bg-sky-600 text-white shadow-[var(--shadow-card)]"
                                    : "bg-brand-cream text-brand-ink-soft border border-brand-ink/10 hover:border-sky-300",
                            ]}
                        >
                            {m.name}
                        </a>
                    ))}
                </div>
            </div>

            <!-- Summary stats -->
            {totalTasks > 0 && (
                <div class="flex items-center justify-between bg-brand-cream rounded-2xl px-5 py-3 shadow-[var(--shadow-card)] border border-brand-ink/10 mb-4">
                    <span class="text-sm text-brand-ink-soft">
                        {t(lang, "pac_total_tasks")(totalTasks)}
                    </span>
                    <div class="flex items-center gap-2">
                        <div class="w-20 bg-brand-cream-deep rounded-full h-2">
                            <div
                                class="bg-brand-mint-deep h-2 rounded-full transition-all"
                                style={`width: ${totalTasks > 0 ? Math.round((completedTasks / totalTasks) * 100) : 0}%`}
                            ></div>
                        </div>
                        <span class="text-sm font-bold text-brand-ink">
                            {t(lang, "pac_completed_count")(completedTasks, totalTasks)}
                        </span>
                    </div>
                </div>
            )}

            <!-- No assignments state -->
            {totalTasks === 0 && (
                <div class="bg-brand-cream rounded-2xl p-8 text-center border border-brand-ink/10 shadow-[var(--shadow-card)]">
                    <div class="w-16 h-16 bg-brand-cream-deep rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-brand-ink-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <p class="text-brand-ink-soft text-sm">{t(lang, "pac_no_assignments")}</p>
                </div>
            )}

            <!-- Calendar grid per member -->
            {activeMemberIds.map((memberId: string) => {
                const memberAssignments = byMember[memberId] ?? {};
                const memberName = memberNameMap[memberId] ?? "?";

                // Count stats for this member
                const memberTotal = Object.values(memberAssignments).flat().length;
                const memberDone = Object.values(memberAssignments).flat().filter((a: any) => a.status === "completed").length;

                return (
                    <div class="mb-6">
                        <!-- Member header -->
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-9 h-9 rounded-full bg-sky-100 flex items-center justify-center text-sky-700 font-bold text-sm">
                                {memberName.charAt(0).toUpperCase()}
                            </div>
                            <div class="flex-1">
                                <p class="font-bold text-brand-ink">{memberName}</p>
                            </div>
                            <span class="text-xs font-medium text-brand-ink-soft">
                                {t(lang, "pac_completed_count")(memberDone, memberTotal)}
                            </span>
                        </div>

                        <!-- Day columns (md+) -->
                        <div class="hidden md:grid grid-cols-7 gap-1">
                            {/* Day headers */}
                            {dayKeys.map((dayKey, i) => (
                                <div class:list={[
                                    "text-center text-xs font-semibold py-1.5 rounded-t-lg",
                                    isToday(weekDays[i])
                                        ? "bg-sky-600 text-white"
                                        : "bg-brand-cream-deep text-brand-ink-soft",
                                ]}>
                                    <div>{t(lang, dayKey)}</div>
                                    <div class:list={[
                                        "text-xs font-normal mt-0.5",
                                        isToday(weekDays[i]) ? "text-sky-100" : "text-brand-ink-soft",
                                    ]}>
                                        {weekDays[i].getDate()}
                                    </div>
                                </div>
                            ))}

                            {/* Task cells */}
                            {weekDays.map((day) => {
                                const dateStr = formatDateISO(day);
                                const dayTasks = memberAssignments[dateStr] ?? [];
                                const todayHighlight = isToday(day);

                                return (
                                    <div class:list={[
                                        "min-h-16 p-0.5 rounded-b-lg border",
                                        todayHighlight
                                            ? "bg-sky-50 border-sky-200"
                                            : "bg-brand-cream border-brand-ink/10",
                                    ]}>
                                        {dayTasks.length === 0 && (
                                            <div class="h-full flex items-center justify-center">
                                                <span class="text-brand-ink-soft text-xs">-</span>
                                            </div>
                                        )}
                                        {dayTasks.map((task: any) => {
                                            const statusColor = task.status === "completed"
                                                ? "bg-brand-mint/20 text-brand-mint-deep border-brand-mint"
                                                : task.status === "overdue"
                                                    ? "bg-red-100 text-red-700 border-red-200"
                                                    : task.status === "cancelled"
                                                        ? "bg-brand-cream-deep text-brand-ink-soft border-brand-ink/10 line-through"
                                                        : "bg-brand-sun/20 text-brand-sun-deep border-brand-sun";

                                            const statusIcon = task.status === "completed"
                                                ? "M5 13l4 4L19 7"
                                                : task.status === "overdue"
                                                    ? "M12 8v4m0 4h.01"
                                                    : "";

                                            const displayTitle = (lang === "es" && task.template_title_es) ? task.template_title_es : task.template_title;
                                            const editable = task.status === "pending" || task.status === "overdue" || task.status === "cancelled";

                                            return (
                                                <button
                                                    type="button"
                                                    class={`w-full text-left text-xs px-1 py-0.5 mb-0.5 rounded border ${statusColor} truncate ${editable ? "hover:ring-2 hover:ring-sky-300 cursor-pointer" : "cursor-default"}`}
                                                    title={`${displayTitle} (${task.status})${task.template_is_bonus ? " [BONUS]" : ""}`}
                                                    disabled={!editable}
                                                    data-edit-assignment={editable ? "1" : undefined}
                                                    data-assignment-id={task.id}
                                                    data-assigned-to={task.assigned_to}
                                                    data-assigned-date={task.assigned_date}
                                                    data-current-status={task.status}
                                                    data-title={displayTitle}
                                                    data-points={task.template_points}
                                                    data-is-bonus={task.template_is_bonus ? "1" : "0"}
                                                >
                                                    <span class="flex items-center gap-0.5">
                                                        {statusIcon && (
                                                            <svg class="w-2.5 h-2.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                                                <path stroke-linecap="round" stroke-linejoin="round" d={statusIcon} />
                                                            </svg>
                                                        )}
                                                        {task.is_locked && (
                                                            <span class="text-[10px] flex-shrink-0" title={lang === "es" ? "Bloqueada" : "Locked"}>🔒</span>
                                                        )}
                                                        {task.approval_status === "pending" && (
                                                            <span class="text-[10px] flex-shrink-0" title={lang === "es" ? "Por aprobar" : "Awaiting approval"}>⏳</span>
                                                        )}
                                                        {task.approval_status === "rejected" && (
                                                            <span class="text-[10px] flex-shrink-0" title={lang === "es" ? "Rechazada" : "Rejected"}>✕</span>
                                                        )}
                                                        <span class="truncate text-[10px] leading-tight">
                                                            {displayTitle.length > 6
                                                                ? displayTitle.slice(0, 6) + ".."
                                                                : displayTitle}
                                                        </span>
                                                    </span>
                                                </button>
                                            );
                                        })}
                                    </div>
                                );
                            })}
                        </div>

                        <!-- Stacked day rows (mobile) -->
                        <div class="md:hidden space-y-1.5">
                            {weekDays.map((day, idx) => {
                                const dateStr = formatDateISO(day);
                                const dayTasks = memberAssignments[dateStr] ?? [];
                                const todayHighlight = isToday(day);

                                return (
                                    <div class:list={[
                                        "rounded-lg border overflow-hidden",
                                        todayHighlight ? "border-sky-300" : "border-brand-ink/10",
                                    ]}>
                                        <div class:list={[
                                            "px-3 py-1.5 flex items-center justify-between text-xs font-semibold",
                                            todayHighlight ? "bg-sky-600 text-white" : "bg-brand-cream-deep text-brand-ink-soft",
                                        ]}>
                                            <span>{t(lang, dayKeys[idx])} · {day.getDate()}</span>
                                            <span class:list={[
                                                "text-[10px] font-normal",
                                                todayHighlight ? "text-sky-100" : "text-brand-ink-soft",
                                            ]}>
                                                {dayTasks.length === 0
                                                    ? "—"
                                                    : (t(lang, "pac_total_tasks") as Function)(dayTasks.length)}
                                            </span>
                                        </div>
                                        {dayTasks.length > 0 && (
                                            <div class="bg-brand-cream p-2 space-y-1.5">
                                                {dayTasks.map((task: any) => {
                                                    const statusColor = task.status === "completed"
                                                        ? "bg-brand-mint/20 text-brand-mint-deep border-brand-mint"
                                                        : task.status === "overdue"
                                                            ? "bg-red-100 text-red-700 border-red-200"
                                                            : task.status === "cancelled"
                                                                ? "bg-brand-cream-deep text-brand-ink-soft border-brand-ink/10 line-through"
                                                                : "bg-brand-sun/20 text-brand-sun-deep border-brand-sun";
                                                    const displayTitle = (lang === "es" && task.template_title_es) ? task.template_title_es : task.template_title;
                                                    const editable = task.status === "pending" || task.status === "overdue" || task.status === "cancelled";
                                                    return (
                                                        <button
                                                            type="button"
                                                            class={`w-full flex items-center justify-between gap-2 px-3 py-2 rounded-lg border ${statusColor} text-left ${editable ? "active:scale-[0.98]" : "cursor-default"}`}
                                                            disabled={!editable}
                                                            data-edit-assignment={editable ? "1" : undefined}
                                                            data-assignment-id={task.id}
                                                            data-assigned-to={task.assigned_to}
                                                            data-assigned-date={task.assigned_date}
                                                            data-current-status={task.status}
                                                            data-title={displayTitle}
                                                            data-points={task.template_points}
                                                            data-is-bonus={task.template_is_bonus ? "1" : "0"}
                                                        >
                                                            <span class="text-sm font-medium truncate flex items-center gap-1.5 flex-wrap">
                                                                <span class="truncate">{displayTitle}</span>
                                                                {task.template_is_bonus && (
                                                                    <span class="text-[10px] font-semibold uppercase tracking-wide text-brand-sun-deep">{t(lang, "dashboard_bonus_badge")}</span>
                                                                )}
                                                                {task.is_locked && (
                                                                    <span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 text-[10px] rounded bg-amber-100 text-amber-800" title={lang === "es" ? "Termina las tareas obligatorias para desbloquear" : "Finish required tasks to unlock"}>
                                                                        <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                                                                        {lang === "es" ? "Bloqueada" : "Locked"}
                                                                    </span>
                                                                )}
                                                                {task.approval_status === "pending" && (
                                                                    <span class="px-1.5 py-0.5 text-[10px] rounded bg-amber-100 text-amber-800">
                                                                        {lang === "es" ? "Por aprobar" : "Awaiting"}
                                                                    </span>
                                                                )}
                                                                {task.approval_status === "approved" && (
                                                                    <span class="px-1.5 py-0.5 text-[10px] rounded bg-green-100 text-green-800">
                                                                        {lang === "es" ? "Aprobada" : "Approved"}
                                                                    </span>
                                                                )}
                                                                {task.approval_status === "rejected" && (
                                                                    <span class="px-1.5 py-0.5 text-[10px] rounded bg-red-100 text-red-800">
                                                                        {lang === "es" ? "Rechazada" : "Rejected"}
                                                                    </span>
                                                                )}
                                                            </span>
                                                            <span class="text-xs font-semibold whitespace-nowrap">+{task.template_points}</span>
                                                        </button>
                                                    );
                                                })}
                                            </div>
                                        )}
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                );
            })}

            <!-- Legend -->
            {totalTasks > 0 && (
                <div class="mt-4 bg-brand-cream rounded-2xl p-4 shadow-[var(--shadow-card)] border border-brand-ink/10">
                    <div class="flex flex-wrap gap-3 justify-center">
                        <div class="flex items-center gap-1.5">
                            <div class="w-3 h-3 rounded bg-brand-sun/20 border border-brand-sun"></div>
                            <span class="text-xs text-brand-ink-soft">{t(lang, "pac_status_pending")}</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <div class="w-3 h-3 rounded bg-brand-mint/20 border border-brand-mint"></div>
                            <span class="text-xs text-brand-ink-soft">{t(lang, "pac_status_completed")}</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <div class="w-3 h-3 rounded bg-red-100 border border-red-200"></div>
                            <span class="text-xs text-brand-ink-soft">{t(lang, "pac_status_overdue")}</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <div class="w-3 h-3 rounded bg-brand-cream-deep border border-brand-ink/10"></div>
                            <span class="text-xs text-brand-ink-soft">{t(lang, "pac_status_cancelled")}</span>
                        </div>
                    </div>
                </div>
            )}

    <!-- Edit-assignment modal -->
    <div id="assignment-edit-modal" class="hidden fixed inset-0 z-50 bg-slate-900/50 backdrop-blur-sm flex items-end md:items-center justify-center p-0 md:p-4">
        <div class="bg-brand-cream w-full md:max-w-md rounded-t-[var(--radius-card)] md:rounded-[var(--radius-card)] border-2 border-brand-ink shadow-[var(--shadow-pop)] border border-brand-ink/10">
            <form id="assignment-edit-form" method="POST" action="/api/assignments/patch" class="p-5 space-y-4">
                <input type="hidden" name="assignment_id" id="edit-assignment-id" />
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-xs font-medium text-brand-ink-soft uppercase tracking-wider">{t(lang, "pac_edit_title")}</p>
                        <h2 id="edit-task-title" class="text-lg font-bold text-brand-ink"></h2>
                        <p id="edit-task-meta" class="text-xs text-brand-ink-soft mt-0.5"></p>
                    </div>
                    <button type="button" id="edit-close" class="text-brand-ink-soft hover:text-brand-ink-soft">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>

                <div>
                    <label class="text-xs font-medium text-brand-ink-soft mb-1 block">{t(lang, "pac_reassign")}</label>
                    <select name="assigned_to" id="edit-assigned-to" class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-sky-500 outline-none bg-brand-cream">
                        {members.map((m: any) => (
                            <option value={m.id}>{m.name}</option>
                        ))}
                    </select>
                </div>

                <div>
                    <label class="text-xs font-medium text-brand-ink-soft mb-1 block">{t(lang, "pac_reschedule")}</label>
                    <input type="date" name="assigned_date" id="edit-assigned-date" class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-sky-500 outline-none" />
                </div>

                <div>
                    <label class="text-xs font-medium text-brand-ink-soft mb-1 block">{t(lang, "pac_set_status")}</label>
                    <select name="status" id="edit-status" class="w-full px-3 py-2.5 rounded-lg border border-brand-ink/20 text-sm focus:ring-2 focus:ring-sky-500 outline-none bg-brand-cream">
                        <option value="pending">{t(lang, "pac_keep_pending")}</option>
                        <option value="cancelled">{t(lang, "pac_set_cancelled")}</option>
                    </select>
                </div>

                <div class="flex items-center gap-2 pt-2">
                    <button type="button" id="edit-cancel" class="flex-1 py-2.5 bg-brand-cream-deep hover:bg-brand-cream-deep text-brand-ink font-semibold text-sm rounded-lg transition-colors">
                        {t(lang, "pac_cancel_btn")}
                    </button>
                    <button type="submit" class="flex-1 py-2.5 bg-sky-600 hover:bg-sky-700 text-white font-semibold text-sm rounded-lg transition-colors shadow-[var(--shadow-card)]">
                        {t(lang, "pac_save")}
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.addEventListener("astro:page-load", () => {
            const modal = document.getElementById("assignment-edit-modal");
            const form = document.getElementById("assignment-edit-form") as HTMLFormElement | null;
            const idInput = document.getElementById("edit-assignment-id") as HTMLInputElement | null;
            const titleEl = document.getElementById("edit-task-title");
            const metaEl = document.getElementById("edit-task-meta");
            const assignedTo = document.getElementById("edit-assigned-to") as HTMLSelectElement | null;
            const assignedDate = document.getElementById("edit-assigned-date") as HTMLInputElement | null;
            const statusSel = document.getElementById("edit-status") as HTMLSelectElement | null;
            const closeBtn = document.getElementById("edit-close");
            const cancelBtn = document.getElementById("edit-cancel");

            if (!modal || !form || !idInput || !assignedTo || !assignedDate || !statusSel) return;

            const open = (btn: HTMLElement) => {
                idInput.value = btn.dataset.assignmentId ?? "";
                if (titleEl) titleEl.textContent = btn.dataset.title ?? "";
                if (metaEl) {
                    const pts = btn.dataset.points ?? "0";
                    const bonus = btn.dataset.isBonus === "1" ? " · bonus" : "";
                    metaEl.textContent = `${pts} pts${bonus}`;
                }
                assignedTo.value = btn.dataset.assignedTo ?? "";
                assignedDate.value = btn.dataset.assignedDate ?? "";
                const current = btn.dataset.currentStatus ?? "pending";
                statusSel.value = current === "cancelled" ? "cancelled" : "pending";
                modal.classList.remove("hidden");
            };
            const close = () => modal.classList.add("hidden");

            document.querySelectorAll<HTMLButtonElement>("[data-edit-assignment]").forEach((btn) => {
                btn.addEventListener("click", () => open(btn));
            });
            closeBtn?.addEventListener("click", close);
            cancelBtn?.addEventListener("click", close);
            modal.addEventListener("click", (e) => { if (e.target === modal) close(); });
        });
    </script>
</PageLayout>
