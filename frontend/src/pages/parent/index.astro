---
import Layout from "../../layouts/Layout.astro";
import BottomNav from "../../components/BottomNav.astro";
import { apiFetch } from "../../lib/api";
import { t } from "../../lib/i18n";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = Astro.cookies.get("lang")?.value ?? "en";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

const { data: family } = await apiFetch<any>("/api/families/me", { token });

// Pending gig approvals count for the badge on the Approvals tile.
const { data: pending } = await apiFetch<any[]>(
    "/api/task-assignments/pending-approvals",
    { token }
);
const pendingApprovals = Array.isArray(pending) ? pending.length : 0;
---

<Layout title={`${t(lang, "parent_dashboard")} - Family Task Manager`}>
    <div class="w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto  bg-brand-cream-deep flex flex-col ">
        <header
            class="bg-gradient-to-br from-slate-800 to-slate-700 text-white pt-12 pb-8 px-6 rounded-b-[var(--radius-tile)] shadow-[var(--shadow-card)]"
        >
            <p class="text-brand-ink-soft text-sm mb-1">
                {t(lang, "parent_dashboard")}
            </p>
            <h1 class="text-2xl font-bold">{family?.name || "—"}</h1>
            <p class="text-brand-ink-soft text-sm mt-1">
                {t(lang, "parent_members_count")(family?.members?.length ?? 0)}
            </p>
        </header>

        <main class="flex-1 px-4 py-6">
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                <a
                    href="/parent/tasks"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-brand-sky transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-brand-cream-deep flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-brand-sky-deep"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "parent_tasks_label")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "parent_tasks_desc")}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/rewards"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-brand-sun transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-brand-sun/20 flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-brand-sun-deep"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "parent_rewards_label")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "parent_rewards_desc")}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/members"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-brand-coral transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-brand-coral/15 flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-brand-coral-deep"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "parent_members_label")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "parent_members_desc")}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/consequences"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-rose-200 transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-rose-50 flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-rose-600"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "parent_consequences_label")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "parent_consequences_desc")}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/approvals"
                    class="relative bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-amber-200 transition-all flex flex-col items-center text-center gap-3"
                >
                    {pendingApprovals > 0 && (
                        <span class="absolute top-2 right-2 min-w-[1.25rem] h-5 px-1.5 rounded-full bg-red-600 text-white text-[10px] font-bold flex items-center justify-center shadow-sm">
                            {pendingApprovals > 9 ? "9+" : pendingApprovals}
                        </span>
                    )}
                    <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center">
                        <svg class="h-6 w-6 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {lang === "es" ? "Aprobaciones" : "Approvals"}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {lang === "es" ? "Revisar gigs pendientes" : "Review pending gigs"}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/assignments"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-sky-200 transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-sky-50 flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-sky-600"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "parent_assignments_label")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "parent_assignments_desc")}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/settings"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-brand-sun transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-brand-sun/20 flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-brand-sun-deep"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                            ></path>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {lang === "es" ? "Configuraci\u00f3n" : "Settings"}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {lang === "es" ? "Plan y suscripci\u00f3n" : "Plan & subscription"}
                        </p>
                    </div>
                </a>
                <a
                    href="/budget"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-emerald-200 transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-brand-mint-deep flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-brand-mint-deep"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "parent_finances_label")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "parent_finances_desc")}
                        </p>
                    </div>
                </a>
            </div>

            {
                family?.members && family.members.length > 0 && (
                    <section class="mt-6 bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10">
                        <h2 class="font-bold text-brand-ink mb-3">
                            {t(lang, "parent_family_members")}
                        </h2>
                        <div class="space-y-3">
                            {family.members.map((m: any) => (
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-brand-cream-deep flex items-center justify-center text-brand-sky-deep font-bold text-sm">
                                        {m.name.charAt(0).toUpperCase()}
                                    </div>
                                    <div class="flex-1">
                                        <p class="font-medium text-brand-ink text-sm">
                                            {m.name}
                                        </p>
                                        <p class="text-xs text-brand-ink-soft">
                                            {m.role}
                                        </p>
                                    </div>
                                    <span class="text-sm font-bold text-brand-sun-deep">
                                        {m.points ?? 0} pts
                                    </span>
                                </div>
                            ))}
                        </div>
                    </section>
                )
            }
        </main>

        <BottomNav active="parent" role={user.role} lang={lang} />
    </div>
</Layout>
