---
import PageLayout from "@components/ui/PageLayout.astro";
import GigsIntroBanner from "../../components/GigsIntroBanner.astro";
import EnablePushButton from "../../components/EnablePushButton.astro";
import TourReplayButton from "../../components/TourReplayButton.astro";
import BossBattleBar from "../../components/BossBattleBar.astro";
import { apiFetch } from "../../lib/api";
import { t } from "../../lib/i18n";

const token = Astro.cookies.get("access_token")?.value;
if (!token) return Astro.redirect("/login");
const lang = (Astro.cookies.get("lang")?.value ?? "es") as "en" | "es";

const { data: user } = await apiFetch<any>("/api/auth/me", { token });
if (!user) {
    Astro.cookies.delete("access_token", { path: "/" });
    return Astro.redirect("/login");
}
if (user.role !== "parent") return Astro.redirect("/dashboard");

const { data: family } = await apiFetch<any>("/api/families/me", { token });

// Cooperative weekly boss battle (Family Cup) — points/analytics based, no pet.
// Best-effort — a null just hides the bar.
const { data: familyCup } = await apiFetch<any>("/api/family-cup/", { token });
const boss = familyCup?.boss ?? null;

// Oversight summary for per-kid cards.
const { data: oversight } = await apiFetch<any>("/api/oversight/summary", { token });
const kidCards: any[] = oversight?.members ?? [];

// Payday surface: kids whose Family Bank payday fired in the last 2 days.
const { data: bankFamily } = await apiFetch<any[]>("/api/bank/family", { token });
const paidRecently = (Array.isArray(bankFamily) ? bankFamily : []).filter(
    (k: any) => k.last_payday_at && Date.now() - new Date(k.last_payday_at).getTime() < 2 * 24 * 3600 * 1000,
);
const paidNames = paidRecently.map((k: any) => k.name).join(", ");

// Pending approvals badge — BOTH sources (task/chore proofs AND gig-board claim proofs).
const [taskPendingRes, gigPendingRes] = await Promise.all([
    apiFetch<any[]>("/api/task-assignments/pending-approvals", { token }),
    apiFetch<any[]>("/api/gigs/claims/pending-approvals", { token }),
]);
const taskPending = Array.isArray(taskPendingRes.data) ? taskPendingRes.data.length : 0;
const gigPending = Array.isArray(gigPendingRes.data) ? gigPendingRes.data.length : 0;
const pendingApprovals = taskPending + gigPending;

interface OnboardingState {
    child_invited: boolean;
    task_created: boolean;
    reward_created: boolean;
    points_awarded: boolean;
    dismissed: boolean;
    flyer_scanned?: boolean; // optional extra step — derived, not part of all_done
    all_done: boolean;
}
let onboarding: OnboardingState | null = null;
try {
    const { data: onboardingData } = await apiFetch<OnboardingState>("/api/families/onboarding", { token });
    onboarding = onboardingData ?? null;
} catch {
    onboarding = null;
}

// Checklist progress for the upgraded "Getting Started" widget.
const onbSteps = onboarding
    ? [onboarding.task_created, onboarding.reward_created, onboarding.child_invited, onboarding.points_awarded]
    : [false, false, false, false];
const onbDone = onbSteps.filter(Boolean).length;
const onbTotal = onbSteps.length;
const onbPct = Math.round((onbDone / onbTotal) * 100);
---

<PageLayout
    title={t(lang, "parent_dashboard") as string}
    role={user.role}
    active="parent"
    lang={lang}
    completedTour={user.completed_welcome_tour ?? true}
    tourUserKey={user.id}
>
    <header
        slot="header"
        class="bg-gradient-to-br from-slate-800 to-slate-700 text-white pt-12 pb-8 px-6 rounded-b-[var(--radius-tile)] shadow-[var(--shadow-card)]"
    >
        <p class="text-brand-ink-soft text-sm mb-1">
            {t(lang, "parent_dashboard")}
        </p>
        <h1 class="text-2xl font-bold">{family?.name || "—"}</h1>
        <p class="text-brand-ink-soft text-sm mt-1">
            {t(lang, "parent_members_count")(family?.members?.length ?? 0)}
        </p>
    </header>

    <Fragment slot="banner">
        <GigsIntroBanner lang={lang} show={!user.acknowledged_gigs_intro} />

        <div class="px-4 mt-4 flex items-center">
            <EnablePushButton lang={lang} />
        </div>
    </Fragment>
            <a href="/family-cup" class="block mb-6">
                <BossBattleBar boss={boss} lang={lang} />
            </a>
            {paidRecently.length > 0 && (
                <a
                    href="/parent/settings/family-bank"
                    class="mb-6 flex items-center gap-4 bg-brand-mint/20 border-2 border-brand-ink rounded-[var(--radius-card)] p-4 shadow-[var(--shadow-card)] hover:-translate-y-0.5 transition-transform"
                >
                    <span class="text-3xl">🏦</span>
                    <div class="min-w-0 flex-1">
                        <p class="font-display font-extrabold text-brand-ink leading-tight">
                            {lang === "es" ? "Domingo de pago" : "Payday"}
                        </p>
                        <p class="text-sm text-brand-ink-soft mt-0.5">
                            {lang === "es"
                                ? `${paidNames} ${paidRecently.length === 1 ? "recibió" : "recibieron"} su pago del Banco Familiar.`
                                : `${paidNames} ${paidRecently.length === 1 ? "got" : "got"} their Family Bank payday.`}
                        </p>
                    </div>
                    <span class="text-brand-mint-deep font-bold flex-shrink-0">→</span>
                </a>
            )}
            {family && family.ai_processing_consent_at == null && (
                <div id="ai-consent-banner" class="mb-6 bg-brand-sky/10 border border-brand-sky/30 rounded-2xl p-5 shadow-[var(--shadow-card)]">
                    <h2 class="font-bold text-brand-ink text-base mb-1">
                        {lang === "es" ? "¿Permitir IA con el contenido de tus hijos?" : "Allow AI on your kids' content?"}
                    </h2>
                    <p class="text-sm text-brand-ink-soft mb-3">
                        {lang === "es"
                            ? "Permitir que la IA procese fotos de tareas y mensajes del chat familiar para validar pruebas automáticamente y ayudar al asistente. Si no lo permites, las pruebas siempre pasan a tu aprobación manual. Puedes cambiarlo cuando quieras en Ajustes de la familia. "
                            : "Allow AI to process task proof photos and family chat messages to auto-validate proofs and help the assistant. If you decline, proofs always go to your manual approval. You can change this anytime in Family settings. "}
                        <a href="/privacidad" class="text-brand-sky-deep font-semibold hover:underline">
                            {lang === "es" ? "Aviso de privacidad" : "Privacy notice"}
                        </a>
                    </p>
                    <div class="flex flex-wrap gap-2">
                        <button
                            id="ai-consent-allow"
                            class="px-4 py-2 rounded-lg bg-brand-sky-deep text-white text-xs font-semibold hover:bg-brand-ink transition-colors cursor-pointer"
                        >
                            {lang === "es" ? "Permitir" : "Allow"}
                        </button>
                        <button
                            id="ai-consent-decline"
                            class="px-4 py-2 rounded-lg bg-brand-cream-deep text-brand-ink text-xs font-semibold hover:bg-brand-cream border border-brand-ink/15 transition-colors cursor-pointer"
                        >
                            {lang === "es" ? "No permitir" : "Don't allow"}
                        </button>
                    </div>
                </div>
            )}
            {!onboarding?.dismissed && (
                <div id="onboarding-widget" class="mb-6 bg-brand-coral/10 border border-brand-coral/20 rounded-2xl p-5 shadow-[var(--shadow-card)]">
                    <div class="flex items-center justify-between mb-2">
                        <h2 class="font-bold text-brand-ink text-base">
                            {t(lang, "pd_onb_title")}
                        </h2>
                        <div class="flex items-center gap-2">
                            <span class="text-xs font-semibold text-brand-ink-soft">{onbDone}/{onbTotal}</span>
                            {onboarding?.all_done && (
                                <button
                                    id="dismiss-onboarding"
                                    class="text-brand-ink-soft hover:text-brand-ink transition-colors text-xl leading-none"
                                    aria-label="Dismiss"
                                >×</button>
                            )}
                        </div>
                    </div>
                    <div
                        class="w-full bg-brand-cream-deep rounded-full h-2 mb-4"
                        role="progressbar"
                        aria-valuenow={onbDone}
                        aria-valuemin={0}
                        aria-valuemax={onbTotal}
                        aria-label={t(lang, "onboarding_progress_label") as string}
                    >
                        <div class="bg-brand-coral h-2 rounded-full transition-all duration-500" style={`width: ${onbPct}%`}></div>
                    </div>
                    {/* Age-preset starter packs (P1-W3): one tap seeds chores +
                        gigs + rewards, completing two checklist steps at once. */}
                    {!onboarding?.all_done && (
                        <a
                            href="/parent/starter-packs"
                            class="mb-4 flex items-center justify-between gap-3 rounded-xl bg-brand-sky-deep/10 border border-brand-sky-deep/30 px-4 py-3 hover:bg-brand-sky-deep/20 transition-colors"
                        >
                            <span class="text-sm font-semibold text-brand-ink">
                                📦 {lang === "es"
                                    ? "Empieza en minutos con un paquete por edad"
                                    : "Start in minutes with an age starter pack"}
                            </span>
                            <span class="text-brand-sky-deep font-bold">→</span>
                        </a>
                    )}
                    <ol class="space-y-2 text-sm">
                        <li class="flex items-center gap-3">
                            <span class={onboarding?.task_created ? "text-green-600" : "text-brand-ink-soft"}>{onboarding?.task_created ? "✅" : "◻"}</span>
                            <span class={onboarding?.task_created ? "line-through text-brand-ink-soft" : "text-brand-ink"}>
                                {t(lang, "pd_onb_task")}
                            </span>
                            {!onboarding?.task_created && <a href="/parent/tasks" class="ml-auto text-brand-sky-deep font-semibold hover:underline text-xs">→</a>}
                        </li>
                        <li class="flex items-center gap-3">
                            <span class={onboarding?.reward_created ? "text-green-600" : "text-brand-ink-soft"}>{onboarding?.reward_created ? "✅" : "◻"}</span>
                            <span class={onboarding?.reward_created ? "line-through text-brand-ink-soft" : "text-brand-ink"}>
                                {t(lang, "pd_onb_reward")}
                            </span>
                            {!onboarding?.reward_created && <a href="/parent/rewards" class="ml-auto text-brand-sky-deep font-semibold hover:underline text-xs">→</a>}
                        </li>
                        <li class="flex items-center gap-3">
                            <span class={onboarding?.child_invited ? "text-green-600" : "text-brand-ink-soft"}>{onboarding?.child_invited ? "✅" : "◻"}</span>
                            <span class={onboarding?.child_invited ? "line-through text-brand-ink-soft" : "text-brand-ink"}>
                                {t(lang, "pd_onb_invite")}
                            </span>
                            {!onboarding?.child_invited && <a href="/parent/members#invite" class="ml-auto text-brand-sky-deep font-semibold hover:underline text-xs">→</a>}
                        </li>
                        <li class="flex items-center gap-3">
                            <span class={onboarding?.points_awarded ? "text-green-600" : "text-brand-ink-soft"}>{onboarding?.points_awarded ? "✅" : "◻"}</span>
                            <span class={onboarding?.points_awarded ? "line-through text-brand-ink-soft" : "text-brand-ink"}>
                                {t(lang, "pd_onb_approve")}
                            </span>
                            {!onboarding?.points_awarded && onboarding?.child_invited && <a href="/parent/approvals" class="ml-auto text-brand-sky-deep font-semibold hover:underline text-xs">→</a>}
                        </li>
                        <li class="flex items-center gap-3">
                            <span class={onboarding?.flyer_scanned ? "text-green-600" : "text-brand-ink-soft"}>{onboarding?.flyer_scanned ? "✅" : "◻"}</span>
                            <span class={onboarding?.flyer_scanned ? "line-through text-brand-ink-soft" : "text-brand-ink"}>
                                📄 {t(lang, "pd_onb_flyer")}
                            </span>
                            <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-brand-cream-deep text-brand-ink-soft">{t(lang, "pd_onb_optional")}</span>
                            {!onboarding?.flyer_scanned && <a href="/calendar/scan" class="ml-auto text-brand-sky-deep font-semibold hover:underline text-xs">→</a>}
                        </li>
                    </ol>
                    {onboarding?.all_done && (
                        <p class="mt-3 text-sm text-green-700 font-semibold">
                            {t(lang, "pd_onb_done")}
                        </p>
                    )}
                    <div class="mt-4 flex flex-wrap gap-2">
                        <TourReplayButton
                            role="parent"
                            lang={lang}
                            userKey={user.id}
                            label={`🧭 ${t(lang, "onboarding_take_tour")}`}
                            class="px-3 py-2 rounded-lg bg-brand-sky-deep text-white text-xs font-semibold hover:bg-brand-ink transition-colors cursor-pointer"
                        />
                        <a
                            href={lang === "es" ? "/ayuda" : "/help"}
                            class="px-3 py-2 rounded-lg bg-brand-cream-deep text-brand-ink text-xs font-semibold hover:bg-brand-cream border border-brand-ink/15 transition-colors"
                        >
                            📖 {t(lang, "onboarding_open_help")}
                        </a>
                    </div>
                </div>
            )}
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                <a
                    href="/parent/tasks"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-brand-sky transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-brand-cream-deep flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-brand-sky-deep"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "parent_tasks_label")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "parent_tasks_desc")}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/rewards"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-brand-sun transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-brand-sun/20 flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-brand-sun-deep"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "parent_rewards_label")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "parent_rewards_desc")}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/members"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-brand-coral transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-brand-coral/15 flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-brand-coral-deep"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "parent_members_label")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "parent_members_desc")}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/consequences"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-rose-200 transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-rose-50 flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-rose-600"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "parent_consequences_label")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "parent_consequences_desc")}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/approvals"
                    class="relative bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-amber-200 transition-all flex flex-col items-center text-center gap-3"
                >
                    {pendingApprovals > 0 && (
                        <span class="absolute top-2 right-2 min-w-[1.25rem] h-5 px-1.5 rounded-full bg-red-600 text-white text-[10px] font-bold flex items-center justify-center shadow-sm">
                            {pendingApprovals > 9 ? "9+" : pendingApprovals}
                        </span>
                    )}
                    <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center">
                        <svg class="h-6 w-6 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "pd_approvals")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "pd_approvals_sub")}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/assignments"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-sky-200 transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-sky-50 flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-sky-600"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "parent_assignments_label")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "parent_assignments_desc")}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/settings"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-brand-sun transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-brand-sun/20 flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-brand-sun-deep"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                            ></path>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "pd_settings")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "pd_settings_sub")}
                        </p>
                    </div>
                </a>
                <a
                    href="/parent/jarvis"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-violet-400 transition-all flex flex-col items-center text-center gap-3"
                >
                    <div class="w-12 h-12 rounded-xl bg-violet-100 flex items-center justify-center">
                        <span class="text-2xl">🤖</span>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">Jarvis</p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "pd_jarvis")}
                        </p>
                    </div>
                </a>
                <a
                    href="/chat"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-sky-300 transition-all flex flex-col items-center text-center gap-3"
                >
                    <div class="w-12 h-12 rounded-xl bg-sky-100 flex items-center justify-center">
                        <svg class="h-6 w-6 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">{t(lang, "pd_chat")}</p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "pd_chat_sub")}
                        </p>
                    </div>
                </a>
                <a
                    href="/budget"
                    class="bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10 hover:shadow-[var(--shadow-card)] hover:border-emerald-200 transition-all flex flex-col items-center text-center gap-3"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-brand-mint-deep flex items-center justify-center"
                    >
                        <svg
                            class="h-6 w-6 text-brand-mint-deep"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-brand-ink">
                            {t(lang, "parent_finances_label")}
                        </p>
                        <p class="text-xs text-brand-ink-soft">
                            {t(lang, "parent_finances_desc")}
                        </p>
                    </div>
                </a>
            </div>

            {
                kidCards.length > 0 && (
                    <section class="mt-6 bg-brand-cream rounded-2xl p-5 shadow-[var(--shadow-card)] border border-brand-ink/10">
                        <h2 class="font-bold text-brand-ink mb-3">
                            {t(lang, "parent_family_members")}
                        </h2>
                        <div class="space-y-4">
                            {kidCards.map((m: any) => (
                                <div class="rounded-xl border border-brand-ink/10 p-3">
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 rounded-full bg-brand-cream-deep flex items-center justify-center text-brand-sky-deep font-bold text-sm">
                                            {m.name.charAt(0).toUpperCase()}
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="font-medium text-brand-ink text-sm truncate">{m.name}</p>
                                            <p class="text-xs text-brand-ink-soft">
                                                {m.role}
                                                {m.gig_trust_streak > 0 && (
                                                    <span class="ml-1">
                                                        🔥{m.gig_trust_streak}
                                                        {m.auto_approve_active && (
                                                            <span class="ml-1 text-brand-mint-deep font-semibold">auto</span>
                                                        )}
                                                    </span>
                                                )}
                                            </p>
                                        </div>
                                        <span class="text-sm font-bold text-brand-sun-deep whitespace-nowrap">
                                            {m.points} pts
                                        </span>
                                    </div>
                                    {m.goal && (
                                        <div class={`mt-2 rounded-lg px-3 py-2 ${m.goal.affordable ? "bg-brand-sun/20" : "bg-brand-cream-deep"}`}>
                                            <div class="flex items-center gap-2">
                                                <span class="text-sm">{m.goal.reward_icon ?? "🎯"}</span>
                                                <p class="text-xs font-semibold text-brand-ink flex-1 truncate">
                                                    {m.goal.reward_title}
                                                </p>
                                                <span class="text-xs text-brand-ink-soft whitespace-nowrap">
                                                    {m.goal.affordable
                                                        ? t(lang, "pd_goal_ready")
                                                        : `${m.goal.pts_to_go} pts`}
                                                </span>
                                            </div>
                                            {!m.goal.affordable && (
                                                <div class="w-full bg-brand-ink/10 rounded-full h-1.5 mt-1.5 overflow-hidden">
                                                    <div
                                                        class="h-1.5 bg-brand-sky-deep rounded-full"
                                                        style={`width: ${m.goal.progress_pct}%`}
                                                    ></div>
                                                </div>
                                            )}
                                        </div>
                                    )}
                                    <div class="flex gap-2 mt-2 flex-wrap">
                                        {m.pending_approvals > 0 && (
                                            <a
                                                href="/parent/approvals"
                                                class="text-[11px] font-semibold px-2 py-0.5 rounded-full bg-amber-100 text-amber-800"
                                            >
                                                {t(lang, "pd_member_to_approve")(m.pending_approvals)}
                                            </a>
                                        )}
                                        {m.open_today > 0 && (
                                            <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full bg-brand-cream-deep text-brand-ink-soft">
                                                {t(lang, "pd_member_tasks_today")(m.open_today)}
                                            </span>
                                        )}
                                        {m.active_consequences > 0 && (
                                            <a
                                                href="/parent/consequences"
                                                class="text-[11px] font-semibold px-2 py-0.5 rounded-full bg-rose-100 text-rose-700"
                                            >
                                                {t(lang, "pd_member_consequences")(m.active_consequences)}
                                            </a>
                                        )}
                                    </div>
                                </div>
                            ))}
                        </div>
                    </section>
                )
            }
</PageLayout>

<script>
    document.getElementById("dismiss-onboarding")?.addEventListener("click", async () => {
        try {
            await fetch("/api/families/onboarding/dismiss", { method: "POST" });
        } finally {
            document.getElementById("onboarding-widget")?.remove();
        }
    });

    // One-time AI-processing consent prompt: either decision PATCHes the
    // family row (server stamps ai_processing_consent_at, so the banner never
    // shows again). On failure the banner stays for a retry.
    const aiConsentDecide = async (allow: boolean) => {
        try {
            const r = await fetch("/api/families/me", {
                method: "PATCH",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ ai_processing_consent: allow }),
            });
            if (r.ok) document.getElementById("ai-consent-banner")?.remove();
        } catch (e) {
            console.error("ai consent decision failed:", e);
        }
    };
    document.getElementById("ai-consent-allow")?.addEventListener("click", () => aiConsentDecide(true));
    document.getElementById("ai-consent-decline")?.addEventListener("click", () => aiConsentDecide(false));
</script>
