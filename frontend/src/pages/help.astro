---
/**
 * Public user guide — English.
 *
 * Renders the canonical docs/USER_GUIDE_EN.md at the repo root. The email
 * welcome template links here for English users (see
 * backend/app/services/email_service.py::_guide_url). Route is in the
 * middleware publicRoutes allowlist so visitors don't need to log in.
 *
 * The Spanish equivalent lives at /ayuda. A small language toggle at the
 * top of each page links to the other.
 */
import Layout from "../layouts/Layout.astro";
// docs/ is mounted read-only at /app/docs inside the frontend container
// via docker-compose (see volumes block). From src/pages/ that's ../../docs.
import { Content as GuideContent } from "../../docs/USER_GUIDE_EN.md";
---

<Layout title="User Guide — Family Task Manager">
    <main class="guide-wrap">
        <nav class="guide-nav">
            <a href="/" class="nav-link">← Back home</a>
            <a href="/ayuda" class="lang-toggle">Español</a>
        </nav>
        <header class="guide-hero">
            <h1 class="guide-hero-title">Help Center</h1>
            <p class="guide-hero-sub">Guides for every part of Family Task Manager</p>
            <input
                id="guide-search"
                type="search"
                class="guide-search"
                placeholder="Search topics…"
                autocomplete="off"
                aria-label="Search the user guide"
            />
        </header>
        <details class="guide-toc-wrap" open>
            <summary>Contents</summary>
            <nav id="guide-toc" class="guide-toc" aria-label="Table of contents"></nav>
            <p id="guide-toc-empty" class="guide-toc-empty" hidden>
                No topics match your search.
            </p>
        </details>
        <article class="guide">
            <GuideContent />
        </article>
    </main>

    <script>
        function initGuideToc() {
            const article = document.querySelector(".guide");
            const toc = document.getElementById("guide-toc");
            const search = document.getElementById(
                "guide-search",
            ) as HTMLInputElement | null;
            const empty = document.getElementById("guide-toc-empty");
            if (!article || !toc || (toc as HTMLElement).dataset.built === "1")
                return;
            (toc as HTMLElement).dataset.built = "1";

            article.querySelectorAll("h1, h2").forEach((h) => {
                if (!h.id) return;
                const a = document.createElement("a");
                a.href = "#" + h.id;
                a.textContent = h.textContent || "";
                a.className = h.tagName === "H1" ? "toc-h1" : "toc-h2";
                toc.appendChild(a);
            });

            search?.addEventListener("input", () => {
                const q = search.value.trim().toLowerCase();
                let shown = 0;
                toc.querySelectorAll("a").forEach((a) => {
                    const match = (a.textContent || "")
                        .toLowerCase()
                        .includes(q);
                    (a as HTMLElement).hidden = q !== "" && !match;
                    if (!(a as HTMLElement).hidden) shown++;
                });
                if (empty) empty.hidden = !(q !== "" && shown === 0);
            });
        }
        // Public page: cover both the view-transition router event and a plain load.
        document.addEventListener("astro:page-load", initGuideToc);
        document.addEventListener("DOMContentLoaded", initGuideToc);
    </script>
</Layout>

<style>
    .guide-wrap {
        max-width: 820px;
        margin: 0 auto;
        padding: 32px 20px 80px;
        color: #1e293b;
        background: #fff;
        min-height: 100vh;
    }
    .guide-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid #e2e8f0;
        font-size: 14px;
    }
    .nav-link {
        color: #64748b;
        text-decoration: none;
        font-weight: 500;
    }
    .nav-link:hover {
        color: #4f46e5;
    }
    .lang-toggle {
        color: #4f46e5;
        text-decoration: none;
        font-weight: 600;
        padding: 6px 12px;
        border: 1px solid #e0e7ff;
        border-radius: 6px;
    }
    .lang-toggle:hover {
        background: #eef2ff;
    }

    /* Markdown prose styles — minimal but readable */
    .guide :global(h1) {
        font-size: 32px;
        font-weight: 800;
        margin: 24px 0 16px;
        color: #0f172a;
        line-height: 1.2;
    }
    .guide :global(h2) {
        font-size: 24px;
        font-weight: 700;
        margin: 32px 0 14px;
        color: #0f172a;
        padding-top: 8px;
        border-top: 1px solid #f1f5f9;
    }
    .guide :global(h3) {
        font-size: 18px;
        font-weight: 600;
        margin: 24px 0 10px;
        color: #1e293b;
    }
    .guide :global(h4) {
        font-size: 16px;
        font-weight: 600;
        margin: 20px 0 8px;
        color: #334155;
    }
    .guide :global(p) {
        margin: 0 0 14px;
        line-height: 1.7;
        color: #334155;
        font-size: 16px;
    }
    .guide :global(ul),
    .guide :global(ol) {
        margin: 0 0 16px;
        padding-left: 24px;
        line-height: 1.7;
        color: #334155;
    }
    .guide :global(li) {
        margin-bottom: 6px;
    }
    .guide :global(strong) {
        color: #0f172a;
        font-weight: 700;
    }
    .guide :global(code) {
        background: #f1f5f9;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 90%;
        font-family: "SF Mono", Menlo, Consolas, monospace;
        color: #be185d;
    }
    .guide :global(pre) {
        background: #0f172a;
        color: #e2e8f0;
        padding: 16px;
        border-radius: 8px;
        overflow-x: auto;
        margin: 0 0 20px;
        font-size: 13px;
    }
    .guide :global(pre code) {
        background: transparent;
        color: inherit;
        padding: 0;
    }
    .guide :global(a) {
        color: #4f46e5;
        text-decoration: underline;
    }
    .guide :global(a:hover) {
        color: #3730a3;
    }
    .guide :global(hr) {
        border: none;
        border-top: 1px solid #e2e8f0;
        margin: 32px 0;
    }
    .guide :global(table) {
        border-collapse: collapse;
        margin: 0 0 20px;
        font-size: 14px;
        width: 100%;
    }
    .guide :global(th),
    .guide :global(td) {
        border: 1px solid #e2e8f0;
        padding: 8px 12px;
        text-align: left;
    }
    .guide :global(th) {
        background: #f8fafc;
        font-weight: 600;
    }
    .guide :global(blockquote) {
        border-left: 4px solid #4f46e5;
        padding-left: 16px;
        margin: 0 0 16px;
        color: #475569;
        font-style: italic;
    }

    /* Help-center hero + search + generated table of contents */
    .guide-hero {
        margin-bottom: 18px;
    }
    .guide-hero-title {
        font-size: 28px;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 4px;
    }
    .guide-hero-sub {
        color: #64748b;
        font-size: 14px;
        margin: 0 0 14px;
    }
    .guide-search {
        width: 100%;
        padding: 10px 14px;
        font-size: 15px;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        outline: none;
        box-sizing: border-box;
    }
    .guide-search:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.12);
    }
    .guide-toc-wrap {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 12px 16px;
        margin-bottom: 28px;
        background: #f8fafc;
    }
    .guide-toc-wrap > summary {
        cursor: pointer;
        font-weight: 700;
        color: #334155;
    }
    .guide-toc {
        display: flex;
        flex-direction: column;
        gap: 2px;
        margin-top: 10px;
        max-height: 340px;
        overflow-y: auto;
    }
    .guide-toc a {
        text-decoration: none;
        color: #475569;
        font-size: 14px;
        padding: 3px 0;
    }
    .guide-toc a:hover {
        color: #4f46e5;
    }
    .guide-toc a.toc-h1 {
        font-weight: 700;
        color: #0f172a;
        margin-top: 8px;
    }
    .guide-toc a.toc-h2 {
        padding-left: 14px;
    }
    .guide-toc-empty {
        color: #94a3b8;
        font-size: 14px;
        margin: 8px 0 0;
    }
</style>
