---
/**
 * Public user guide — English. Renders docs/USER_GUIDE_EN.md inside the shared
 * GuideShell (hero + search + auto TOC + prose styling). Linked from the welcome
 * email (backend email_service.py::_guide_url) and in the middleware
 * publicRoutes allowlist. The Spanish equivalent is /ayuda.
 */
import GuideShell from "../components/GuideShell.astro";
// docs/ is mounted read-only at /app/docs inside the frontend container via
// docker-compose. From src/pages/ that's ../../docs.
import { Content as GuideContent } from "../../docs/USER_GUIDE_EN.md";
---

<GuideShell
    title="User Guide — Family Task Manager"
    description="Family Task Manager help center: step-by-step guides to set up your family, create chores, reward kids with points and prizes, and run the family budget."
    lang="en"
    alternates={{ es: "/ayuda", en: "/help" }}
    backHref="/"
    backLabel="← Back home"
    toggleHref="/ayuda"
    toggleLabel="Español"
    heroTitle="Help Center"
    heroSub="Guides for every part of Family Task Manager"
    searchPlaceholder="Search topics…"
    searchAria="Search the user guide"
    contentsLabel="Contents"
    noResultsText="No topics match your search."
    tocAria="Table of contents"
    privacyLabel="Privacy Notice"
    termsLabel="Terms of Service"
    supportLabel="Contact support"
>
    <GuideContent />
</GuideShell>
