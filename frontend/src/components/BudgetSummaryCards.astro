---
interface Props {
    income: number;
    budgeted: number;
    spent: number;
    lang: 'en' | 'es';
    t: (lang: string, key: string) => string;
    formatCurrency: (amount: number) => string;
}

const { income, budgeted, spent, lang, t, formatCurrency } = Astro.props;
---

<div class="px-6 py-4 grid grid-cols-3 gap-3">
    <div class="bg-brand-mint border-2 border-brand-ink rounded-[var(--radius-card)] p-4 shadow-[var(--shadow-card)]">
        <p class="text-[10px] text-brand-ink font-extrabold mb-1 uppercase tracking-wider font-sans">{lang === "es" ? "Ingresos" : "Income"}</p>
        <p class="font-display text-lg font-extrabold text-brand-ink num">{formatCurrency(income)}</p>
    </div>
    <div class="bg-brand-sky border-2 border-brand-ink rounded-[var(--radius-card)] p-4 shadow-[var(--shadow-card)]">
        <p class="text-[10px] text-brand-ink font-extrabold mb-1 uppercase tracking-wider font-sans">{t(lang, 'fin_budgeted')}</p>
        <p class="font-display text-lg font-extrabold text-brand-ink num">{formatCurrency(budgeted)}</p>
    </div>
    <div class="bg-brand-coral border-2 border-brand-ink rounded-[var(--radius-card)] p-4 shadow-[var(--shadow-card)]">
        <p class="text-[10px] text-brand-ink font-extrabold mb-1 uppercase tracking-wider font-sans">{t(lang, 'fin_spent')}</p>
        <p class="font-display text-lg font-extrabold text-brand-ink num">{formatCurrency(spent)}</p>
    </div>
</div>
