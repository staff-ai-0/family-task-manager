---
/**
 * InvitationModal Component
 * Modal for sending family invitations
 * 
 * Props:
 * - familyId: string - The family ID
 * - familyName: string - The family name
 * - lang: 'en' | 'es' - language code
 */

interface Props {
    familyId: string;
    familyName: string;
    lang: 'en' | 'es';
}

const {
    familyId,
    familyName,
    lang
} = Astro.props;
---

<div id="invitation-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-6">
    <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full">
        <div class="bg-gradient-to-r from-cyan-500 to-blue-600 text-white px-6 py-4 rounded-t-2xl">
            <div class="flex items-center justify-between">
                <h2 class="text-xl font-bold">
                    {lang === "es" ? "Invitar a la familia" : "Invite to family"}
                </h2>
                <button id="invitation-close-btn" class="text-white hover:text-cyan-100 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
        
        <div class="p-6 space-y-4">
            <!-- Family name display -->
            <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
                <p class="text-xs text-blue-600 font-semibold mb-1 uppercase tracking-wider">
                    {lang === "es" ? "Tu familia" : "Your family"}
                </p>
                <p class="text-lg font-bold text-blue-700">
                    {familyName}
                </p>
            </div>

            <!-- Error message -->
            <div id="invitation-error" class="hidden p-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm"></div>

            <!-- Success message -->
            <div id="invitation-success" class="hidden p-3 rounded-lg bg-green-50 border border-green-200 text-green-700 text-sm"></div>

            <!-- Invite form -->
            <form id="invitation-form" class="space-y-4">
                <!-- Email input -->
                <div>
                    <label for="invite-email" class="block text-xs font-semibold text-slate-700 mb-2">
                        {lang === "es" ? "Email de la persona a invitar" : "Email to invite"}
                    </label>
                    <input
                        type="email"
                        id="invite-email"
                        name="email"
                        required
                        placeholder={lang === "es" ? "ejemplo@correo.com" : "example@email.com"}
                        class="w-full px-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition-all"
                    />
                </div>

                <!-- Optional message -->
                <div>
                    <label for="invite-message" class="block text-xs font-semibold text-slate-700 mb-2">
                        {lang === "es" ? "Mensaje (opcional)" : "Message (optional)"}
                    </label>
                    <textarea
                        id="invite-message"
                        name="message"
                        rows="3"
                        placeholder={lang === "es" 
                            ? "¡Únete a nuestra familia! Podemos organizar tareas juntos..." 
                            : "Join us! We can organize tasks together..."}
                        class="w-full px-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition-all resize-none"
                    ></textarea>
                </div>

                <!-- Role selector -->
                <div>
                    <label for="invite-role" class="block text-xs font-semibold text-slate-700 mb-2">
                        {lang === "es" ? "Rol en la familia" : "Role in family"}
                    </label>
                    <select
                        id="invite-role"
                        name="role"
                        class="w-full px-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition-all bg-white"
                    >
                        <option value="child">
                            {lang === "es" ? "Niño (Child)" : "Child"}
                        </option>
                        <option value="teen">
                            {lang === "es" ? "Adolescente (Teen)" : "Teen"}
                        </option>
                        <option value="parent">
                            {lang === "es" ? "Padre/Madre (Parent)" : "Parent"}
                        </option>
                    </select>
                    <p class="text-xs text-slate-500 mt-1">
                        {lang === "es" 
                            ? "El rol puede ser cambiado después"
                            : "Role can be changed later"}
                    </p>
                </div>
                <button
                    type="submit"
                    id="invitation-submit"
                    class="w-full bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-600 hover:to-blue-700 text-white font-bold py-2 rounded-lg transition-all transform hover:scale-105 active:scale-95 flex items-center justify-center gap-2"
                >
                    <span id="invitation-submit-text">
                        {lang === "es" ? "Enviar invitación" : "Send invitation"}
                    </span>
                </button>
            </form>

            <!-- Pending invitations section -->
            <div class="pt-4 border-t border-slate-200">
                <p class="text-xs text-slate-500 text-center py-3">
                    {lang === "es" 
                        ? "Las invitaciones pendientes aparecerán en la sección principal después de ser enviadas."
                        : "Pending invitations will appear in the main section after being sent."}
                </p>
            </div>
        </div>
    </div>
</div>

<script define:vars={{ familyId, lang }}>
    const modal = document.getElementById("invitation-modal");
    const form = document.getElementById("invitation-form");
    const closeBtn = document.getElementById("invitation-close-btn");
    const errorDiv = document.getElementById("invitation-error");
    const successDiv = document.getElementById("invitation-success");
    const submitBtn = document.getElementById("invitation-submit");
    const submitText = document.getElementById("invitation-submit-text");

    // Open/Close modal functionality
    window.openInvitationModal = () => {
        modal.classList.remove("hidden");
    };

    window.closeInvitationModal = () => {
        modal.classList.add("hidden");
    };

    closeBtn.addEventListener("click", window.closeInvitationModal);
    modal.addEventListener("click", (e) => {
        if (e.target === modal) window.closeInvitationModal();
    });

    // Submit form
    form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const emailInput = document.getElementById("invite-email");
        const messageInput = document.getElementById("invite-message");
        const roleInput = document.getElementById("invite-role");

        const email = emailInput.value.trim();
        const message = messageInput.value.trim();
        const role = roleInput.value;

        // Clear messages
        errorDiv.classList.add("hidden");
        successDiv.classList.add("hidden");

        // Validation
        if (!email) {
            errorDiv.textContent = lang === "es" ? "El email es requerido" : "Email is required";
            errorDiv.classList.remove("hidden");
            return;
        }

        // Submit
        submitBtn.disabled = true;
        submitText.textContent = lang === "es" ? "Enviando..." : "Sending...";

        try {
            const response = await fetch("/api/invitations/send", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                credentials: 'include',
                body: JSON.stringify({
                    email,
                    message: message || undefined,
                    role,
                    family_id: familyId
                })
            });

            const data = await response.json();

            if (data.success) {
                successDiv.textContent = lang === "es" 
                    ? "¡Invitación enviada a " + email + "!" 
                    : "Invitation sent to " + email + "!";
                successDiv.classList.remove("hidden");
                form.reset();
                
                // Close modal after 1.5 seconds
                setTimeout(() => {
                    window.closeInvitationModal();
                    // Reload page to refresh the pending invitations list on the main page
                    window.location.reload();
                }, 1500);
            } else {
                errorDiv.textContent = data.error || (lang === "es" ? "Error al enviar la invitación" : "Error sending invitation");
                errorDiv.classList.remove("hidden");
            }
        } catch (error) {
            console.error("Error:", error);
            errorDiv.textContent = lang === "es" ? "Error de conexión. Intenta de nuevo." : "Connection error. Please try again.";
            errorDiv.classList.remove("hidden");
        } finally {
            submitBtn.disabled = false;
            submitText.textContent = lang === "es" ? "Enviar invitación" : "Send invitation";
        }
    });
</script>
