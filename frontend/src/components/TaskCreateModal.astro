---
/**
 * Two-step task creation modal.
 * Step 1: Preset grid with search.
 * Step 2: 5-field mini-form (name, difficulty, frequency, assignment, bonus).
 *
 * The trigger button (id="tcm-trigger") is placed by the PARENT PAGE (tasks.astro).
 */
import { TASK_PRESETS } from "@lib/task-presets";

interface Props {
    lang: "en" | "es";
    token: string;
    memberList: Array<{ id: string; name: string; role: string }>;
}

const { lang, token, memberList } = Astro.props;

const customPreset = { emoji: "✏️", title: "", title_es: "", effort_level: 1, interval_days: 1 };

// Weekday chips: Mon=0 .. Sun=6 (backend convention)
const dowLabels = lang === "es"
    ? ["L", "M", "X", "J", "V", "S", "D"]
    : ["M", "T", "W", "T", "F", "S", "S"];
---

<!-- Backdrop -->
<div
    id="tcm-backdrop"
    class="fixed inset-0 bg-black/50 z-[55] hidden opacity-0 transition-opacity duration-300"
></div>

<!-- Dialog -->
<div
    id="tcm-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="tcm-dialog-title"
    class="hidden fixed inset-0 z-[60] flex items-end sm:items-center justify-center p-0 sm:p-4"
>
    <div class="w-full sm:max-w-lg bg-brand-cream rounded-t-[var(--radius-card)] sm:rounded-[var(--radius-card)] shadow-[var(--shadow-pop)] max-h-[90dvh] flex flex-col pb-[env(safe-area-inset-bottom,0px)] sm:pb-0">

        <!-- Header -->
        <div class="flex items-center justify-between px-5 pt-5 pb-3 border-b border-brand-ink/10 flex-shrink-0">
            <h2 id="tcm-dialog-title" class="font-display text-lg font-extrabold text-brand-ink">
                {lang === "es" ? "Nueva tarea" : "New Task"}
            </h2>
            <button
                id="tcm-close"
                type="button"
                class="h-8 w-8 rounded-lg bg-brand-cream-deep hover:bg-brand-cream-deep text-brand-ink-soft hover:text-brand-ink flex items-center justify-center transition-colors"
                aria-label={lang === "es" ? "Cerrar" : "Close"}
            >
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <!-- Step 1: Preset Grid -->
        <div id="tcm-step-1" class="flex flex-col flex-1 overflow-hidden">
            <!-- Search -->
            <div class="px-5 pt-4 pb-3 flex-shrink-0">
                <div class="relative">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-brand-ink-soft" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <input
                        id="tcm-search"
                        type="search"
                        placeholder={lang === "es" ? "Buscar tarea…" : "Search task…"}
                        class="w-full pl-9 pr-4 py-2 text-sm border border-brand-ink/20 rounded-xl focus:ring-2 focus:ring-brand-sky-deep focus:border-brand-sky-deep outline-none bg-brand-cream"
                        autocomplete="off"
                    />
                </div>
            </div>

            <!-- Preset cards grid -->
            <div class="flex-1 overflow-y-auto px-5 pb-5">
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-3" data-tour="task-template-grid">
                    {TASK_PRESETS.map((p) => (
                        <button
                            type="button"
                            class="tcm-preset-card text-left p-3 bg-brand-cream-deep hover:bg-brand-sky/10 border-2 border-transparent hover:border-brand-sky-deep rounded-[var(--radius-card)] transition-all duration-150 active:scale-[0.97]"
                            data-preset={JSON.stringify(p)}
                        >
                            <div class="text-2xl mb-1.5">{p.emoji}</div>
                            <p class="text-xs font-semibold text-brand-ink leading-snug line-clamp-2">{lang === "es" && p.title_es ? p.title_es : p.title}</p>
                            <div class="flex items-center gap-1.5 mt-1.5 flex-wrap">
                                <span class={`text-[10px] font-medium px-1.5 py-0.5 rounded-full ${
                                    p.effort_level === 3 ? "bg-brand-coral/15 text-brand-coral-deep" :
                                    p.effort_level === 2 ? "bg-brand-sun/20 text-brand-sun-deep" :
                                    "bg-brand-mint/15 text-brand-mint-deep"
                                }`}>
                                    {p.effort_level === 3 ? (lang === "es" ? "Difícil" : "Hard") :
                                     p.effort_level === 2 ? (lang === "es" ? "Medio" : "Medium") :
                                     (lang === "es" ? "Fácil" : "Easy")}
                                </span>
                                <span class="text-[10px] text-brand-ink-soft">
                                    {p.interval_days === 1 ? (lang === "es" ? "Diario" : "Daily") :
                                     p.interval_days === 7 ? (lang === "es" ? "Semanal" : "Weekly") :
                                     (lang === "es" ? `c/${p.interval_days}d` : `${p.interval_days}d`)}
                                </span>
                            </div>
                        </button>
                    ))}

                    <!-- Custom card -->
                    <button
                        type="button"
                        class="tcm-preset-card text-left p-3 bg-brand-cream-deep hover:bg-brand-sky/10 border-2 border-dashed border-brand-ink/20 hover:border-brand-sky-deep rounded-[var(--radius-card)] transition-all duration-150 active:scale-[0.97]"
                        data-preset={JSON.stringify(customPreset)}
                    >
                        <div class="text-2xl mb-1.5">✏️</div>
                        <p class="text-xs font-semibold text-brand-ink-soft leading-snug">
                            {lang === "es" ? "Personalizada" : "Custom"}
                        </p>
                        <p class="text-[10px] text-brand-ink-soft mt-1">
                            {lang === "es" ? "Desde cero" : "Start from scratch"}
                        </p>
                    </button>
                </div>
            </div>
        </div>

        <!-- Step 2: Mini-form -->
        <div id="tcm-step-2" class="hidden flex-col flex-1 overflow-hidden">
            <div class="flex-1 overflow-y-auto px-5 pt-4 pb-3 space-y-5">

                <!-- 1. Task name -->
                <div>
                    <label for="tcm-name" class="block text-xs font-semibold text-brand-ink-soft uppercase tracking-wider mb-1.5">
                        {lang === "es" ? "Nombre de la tarea" : "Task name"}
                    </label>
                    <input
                        id="tcm-name"
                        type="text"
                        autocomplete="off"
                        placeholder={lang === "es" ? "Ej. Lavar platos" : "e.g. Wash Dishes"}
                        class="w-full px-3 py-2.5 border border-brand-ink/20 rounded-xl text-sm font-medium focus:ring-2 focus:ring-brand-sky-deep focus:border-brand-sky-deep outline-none bg-brand-cream"
                    />
                </div>

                <!-- 2. Difficulty chips -->
                <div>
                    <p class="text-xs font-semibold text-brand-ink-soft uppercase tracking-wider mb-2">
                        {lang === "es" ? "Dificultad" : "Difficulty"}
                    </p>
                    <div class="flex gap-2" data-chipgroup="effort">
                        <button type="button" class="tcm-chip flex-1 py-2 px-3 text-sm font-semibold rounded-xl border-2 transition-colors" data-value="1">
                            {lang === "es" ? "Fácil ×1" : "Easy ×1"}
                        </button>
                        <button type="button" class="tcm-chip flex-1 py-2 px-3 text-sm font-semibold rounded-xl border-2 transition-colors" data-value="2">
                            {lang === "es" ? "Medio ×1.5" : "Med ×1.5"}
                        </button>
                        <button type="button" class="tcm-chip flex-1 py-2 px-3 text-sm font-semibold rounded-xl border-2 transition-colors" data-value="3">
                            {lang === "es" ? "Difícil ×2" : "Hard ×2"}
                        </button>
                    </div>
                </div>

                <!-- 3. How Often chips -->
                <div>
                    <p class="text-xs font-semibold text-brand-ink-soft uppercase tracking-wider mb-2">
                        {lang === "es" ? "¿Con qué frecuencia?" : "How Often"}
                    </p>
                    <div class="flex gap-2 flex-wrap" data-chipgroup="interval">
                        <button type="button" class="tcm-chip flex-1 py-2 px-3 text-sm font-semibold rounded-xl border-2 transition-colors" data-value="1">
                            {lang === "es" ? "Diario" : "Daily"}
                        </button>
                        <button type="button" class="tcm-chip flex-1 py-2 px-3 text-sm font-semibold rounded-xl border-2 transition-colors" data-value="3">
                            {lang === "es" ? "c/3 días" : "Every 3d"}
                        </button>
                        <button type="button" class="tcm-chip flex-1 py-2 px-3 text-sm font-semibold rounded-xl border-2 transition-colors" data-value="7">
                            {lang === "es" ? "Semanal" : "Weekly"}
                        </button>
                        <button type="button" class="tcm-chip flex-1 py-2 px-3 text-sm font-semibold rounded-xl border-2 transition-colors" data-value="interval" title={lang === "es" ? "Se reprograma N días después de completarla" : "Reschedules N days after it's completed"}>
                            {lang === "es" ? "Al terminar" : "After done"}
                        </button>
                    </div>
                    <!-- N-days input (revealed for 'after done' mode) -->
                    <div id="tcm-interval-n-wrap" class="hidden mt-3 flex items-center gap-2 p-3 bg-brand-cream-deep rounded-xl border border-brand-ink/10">
                        <span class="text-sm text-brand-ink">{lang === "es" ? "Cada" : "Every"}</span>
                        <input
                            id="tcm-interval-n"
                            type="number"
                            min="1"
                            max="90"
                            value="3"
                            class="w-20 px-3 py-2 text-sm border border-brand-ink/20 rounded-lg focus:ring-2 focus:ring-brand-sky-deep focus:border-brand-sky-deep outline-none bg-brand-cream"
                        />
                        <span class="text-sm text-brand-ink flex-1">
                            {lang === "es" ? "días después de completarla" : "days after it's completed"}
                        </span>
                    </div>
                    <!-- Weekday picker (optional exact days, Mon=0..Sun=6) -->
                    <div id="tcm-dow-wrap" class="mt-3">
                        <p class="text-[11px] font-medium text-brand-ink-soft mb-1.5">
                            {lang === "es" ? "Días exactos (opcional)" : "Exact days (optional)"}
                        </p>
                        <div class="flex gap-1.5" data-dowgroup>
                            {dowLabels.map((d, i) => (
                                <button
                                    type="button"
                                    class="tcm-dow h-8 w-8 text-xs font-bold rounded-full border-2 border-transparent bg-brand-cream-deep text-brand-ink-soft transition-colors"
                                    data-dow={i}
                                    aria-pressed="false"
                                >{d}</button>
                            ))}
                        </div>
                        <p id="tcm-dow-note" class="hidden text-[11px] text-brand-ink-soft mt-1.5">
                            {lang === "es"
                                ? "La tarea caerá exactamente en esos días cada semana."
                                : "The task will land exactly on those days each week."}
                        </p>
                    </div>
                </div>

                <!-- 4. Assign To chips -->
                <div data-tour="task-assign">
                    <p class="text-xs font-semibold text-brand-ink-soft uppercase tracking-wider mb-2">
                        {lang === "es" ? "Asignar a" : "Assign To"}
                    </p>
                    <div class="flex gap-2" data-chipgroup="assignment">
                        <button type="button" class="tcm-chip flex-1 py-2 px-2 text-xs font-semibold rounded-xl border-2 transition-colors" data-value="auto">
                            {lang === "es" ? "Auto" : "Auto"}
                        </button>
                        <button type="button" class="tcm-chip flex-1 py-2 px-2 text-xs font-semibold rounded-xl border-2 transition-colors" data-value="fixed">
                            {lang === "es" ? "Fijo" : "Fixed"}
                        </button>
                        <button type="button" class="tcm-chip flex-1 py-2 px-2 text-xs font-semibold rounded-xl border-2 transition-colors" data-value="rotate">
                            {lang === "es" ? "Rotación" : "Rotate"}
                        </button>
                    </div>

                    <!-- One-line explainer that follows the selected chip -->
                    <p id="tcm-assign-hint" class="text-[11px] text-brand-ink-soft mt-1.5 px-1"></p>

                    <!-- Member checkboxes (revealed for fixed/rotate) -->
                    <div id="tcm-members" class="hidden mt-3 space-y-2 p-3 bg-brand-cream-deep rounded-xl border border-brand-ink/10">
                        {memberList.map((member) => (
                            <label class="flex items-center gap-2 cursor-pointer hover:bg-brand-cream px-2 py-1.5 rounded-lg transition-colors">
                                <input
                                    type="checkbox"
                                    class="tcm-member-cb w-4 h-4 text-brand-sky-deep border-brand-ink/20 rounded focus:ring-2 focus:ring-brand-sky-deep"
                                    value={member.id}
                                    data-name={member.name}
                                />
                                <span class="text-sm text-brand-ink flex-1">{member.name}</span>
                                <span class="text-xs text-brand-ink-soft">{member.role.toLowerCase()}</span>
                            </label>
                        ))}
                        <p id="tcm-rotate-hint" class="hidden text-[11px] text-brand-ink-soft px-2 pt-1">
                            {lang === "es"
                                ? "Sin selección = rota entre todos"
                                : "No selection = rotates among everyone"}
                        </p>
                        <p id="tcm-fixed-error" class="hidden text-[11px] text-red-600 px-2 pt-1">
                            {lang === "es"
                                ? "Para asignación fija selecciona al menos un miembro."
                                : "Fixed assignment needs at least one member selected."}
                        </p>
                    </div>
                </div>

                <!-- 4b. Photo proof toggle -->
                <div class="flex items-center gap-3 py-1">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input id="tcm-proof" type="checkbox" class="sr-only peer" />
                        <div class="w-9 h-5 bg-brand-cream-deep rounded-full peer peer-checked:bg-brand-sky-deep peer-focus:ring-2 peer-focus:ring-sky-300 transition-colors after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-brand-cream after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-full"></div>
                    </label>
                    <div>
                        <span class="text-sm font-medium text-brand-ink">📸 {lang === "es" ? "Requiere foto" : "Requires photo"}</span>
                        <p class="text-xs text-brand-ink-soft">
                            {lang === "es" ? "Deben subir foto; tú apruebas antes de dar puntos." : "Kid must attach a photo; you approve before points."}
                        </p>
                    </div>
                </div>

                <!-- 5. Bonus toggle -->
                <div class="flex items-center gap-3 py-1">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input id="tcm-bonus" type="checkbox" class="sr-only peer" />
                        <div class="w-9 h-5 bg-brand-cream-deep rounded-full peer peer-checked:bg-brand-sun-deep peer-focus:ring-2 peer-focus:ring-amber-300 transition-colors after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-brand-cream after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-full"></div>
                    </label>
                    <div>
                        <span class="text-sm font-medium text-brand-ink">⭐ {lang === "es" ? "Tarea bonus" : "Bonus task"}</span>
                        <p class="text-xs text-brand-ink-soft">
                            {lang === "es" ? "Opcional, no se penaliza si no se hace." : "Optional, no penalty if skipped."}
                        </p>
                    </div>
                </div>

                <!-- Points (explicit at create time, not silently zeroed) -->
                <div class="flex items-center gap-3 py-1">
                    <label for="tcm-points" class="text-sm font-medium text-brand-ink whitespace-nowrap">
                        ⭐ {lang === "es" ? "Puntos" : "Points"}
                    </label>
                    <input
                        id="tcm-points"
                        type="number"
                        min="0"
                        step="1"
                        value="10"
                        class="w-24 px-3 py-2 text-sm border border-brand-ink/20 rounded-lg focus:ring-2 focus:ring-brand-sky-deep focus:border-brand-sky-deep outline-none bg-brand-cream"
                    />
                    <span class="text-xs text-brand-ink-soft">
                        {lang === "es" ? "que gana al completarla" : "earned on completion"}
                    </span>
                </div>

                <!-- Advanced collapse -->
                <details class="bg-brand-cream-deep/50 rounded-xl border border-brand-ink/10">
                    <summary class="px-4 py-3 text-sm font-medium text-brand-ink cursor-pointer select-none">
                        {lang === "es" ? "⚙️ Opciones avanzadas" : "⚙️ Advanced options"}
                    </summary>
                    <div class="px-4 pb-4 pt-2 space-y-4">
                        <!-- Description -->
                        <div>
                            <label for="tcm-desc" class="block text-xs font-medium text-brand-ink-soft mb-1">
                                {lang === "es" ? "Descripción" : "Description"}
                            </label>
                            <textarea
                                id="tcm-desc"
                                rows={2}
                                placeholder={lang === "es" ? "Instrucciones opcionales…" : "Optional instructions…"}
                                class="w-full px-3 py-2 text-sm border border-brand-ink/20 rounded-lg focus:ring-2 focus:ring-brand-sky-deep focus:border-brand-sky-deep outline-none resize-none bg-brand-cream"
                            ></textarea>
                        </div>

                        <!-- Allowed roles -->
                        <div>
                            <p class="text-xs font-medium text-brand-ink-soft mb-2">
                                {lang === "es" ? "Roles permitidos" : "Allowed roles"}
                            </p>
                            <div class="flex gap-4 flex-wrap">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" class="tcm-role-cb w-4 h-4 text-brand-sky-deep border-brand-ink/20 rounded focus:ring-2 focus:ring-brand-sky-deep" value="parent" />
                                    <span class="text-sm text-brand-ink">{lang === "es" ? "Padre/Madre" : "Parent"}</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" class="tcm-role-cb w-4 h-4 text-brand-sky-deep border-brand-ink/20 rounded focus:ring-2 focus:ring-brand-sky-deep" value="teen" />
                                    <span class="text-sm text-brand-ink">{lang === "es" ? "Teen" : "Teen"}</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" class="tcm-role-cb w-4 h-4 text-brand-sky-deep border-brand-ink/20 rounded focus:ring-2 focus:ring-brand-sky-deep" value="child" />
                                    <span class="text-sm text-brand-ink">{lang === "es" ? "Niño/a" : "Child"}</span>
                                </label>
                            </div>
                        </div>

                        <!-- Gig mode — only meaningful for bonus tasks; hidden for mandatory chores -->
                        <div id="tcm-gig-wrap" class="hidden">
                            <label for="tcm-gig" class="block text-xs font-medium text-brand-ink-soft mb-1">
                                {lang === "es" ? "Modo de gig" : "Gig mode"}
                            </label>
                            <select
                                id="tcm-gig"
                                class="w-full px-3 py-2 text-sm border border-brand-ink/20 rounded-lg focus:ring-2 focus:ring-brand-sky-deep focus:border-brand-sky-deep outline-none bg-brand-cream"
                            >
                                <option value="claim">{lang === "es" ? "Reservar (default)" : "Claim (default)"}</option>
                                <option value="competition">{lang === "es" ? "🏆 Competencia" : "🏆 Competition"}</option>
                                <option value="rotation">{lang === "es" ? "🔄 Rotación" : "🔄 Rotation"}</option>
                                <option value="collaboration">{lang === "es" ? "🤝 Colaboración" : "🤝 Collaboration"}</option>
                            </select>
                        </div>

                        <!-- Blocks rewards -->
                        <div class="flex items-center gap-3">
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input id="tcm-blocks-rewards" type="checkbox" class="sr-only peer" />
                                <div class="w-9 h-5 bg-brand-cream-deep rounded-full peer peer-checked:bg-brand-coral-deep peer-focus:ring-2 peer-focus:ring-red-300 transition-colors after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-brand-cream after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-full"></div>
                            </label>
                            <div>
                                <span class="text-sm font-medium text-brand-ink">🔒 {lang === "es" ? "Bloquea recompensas" : "Blocks rewards"}</span>
                                <p class="text-xs text-brand-ink-soft">
                                    {lang === "es" ? "No se pueden canjear mientras esté pendiente." : "Can't redeem rewards while open."}
                                </p>
                            </div>
                        </div>
                    </div>
                </details>

                <!-- Error div -->
                <div id="tcm-error" class="hidden text-sm text-red-600 px-1"></div>
            </div>

            <!-- Footer buttons -->
            <div class="flex gap-3 px-5 py-4 border-t border-brand-ink/10 flex-shrink-0">
                <button
                    id="tcm-back"
                    type="button"
                    class="hidden flex-none py-2.5 px-4 text-sm font-semibold border-2 border-brand-ink/20 text-brand-ink rounded-xl hover:bg-brand-cream-deep transition-colors"
                >
                    ← {lang === "es" ? "Volver" : "Back"}
                </button>
                <button
                    id="tcm-submit"
                    type="button"
                    data-tour="task-submit"
                    class="hidden flex-1 py-2.5 bg-brand-sky-deep hover:bg-brand-ink active:scale-[0.98] text-white font-semibold text-sm rounded-xl shadow-[var(--shadow-card)] transition-all duration-150"
                >
                    {lang === "es" ? "Crear tarea" : "Create Task"}
                </button>
            </div>
        </div>

    </div>
</div>

<script define:vars={{ token, lang }}>
(function initTaskCreateModal() {
    const isEs = lang === "es";
    const backdrop = document.getElementById("tcm-backdrop");
    const modal = document.getElementById("tcm-modal");
    const step1 = document.getElementById("tcm-step-1");
    const step2 = document.getElementById("tcm-step-2");
    const closeBtn = document.getElementById("tcm-close");
    const backBtn = document.getElementById("tcm-back");
    const submitBtn = document.getElementById("tcm-submit");
    const nameInput = document.getElementById("tcm-name");
    const searchInput = document.getElementById("tcm-search");
    const bonusChk = document.getElementById("tcm-bonus");
    const blocksChk = document.getElementById("tcm-blocks-rewards");
    const proofChk = document.getElementById("tcm-proof");
    const gigSelect = document.getElementById("tcm-gig");
    const gigWrap = document.getElementById("tcm-gig-wrap");
    const pointsInput = document.getElementById("tcm-points");
    const intervalNWrap = document.getElementById("tcm-interval-n-wrap");
    const intervalNInput = document.getElementById("tcm-interval-n");

    // Gig mode is only relevant to bonus tasks — keep its jargon out of plain chores.
    bonusChk?.addEventListener("change", () => {
        gigWrap?.classList.toggle("hidden", !bonusChk.checked);
    });
    const descTA = document.getElementById("tcm-desc");
    const membersDiv = document.getElementById("tcm-members");
    const errorDiv = document.getElementById("tcm-error");
    const assignHint = document.getElementById("tcm-assign-hint");
    const rotateHint = document.getElementById("tcm-rotate-hint");
    const fixedError = document.getElementById("tcm-fixed-error");
    const dowWrap = document.getElementById("tcm-dow-wrap");
    const dowNote = document.getElementById("tcm-dow-note");
    const submitBtnOriginalText = submitBtn?.textContent ?? "";

    if (!backdrop || !modal) return;

    // ----- Chip state -----
    const chipState = { effort: "1", interval: "1", assignment: "auto" };

    // ----- Weekday picker state (Mon=0 .. Sun=6) -----
    const dowState = new Set();

    function selectedDows() {
        return Array.from(dowState).map(Number).sort((a, b) => a - b);
    }

    function refreshDowStyles() {
        modal.querySelectorAll(".tcm-dow").forEach((btn) => {
            const active = dowState.has(String(btn.dataset.dow));
            btn.classList.toggle("bg-brand-sky-deep", active);
            btn.classList.toggle("text-white", active);
            btn.classList.toggle("border-brand-sky-deep", active);
            btn.classList.toggle("bg-brand-cream-deep", !active);
            btn.classList.toggle("text-brand-ink-soft", !active);
            btn.classList.toggle("border-transparent", !active);
            btn.setAttribute("aria-pressed", active ? "true" : "false");
        });
        if (dowNote) dowNote.classList.toggle("hidden", dowState.size === 0);
    }

    modal.querySelectorAll(".tcm-dow").forEach((btn) => {
        btn.addEventListener("click", () => {
            const d = String(btn.dataset.dow);
            if (dowState.has(d)) dowState.delete(d);
            else dowState.add(d);
            refreshDowStyles();
        });
    });

    // ----- Assignment chip explainer + rotate hint -----
    const assignHints = {
        auto: isEs ? "Se reparte automáticamente balanceando puntos" : "Balanced automatically by points",
        fixed: isEs ? "Siempre la(s) misma(s) persona(s)" : "Always the same person(s)",
        rotate: isEs ? "Se turnan" : "They take turns",
    };

    function checkedMemberCount() {
        return modal.querySelectorAll(".tcm-member-cb:checked").length;
    }

    function refreshAssignmentHints() {
        if (assignHint) assignHint.textContent = assignHints[chipState.assignment] ?? "";
        if (rotateHint) {
            rotateHint.classList.toggle(
                "hidden",
                !(chipState.assignment === "rotate" && checkedMemberCount() === 0),
            );
        }
        if (fixedError && chipState.assignment !== "fixed") fixedError.classList.add("hidden");
        if (fixedError && checkedMemberCount() > 0) fixedError.classList.add("hidden");
    }

    modal.querySelectorAll(".tcm-member-cb").forEach((cb) => {
        cb.addEventListener("change", () => {
            refreshAssignmentHints();
            // Checking a specific member (fixed/rotate mode) is also a real assignee pick.
            if (cb.checked) {
                window.dispatchEvent(new CustomEvent("ftm:mission", { detail: { signal: "task-assignee-selected" } }));
            }
        });
    });

    function activateChip(group, value) {
        chipState[group] = String(value);
        const container = modal.querySelector(`[data-chipgroup="${group}"]`);
        if (!container) return;
        container.querySelectorAll(".tcm-chip").forEach((btn) => {
            const isActive = String(btn.dataset.value) === String(value);
            btn.classList.toggle("bg-brand-sky-deep", isActive);
            btn.classList.toggle("text-white", isActive);
            btn.classList.toggle("border-brand-sky-deep", isActive);
            btn.classList.toggle("bg-brand-cream-deep", !isActive);
            btn.classList.toggle("text-brand-ink-soft", !isActive);
            btn.classList.toggle("border-transparent", !isActive);
        });

        // Show/hide member list for assignment chips
        if (group === "assignment" && membersDiv) {
            if (value === "fixed" || value === "rotate") {
                membersDiv.classList.remove("hidden");
            } else {
                membersDiv.classList.add("hidden");
            }
        }
        if (group === "assignment") refreshAssignmentHints();

        // Show/hide the N-days input for the 'after done' recurrence mode
        if (group === "interval" && intervalNWrap) {
            intervalNWrap.classList.toggle("hidden", String(value) !== "interval");
        }
        // Weekday picker only applies to weekly-expansion modes, not 'after done'
        if (group === "interval" && dowWrap) {
            const hideDow = String(value) === "interval";
            dowWrap.classList.toggle("hidden", hideDow);
            if (hideDow) {
                dowState.clear();
                refreshDowStyles();
            }
        }
    }

    // Wire chip groups
    modal.querySelectorAll("[data-chipgroup]").forEach((group) => {
        group.querySelectorAll(".tcm-chip").forEach((btn) => {
            btn.addEventListener("click", () => {
                const groupName = group.dataset.chipgroup;
                activateChip(groupName, btn.dataset.value);
                // "Assign To" chip (auto/fixed/rotate) is itself picking who does it —
                // Auto is a valid, real assignee choice, not just a passive default.
                if (groupName === "assignment") {
                    window.dispatchEvent(new CustomEvent("ftm:mission", { detail: { signal: "task-assignee-selected" } }));
                }
            });
        });
    });

    // ----- Open / Close -----
    function handleEscape(e) {
        if (e.key === "Escape") closeModal();
    }

    function openModal() {
        resetModal();
        backdrop.classList.remove("hidden");
        modal.classList.remove("hidden");
        modal.classList.add("flex");
        requestAnimationFrame(() => {
            backdrop.classList.remove("opacity-0");
            backdrop.classList.add("opacity-100");
        });
        document.addEventListener("keydown", handleEscape);
        setTimeout(() => searchInput?.focus(), 200);
    }

    function closeModal() {
        document.removeEventListener("keydown", handleEscape);
        backdrop.classList.remove("opacity-100");
        backdrop.classList.add("opacity-0");
        setTimeout(() => {
            backdrop.classList.add("hidden");
            modal.classList.add("hidden");
            modal.classList.remove("flex");
            resetModal();
        }, 300);
    }

    function resetModal() {
        showStep(1);
        if (nameInput) nameInput.value = "";
        if (searchInput) searchInput.value = "";
        if (descTA) descTA.value = "";
        if (bonusChk) bonusChk.checked = false;
        if (blocksChk) blocksChk.checked = false;
        if (proofChk) proofChk.checked = false;
        if (gigSelect) gigSelect.value = "claim";
        if (gigWrap) gigWrap.classList.add("hidden");
        if (pointsInput) pointsInput.value = "10";
        if (intervalNInput) intervalNInput.value = "3";
        if (intervalNWrap) intervalNWrap.classList.add("hidden");
        if (errorDiv) { errorDiv.textContent = ""; errorDiv.classList.add("hidden"); }
        if (fixedError) fixedError.classList.add("hidden");
        if (membersDiv) membersDiv.classList.add("hidden");
        modal.querySelectorAll(".tcm-member-cb").forEach((cb) => { cb.checked = false; });
        modal.querySelectorAll(".tcm-role-cb").forEach((cb) => { cb.checked = false; });
        dowState.clear();
        refreshDowStyles();
        if (dowWrap) dowWrap.classList.remove("hidden");
        // Reset chips to defaults
        activateChip("effort", "1");
        activateChip("interval", "1");
        activateChip("assignment", "auto");
        // Show all presets
        filterPresets("");
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = submitBtnOriginalText; }
    }

    // ----- Step navigation -----
    function showStep(n) {
        if (n === 1) {
            step1.classList.remove("hidden");
            step1.classList.add("flex");
            step2.classList.add("hidden");
            step2.classList.remove("flex");
            if (backBtn) backBtn.classList.add("hidden");
            if (submitBtn) submitBtn.classList.add("hidden");
        } else {
            step1.classList.add("hidden");
            step1.classList.remove("flex");
            step2.classList.remove("hidden");
            step2.classList.add("flex");
            if (backBtn) backBtn.classList.remove("hidden");
            if (submitBtn) submitBtn.classList.remove("hidden");
            setTimeout(() => nameInput?.focus(), 100);
        }
    }

    // ----- Filter presets -----
    function filterPresets(query) {
        const q = (query || "").toLowerCase().trim();
        modal.querySelectorAll(".tcm-preset-card").forEach((card) => {
            if (!q) {
                card.style.display = "";
                return;
            }
            try {
                const preset = JSON.parse(card.dataset.preset || "{}");
                const title = (preset.title || "").toLowerCase();
                const titleEs = (preset.title_es || "").toLowerCase();
                card.style.display = (title.includes(q) || titleEs.includes(q)) ? "" : "none";
            } catch (_) {
                card.style.display = "";
            }
        });
    }

    // ----- Preset card click -----
    modal.querySelectorAll(".tcm-preset-card").forEach((card) => {
        card.addEventListener("click", () => {
            try {
                const preset = JSON.parse(card.dataset.preset || "{}");
                if (nameInput) nameInput.value = (isEs && preset.title_es ? preset.title_es : preset.title) || "";
                if (pointsInput) pointsInput.value = String(preset.points ?? 10);
                activateChip("effort", String(preset.effort_level || "1"));
                activateChip("interval", String(preset.interval_days || "1"));
                showStep(2);
                window.dispatchEvent(new CustomEvent("ftm:mission", { detail: { signal: "task-template-selected" } }));
            } catch (_) { /* silent */ }
        });
    });

    // ----- Create handler -----
    async function handleCreate() {
        if (errorDiv) { errorDiv.textContent = ""; errorDiv.classList.add("hidden"); }

        const title = (nameInput?.value || "").trim();
        if (!title) {
            showError(document.documentElement.lang === "es"
                ? "Ingresa el nombre de la tarea"
                : "Enter a task name");
            nameInput?.focus();
            return;
        }

        const isBonus = bonusChk?.checked || false;
        const blocksRewards = blocksChk?.checked || false;
        const gigMode = gigSelect?.value || "claim";
        const description = (descTA?.value || "").trim() || null;
        const assignedUserIds = Array.from(modal.querySelectorAll(".tcm-member-cb:checked")).map((cb) => cb.value);
        const allowedRoles = Array.from(modal.querySelectorAll(".tcm-role-cb:checked")).map((cb) => cb.value);

        // FIXED requires at least one member (backend now 422s otherwise).
        // ROTATE with none checked is valid: rotates among everyone.
        if (chipState.assignment === "fixed" && assignedUserIds.length === 0) {
            if (fixedError) fixedError.classList.remove("hidden");
            showError(isEs
                ? "Para asignación fija selecciona al menos un miembro."
                : "Fixed assignment needs at least one member selected.");
            return;
        }

        const points = parseInt(pointsInput?.value, 10);
        if (isNaN(points) || points < 1) {
            showError(document.documentElement.lang === "es"
                ? "Los puntos deben ser al menos 1"
                : "Points must be at least 1");
            pointsInput?.focus();
            return;
        }

        // 'interval' chip = 'every N days since last completion' mode.
        const isIntervalMode = chipState.interval === "interval";
        let recurEveryN = null;
        if (isIntervalMode) {
            recurEveryN = parseInt(intervalNInput?.value, 10);
            if (isNaN(recurEveryN) || recurEveryN < 1 || recurEveryN > 90) {
                showError(document.documentElement.lang === "es"
                    ? "Los días deben estar entre 1 y 90"
                    : "Days must be between 1 and 90");
                intervalNInput?.focus();
                return;
            }
        }

        // Weekday picker (Mon=0..Sun=6): when set, weekly expansion lands
        // exactly on those days and interval_days is ignored by the backend.
        const daysOfWeek = isIntervalMode ? [] : selectedDows();

        if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = "…"; }

        // The parent authors in the UI language. Map that onto the canonical
        // columns (title/description = English base, NON-NULL; *_es = Spanish)
        // so Spanish-typed text no longer lands in the English column. Translate
        // the other language now via the stateless endpoint, bounded so a slow
        // LLM proxy never stalls creation; on failure we degrade, never block.
        const uiLang = isEs ? "es" : "en";
        const otherLang = isEs ? "en" : "es";
        let altTitle = "";
        let altDesc = null;
        {
            const ac = new AbortController();
            const tmo = setTimeout(() => ac.abort(), 6000);
            try {
                const tRes = await fetch("/api/task-templates/translate-text", {
                    method: "POST",
                    headers: { "Content-Type": "application/json", "Authorization": `Bearer ${token}` },
                    body: JSON.stringify({ title, description, source_lang: uiLang, target_lang: otherLang }),
                    signal: ac.signal,
                });
                if (tRes.ok) {
                    const tData = await tRes.json();
                    altTitle = (tData.title || "").trim();
                    altDesc = (tData.description || "").trim() || null;
                }
            } catch (_) { /* silent (incl. abort / 403 free plan) — create untranslated */ }
            finally { clearTimeout(tmo); }
        }

        let titleEn, descEn, titleEs, descEs;
        if (isEs) {
            titleEs = title; descEs = description;
            titleEn = altTitle || title;        // NOT NULL base; degrade to ES if translation unavailable
            descEn = altDesc ?? description;
        } else {
            titleEn = title; descEn = description;
            titleEs = altTitle || null; descEs = altDesc ?? null;
        }

        const payload = {
            title: titleEn,
            description: descEn || null,
            title_es: titleEs || null,
            description_es: descEs || null,
            points,
            effort_level: parseInt(chipState.effort, 10),
            interval_days: isIntervalMode ? 7 : parseInt(chipState.interval, 10),
            recurrence_mode: isIntervalMode ? "since_completion" : "weekly",
            recur_every_n_days: recurEveryN,
            days_of_week: daysOfWeek.length > 0 ? daysOfWeek : null,
            requires_proof: proofChk?.checked || false,
            is_bonus: isBonus,
            blocks_rewards: blocksRewards,
            gig_mode: gigMode,
            collaboration_min_count: 2,
            auto_late_penalty: false,
            late_restriction_type: null,
            late_severity: null,
            late_duration_days: 1,
            assignment_type: chipState.assignment,
            assigned_user_ids: assignedUserIds.length > 0 ? assignedUserIds : null,
            allowed_roles: allowedRoles.length > 0 ? allowedRoles : null,
        };

        try {
            const res = await fetch("/api/task-templates/", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": `Bearer ${token}`,
                },
                body: JSON.stringify(payload),
            });

            if (!res.ok) {
                const errData = await res.json().catch(() => ({}));
                throw new Error(errData.detail || `Error ${res.status}`);
            }

            await res.json();
            window.dispatchEvent(new CustomEvent("ftm:mission", { detail: { signal: "task-created" } }));
            closeModal();
            refreshTemplateList();
        } catch (err) {
            showError(err.message || "Error creating task");
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.textContent = submitBtnOriginalText;
            }
        }
    }

    // ----- Refresh template list -----
    async function refreshTemplateList() {
        try {
            const res = await fetch("/api/task-templates/", {
                headers: { "Authorization": `Bearer ${token}` },
            });
            if (!res.ok) return;
            const templates = await res.json();

            const container = document.getElementById("template-list-container");
            if (!container) return;

            // This page lists mandatory chores only — gigs/bonus live in /parent/gigs.
            const chores = (Array.isArray(templates) ? templates : []).filter((t) => !t.is_bonus);

            if (chores.length === 0) {
                container.innerHTML = `<p class="text-brand-ink-soft text-sm text-center py-6">${
                    isEs ? "Ninguna tarea todavía." : "No tasks yet."
                }</p>`;
                return;
            }

            container.innerHTML = chores.map(renderTemplateCard).join("");
        } catch (_) { /* silent — leave stale list */ }
    }

    // ----- HTML escape helper (prevents XSS when interpolating user data into innerHTML) -----
    function escapeHtml(str) {
        return String(str ?? "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;");
    }

    // ----- Render a template card matching the SSR structure -----
    function renderTemplateCard(tmpl) {
        const isActive = tmpl.is_active !== false;
        const isBonus = !!tmpl.is_bonus;
        const effortLevel = tmpl.effort_level || 1;
        const pts = tmpl.points || 0;
        const effectivePts = Math.round(pts * (effortLevel === 3 ? 2 : effortLevel === 2 ? 1.5 : 1));
        const multiplierNote = effortLevel > 1
            ? `<span class="ml-1 text-brand-ink-soft font-normal">(${pts} × ${effortLevel === 3 ? "2" : "1.5"})</span>`
            : "";

        const freqMap = isEs
            ? { 1: "Diaria", 3: "Cada 3d", 7: "Semanal" }
            : { 1: "Daily", 3: "Every 3d", 7: "Weekly" };
        const freqLabel = tmpl.recurrence_mode === "since_completion"
            ? (isEs ? `c/${tmpl.recur_every_n_days || 1}d al terminar` : `every ${tmpl.recur_every_n_days || 1}d after done`)
            : (freqMap[tmpl.interval_days] || (isEs ? `Cada ${tmpl.interval_days}d` : `Every ${tmpl.interval_days}d`));
        const proofBadge = tmpl.requires_proof
            ? `<span class="text-xs font-medium px-2 py-0.5 rounded-full bg-brand-sky/15 text-brand-sky-deep">📸 ${isEs ? "Foto" : "Photo"}</span>`
            : "";

        const esMissingBadge = !tmpl.title_es
            ? `<span class="inline-block ml-2 text-[10px] font-normal px-1.5 py-0.5 rounded bg-orange-100 text-orange-700 border border-orange-200" title="${isEs ? "Falta traduccion" : "Translation missing"}">${isEs ? "Falta ES" : "ES missing"}</span>`
            : "";

        const bonusBadgeClass = isBonus
            ? "bg-brand-sun/20 text-brand-sun-deep"
            : "bg-brand-sky/15 text-brand-sky-deep";
        const bonusBadgeText = isBonus
            ? "Bonus"
            : (isEs ? "Obligatoria" : "Required");

        const assignmentBadge = (tmpl.assignment_type && tmpl.assignment_type !== "auto")
            ? `<span class="text-xs font-medium px-2 py-0.5 rounded-full ${tmpl.assignment_type === "fixed" ? "bg-brand-coral/15 text-brand-coral-deep" : "bg-brand-mint/20 text-brand-mint-deep"}">${tmpl.assignment_type === "fixed" ? (isEs ? "📌 Fijo" : "📌 Fixed") : (isEs ? "🔄 Rotación" : "🔄 Rotate")}</span>`
            : "";

        const inactiveBadge = !isActive
            ? `<span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-red-100 text-red-600">${isEs ? "Inactiva" : "Inactive"}</span>`
            : "";

        const descriptionHtml = tmpl.description
            ? `<p class="text-xs text-brand-ink-soft line-clamp-1">${escapeHtml(tmpl.description)}</p>`
            : "";

        const toggleIcon = isActive
            ? `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />`
            : `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />`;
        const toggleClass = isActive
            ? "bg-brand-mint/20 text-brand-mint-deep hover:bg-brand-mint"
            : "bg-brand-cream-deep text-brand-ink-soft hover:bg-brand-mint/20 hover:text-brand-mint-deep";

        return `
<div class="bg-brand-cream rounded-2xl p-4 shadow-[var(--shadow-card)] border ${isActive ? "border-brand-ink/10" : "border-brand-ink/10 opacity-60"}">
    <div class="flex items-start justify-between gap-3">
        <div class="flex-1">
            <div class="flex items-center gap-2 flex-wrap mb-1">
                <h3 class="font-bold text-brand-ink text-sm">
                    ${escapeHtml(tmpl.title)}${esMissingBadge}
                </h3>
                <span class="text-xs font-semibold px-2 py-0.5 rounded-full ${bonusBadgeClass}">${bonusBadgeText}</span>
                <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-brand-cream-deep text-brand-ink-soft">${freqLabel}</span>
                ${proofBadge}
                ${assignmentBadge}
                ${inactiveBadge}
            </div>
            ${descriptionHtml}
            <p class="text-xs text-brand-sun-deep font-semibold mt-1">
                +${effectivePts} pts${multiplierNote}
            </p>
        </div>
        <div class="flex gap-1.5 flex-shrink-0">
            <form method="POST">
                <input type="hidden" name="action" value="toggle" />
                <input type="hidden" name="template_id" value="${escapeHtml(tmpl.id)}" />
                <button type="submit" title="${isActive ? (isEs ? "Desactivar" : "Deactivate") : (isEs ? "Activar" : "Activate")}"
                    class="h-8 w-8 rounded-lg flex items-center justify-center transition-colors ${toggleClass}">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">${toggleIcon}</svg>
                </button>
            </form>
            <a href="/parent/tasks/${escapeHtml(tmpl.id)}/edit"
                class="h-8 w-8 rounded-lg bg-brand-cream-deep hover:bg-brand-cream-deep text-brand-ink-soft hover:text-brand-sky-deep flex items-center justify-center transition-colors">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
            </a>
            <form method="POST">
                <input type="hidden" name="action" value="delete" />
                <input type="hidden" name="template_id" value="${escapeHtml(tmpl.id)}" />
                <button type="submit"
                    onclick="return confirm('${isEs ? "Eliminar esta plantilla y todas sus asignaciones?" : "Delete this template and all its assignments?"}')"
                    class="h-8 w-8 rounded-lg bg-brand-cream-deep hover:bg-red-100 text-brand-ink-soft hover:text-red-500 flex items-center justify-center transition-colors">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                </button>
            </form>
        </div>
    </div>
</div>`;
    }

    // ----- Helpers -----
    function showError(msg) {
        if (errorDiv) {
            errorDiv.textContent = msg;
            errorDiv.classList.remove("hidden");
        }
    }

    // ----- Wire events -----
    // Trigger is in tasks.astro (id="tcm-trigger")
    const triggerBtn = document.getElementById("tcm-trigger");
    if (triggerBtn) triggerBtn.addEventListener("click", openModal);

    if (closeBtn) closeBtn.addEventListener("click", closeModal);
    backdrop.addEventListener("click", closeModal);
    if (backBtn) backBtn.addEventListener("click", () => showStep(1));
    if (submitBtn) {
        submitBtn.addEventListener("click", handleCreate);
    }
    if (searchInput) searchInput.addEventListener("input", (e) => filterPresets(e.target.value));

    // Initialize chip active styles on load
    activateChip("effort", "1");
    activateChip("interval", "1");
    activateChip("assignment", "auto");

    // Back-compat: hide back/submit at init (step 1 is shown)
    if (backBtn) backBtn.classList.add("hidden");
    if (submitBtn) submitBtn.classList.add("hidden");

    // View Transitions re-init
    document.addEventListener("astro:after-swap", initTaskCreateModal);
})();
</script>
