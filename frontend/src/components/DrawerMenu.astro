---
/**
 * DrawerMenu - Slide-out navigation drawer for budget pages
 * Opened via #drawer-toggle button in BudgetNavNew
 */

interface Props {
    lang: "en" | "es";
}

const { lang } = Astro.props;
const es = lang === "es";

const sections = [
    {
        title: es ? "Gestión" : "Management",
        links: [
            { emoji: "🏦", label: es ? "Cuentas" : "Accounts", href: "/budget/settings#accounts" },
            { emoji: "🏷️", label: es ? "Categorías" : "Categories", href: "/budget/settings" },
            { emoji: "👤", label: es ? "Beneficiarios" : "Payees", href: "/budget/settings#payees" },
        ],
    },
    {
        title: es ? "Herramientas" : "Tools",
        links: [
            { emoji: "📸", label: es ? "Escanear ticket" : "Scan receipt", href: "/budget/scan-receipt" },
            { emoji: "📥", label: es ? "Importar CSV" : "Import CSV", href: "/budget/import" },
            { emoji: "🔄", label: es ? "Recurrentes" : "Recurring", href: "/budget/settings#recurring" },
            { emoji: "⚡", label: es ? "Reglas auto" : "Auto rules", href: "/budget/settings#rules" },
        ],
    },
    {
        title: es ? "Sistema" : "System",
        links: [
            { emoji: "💾", label: es ? "Respaldos" : "Backups", href: "/budget/settings#backups" },
            { emoji: "⚙️", label: es ? "Configuración" : "Settings", href: "/budget/settings" },
        ],
    },
];
---

<!-- Backdrop -->
<div
    id="drawer-backdrop"
    class="fixed inset-0 bg-black/50 z-30 hidden opacity-0 transition-opacity duration-300"
></div>

<!-- Panel -->
<div
    id="drawer-panel"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation menu"
    class="fixed top-0 left-0 h-full w-72 bg-brand-cream z-40 shadow-[var(--shadow-pop)] transform -translate-x-full transition-transform duration-300 flex flex-col"
>
    <!-- Header -->
    <div class="flex items-center justify-between p-4 border-b border-brand-ink/10">
        <span class="text-lg font-bold text-brand-ink">
            {es ? "Menú" : "Menu"}
        </span>
        <button
            id="drawer-close"
            type="button"
            class="p-2 text-brand-ink-soft hover:text-brand-ink-soft transition-colors"
            aria-label={es ? "Cerrar menú" : "Close menu"}
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>

    <!-- Sections -->
    <nav class="overflow-y-auto flex-1 py-2">
        {sections.map(section => (
            <div class="mb-2">
                <h3 class="px-4 py-2 text-xs font-semibold uppercase tracking-wider text-brand-ink-soft">
                    {section.title}
                </h3>
                {section.links.map(link => (
                    <a
                        href={link.href}
                        class="flex items-center gap-3 px-4 py-2.5 text-sm text-brand-ink hover:bg-brand-cream-deep transition-colors"
                    >
                        <span class="text-lg">{link.emoji}</span>
                        {link.label}
                    </a>
                ))}
            </div>
        ))}
    </nav>
</div>

<script>
    function initDrawer() {
        const toggle = document.getElementById("drawer-toggle");
        const close = document.getElementById("drawer-close");
        const backdrop = document.getElementById("drawer-backdrop");
        const panel = document.getElementById("drawer-panel");

        if (!toggle || !close || !backdrop || !panel) return;

        // Capture as non-null for use inside nested callbacks
        const safeToggle: HTMLElement = toggle;
        const safeBackdrop: HTMLElement = backdrop;
        const safePanel: HTMLElement = panel;

        function openDrawer() {
            safeBackdrop.classList.remove("hidden");
            requestAnimationFrame(() => {
                safeBackdrop.classList.remove("opacity-0");
                safePanel.classList.remove("-translate-x-full");
            });
            safeToggle.setAttribute("aria-expanded", "true");
        }

        function closeDrawer() {
            safeBackdrop.classList.add("opacity-0");
            safePanel.classList.add("-translate-x-full");
            safeToggle.setAttribute("aria-expanded", "false");
            setTimeout(() => {
                safeBackdrop.classList.add("hidden");
            }, 300);
        }

        safeToggle.addEventListener("click", openDrawer);
        close.addEventListener("click", closeDrawer);
        safeBackdrop.addEventListener("click", closeDrawer);
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && !safeBackdrop.classList.contains("hidden")) {
                closeDrawer();
                safeToggle.focus();
            }
        });
    }

    // Init on first load
    initDrawer();

    // Re-init after Astro view transitions
    document.addEventListener("astro:after-swap", initDrawer);
</script>
