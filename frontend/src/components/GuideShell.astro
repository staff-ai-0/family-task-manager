---
/**
 * Shared shell for the public user-guide pages (/help, /ayuda). Owns the hero,
 * the client-side heading search, the auto-generated table of contents, and all
 * prose styling — so the EN and ES pages can't drift. Each page passes its
 * language-specific labels and slots in the rendered markdown guide.
 */
import Layout from "../layouts/Layout.astro";

interface Props {
    title: string;
    backHref: string;
    backLabel: string;
    toggleHref: string;
    toggleLabel: string;
    heroTitle: string;
    heroSub: string;
    searchPlaceholder: string;
    searchAria: string;
    contentsLabel: string;
    noResultsText: string;
    tocAria: string;
}
const {
    title,
    backHref,
    backLabel,
    toggleHref,
    toggleLabel,
    heroTitle,
    heroSub,
    searchPlaceholder,
    searchAria,
    contentsLabel,
    noResultsText,
    tocAria,
} = Astro.props;
---

<Layout title={title}>
    <main class="guide-wrap">
        <nav class="guide-nav">
            <a href={backHref} class="nav-link">{backLabel}</a>
            <a href={toggleHref} class="lang-toggle">{toggleLabel}</a>
        </nav>
        <header class="guide-hero">
            <h1 class="guide-hero-title">{heroTitle}</h1>
            <p class="guide-hero-sub">{heroSub}</p>
            <input
                id="guide-search"
                type="search"
                class="guide-search"
                placeholder={searchPlaceholder}
                autocomplete="off"
                aria-label={searchAria}
            />
        </header>
        <details class="guide-toc-wrap" open>
            <summary>{contentsLabel}</summary>
            <nav id="guide-toc" class="guide-toc" aria-label={tocAria}></nav>
            <p id="guide-toc-empty" class="guide-toc-empty" hidden>
                {noResultsText}
            </p>
        </details>
        <article class="guide">
            <slot />
        </article>
    </main>

    <script>
        function initGuideToc() {
            const article = document.querySelector(".guide");
            const toc = document.getElementById("guide-toc");
            const search = document.getElementById(
                "guide-search",
            ) as HTMLInputElement | null;
            const empty = document.getElementById("guide-toc-empty");
            if (!article || !toc || (toc as HTMLElement).dataset.built === "1")
                return;
            (toc as HTMLElement).dataset.built = "1";

            article.querySelectorAll("h1, h2").forEach((h) => {
                if (!h.id) return;
                const a = document.createElement("a");
                a.href = "#" + h.id;
                a.textContent = h.textContent || "";
                a.className = h.tagName === "H1" ? "toc-h1" : "toc-h2";
                toc.appendChild(a);
            });

            search?.addEventListener("input", () => {
                const q = search.value.trim().toLowerCase();
                let shown = 0;
                toc.querySelectorAll("a").forEach((a) => {
                    const match = (a.textContent || "")
                        .toLowerCase()
                        .includes(q);
                    (a as HTMLElement).hidden = q !== "" && !match;
                    if (!(a as HTMLElement).hidden) shown++;
                });
                if (empty) empty.hidden = !(q !== "" && shown === 0);
            });
        }
        // Render mermaid diagrams emitted as <pre class="mermaid"> by the
        // remarkMermaid plugin (see astro.config.mjs). Lazy-imported so mermaid
        // only loads on the guide pages.
        let mermaidLib: any = null;
        async function initGuideMermaid() {
            const blocks = document.querySelectorAll<HTMLElement>(
                "pre.mermaid:not([data-processed])",
            );
            if (!blocks.length) return;
            if (!mermaidLib) {
                mermaidLib = (await import("mermaid")).default;
                mermaidLib.initialize({
                    startOnLoad: false,
                    theme: "default",
                    securityLevel: "loose",
                });
            }
            try {
                await mermaidLib.run({ nodes: Array.from(blocks) });
            } catch (e) {
                console.error("mermaid render failed", e);
            }
        }

        // Public page: cover both the view-transition router event and a plain load.
        document.addEventListener("astro:page-load", initGuideToc);
        document.addEventListener("DOMContentLoaded", initGuideToc);
        document.addEventListener("astro:page-load", initGuideMermaid);
        document.addEventListener("DOMContentLoaded", initGuideMermaid);
    </script>
</Layout>

<style>
    .guide-wrap {
        max-width: 820px;
        margin: 0 auto;
        padding: 32px 20px 80px;
        color: #1e293b;
        background: #fff;
        min-height: 100vh;
    }
    .guide-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid #e2e8f0;
        font-size: 14px;
    }
    .nav-link {
        color: #64748b;
        text-decoration: none;
        font-weight: 500;
    }
    .nav-link:hover {
        color: #4f46e5;
    }
    .lang-toggle {
        color: #4f46e5;
        text-decoration: none;
        font-weight: 600;
        padding: 6px 12px;
        border: 1px solid #e0e7ff;
        border-radius: 6px;
    }
    .lang-toggle:hover {
        background: #eef2ff;
    }

    /* Markdown prose styles — minimal but readable */
    .guide :global(h1) {
        font-size: 32px;
        font-weight: 800;
        margin: 24px 0 16px;
        color: #0f172a;
        line-height: 1.2;
    }
    .guide :global(h2) {
        font-size: 24px;
        font-weight: 700;
        margin: 32px 0 14px;
        color: #0f172a;
        padding-top: 8px;
        border-top: 1px solid #f1f5f9;
    }
    .guide :global(h3) {
        font-size: 18px;
        font-weight: 600;
        margin: 24px 0 10px;
        color: #1e293b;
    }
    .guide :global(h4) {
        font-size: 16px;
        font-weight: 600;
        margin: 20px 0 8px;
        color: #334155;
    }
    .guide :global(p) {
        margin: 0 0 14px;
        line-height: 1.7;
        color: #334155;
        font-size: 16px;
    }
    .guide :global(ul),
    .guide :global(ol) {
        margin: 0 0 16px;
        padding-left: 24px;
        line-height: 1.7;
        color: #334155;
    }
    .guide :global(li) {
        margin-bottom: 6px;
    }
    .guide :global(strong) {
        color: #0f172a;
        font-weight: 700;
    }
    .guide :global(code) {
        background: #f1f5f9;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 90%;
        font-family: "SF Mono", Menlo, Consolas, monospace;
        color: #be185d;
    }
    .guide :global(pre) {
        background: #0f172a;
        color: #e2e8f0;
        padding: 16px;
        border-radius: 8px;
        overflow-x: auto;
        margin: 0 0 20px;
        font-size: 13px;
    }
    .guide :global(pre code) {
        background: transparent;
        color: inherit;
        padding: 0;
    }
    /* Mermaid diagrams render as inline SVG inside <pre class="mermaid"> —
       drop the dark code-block chrome and center the figure. */
    .guide :global(pre.mermaid) {
        background: #fff;
        color: #1e293b;
        padding: 8px 0;
        text-align: center;
        overflow-x: auto;
        font-family: inherit;
    }
    .guide :global(pre.mermaid svg) {
        max-width: 100%;
        height: auto;
    }
    /* Pre-render: show the raw source faintly rather than dark-on-dark. */
    .guide :global(pre.mermaid:not([data-processed])) {
        color: #94a3b8;
        font-family: "SF Mono", Menlo, Consolas, monospace;
        font-size: 12px;
        text-align: left;
    }
    .guide :global(a) {
        color: #4f46e5;
        text-decoration: underline;
    }
    .guide :global(a:hover) {
        color: #3730a3;
    }
    .guide :global(hr) {
        border: none;
        border-top: 1px solid #e2e8f0;
        margin: 32px 0;
    }
    .guide :global(table) {
        border-collapse: collapse;
        margin: 0 0 20px;
        font-size: 14px;
        width: 100%;
    }
    .guide :global(th),
    .guide :global(td) {
        border: 1px solid #e2e8f0;
        padding: 8px 12px;
        text-align: left;
    }
    .guide :global(th) {
        background: #f8fafc;
        font-weight: 600;
    }
    .guide :global(blockquote) {
        border-left: 4px solid #4f46e5;
        padding-left: 16px;
        margin: 0 0 16px;
        color: #475569;
        font-style: italic;
    }

    /* Help-center hero + search + generated table of contents */
    .guide-hero {
        margin-bottom: 18px;
    }
    .guide-hero-title {
        font-size: 28px;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 4px;
    }
    .guide-hero-sub {
        color: #64748b;
        font-size: 14px;
        margin: 0 0 14px;
    }
    .guide-search {
        width: 100%;
        padding: 10px 14px;
        font-size: 15px;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        outline: none;
        box-sizing: border-box;
    }
    .guide-search:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.12);
    }
    .guide-toc-wrap {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 12px 16px;
        margin-bottom: 28px;
        background: #f8fafc;
    }
    .guide-toc-wrap > summary {
        cursor: pointer;
        font-weight: 700;
        color: #334155;
    }
    .guide-toc {
        display: flex;
        flex-direction: column;
        gap: 2px;
        margin-top: 10px;
        max-height: 340px;
        overflow-y: auto;
    }
    .guide-toc a {
        text-decoration: none;
        color: #475569;
        font-size: 14px;
        padding: 3px 0;
    }
    .guide-toc a:hover {
        color: #4f46e5;
    }
    .guide-toc a.toc-h1 {
        font-weight: 700;
        color: #0f172a;
        margin-top: 8px;
    }
    .guide-toc a.toc-h2 {
        padding-left: 14px;
    }
    .guide-toc-empty {
        color: #94a3b8;
        font-size: 14px;
        margin: 8px 0 0;
    }
</style>
