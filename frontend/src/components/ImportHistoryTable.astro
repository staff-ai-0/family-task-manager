---
import type { BudgetImportLog } from "@lib/types/budget";
import { t } from "@lib/i18n";

interface Props {
    logs: BudgetImportLog[];
    lang: string;
}

const { logs = [], lang } = Astro.props;

const statusColor = (status: string) => {
    if (status === "success") return "bg-green-100 text-green-700 border-green-200";
    if (status === "failed") return "bg-red-100 text-red-700 border-red-200";
    return "bg-amber-100 text-amber-700 border-amber-200";
};
---

{logs.length === 0 ? (
    <p class="text-sm text-slate-500">{t(lang, "fin_settings_import_history_empty")}</p>
 ) : (
    <div class="overflow-auto border border-slate-200 rounded-xl">
        <table class="min-w-full text-sm">
            <thead class="bg-slate-50 text-slate-600">
                <tr>
                    <th class="text-left px-3 py-2">{t(lang, 'fin_settings_import_history_columns').filename}</th>
                    <th class="text-left px-3 py-2">{t(lang, 'fin_settings_import_history_columns').account}</th>
                    <th class="text-left px-3 py-2">{t(lang, 'fin_settings_import_history_columns').rows}</th>
                    <th class="text-left px-3 py-2">{t(lang, 'fin_settings_import_history_columns').imported}</th>
                    <th class="text-left px-3 py-2">{t(lang, 'fin_settings_import_history_columns').skipped}</th>
                    <th class="text-left px-3 py-2">{t(lang, 'fin_settings_import_history_columns').status}</th>
                    <th class="text-left px-3 py-2">{t(lang, 'fin_settings_import_history_columns').created_at}</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {logs.map((log) => (
                    <tr>
                        <td class="px-3 py-2 font-medium text-slate-800">{log.filename ?? "-"}</td>
                        <td class="px-3 py-2 text-slate-700">{log.account_name ?? "-"}</td>
                        <td class="px-3 py-2 text-slate-600">{log.total_rows ?? 0}</td>
                        <td class="px-3 py-2 text-green-700">{log.successful_imports ?? 0}</td>
                        <td class="px-3 py-2 text-amber-700">{log.skipped_rows ?? 0}</td>
                        <td class="px-3 py-2">
                            <span class={`px-2 py-1 rounded-full text-xs font-semibold border ${statusColor(log.status ?? "partial")}`}>
                                {log.status === "success"
                                    ? t(lang, "fin_settings_status_success")
                                    : log.status === "failed"
                                        ? t(lang, "fin_settings_status_failed")
                                        : t(lang, "fin_settings_status_partial")}
                            </span>
                        </td>
                        <td class="px-3 py-2 text-slate-600">{log.created_at ? new Date(log.created_at).toLocaleString(lang) : "-"}</td>
                    </tr>
                ))}
            </tbody>
        </table>
    </div>
 )}
