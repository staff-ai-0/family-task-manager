---
/**
 * BudgetNavNew - 3-tab navigation bar for budget pages
 * Replaces the old 6-tab BudgetNav with a cleaner layout:
 * hamburger (left) | 3 centered tabs | spacer (right)
 */

interface Props {
    active: "month" | "transactions" | "reports" | "receipt-drafts" | "none";
    lang: "en" | "es";
    pendingDrafts?: number;
}

const { active, lang, pendingDrafts = 0 } = Astro.props;
const es = lang === "es";

const tabs = [
    {
        id: "month" as const,
        label: es ? "Mes" : "Month",
        href: "/budget/",
        icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
    },
    {
        id: "transactions" as const,
        label: es ? "Movimientos" : "Transactions",
        href: "/budget/transactions",
        icon: "M4 6h16M4 10h16M4 14h16M4 18h16",
    },
    {
        id: "reports" as const,
        label: es ? "Reportes" : "Reports",
        href: "/budget/reports",
        icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
    },
];
---

<div class="bg-brand-cream border-b border-brand-ink/10 shadow-[var(--shadow-card)] sticky top-0 z-20">
    <div class="max-w-md md:max-w-4xl lg:max-w-6xl mx-auto flex items-center">
        <!-- Hamburger button -->
        <button
            id="drawer-toggle"
            type="button"
            class="p-3 text-brand-ink-soft hover:text-brand-ink transition-colors"
            aria-label={es ? "Abrir menú" : "Open menu"}
            aria-expanded="false"
            aria-controls="drawer-panel"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>

        <!-- Centered tabs -->
        <nav class="flex flex-1 justify-center">
            {tabs.map(tab => (
                <a
                    href={tab.href}
                    aria-current={active === tab.id ? "page" : undefined}
                    class={`flex flex-col items-center gap-1 px-4 py-3 text-xs font-semibold whitespace-nowrap border-b-2 transition-colors ${
                        active === tab.id
                            ? "border-brand-ink text-brand-sky-deep"
                            : "border-transparent text-brand-ink-soft hover:text-brand-ink-soft"
                    }`}
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={tab.icon} />
                    </svg>
                    {tab.label}
                </a>
            ))}
        </nav>

        <!-- Receipt review queue button with pending badge -->
        <a
            href="/budget/receipt-drafts"
            aria-label={es ? "Revisar recibos pendientes" : "Review pending receipts"}
            class={`relative p-3 transition-colors ${
                active === "receipt-drafts"
                    ? "text-brand-coral-deep"
                    : "text-brand-ink-soft hover:text-brand-ink-soft"
            }`}
        >
            <!-- Receipt / inbox icon -->
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            {pendingDrafts > 0 && (
                <span class="absolute top-1.5 right-1.5 min-w-[16px] h-4 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center px-0.5 leading-none">
                    {pendingDrafts > 9 ? "9+" : pendingDrafts}
                </span>
            )}
        </a>
    </div>
</div>

<script>
// Keyboard shortcuts (desktop parity with Actual): active on every budget
// page since this nav renders on all of them. Guarded per-window.
if (!(window as any).__budgetKeys) {
    (window as any).__budgetKeys = true;
    let gPending = false;
    let gTimer: ReturnType<typeof setTimeout> | undefined;

    function typingContext(el: any) {
        const t = el;
        if (!t) return false;
        const tag = t.tagName;
        return tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT" || t.isContentEditable;
    }

    function showKeysHelp() {
        const existingHelp = document.getElementById("keys-help");
        if (existingHelp) { existingHelp.remove(); return; }
        const es = document.documentElement.lang !== "en";
        const div = document.createElement("div");
        div.id = "keys-help";
        div.className = "fixed inset-0 bg-black/50 z-[90] flex items-center justify-center p-6";
        div.innerHTML = `
          <div class="bg-brand-cream rounded-2xl border-2 border-brand-ink shadow-xl max-w-sm w-full p-5">
            <h3 class="font-bold text-brand-ink mb-3">${es ? "Atajos de teclado" : "Keyboard shortcuts"}</h3>
            <dl class="text-sm text-brand-ink space-y-1.5">
              <div class="flex justify-between"><dt><kbd class="px-1.5 py-0.5 bg-brand-cream-deep rounded border border-brand-ink/20 text-xs">n</kbd></dt><dd>${es ? "Nuevo gasto" : "New expense"}</dd></div>
              <div class="flex justify-between"><dt><kbd class="px-1.5 py-0.5 bg-brand-cream-deep rounded border border-brand-ink/20 text-xs">/</kbd></dt><dd>${es ? "Buscar" : "Search"}</dd></div>
              <div class="flex justify-between"><dt><kbd class="px-1.5 py-0.5 bg-brand-cream-deep rounded border border-brand-ink/20 text-xs">g m</kbd></dt><dd>${es ? "Ir a Mes" : "Go to Month"}</dd></div>
              <div class="flex justify-between"><dt><kbd class="px-1.5 py-0.5 bg-brand-cream-deep rounded border border-brand-ink/20 text-xs">g t</kbd></dt><dd>${es ? "Ir a Transacciones" : "Go to Transactions"}</dd></div>
              <div class="flex justify-between"><dt><kbd class="px-1.5 py-0.5 bg-brand-cream-deep rounded border border-brand-ink/20 text-xs">g r</kbd></dt><dd>${es ? "Ir a Reportes" : "Go to Reports"}</dd></div>
              <div class="flex justify-between"><dt><kbd class="px-1.5 py-0.5 bg-brand-cream-deep rounded border border-brand-ink/20 text-xs">?</kbd></dt><dd>${es ? "Esta ayuda" : "This help"}</dd></div>
            </dl>
          </div>`;
        div.addEventListener("click", () => div.remove());
        document.body.appendChild(div);
    }

    document.addEventListener("keydown", (ev) => {
        if (typingContext(ev.target) || ev.metaKey || ev.ctrlKey || ev.altKey) return;
        if (gPending) {
            gPending = false;
            clearTimeout(gTimer);
            if (ev.key === "m") { ev.preventDefault(); location.href = "/budget/"; }
            else if (ev.key === "t") { ev.preventDefault(); location.href = "/budget/transactions"; }
            else if (ev.key === "r") { ev.preventDefault(); location.href = "/budget/reports"; }
            return;
        }
        if (ev.key === "g") { gPending = true; gTimer = setTimeout(() => { gPending = false; }, 800); return; }
        if (ev.key === "n") { ev.preventDefault(); document.getElementById("fab-button")?.click(); return; }
        if (ev.key === "/") {
            const search = document.getElementById("filter-search");
            if (search) { ev.preventDefault(); search.focus(); }
            else { ev.preventDefault(); location.href = "/budget/transactions"; }
            return;
        }
        if (ev.key === "?") { ev.preventDefault(); showKeysHelp(); return; }
        if (ev.key === "Escape") { document.getElementById("keys-help")?.remove(); }
    });
}
</script>

<script>
// Scoped undo (Actual-parity, pragmatic): actions with a clean inverse queue
// it in sessionStorage before their reload; this nav (on every budget page)
// shows a 10s "Deshacer" toast after the reload and executes the inverse.
if (!(window as any).__budgetUndo) {
    (window as any).__budgetUndo = true;
    const KEY = "budget_undo";
    const TTL_MS = 15000;

    (window as any).queueUndo = (label: string, calls: any) => {
        sessionStorage.setItem(KEY, JSON.stringify({ label, calls, ts: Date.now() }));
        // Show immediately too — some callers (Assign Funds) don't reload.
        document.getElementById("undo-toast")?.remove();
        showUndoToast();
    };

    function showUndoToast() {
        const raw = sessionStorage.getItem(KEY);
        if (!raw) return;
        let data;
        try { data = JSON.parse(raw); } catch { sessionStorage.removeItem(KEY); return; }
        const age = Date.now() - (data.ts || 0);
        if (age > TTL_MS) { sessionStorage.removeItem(KEY); return; }
        const es = document.documentElement.lang !== "en";

        const toast = document.createElement("div");
        toast.id = "undo-toast";
        toast.className = "fixed bottom-20 left-1/2 -translate-x-1/2 z-[95] bg-brand-ink text-brand-cream rounded-xl px-4 py-2.5 shadow-xl flex items-center gap-3 text-sm";
        toast.innerHTML = `<span>${data.label}</span>
            <button id="undo-do" class="font-bold underline text-brand-sky whitespace-nowrap">${es ? "Deshacer" : "Undo"}</button>
            <button id="undo-x" class="text-brand-cream/60">✕</button>`;
        document.body.appendChild(toast);

        const remove = () => { toast.remove(); sessionStorage.removeItem(KEY); };
        const timer = setTimeout(remove, TTL_MS - age);

        toast.querySelector("#undo-x")?.addEventListener("click", () => { clearTimeout(timer); remove(); });
        toast.querySelector("#undo-do")?.addEventListener("click", async () => {
            clearTimeout(timer);
            const btn = toast.querySelector("#undo-do") as HTMLButtonElement;
            btn.disabled = true;
            btn.textContent = "…";
            try {
                for (const c of data.calls) {
                    const res = await fetch(c.url, {
                        method: c.method,
                        headers: c.body ? { "Content-Type": "application/json" } : undefined,
                        body: c.body ? JSON.stringify(c.body) : undefined,
                    });
                    if (!res.ok) throw new Error(String(res.status));
                }
                remove();
                location.reload();
            } catch {
                btn.textContent = es ? "Falló" : "Failed";
                setTimeout(remove, 1500);
            }
        });
    }
    showUndoToast();
    document.addEventListener("astro:page-load", showUndoToast);
}
</script>
