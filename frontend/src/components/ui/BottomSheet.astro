---
/**
 * BottomSheet — slide-up modal shell with custom-event open/close API.
 * Callers: document.dispatchEvent(new Event("open-{id}")) / ("close-{id}")
 * @prop id     Unique string; backdrop = "${id}-backdrop", close btn = "${id}-close"
 * @prop title  Heading shown in the modal title bar
 * @prop lang   "en" | "es" (default "en")
 */
interface Props {
  id: string;
  title: string;
  lang?: "en" | "es";
}
const { id, title, lang = "en" } = Astro.props;
---

<div
  id={`${id}-backdrop`}
  class="hidden fixed inset-0 bg-black/50 z-40 transition-opacity duration-300"
></div>

<div
  id={id}
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${id}-title`}
  class="fixed bottom-0 left-0 right-0 z-50 translate-y-full transition-transform duration-300 ease-out bg-brand-cream rounded-t-[var(--radius-tile)] border-t-2 border-x-2 border-brand-ink shadow-[var(--shadow-pop)] flex flex-col max-h-[90dvh]"
>
  <div class="flex justify-center pt-3 pb-1 flex-shrink-0">
    <div class="w-10 h-1 rounded-full bg-brand-ink/20"></div>
  </div>
  <div class="flex items-center justify-between px-6 py-3 border-b border-brand-ink/10 flex-shrink-0">
    <h2 id={`${id}-title`} class="font-display text-lg font-extrabold text-brand-ink">{title}</h2>
    <button
      id={`${id}-close`}
      class="text-brand-ink-soft hover:text-brand-ink p-1 rounded-lg"
      aria-label={lang === "es" ? "Cerrar" : "Close"}
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  <div class="flex-1 overflow-y-auto">
    <slot />
  </div>
</div>

<script define:vars={{ id }}>
(function () {
  var panel = document.getElementById(id);
  var backdrop = document.getElementById(id + "-backdrop");
  var closeBtn = document.getElementById(id + "-close");
  var lastFocus = null;
  var isOpen = false;

  function open() {
    if (isOpen) return;
    isOpen = true;
    window.__ftmSheets = (window.__ftmSheets || 0) + 1;
    lastFocus = document.activeElement;
    backdrop.classList.remove("hidden");
    panel.classList.remove("translate-y-full");
    document.body.style.overflow = "hidden";
    closeBtn.focus();
  }

  function close() {
    if (!isOpen) return;
    isOpen = false;
    window.__ftmSheets = Math.max(0, (window.__ftmSheets || 1) - 1);
    panel.classList.add("translate-y-full");
    backdrop.classList.add("hidden");
    if (window.__ftmSheets === 0) {
      document.body.style.overflow = "";
    }
    if (lastFocus) { lastFocus.focus(); lastFocus = null; }
  }

  document.addEventListener("open-" + id, open);
  document.addEventListener("close-" + id, close);
  backdrop.addEventListener("click", close);
  closeBtn.addEventListener("click", close);
  document.addEventListener("keydown", function (e) {
    if (isOpen && e.key === "Escape") { e.preventDefault(); close(); }
  });
})();
</script>
