---
import Button from "./Button.astro";

/**
 * EmptyState — centered empty-state block with icon, title, optional subtitle, and optional CTA.
 * When ctaId is provided, the CTA button clicks the element with that id (delegation via inline script).
 * When ctaHref is provided (and no ctaId), the CTA renders as an <a href>.
 * @prop icon      Emoji displayed large above title
 * @prop title     Primary message
 * @prop subtitle  Secondary message (optional)
 * @prop ctaLabel  CTA button text (renders button/link only when set)
 * @prop ctaId     If set, CTA click delegates to element with this id
 * @prop ctaHref   If set and ctaId absent, CTA renders as <a href>
 * @prop ctaTone   Button tone: "sky" | "coral" | "mint" (default "sky")
 */
interface Props {
  icon: string;
  title: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaId?: string;
  ctaHref?: string;
  ctaTone?: "sky" | "coral" | "mint";
}
const {
  icon,
  title,
  subtitle,
  ctaLabel,
  ctaId,
  ctaHref,
  ctaTone = "sky",
} = Astro.props;

if (import.meta.env.DEV && ctaId && ctaHref) {
  console.warn(`EmptyState: both ctaId="${ctaId}" and ctaHref="${ctaHref}" provided — ctaHref is ignored when ctaId is set.`);
}

const variantMap: Record<string, "primary" | "secondary" | "mint"> = {
  sky:   "secondary",
  coral: "primary",
  mint:  "mint",
};
const ctaVariant = variantMap[ctaTone] ?? "secondary";
---

<div class="flex flex-col items-center justify-center py-10 text-center">
  <p class="text-4xl mb-3" aria-hidden="true">{icon}</p>
  <p class="font-display font-extrabold text-brand-ink mb-1">{title}</p>
  {subtitle && <p class="text-sm text-brand-ink-soft mb-4">{subtitle}</p>}
  {ctaLabel && ctaId && (
    <Button id={`${ctaId}-empty-cta`} variant={ctaVariant} size="sm" class="mt-4">{ctaLabel}</Button>
  )}
  {ctaLabel && !ctaId && ctaHref && (
    <Button href={ctaHref} variant={ctaVariant} size="sm" class="mt-4">{ctaLabel}</Button>
  )}
</div>

{ctaId && (
  <script define:vars={{ ctaId }}>
  (function () {
    document.addEventListener("astro:page-load", function () {
      var emptyCta = document.getElementById(ctaId + "-empty-cta");
      var target = document.getElementById(ctaId);
      if (emptyCta && target) {
        emptyCta.addEventListener("click", function () { target.click(); });
      }
    }, { once: true });
  })();
  </script>
)}
