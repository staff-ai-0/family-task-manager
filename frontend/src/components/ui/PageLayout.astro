---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "./PageHeader.astro";
import BottomNav from "../BottomNav.astro";
import WelcomeTour from "../WelcomeTour.astro";
import type { TourRole } from "../../lib/tourSteps";

/**
 * PageLayout — full-page shell: Layout + PageHeader + <main> + BottomNav.
 * Reduces the ~25-line boilerplate on every page to a single component.
 * @prop title          Page title (also sets <title> tag as "{title} - Family Task Manager")
 * @prop tone           Header background color (default "sky")
 * @prop headerClass    Custom header bg classes (e.g. gradient) — replaces tone bg + ink border (see PageHeader)
 * @prop dark           White-text header mode for dark/gradient backgrounds
 * @prop backClass      Exact back-link color classes (overrides dark/light default)
 * @prop backHref       Optional back link in header
 * @prop backLabel      Back link text (default "Back" / "Volver"; pass t(lang,"back_parent") for context-specific label)
 * @prop description    Meta description for the page
 * @prop role           User role — passed to BottomNav for tab visibility (default "child"; always pass user.role on role-aware pages)
 * @prop active         Active nav tab key
 * @prop lang           "en" | "es" (default "en")
 * @prop mainClass      CSS classes for <main> (default "flex-1 px-4 py-6")
 * @prop containerClass CSS classes for the content wrapper div (default includes bg-brand-cream-deep + responsive max-width)
 * Slots:
 *   header       — when provided, REPLACES PageHeader entirely (hero/composite headers
 *                  keep their exact markup; title prop then only sets the <title> tag)
 *   actions      — forwarded to PageHeader's "actions" slot (right of title row)
 *   header-extra — forwarded to PageHeader's "sub" slot (below title row; use for subtitle/stat line)
 *   banner       — rendered between header and <main> (intro banners, push prompts, flash strips)
 *   default      — page body rendered inside <main>
 */
interface Props {
  title: string;
  tone?: "sky" | "coral" | "mint" | "sun" | "cream";
  headerClass?: string;
  dark?: boolean;
  backClass?: string;
  backHref?: string;
  backLabel?: string;
  description?: string;
  role?: string;
  active?: "tasks" | "rewards" | "profile" | "parent" | "budget" | "notifications" | "pet" | "chat" | "gigs";
  lang?: "en" | "es";
  /** Resolved gig-term label (gigTerm().Many) — forwarded to BottomNav's
   *  "Gigs" tab. Only pages on the gig surface pass this; everywhere else
   *  BottomNav keeps its own "Gigs" default. */
  gigTerm?: string;
  mainClass?: string;
  containerClass?: string;
  /**
   * Pass the user's `completed_welcome_tour` flag on the role HOME pages
   * (/parent, /dashboard) to auto-start the welcome tour for first-time users.
   * Defaults to true (= "already done") so other pages never trigger it.
   */
  completedTour?: boolean;
  /** User id — makes the welcome-tour localStorage guard per-user (shared devices). */
  tourUserKey?: string;
}

const {
  title,
  tone = "sky",
  headerClass,
  dark = false,
  backClass,
  backHref,
  backLabel,
  description,
  role = "child",
  active,
  lang = "en",
  gigTerm,
  mainClass = "flex-1 px-4 py-6",
  containerClass = "w-full max-w-md md:max-w-4xl lg:max-w-6xl mx-auto bg-brand-cream-deep",
  completedTour = true,
  tourUserKey,
} = Astro.props;

// Auto-start the welcome tour for first-time users on the home page that owns
// the full tour for their role: the PARENT setup tour fires on /parent (where
// the getting-started checklist it highlights actually lives), and the kid/teen
// earn tour fires on /dashboard. A new parent lands on /dashboard first but gets
// the tour when they open Manage (/parent) — this guarantees they see the whole
// parent flow, checklist step included, rather than a truncated version.
const _tourPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const _isParent = String(role).toLowerCase() === "parent";
const tourRole: TourRole = _isParent ? "parent" : "kid";
// New parents land on /dashboard (not /parent), so allow the parent tour on
// both — the tour's present-filter drops the /parent-only checklist step when
// it's absent, so the welcome + nav + help steps still run on /dashboard.
const showWelcomeTour =
  completedTour === false &&
  ((_isParent && (_tourPath === "/parent" || _tourPath === "/dashboard")) ||
    (!_isParent && _tourPath === "/dashboard"));
---

<Layout title={`${title} - Family Task Manager`} lang={lang} description={description}>
  <div class={`flex flex-col min-h-dvh ${containerClass}`}>
    {Astro.slots.has("header") ? (
      <slot name="header" />
    ) : (
      <PageHeader title={title} tone={tone} headerClass={headerClass} dark={dark} backClass={backClass} backHref={backHref} backLabel={backLabel} lang={lang}>
        <slot name="actions" slot="actions" />
        <slot name="header-extra" slot="sub" />
      </PageHeader>
    )}
    <slot name="banner" />
    {showWelcomeTour && <WelcomeTour role={tourRole} lang={lang} userKey={tourUserKey} />}
    <main class={mainClass}>
      <slot />
    </main>
    <BottomNav active={active} role={role} lang={lang} gigTerm={gigTerm} />
  </div>
</Layout>
