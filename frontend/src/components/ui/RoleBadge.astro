---
/**
 * RoleBadge — Parent / Teen / Child silhouette badge.
 * Per brand guide: distinct outline shapes so colour-blind users still
 * tell roles apart. See Brand Guide.html §08.
 *
 * @prop role  "parent" | "teen" | "child"
 * @prop size  px. Default 48.
 */
interface Props {
  role: "parent" | "teen" | "child";
  size?: number;
  class?: string;
}
const { role, size = 48, class: className = "" } = Astro.props;
const label = { parent: "Parent", teen: "Teen", child: "Child" }[role];
---

{role === "parent" && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 80" width={size} height={size} class={className} role="img" aria-label={label}>
    <title>{label}</title>
    <circle cx="40" cy="40" r="36" fill="#FFC857" stroke="#1F2937" stroke-width="5"/>
    <circle cx="40" cy="32" r="11" fill="#FBD3B2" stroke="#1F2937" stroke-width="4"/>
    <path d="M22,60 Q22,46 40,46 Q58,46 58,60 L58,66 L22,66 Z" fill="#4FB8E6" stroke="#1F2937" stroke-width="4" stroke-linejoin="round"/>
    <path d="M32,22 L36,16 L40,22 L44,16 L48,22 Z" fill="#FF8A65" stroke="#1F2937" stroke-width="3" stroke-linejoin="round"/>
  </svg>
)}

{role === "teen" && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 80" width={size} height={size} class={className} role="img" aria-label={label}>
    <title>{label}</title>
    <path d="M40,4 L72,22 L72,58 L40,76 L8,58 L8,22 Z" fill="#5DD4A8" stroke="#1F2937" stroke-width="5" stroke-linejoin="round"/>
    <circle cx="40" cy="34" r="11" fill="#C68A60" stroke="#1F2937" stroke-width="4"/>
    <path d="M22,62 Q22,48 40,48 Q58,48 58,62 L58,68 L22,68 Z" fill="#FF8A65" stroke="#1F2937" stroke-width="4" stroke-linejoin="round"/>
  </svg>
)}

{role === "child" && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 80" width={size} height={size} class={className} role="img" aria-label={label}>
    <title>{label}</title>
    <path d="M40,4 L50,28 L76,30 L56,48 L62,72 L40,60 L18,72 L24,48 L4,30 L30,28 Z" fill="#FF8A65" stroke="#1F2937" stroke-width="5" stroke-linejoin="round"/>
    <circle cx="40" cy="38" r="10" fill="#8E5B3D" stroke="#1F2937" stroke-width="4"/>
    <path d="M28,54 Q28,44 40,44 Q52,44 52,54 L40,54 Z" fill="#FFF8F0" stroke="#1F2937" stroke-width="3" stroke-linejoin="round"/>
  </svg>
)}
