---
import { t } from "../lib/i18n";
import { apiFetch } from "../lib/api";
interface Props {
    active?: "tasks" | "rewards" | "profile" | "parent" | "budget" | "notifications" | "pet" | "chat" | "gigs";
    role?: string;
    lang?: string;
}
const { active = "tasks", role = "child", lang = "en" } = Astro.props;
const nextLang = lang === "es" ? "en" : "es";
const langLabel = lang === "es" ? "EN" : "ES";

const token = Astro.cookies.get("access_token")?.value;
let unreadCount = 0;
if (token) {
    try {
        const { data } = await apiFetch<{ unread: number }>(
            "/api/notifications/unread-count",
            { token },
        );
        unreadCount = data?.unread ?? 0;
    } catch {
        unreadCount = 0;
    }
}

const itemBase = "shrink-0 flex flex-col items-center justify-center gap-0.5 px-1 py-1 rounded-full transition-all";
const itemIdle = "text-brand-ink-soft hover:text-brand-ink";
const itemActive = "bg-brand-coral text-brand-ink border-2 border-brand-ink shadow-[2px_2px_0_var(--color-brand-ink)]";
---

<div class="bottom-nav-spacer" aria-hidden="true"></div>

<nav
    class="fixed bottom-0 left-0 right-0 bg-brand-cream border-t-2 border-brand-ink safe-area-bottom z-50"
>
    <div class="nav-row mx-auto flex justify-around items-center px-1 py-2">
        <a href="/dashboard" data-nav-key="tasks" class={`${itemBase} ${active === "tasks" ? itemActive : itemIdle}`}>
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
            </svg>
            <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">{t(lang, "nav_tasks")}</span>
        </a>

        {role !== "parent" && (
            <a href="/gigs" data-nav-key="gigs" class={`${itemBase} ${active === "gigs" ? itemActive : itemIdle}`}>
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">Gigs</span>
            </a>
        )}

        <a href="/rewards" data-nav-key="rewards" class={`${itemBase} ${active === "rewards" ? itemActive : itemIdle}`}>
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
            </svg>
            <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">{t(lang, "nav_rewards")}</span>
        </a>

        <a href="/notifications" data-nav-key="notifications" class={`${itemBase} relative ${active === "notifications" ? itemActive : itemIdle}`}>
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            {unreadCount > 0 && (
                <span class="absolute top-0 right-1 min-w-[18px] h-[18px] px-1 flex items-center justify-center bg-brand-coral text-white text-[10px] font-bold rounded-full border-2 border-brand-cream">
                    {unreadCount > 99 ? "99+" : unreadCount}
                </span>
            )}
            <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">
                {lang === "es" ? "Avisos" : "Inbox"}
            </span>
        </a>

        <a href="/chat" data-nav-key="chat" class={`${itemBase} ${active === "chat" ? itemActive : itemIdle}`}>
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">
                {lang === "es" ? "Chat" : "Chat"}
            </span>
        </a>

        {role !== "parent" && (
            <a href="/pet" data-nav-key="pet" class={`${itemBase} ${active === "pet" ? itemActive : itemIdle}`}>
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4.318 6.318a4.5 4.5 0 016.364 0L12 7.636l1.318-1.318a4.5 4.5 0 116.364 6.364L12 20.364l-7.682-7.682a4.5 4.5 0 010-6.364z" />
                </svg>
                <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">
                    {lang === "es" ? "Mascota" : "Pet"}
                </span>
            </a>
        )}

        <a href="/profile" data-nav-key="profile" class={`${itemBase} ${active === "profile" ? itemActive : itemIdle}`}>
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">{t(lang, "nav_profile")}</span>
        </a>

        {role === "parent" && (
            <a href="/parent/gigs" data-nav-key="gigs" class={`${itemBase} ${active === "gigs" ? itemActive : itemIdle}`}>
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">Gigs</span>
            </a>
        )}

        {role === "parent" && (
            <a href="/budget/month" data-nav-key="budget" class={`${itemBase} ${active === "budget" ? itemActive : itemIdle}`}>
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">{t(lang, "nav_budget")}</span>
            </a>
        )}

        {role === "parent" && (
            <a href="/parent" data-nav-key="parent" class={`${itemBase} ${active === "parent" ? itemActive : itemIdle}`}>
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">{t(lang, "nav_manage")}</span>
            </a>
        )}

        <form method="POST" action="/api/lang" class="inline">
            <input type="hidden" name="lang" value={nextLang} />
            <button type="submit" title={t(lang, "lang_toggle") as string}
                class={`${itemBase} ${itemIdle}`}>
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
                </svg>
                <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">{langLabel}</span>
            </button>
        </form>

        <form method="POST" action="/api/auth/logout" class="inline">
            <input type="hidden" name="action" value="logout" />
            <button type="submit" class={`${itemBase} text-brand-ink-soft hover:text-brand-coral-deep`}>
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">{t(lang, "nav_logout")}</span>
            </button>
        </form>
    </div>
</nav>

<script>
    const ACTIVE = "bg-brand-coral text-brand-ink border-2 border-brand-ink shadow-[2px_2px_0_var(--color-brand-ink)]";
    const IDLE   = "text-brand-ink-soft hover:text-brand-ink";

    function urlToKey(path: string): string {
        if (path.startsWith("/budget"))        return "budget";
        if (path.startsWith("/gigs"))          return "gigs";
        if (path.startsWith("/parent/gigs"))   return "gigs";
        if (path.startsWith("/parent/jarvis")) return "parent";
        if (path.startsWith("/parent"))        return "parent";
        if (path.startsWith("/rewards"))       return "rewards";
        if (path.startsWith("/notifications")) return "notifications";
        if (path.startsWith("/chat"))          return "chat";
        if (path.startsWith("/pet"))           return "pet";
        if (path.startsWith("/profile"))       return "profile";
        return "tasks";
    }

    function syncNav() {
        const key = urlToKey(window.location.pathname);
        document.querySelectorAll<HTMLElement>("[data-nav-key]").forEach((el) => {
            const isActive = el.dataset.navKey === key;
            ACTIVE.split(" ").forEach((c) => el.classList.toggle(c, isActive));
            IDLE.split(" ").forEach((c) => el.classList.toggle(c, !isActive));
        });
    }

    // Sync active item after every navigation (full load or view transition).
    document.addEventListener("astro:page-load", syncNav);
</script>

<style>
    .safe-area-bottom {
        padding-bottom: env(safe-area-inset-bottom, 0px);
    }
    /* Keep the bar centered + capped on wide screens, but never clip items:
       allow horizontal scroll as a safety net for the longest translations. */
    .nav-row {
        max-width: 28rem;
        overflow-x: auto;
        scrollbar-width: none;
    }
    .nav-row::-webkit-scrollbar { display: none; }
    /* On narrow phones the full label set overflows (9-10 items), so go
       icon-only — labels become screen-reader-only (still accessible, zero
       width) so every destination fits and stays reachable. */
    @media (max-width: 430px) {
        .nav-row { max-width: 100%; }
        .nav-label {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }
    }
    .bottom-nav-spacer {
        display: block;
        width: 100%;
        height: calc(64px + 24px + env(safe-area-inset-bottom, 0px));
        flex-shrink: 0;
        pointer-events: none;
    }
</style>
