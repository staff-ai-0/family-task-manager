---
import { t } from "../lib/i18n";
import { apiFetch } from "../lib/api";
import MoreSheet from "./MoreSheet.astro";

interface Props {
    active?: "tasks" | "rewards" | "profile" | "parent" | "budget" | "notifications" | "pet" | "chat" | "gigs" | "approvals" | "more";
    role?: string;
    lang?: string;
}
const { active = "tasks", role = "child", lang = "en" } = Astro.props;
const es = lang === "es";
const isParent = role === "parent";

const token = Astro.cookies.get("access_token")?.value;
let unreadCount = 0;
let pendingApprovals = 0;
if (token) {
    try {
        const [unread, taskPending, gigPending] = await Promise.all([
            apiFetch<{ unread: number }>("/api/notifications/unread-count", { token }),
            isParent
                ? apiFetch<any[]>("/api/task-assignments/pending-approvals", { token })
                : Promise.resolve({ data: null as any[] | null }),
            isParent
                ? apiFetch<any[]>("/api/gigs/claims/pending-approvals", { token })
                : Promise.resolve({ data: null as any[] | null }),
        ]);
        unreadCount = unread.data?.unread ?? 0;
        pendingApprovals = (taskPending.data?.length ?? 0) + (gigPending.data?.length ?? 0);
    } catch {
        unreadCount = 0;
        pendingApprovals = 0;
    }
}

const I = {
    tasks: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
    gigs: "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
    rewards: "M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7",
    chat: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
    home: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
    approvals: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
    budget: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    more: "M4 6h16M4 12h16M4 18h16",
};

type Item = { key: string; href: string; label: string; icon: string; badge?: number };

const kidItems: Item[] = [
    { key: "tasks",   href: "/dashboard", label: t(lang, "nav_tasks") as string,   icon: I.tasks },
    { key: "gigs",    href: "/gigs",      label: "Gigs",                            icon: I.gigs },
    { key: "rewards", href: "/rewards",   label: t(lang, "nav_rewards") as string, icon: I.rewards },
    { key: "chat",    href: "/chat",      label: "Chat",                            icon: I.chat },
];
const parentItems: Item[] = [
    { key: "parent",    href: "/parent",            label: es ? "Inicio" : "Home",        icon: I.home },
    { key: "approvals", href: "/parent/approvals",  label: es ? "Aprobar" : "Approve",    icon: I.approvals, badge: pendingApprovals },
    { key: "budget",    href: "/budget/month",      label: t(lang, "nav_budget") as string, icon: I.budget },
    { key: "gigs",      href: "/parent/gigs",       label: "Gigs",                        icon: I.gigs },
];
const items = isParent ? parentItems : kidItems;
// The "More" item carries the unread badge, since Inbox now lives inside it.

const itemBase = "shrink-0 flex flex-col items-center justify-center gap-0.5 px-1 py-1 rounded-full transition-all flex-1";
const itemIdle = "text-brand-ink-soft hover:text-brand-ink";
const itemActive = "bg-brand-coral text-brand-ink border-2 border-brand-ink shadow-[2px_2px_0_var(--color-brand-ink)]";
---

<div class="bottom-nav-spacer" aria-hidden="true"></div>

<nav
    class="fixed bottom-0 left-0 right-0 bg-brand-cream border-t-2 border-brand-ink safe-area-bottom z-50"
    data-role={role}
>
    <div class="nav-row mx-auto flex justify-around items-center px-1 py-2">
        {items.map((it) => (
            <a href={it.href} data-nav-key={it.key} class={`${itemBase} relative ${active === it.key ? itemActive : itemIdle}`}>
                {(it.badge ?? 0) > 0 && (
                    <span class="absolute top-0 right-1 min-w-[18px] h-[18px] px-1 flex items-center justify-center bg-brand-coral text-white text-[10px] font-bold rounded-full border-2 border-brand-cream">
                        {it.badge! > 99 ? "99+" : it.badge}
                    </span>
                )}
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={it.icon} />
                </svg>
                <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">{it.label}</span>
            </a>
        ))}

        <button type="button" id="more-nav-btn" data-nav-key="more" class={`${itemBase} relative ${active === "more" ? itemActive : itemIdle}`}>
            {unreadCount > 0 && (
                <span class="absolute top-0 right-1 min-w-[18px] h-[18px] px-1 flex items-center justify-center bg-brand-coral text-white text-[10px] font-bold rounded-full border-2 border-brand-cream">
                    {unreadCount > 99 ? "99+" : unreadCount}
                </span>
            )}
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={I.more} />
            </svg>
            <span class="nav-label text-[10px] font-extrabold font-sans tracking-wider uppercase">{es ? "Más" : "More"}</span>
        </button>
    </div>
</nav>

<MoreSheet role={role} lang={lang} unread={unreadCount} />

<script>
    const ACTIVE = "bg-brand-coral text-brand-ink border-2 border-brand-ink shadow-[2px_2px_0_var(--color-brand-ink)]";
    const IDLE   = "text-brand-ink-soft hover:text-brand-ink";

    // Paths that resolve to a top-nav item; everything else (secondary pages)
    // highlights the "More" item. Role-aware: chat is a top item for kids but
    // lives under More for parents.
    function urlToKey(path: string, isParent: boolean): string {
        if (isParent) {
            if (path.startsWith("/parent/approvals")) return "approvals";
            if (path.startsWith("/parent/gigs"))      return "gigs";
            if (path.startsWith("/parent"))           return "parent";
            if (path.startsWith("/budget"))           return "budget";
            return "more";
        }
        if (path.startsWith("/dashboard")) return "tasks";
        if (path.startsWith("/gigs"))      return "gigs";
        if (path.startsWith("/rewards"))   return "rewards";
        if (path.startsWith("/chat"))      return "chat";
        return "more";
    }

    function syncNav() {
        const nav = document.querySelector<HTMLElement>("nav[data-role]");
        const isParent = nav?.dataset.role === "parent";
        const key = urlToKey(window.location.pathname, !!isParent);
        document.querySelectorAll<HTMLElement>("[data-nav-key]").forEach((el) => {
            const isActive = el.dataset.navKey === key;
            ACTIVE.split(" ").forEach((c) => el.classList.toggle(c, isActive));
            IDLE.split(" ").forEach((c) => el.classList.toggle(c, !isActive));
        });
    }

    document.addEventListener("astro:page-load", syncNav);
</script>

<style>
    .safe-area-bottom {
        padding-bottom: env(safe-area-inset-bottom, 0px);
    }
    /* Exactly 5 items now — labels stay visible at every width (no overflow,
       no icon-only fallback needed). */
    .nav-row {
        max-width: 30rem;
    }
    .bottom-nav-spacer {
        display: block;
        width: 100%;
        height: calc(64px + 24px + env(safe-area-inset-bottom, 0px));
        flex-shrink: 0;
        pointer-events: none;
    }
</style>
