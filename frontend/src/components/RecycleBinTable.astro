---
/**
 * RecycleBinTable Component
 * Displays deleted items (transactions, accounts, categories) with restore/delete options
 * 
 * Props:
 * - session: Session - authenticated user session with token
 */

interface DeletedItem {
  id: string;
  type: "transaction" | "account" | "category" | "category_group";
  name: string;
  deleted_at: string;
  deleted_by_id: string;
  details?: string;
}

interface Session {
  token: string;
}

interface Props {
  session: Session;
}

const { session } = Astro.props;
---

<div class="bg-white rounded-lg shadow">
  <!-- Table Header -->
  <div class="px-6 py-4 border-b border-gray-200">
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-semibold text-gray-900">Deleted Items</h2>
      <div class="flex gap-2">
        <button
          id="filter-btn"
          class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition"
        >
          Filter
        </button>
        <button
          id="empty-btn"
          class="px-4 py-2 text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded-lg transition"
        >
          Empty Bin
        </button>
      </div>
    </div>
  </div>

  <!-- Table Body -->
  <div id="recycle-bin-content" class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Item
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Type
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Deleted Date
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Days Remaining
          </th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
            Actions
          </th>
        </tr>
      </thead>
      <tbody id="items-tbody" class="bg-white divide-y divide-gray-200">
        <!-- Loading state -->
        <tr>
          <td colspan="5" class="px-6 py-8 text-center">
            <div class="flex justify-center">
              <div class="animate-spin h-6 w-6 text-primary-600"></div>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="hidden px-6 py-12 text-center">
    <svg
      class="mx-auto h-12 w-12 text-gray-400"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"
      />
    </svg>
    <h3 class="mt-4 text-lg font-medium text-gray-900">No deleted items</h3>
    <p class="mt-2 text-gray-600">Your recycle bin is empty</p>
  </div>
</div>

<!-- Restore Confirmation Modal -->
<div
  id="restore-modal"
  class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center"
>
  <div class="bg-white rounded-lg shadow-lg p-6 max-w-sm w-full mx-4">
    <h3 class="text-lg font-semibold text-gray-900 mb-2">Restore Item?</h3>
    <p class="text-gray-600 mb-6">
      Are you sure you want to restore <span id="restore-item-name" class="font-semibold"></span>?
    </p>
    <div class="flex gap-3 justify-end">
      <button
        id="restore-cancel-btn"
        class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition"
      >
        Cancel
      </button>
      <button
        id="restore-confirm-btn"
        class="px-4 py-2 text-white bg-green-600 hover:bg-green-700 rounded-lg transition"
      >
        Restore
      </button>
    </div>
  </div>
</div>

<!-- Permanent Delete Confirmation Modal -->
<div
  id="delete-modal"
  class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center"
>
  <div class="bg-white rounded-lg shadow-lg p-6 max-w-sm w-full mx-4">
    <h3 class="text-lg font-semibold text-gray-900 mb-2">Permanently Delete?</h3>
    <p class="text-gray-600 mb-6">
      Permanently delete <span id="delete-item-name" class="font-semibold"></span>? This cannot be undone.
    </p>
    <div class="flex gap-3 justify-end">
      <button
        id="delete-cancel-btn"
        class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition"
      >
        Cancel
      </button>
      <button
        id="delete-confirm-btn"
        class="px-4 py-2 text-white bg-red-600 hover:bg-red-700 rounded-lg transition"
      >
        Delete
      </button>
    </div>
  </div>
</div>

<!-- Empty Bin Confirmation Modal -->
<div
  id="empty-bin-modal"
  class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center"
>
  <div class="bg-white rounded-lg shadow-lg p-6 max-w-sm w-full mx-4">
    <h3 class="text-lg font-semibold text-gray-900 mb-2">Empty Recycle Bin?</h3>
    <p class="text-gray-600 mb-2">
      Permanently delete all items that have been in the recycle bin for more than 30 days?
    </p>
    <p class="text-sm text-gray-500 mb-6">
      Newer items will be kept and can still be restored.
    </p>
    <div class="flex gap-3 justify-end">
      <button
        id="empty-cancel-btn"
        class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition"
      >
        Cancel
      </button>
      <button
        id="empty-confirm-btn"
        class="px-4 py-2 text-white bg-red-600 hover:bg-red-700 rounded-lg transition"
      >
        Empty Bin
      </button>
    </div>
  </div>
</div>

<script define:vars={{ token: session.token }}>
  document.addEventListener('astro:page-load', () => {
  let allItems = [];
  let currentFilter = null;
  let pendingAction = null;

  const tbody = document.getElementById("items-tbody");
  const emptyState = document.getElementById("empty-state");
  const restoreModal = document.getElementById("restore-modal");
  const deleteModal = document.getElementById("delete-modal");
  const emptyBinModal = document.getElementById("empty-bin-modal");

  // Load deleted items on mount
  async function loadDeletedItems() {
    try {
      const query = currentFilter ? `?item_type=${currentFilter}` : "";
      const response = await fetch(`/api/budget/recycle-bin${query}`, {
        headers: { Authorization: `Bearer ${token}` },
      });

      if (!response.ok) throw new Error("Failed to load deleted items");
      const data = await response.json();
      allItems = data.data || [];
      renderTable();
    } catch (error) {
      console.error("Error loading deleted items:", error);
      tbody.innerHTML = `
        <tr>
          <td colspan="5" class="px-6 py-8 text-center text-red-600">
            Failed to load items
          </td>
        </tr>
      `;
    }
  }

  function renderTable() {
    if (allItems.length === 0) {
      tbody.parentElement.classList.add("hidden");
      emptyState.classList.remove("hidden");
      return;
    }

    tbody.parentElement.classList.remove("hidden");
    emptyState.classList.add("hidden");

    tbody.innerHTML = allItems
      .map((item) => {
        const deletedDate = new Date(item.deleted_at);
        const now = new Date();
        const daysAgo = Math.floor((now - deletedDate) / (1000 * 60 * 60 * 24));
        const daysRemaining = Math.max(0, 30 - daysAgo);

        return `
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 text-sm text-gray-900">${escapeHtml(item.name)}</td>
          <td class="px-6 py-4 text-sm">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
              ${getItemTypeLabel(item.type)}
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600">
            ${deletedDate.toLocaleDateString()} ${deletedDate.toLocaleTimeString()}
          </td>
          <td class="px-6 py-4 text-sm">
            <span class="${daysRemaining <= 5 ? "text-red-600 font-semibold" : "text-gray-600"}">
              ${daysRemaining} days
            </span>
          </td>
          <td class="px-6 py-4 text-right text-sm">
            <button
              class="restore-btn text-green-600 hover:text-green-700 font-medium mr-4"
              data-id="${item.id}"
              data-type="${item.type}"
              data-name="${item.name}"
            >
              Restore
            </button>
            <button
              class="delete-btn text-red-600 hover:text-red-700 font-medium"
              data-id="${item.id}"
              data-type="${item.type}"
              data-name="${item.name}"
            >
              Delete
            </button>
          </td>
        </tr>
      `;
      })
      .join("");

    attachEventListeners();
  }

  function attachEventListeners() {
    document.querySelectorAll(".restore-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const name = e.target.dataset.name;
        document.getElementById("restore-item-name").textContent = name;
        pendingAction = {
          action: "restore",
          id: e.target.dataset.id,
          type: e.target.dataset.type,
          name: name,
        };
        restoreModal.classList.remove("hidden");
      });
    });

    document.querySelectorAll(".delete-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const name = e.target.dataset.name;
        document.getElementById("delete-item-name").textContent = name;
        pendingAction = {
          action: "delete",
          id: e.target.dataset.id,
          type: e.target.dataset.type,
          name: name,
        };
        deleteModal.classList.remove("hidden");
      });
    });
  }

  // Modal handlers
  document.getElementById("restore-cancel-btn").addEventListener("click", () => {
    restoreModal.classList.add("hidden");
    pendingAction = null;
  });

  document.getElementById("restore-confirm-btn").addEventListener("click", async () => {
    if (!pendingAction) return;
    await performAction(pendingAction);
    restoreModal.classList.add("hidden");
  });

  document.getElementById("delete-cancel-btn").addEventListener("click", () => {
    deleteModal.classList.add("hidden");
    pendingAction = null;
  });

  document.getElementById("delete-confirm-btn").addEventListener("click", async () => {
    if (!pendingAction) return;
    await performAction(pendingAction);
    deleteModal.classList.add("hidden");
  });

  document.getElementById("empty-btn").addEventListener("click", () => {
    emptyBinModal.classList.remove("hidden");
  });

  document.getElementById("empty-cancel-btn").addEventListener("click", () => {
    emptyBinModal.classList.add("hidden");
  });

  document.getElementById("empty-confirm-btn").addEventListener("click", async () => {
    try {
      const response = await fetch("/api/budget/recycle-bin", {
        method: "DELETE",
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!response.ok) throw new Error("Failed to empty bin");
      emptyBinModal.classList.add("hidden");
      await loadDeletedItems();
      showNotification("Recycle bin emptied", "success");
    } catch (error) {
      console.error("Error emptying bin:", error);
      showNotification("Failed to empty recycle bin", "error");
    }
  });

  async function performAction(action) {
    try {
      const typeEndpoints = {
        transaction: 'transactions',
        account: 'accounts',
        category: 'categories',
        category_group: 'category-groups',
      };
      
      const endpoint =
        action.action === "restore"
          ? `/api/budget/recycle-bin/${typeEndpoints[action.type]}/${action.id}/restore`
          : `/api/budget/recycle-bin/${typeEndpoints[action.type]}/${action.id}/permanently`;

      const response = await fetch(endpoint, {
        method: "POST",
        headers: { Authorization: `Bearer ${token}` },
      });

      if (!response.ok) throw new Error("Action failed");

      const message =
        action.action === "restore"
          ? `${action.name} restored successfully`
          : `${action.name} permanently deleted`;

      showNotification(message, "success");
      await loadDeletedItems();
    } catch (error) {
      console.error("Error performing action:", error);
      showNotification("Action failed", "error");
    }
    pendingAction = null;
  }

  function getItemTypeLabel(type) {
    const labels = {
      transaction: "Transaction",
      account: "Account",
      category: "Category",
      category_group: "Category Group",
    };
    return labels[type] || type;
  }

  function escapeHtml(text) {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  function showNotification(message, type) {
    const notification = document.createElement("div");
    notification.className = `fixed top-4 right-4 px-4 py-3 rounded-lg text-white ${
      type === "success" ? "bg-green-600" : "bg-red-600"
    } shadow-lg z-40`;
    notification.textContent = message;
    document.body.appendChild(notification);

    setTimeout(() => {
      notification.remove();
    }, 3000);
  }

  // Close modals on backdrop click
  [restoreModal, deleteModal, emptyBinModal].forEach((modal) => {
    if (modal) {
      modal.addEventListener("click", (e) => {
        if (e.target === modal) {
          modal.classList.add("hidden");
          pendingAction = null;
        }
      });
    }
  });

  // Load items on mount
  loadDeletedItems();
  });
</script>
