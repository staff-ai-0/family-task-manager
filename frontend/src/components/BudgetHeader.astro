---
interface Props {
    title: string;
    lang: 'en' | 'es';
}
const { title, lang } = Astro.props;
---

<header class="bg-brand-sky text-brand-ink pt-12 pb-6 px-6 border-b-4 border-brand-ink">
    <div class="flex items-center justify-between mb-6">
        <a href="/dashboard" class="text-brand-ink hover:text-brand-ink-soft transition border-2 border-brand-ink bg-brand-cream rounded-full p-1.5 shadow-[2px_2px_0_var(--color-brand-ink)]">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
        </a>
        <h1 class="font-display text-2xl font-extrabold tracking-tight">{title}</h1>
        <div class="w-9"></div>
    </div>

    <slot />
</header>
