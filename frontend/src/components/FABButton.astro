---
/**
 * Floating Action Button for quick expense entry.
 * Fixed position, bottom-right corner.
 */
---

<button
    id="fab-button"
    aria-label="Register expense"
    class="fixed bottom-20 right-4 md:bottom-8 md:right-8 z-20 w-14 h-14 bg-primary-600 hover:bg-primary-700 active:scale-95 text-white rounded-full shadow-lg flex items-center justify-center transition-all duration-150"
>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
</button>
