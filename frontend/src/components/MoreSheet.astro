---
/**
 * "More" bottom-sheet — houses secondary destinations that don't fit the
 * 5-item BottomNav, plus the language toggle and (confirmed) logout.
 *
 * Opened by the "More" item in BottomNav (button#more-nav-btn). Role-aware:
 * kids get a short list, parents get the full management surface. Several of
 * these pages (meals, shopping, calendar, dm) previously had NO nav entry
 * anywhere — this is their first discoverable home.
 */
import { t } from "../lib/i18n";

interface Props {
    role?: string;
    lang?: string;
    unread?: number;
}
const { role = "child", lang = "en", unread = 0 } = Astro.props;
const es = lang === "es";
const isParent = role === "parent";
const nextLang = es ? "en" : "es";

type Link = { href: string; label: string; icon: string; badge?: number };

// Icon paths (heroicons-style, single <path d>).
const I = {
    bell: "M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9",
    pet: "M4.318 6.318a4.5 4.5 0 016.364 0L12 7.636l1.318-1.318a4.5 4.5 0 116.364 6.364L12 20.364l-7.682-7.682a4.5 4.5 0 010-6.364z",
    meals: "M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z",
    shopping: "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z",
    calendar: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
    chat: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
    dm: "M3 5a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2h-6l-4 4v-4H5a2 2 0 01-2-2V5z",
    profile: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
    members: "M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4zm6 0a4 4 0 10-3-6.65",
    rewards: "M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7",
    consequences: "M12 9v2m0 4h.01M5 19h14a2 2 0 001.84-2.75L13.74 4a2 2 0 00-3.5 0l-7.1 12.25A2 2 0 004.99 19z",
    assignments: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2",
    jarvis: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
    kiosk: "M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h10a2 2 0 012 2v14a2 2 0 01-2 2z",
    settings: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z",
    tasks: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
    payouts: "M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z",
    analytics: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
    help: "M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
};

const inbox: Link = { href: "/notifications", label: es ? "Avisos" : "Inbox", icon: I.bell, badge: unread };

const help: Link = { href: es ? "/ayuda" : "/help", label: es ? "Ayuda" : "Help", icon: I.help };

const kidLinks: Link[] = [
    inbox,
    { href: "/pet", label: es ? "Mascota" : "Pet", icon: I.pet },
    { href: "/meals", label: es ? "Comidas" : "Meals", icon: I.meals },
    { href: "/shopping", label: es ? "Compras" : "Shopping", icon: I.shopping },
    { href: "/calendar", label: es ? "Calendario" : "Calendar", icon: I.calendar },
    { href: "/dm", label: es ? "Mensajes" : "Messages", icon: I.dm },
    { href: "/profile", label: t(lang, "nav_profile") as string, icon: I.profile },
    help,
];

const parentLinks: Link[] = [
    inbox,
    { href: "/parent/tasks", label: es ? "Tareas" : "Tasks", icon: I.tasks },
    { href: "/parent/members", label: es ? "Miembros" : "Members", icon: I.members },
    { href: "/parent/rewards", label: t(lang, "nav_rewards") as string, icon: I.rewards },
    { href: "/parent/consequences", label: es ? "Consecuencias" : "Consequences", icon: I.consequences },
    { href: "/parent/payouts", label: es ? "Pagos" : "Payouts", icon: I.payouts },
    { href: "/parent/assignments", label: es ? "Asignaciones" : "Assignments", icon: I.assignments },
    { href: "/parent/analytics", label: es ? "Análisis" : "Analytics", icon: I.analytics },
    { href: "/parent/jarvis", label: "Jarvis", icon: I.jarvis },
    { href: "/chat", label: "Chat", icon: I.chat },
    { href: "/dm", label: es ? "Mensajes" : "Messages", icon: I.dm },
    { href: "/meals", label: es ? "Comidas" : "Meals", icon: I.meals },
    { href: "/shopping", label: es ? "Compras" : "Shopping", icon: I.shopping },
    { href: "/calendar", label: es ? "Calendario" : "Calendar", icon: I.calendar },
    { href: "/parent/kiosk", label: "Kiosk", icon: I.kiosk },
    { href: "/parent/settings", label: es ? "Ajustes" : "Settings", icon: I.settings },
    { href: "/profile", label: t(lang, "nav_profile") as string, icon: I.profile },
    help,
];

const links = isParent ? parentLinks : kidLinks;
---

<div id="more-backdrop" class="fixed inset-0 bg-black/50 z-[55] hidden opacity-0 transition-opacity duration-300"></div>

<div
    id="more-sheet"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    inert
    aria-label={es ? "Más opciones" : "More options"}
    class="fixed bottom-0 left-0 right-0 z-[60] translate-y-full transition-transform duration-300 ease-out"
>
    <div class="max-w-md mx-auto bg-brand-cream rounded-t-[var(--radius-card)] border-t-2 border-brand-ink shadow-[var(--shadow-stamp)] max-h-[80vh] overflow-y-auto safe-area-bottom">
        <div class="flex justify-center pt-3 pb-1"><div class="w-10 h-1 bg-brand-cream-deep rounded-full"></div></div>
        <div class="flex items-center justify-between px-5 pt-1 pb-3">
            <h2 class="text-lg font-bold text-brand-ink">{es ? "Más" : "More"}</h2>
            <button type="button" id="more-close" class="text-brand-ink-soft hover:text-brand-ink p-2.5 -m-1" aria-label={es ? "Cerrar" : "Close"}>
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>

        <div class="grid grid-cols-3 gap-2 px-4 pb-3">
            {links.map((l) => (
                <a href={l.href} class="relative flex flex-col items-center justify-center gap-1.5 rounded-2xl bg-brand-cream-deep/60 hover:bg-brand-cream-deep p-3 text-center transition-colors">
                    {(l.badge ?? 0) > 0 && (
                        <span class="absolute top-1.5 right-1.5 min-w-[18px] h-[18px] px-1 flex items-center justify-center bg-brand-coral text-white text-[10px] font-bold rounded-full">
                            {l.badge! > 99 ? "99+" : l.badge}
                        </span>
                    )}
                    <svg class="h-6 w-6 text-brand-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={l.icon} /></svg>
                    <span class="text-[11px] font-semibold text-brand-ink leading-tight">{l.label}</span>
                </a>
            ))}
        </div>

        <div class="flex gap-2 px-4 pb-5 pt-2 border-t border-brand-ink/10">
            <form method="POST" action="/api/lang" class="flex-1">
                <input type="hidden" name="lang" value={nextLang} />
                <button type="submit" class="w-full flex items-center justify-center gap-2 py-2.5 rounded-xl bg-brand-cream-deep text-brand-ink font-semibold text-sm hover:bg-brand-cream-deep/80 transition-colors">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" /></svg>
                    {es ? "English" : "Español"}
                </button>
            </form>
            <form method="POST" action="/api/auth/logout" class="flex-1" data-logout-form>
                <input type="hidden" name="action" value="logout" />
                <button type="submit" class="w-full flex items-center justify-center gap-2 py-2.5 rounded-xl border border-red-300 text-red-700 font-semibold text-sm hover:bg-red-50 transition-colors">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                    {t(lang, "nav_logout")}
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener("astro:page-load", () => {
        const backdrop = document.getElementById("more-backdrop");
        const sheet = document.getElementById("more-sheet");
        const openBtn = document.getElementById("more-nav-btn");
        const closeBtn = document.getElementById("more-close");
        if (!backdrop || !sheet || !openBtn) return;

        const open = () => {
            // Remove inert/aria-hidden so the sheet is focusable + announced
            // ONLY while open — otherwise its ~15 off-screen links sit in the
            // tab order and screen readers announce a phantom open modal.
            sheet.removeAttribute("inert");
            sheet.removeAttribute("aria-hidden");
            openBtn.setAttribute("aria-expanded", "true");
            backdrop.classList.remove("hidden");
            requestAnimationFrame(() => {
                backdrop.classList.remove("opacity-0");
                backdrop.classList.add("opacity-100");
                sheet.classList.remove("translate-y-full");
            });
            closeBtn?.focus();
        };
        const close = () => {
            backdrop.classList.remove("opacity-100");
            backdrop.classList.add("opacity-0");
            sheet.classList.add("translate-y-full");
            openBtn.setAttribute("aria-expanded", "false");
            setTimeout(() => {
                backdrop.classList.add("hidden");
                sheet.setAttribute("inert", "");
                sheet.setAttribute("aria-hidden", "true");
            }, 300);
            openBtn.focus();
        };

        openBtn.addEventListener("click", (e) => { e.preventDefault(); open(); });
        closeBtn?.addEventListener("click", close);
        backdrop.addEventListener("click", close);
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && !backdrop.classList.contains("hidden")) close();
        });

        // Trap Tab within the sheet while open (background is not inert).
        sheet.addEventListener("keydown", (e) => {
            if (e.key !== "Tab") return;
            const f = sheet.querySelectorAll<HTMLElement>('a[href], button:not([disabled])');
            if (!f.length) return;
            const first = f[0], last = f[f.length - 1];
            if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
            else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
        });

        // Confirm logout so an accidental tap on a shared tablet doesn't force
        // a full re-login.
        const es = document.documentElement.lang === "es";
        sheet.querySelector<HTMLFormElement>("form[data-logout-form]")?.addEventListener("submit", (e) => {
            if (!window.confirm(es ? "¿Cerrar sesión?" : "Log out?")) e.preventDefault();
        });
    });
</script>
