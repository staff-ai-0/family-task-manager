---
/**
 * ReportSubTabs - Horizontal pill buttons for switching between report views.
 * Used on the unified /budget/reports page.
 */

interface Props {
    active: "spending" | "cashflow" | "networth" | "forecast" | "analysis";
    lang: "en" | "es";
}

const { active, lang } = Astro.props;
const es = lang === "es";

const tabs = [
    { id: "spending" as const, label: es ? "Gastos" : "Spending" },
    { id: "cashflow" as const, label: es ? "Flujo" : "Cashflow" },
    { id: "forecast" as const, label: es ? "Pronóstico" : "Forecast" },
    { id: "networth" as const, label: es ? "Patrimonio" : "Net Worth" },
    { id: "analysis" as const, label: es ? "Plan vs Real" : "Budget vs Actual" },
];
---

<div class="px-4 pt-3 pb-1 overflow-x-auto">
    <div class="flex gap-2 min-w-max">
        {tabs.map(tab => (
            <button
                type="button"
                class={`report-tab px-4 py-1.5 rounded-full text-sm font-semibold whitespace-nowrap transition-colors ${
                    active === tab.id
                        ? "bg-brand-sky-deep text-white"
                        : "bg-brand-cream-deep text-brand-ink-soft hover:bg-brand-cream-deep"
                }`}
                data-tab={tab.id}
            >
                {tab.label}
            </button>
        ))}
    </div>
</div>
