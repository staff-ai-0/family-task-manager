---
/**
 * EditMemberModal Component
 * Modal for editing member details (role, etc.)
 * 
 * Props:
 * - lang: 'en' | 'es' - language code
 */

interface Props {
    lang: 'en' | 'es';
}

const { lang } = Astro.props;
---

<div id="edit-member-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-6">
    <div class="bg-brand-cream rounded-[var(--radius-card)] border-2 border-brand-ink shadow-[var(--shadow-pop)] max-w-md w-full">
        <div class="bg-brand-coral text-brand-ink px-6 py-4 rounded-t-[var(--radius-card)]">
            <div class="flex items-center justify-between">
                <h2 class="text-xl font-bold">
                    {lang === "es" ? "Editar Miembro" : "Edit Member"}
                </h2>
                <button id="edit-member-close-btn" class="text-white hover:text-brand-coral-deep transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
        
        <div class="p-6 space-y-4">
            <!-- Member name display -->
            <div class="bg-brand-cream-deep border border-brand-ink/10 rounded-xl p-4">
                <p class="text-xs text-brand-ink-soft font-semibold mb-1 uppercase tracking-wider">
                    {lang === "es" ? "Miembro" : "Member"}
                </p>
                <p id="edit-member-name" class="text-lg font-bold text-brand-ink">
                    --
                </p>
            </div>

            <!-- Error message -->
            <div id="edit-member-error" class="hidden p-3 rounded-lg bg-red-100 border border-red-200 text-red-700 text-sm"></div>

            <!-- Success message -->
            <div id="edit-member-success" class="hidden p-3 rounded-lg bg-brand-mint/20 border border-brand-mint text-brand-mint-deep text-sm"></div>

            <!-- Edit form -->
            <form id="edit-member-form" class="space-y-4">
                <!-- Role selector -->
                <div>
                    <label for="edit-member-role" class="block text-xs font-semibold text-brand-ink mb-2">
                        {lang === "es" ? "Rol" : "Role"} *
                    </label>
                    <select
                        id="edit-member-role"
                        name="role"
                        required
                        class="w-full px-4 py-2 border border-brand-ink/20 rounded-lg text-sm focus:ring-2 focus:ring-brand-coral focus:border-transparent outline-none transition-all bg-brand-cream"
                    >
                        <option value="child">
                            {lang === "es" ? "Niño (Child)" : "Child"}
                        </option>
                        <option value="teen">
                            {lang === "es" ? "Adolescente (Teen)" : "Teen"}
                        </option>
                        <option value="parent">
                            {lang === "es" ? "Padre/Madre (Parent)" : "Parent"}
                        </option>
                    </select>
                </div>

                <!-- Submit button -->
                <button
                    type="submit"
                    id="edit-member-submit"
                    class="w-full bg-brand-coral text-brand-ink font-bold py-2 rounded-lg transition-all transform hover:scale-105 active:scale-95 flex items-center justify-center gap-2"
                >
                    <span id="edit-member-submit-text">
                        {lang === "es" ? "Guardar cambios" : "Save changes"}
                    </span>
                </button>

                <!-- Cancel button -->
                <button
                    type="button"
                    id="edit-member-cancel"
                    class="w-full bg-brand-cream-deep hover:bg-brand-cream-deep text-brand-ink font-semibold py-2 rounded-lg transition-colors"
                >
                    {lang === "es" ? "Cancelar" : "Cancel"}
                </button>
            </form>
        </div>
    </div>
</div>

<script define:vars={{ lang }}>
    document.addEventListener('astro:page-load', () => {
    const modal = document.getElementById("edit-member-modal");
    const form = document.getElementById("edit-member-form");
    const closeBtn = document.getElementById("edit-member-close-btn");
    const cancelBtn = document.getElementById("edit-member-cancel");
    const errorDiv = document.getElementById("edit-member-error");
    const successDiv = document.getElementById("edit-member-success");
    const submitBtn = document.getElementById("edit-member-submit");
    const submitText = document.getElementById("edit-member-submit-text");
    const memberNameDiv = document.getElementById("edit-member-name");
    const roleSelect = document.getElementById("edit-member-role");

    let currentMemberId = null;

    // Open/Close modal functionality
    window.openEditMemberModal = (memberId, memberName, currentRole) => {
        currentMemberId = memberId;
        memberNameDiv.textContent = memberName;
        roleSelect.value = currentRole;
        errorDiv.classList.add("hidden");
        successDiv.classList.add("hidden");
        modal.classList.remove("hidden");
    };

    window.closeEditMemberModal = () => {
        modal.classList.add("hidden");
        currentMemberId = null;
    };

    closeBtn.addEventListener("click", window.closeEditMemberModal);
    cancelBtn.addEventListener("click", window.closeEditMemberModal);
    modal.addEventListener("click", (e) => {
        if (e.target === modal) window.closeEditMemberModal();
    });

    // Submit form
    form.addEventListener("submit", async (e) => {
        e.preventDefault();

        if (!currentMemberId) return;

        const role = roleSelect.value;

        // Clear messages
        errorDiv.classList.add("hidden");
        successDiv.classList.add("hidden");

        // Submit
        submitBtn.disabled = true;
        submitText.textContent = lang === "es" ? "Guardando..." : "Saving...";

        try {
            const response = await fetch(`/api/users/${currentMemberId}/role`, {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ role })
            });

            const data = await response.json();

            if (response.ok) {
                successDiv.textContent = lang === "es" 
                    ? "Cambios guardados exitosamente" 
                    : "Changes saved successfully";
                successDiv.classList.remove("hidden");
                
                // Close modal after 1.5 seconds
                setTimeout(() => {
                    window.closeEditMemberModal();
                    // Reload page to show updated member
                    window.location.reload();
                }, 1500);
            } else {
                errorDiv.textContent = data.detail || (lang === "es" ? "Error al guardar cambios" : "Error saving changes");
                errorDiv.classList.remove("hidden");
            }
        } catch (error) {
            console.error("Error:", error);
            errorDiv.textContent = lang === "es" ? "Error de conexión. Intenta de nuevo." : "Connection error. Please try again.";
            errorDiv.classList.remove("hidden");
        } finally {
            submitBtn.disabled = false;
            submitText.textContent = lang === "es" ? "Guardar cambios" : "Save changes";
        }
    });
    });
</script>
