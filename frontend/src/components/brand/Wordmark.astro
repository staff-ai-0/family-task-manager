---
/**
 * Wordmark — "Family Task Manager." in Plus Jakarta 800.
 * Uses a real <span> (not an SVG) so it stays selectable + accessible.
 *
 * @prop size     "sm" | "md" | "lg" | "xl"  default "md"
 * @prop stacked  Break onto two lines (default true at md+).
 * @prop tone     "ink" | "cream" — text colour token. Default "ink".
 * @prop class    Extra tailwind classes.
 */
interface Props {
  size?: "sm" | "md" | "lg" | "xl";
  stacked?: boolean;
  tone?: "ink" | "cream";
  class?: string;
}
const { size = "md", stacked = false, tone = "ink", class: className = "" } = Astro.props;

const sizes = {
  sm: "text-lg",
  md: "text-2xl",
  lg: "text-4xl",
  xl: "text-6xl",
};
const toneCls = tone === "ink" ? "text-brand-ink" : "text-brand-cream";
---

<span
  class={`font-display font-extrabold leading-[0.95] tracking-[-0.025em] ${sizes[size]} ${toneCls} ${className}`}
  aria-label="Family Task Manager"
>
  {stacked ? (
    <>
      Family Task<br />Manager<span class="text-brand-coral">.</span>
    </>
  ) : (
    <>Family Task Manager<span class="text-brand-coral">.</span></>
  )}
</span>
