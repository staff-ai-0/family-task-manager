---
import "../styles/global.css";
import { t } from "../lib/i18n";
import ToastContainer from "../components/ToastContainer.astro";
import Head from "../components/meta/Head.astro";
interface Props {
	title?: string;
	description?: string;
	lang?: string;
	theme?: "light" | "dark" | "system";
	uiMode?: "kid" | "teen" | "adult";
	/** SEO: canonical URL override (defaults to the current request URL). */
	canonical?: string;
	/** SEO: social-share image path (defaults to /og.png). */
	ogImage?: string;
	/** SEO: Open Graph type (defaults to "website"). */
	ogType?: string;
	/** SEO: emit noindex,nofollow for utility/thin pages. */
	noindex?: boolean;
	/** SEO: JSON-LD structured-data object(s). */
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
	/** SEO: per-language canonical alternates for hreflang (path or absolute URL). */
	alternates?: { es?: string; en?: string };
}
const lang = Astro.props.lang ?? Astro.cookies.get("lang")?.value ?? "es";
const {
	title = "Family Task Manager",
	description = t(lang, "meta_description") as string,
	theme = "system",
	uiMode,
	canonical,
	ogImage,
	ogType,
	noindex,
	jsonLd,
	alternates,
} = Astro.props;

// Derive UI mode from role cookie if not explicitly passed.
const cookieRole = Astro.cookies.get("ui_role")?.value;
const resolvedUiMode = uiMode
	?? (cookieRole === "teen" ? "teen" : cookieRole === "parent" ? "adult" : "kid");

---

<!doctype html>
<html lang={lang} data-theme={theme === "dark" ? "dark" : undefined}>
	<head>
		<Head
			title={title}
			description={description}
			lang={lang}
			canonical={canonical}
			ogImage={ogImage}
			ogType={ogType}
			noindex={noindex}
			jsonLd={jsonLd}
			alternates={alternates}
		/>
		{theme === "system" && (
			<script is:inline>
				try {
					const m = window.matchMedia("(prefers-color-scheme: dark)");
					if (m.matches) document.documentElement.setAttribute("data-theme", "dark");
					m.addEventListener("change", (e) => {
						document.documentElement.setAttribute("data-theme", e.matches ? "dark" : "light");
					});
				} catch (_) {}
			</script>
		)}
	</head>
<body class="bg-brand-cream text-brand-ink antialiased" data-ui-mode={resolvedUiMode}>
    <ToastContainer />

    <!-- Email verification prompts render per-page via VerifyEmailBanner.astro
         (dashboard) — the old global #verify-banner strip lived here and
         stacked on top of it, so it was removed. -->

    <div class="app-shell">
        <slot />
    </div>
    <slot name="overlays" />

    <script is:inline>
        // ClientRouter removed — dispatch astro:page-load once on initial load.
        // Must fire AFTER deferred/module page scripts have executed and
        // registered their listeners. Hoisted Astro scripts (any <script>
        // with an import) ship as async-fetched `type=module` bundles, so a
        // bare requestAnimationFrame can race ahead of them and the one-shot
        // event gets missed (symptom: buttons whose handlers live in those
        // bundles "do nothing"). DOMContentLoaded is the correct barrier —
        // deferred + module scripts are guaranteed to have run by then.
        (function firePageLoadOnce() {
            var fire = function () {
                document.dispatchEvent(new Event('astro:page-load'));
            };
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', fire, { once: true });
            } else {
                fire();
            }
        })();
    </script>

    <script is:inline>
        // Register the service worker for everyone — offline fallback,
        // asset caching, and notification-click routing live in sw.js.
        // (Previously only EnablePushButton registered it, so the PWA the
        // install banner promotes had no offline support unless the user
        // had tapped "Enable push".)
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register("/sw.js").catch(function () {});
        }
    </script>

    <script is:inline>
(function installBanner() {
    // Skip if already running as installed PWA
    if (window.matchMedia('(display-mode: standalone)').matches || navigator.standalone) return;

    // Check 30-day dismiss TTL
    var dismissed = parseInt(localStorage.getItem('ftm-install-dismissed') || '0', 10);
    if (dismissed && Date.now() - dismissed < 30 * 86400 * 1000) return;

    var lang = (document.cookie.match(/(?:^|;\s*)lang=([^;]+)/) || [])[1] || 'es';
    var isES = lang === 'es';

    function createBanner(type) {
        var div = document.createElement('div');
        div.id = 'install-banner';
        div.setAttribute('style', [
            'position:fixed;bottom:0;left:0;right:0;z-index:9999',
            'padding:12px 16px',
            'background:rgba(255,107,74,0.1)',
            'border-top:1px solid rgba(255,107,74,0.25)',
            'display:flex;align-items:center;gap:12px',
            'font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif',
            'backdrop-filter:blur(8px)',
        ].join(';'));

        if (type === 'ios') {
            div.innerHTML = '<span style="font-size:1.2rem">📱</span>'
                + '<span style="flex:1;font-size:0.875rem;color:#1a1a2e">'
                + (isES ? 'Toca <b>Compartir ↑</b> → &ldquo;Añadir a inicio&rdquo;'
                        : 'Tap <b>Share ↑</b> → &ldquo;Add to Home Screen&rdquo;')
                + '</span>'
                + '<button id="install-banner-close" style="background:none;border:none;font-size:1.4rem;cursor:pointer;color:#888;line-height:1;padding:4px">×</button>';
        } else {
            div.innerHTML = '<span style="font-size:1.2rem">📱</span>'
                + '<span style="flex:1;font-size:0.875rem;color:#1a1a2e">'
                + (isES ? 'Agrega a tu pantalla de inicio' : 'Add to your home screen')
                + '</span>'
                + '<button id="install-banner-add" style="background:#4FB8E6;color:#fff;border:none;border-radius:8px;padding:6px 14px;font-size:0.8rem;font-weight:600;cursor:pointer">'
                + (isES ? 'Agregar' : 'Add')
                + '</button>'
                + '<button id="install-banner-close" style="background:none;border:none;font-size:1.4rem;cursor:pointer;color:#888;line-height:1;padding:4px">×</button>';
        }
        return div;
    }

    function dismiss() {
        localStorage.setItem('ftm-install-dismissed', String(Date.now()));
        var b = document.getElementById('install-banner');
        if (b) b.remove();
        clearTimeout(autoHideTimer);
    }

    var deferredPrompt = null;
    var autoHideTimer = null;
    var bannerShown = false;

    function showBanner(type) {
        if (bannerShown || document.getElementById('install-banner')) return;
        bannerShown = true;
        var banner = createBanner(type);
        document.body.appendChild(banner);

        document.getElementById('install-banner-close').addEventListener('click', dismiss);

        if (type !== 'ios') {
            document.getElementById('install-banner-add').addEventListener('click', function () {
                dismiss();
                if (deferredPrompt) {
                    deferredPrompt.prompt();
                    deferredPrompt.userChoice.then(function () { deferredPrompt = null; });
                }
            });
        }

        autoHideTimer = setTimeout(dismiss, 15000);
    }

    window.addEventListener('beforeinstallprompt', function (e) {
        e.preventDefault();
        deferredPrompt = e;
        setTimeout(function () { showBanner('chrome'); }, 3000);
    });

    // iOS Safari: no beforeinstallprompt — detect and show static tip
    var isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent) && !window.MSStream;
    if (isIOS) {
        setTimeout(function () { showBanner('ios'); }, 3000);
    }
})();
    </script>
</body>
</html>
