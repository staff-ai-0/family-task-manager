---
/**
 * Mark — Family Task Manager primary mark (Family Huddle + Check)
 *
 * @prop size      Pixel size (height = width). Default 64.
 * @prop title     A11y label. Defaults to "Family Task Manager".
 * @prop variant   "huddle" | "heart" | "star". Default "huddle".
 * @prop class     Tailwind classes to merge.
 *
 * <Mark size={96} />
 * <Mark variant="heart" />
 */
interface Props {
  size?: number;
  title?: string;
  variant?: "huddle" | "heart" | "star";
  class?: string;
}
const {
  size = 64,
  title = "Family Task Manager",
  variant = "huddle",
  class: className = "",
} = Astro.props;
---

{variant === "huddle" && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width={size} height={size} class={className} role="img" aria-label={title}>
    <title>{title}</title>
    <path d="M40,8 H216 C233.673,8 248,22.327 248,40 V216 C248,233.673 233.673,248 216,248 H40 C22.327,248 8,233.673 8,216 V40 C8,22.327 22.327,8 40,8 Z" fill="#4FB8E6" stroke="#1F2937" stroke-width="8" stroke-linejoin="round"/>
    <path d="M8,176 C70,160 186,160 248,176 L248,216 C248,233.673 233.673,248 216,248 H40 C22.327,248 8,233.673 8,216 Z" fill="#FFC857" stroke="#1F2937" stroke-width="8" stroke-linejoin="round"/>
    <path d="M40,228 Q40,166 96,166 Q120,166 120,210 L120,250 L36,250 Z" fill="#FFF8F0" stroke="#1F2937" stroke-width="7" stroke-linejoin="round"/>
    <path d="M84,228 Q84,160 132,160 Q172,160 172,212 L172,250 L84,250 Z" fill="#FF8A65" stroke="#1F2937" stroke-width="7" stroke-linejoin="round"/>
    <path d="M148,228 Q148,168 178,168 Q210,168 210,214 L210,250 L148,250 Z" fill="#5DD4A8" stroke="#1F2937" stroke-width="7" stroke-linejoin="round"/>
    <path d="M188,232 Q188,194 212,194 Q236,194 236,224 L236,250 L188,250 Z" fill="#FFF8F0" stroke="#1F2937" stroke-width="7" stroke-linejoin="round"/>
    <circle cx="74" cy="142" r="26" fill="#E8B690" stroke="#1F2937" stroke-width="7"/>
    <circle cx="124" cy="130" r="30" fill="#FBD3B2" stroke="#1F2937" stroke-width="7"/>
    <circle cx="174" cy="146" r="24" fill="#C68A60" stroke="#1F2937" stroke-width="7"/>
    <circle cx="216" cy="166" r="18" fill="#8E5B3D" stroke="#1F2937" stroke-width="7"/>
    <path d="M52,130 Q60,108 78,110 Q98,112 96,134 Q86,124 76,124 Q62,124 52,134 Z" fill="#1F1A17"/>
    <path d="M98,116 Q110,96 130,98 Q152,100 152,124 Q140,114 124,114 Q108,114 98,128 Z" fill="#4E3A2A"/>
    <path d="M154,138 Q160,120 174,122 Q192,124 192,140 Q184,134 176,134 Q164,134 154,144 Z" fill="#1F1A17"/>
    <path d="M202,158 Q208,148 218,150 Q230,152 230,162 Q224,156 218,156 Q210,156 202,164 Z" fill="#4E3A2A"/>
    <circle cx="212" cy="58" r="34" fill="#FFC857" stroke="#1F2937" stroke-width="8"/>
    <path d="M198,60 L210,72 L228,50" fill="none" stroke="#1F2937" stroke-width="9" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
)}

{variant === "heart" && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width={size} height={size} class={className} role="img" aria-label={title}>
    <title>{title}</title>
    <rect x="8" y="8" width="240" height="240" rx="48" fill="#FFF8F0" stroke="#1F2937" stroke-width="8"/>
    <path d="M128,212 C 60,168 28,128 28,88 C 28,58 52,40 78,40 C 100,40 120,52 128,72 C 136,52 156,40 178,40 C 204,40 228,58 228,88 C 228,128 196,168 128,212 Z" fill="#FF8A65" stroke="#1F2937" stroke-width="8" stroke-linejoin="round"/>
    <g stroke="#1F2937" stroke-width="7" stroke-linecap="round">
      <circle cx="70" cy="86" r="10" fill="#FFC857"/>
      <path d="M64,86 L70,92 L78,80" fill="none" stroke-width="5"/>
      <line x1="92" y1="86" x2="176" y2="86"/>
      <circle cx="70" cy="118" r="10" fill="#5DD4A8"/>
      <path d="M64,118 L70,124 L78,112" fill="none" stroke-width="5"/>
      <line x1="92" y1="118" x2="186" y2="118"/>
      <circle cx="70" cy="150" r="10" fill="#4FB8E6"/>
      <path d="M64,150 L70,156 L78,144" fill="none" stroke-width="5"/>
      <line x1="92" y1="150" x2="172" y2="150"/>
    </g>
  </svg>
)}

{variant === "star" && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width={size} height={size} class={className} role="img" aria-label={title}>
    <title>{title}</title>
    <rect x="8" y="8" width="240" height="240" rx="48" fill="#4FB8E6" stroke="#1F2937" stroke-width="8"/>
    <path d="M40,140 L128,60 L216,140 L216,216 C216,222 211,228 204,228 L52,228 C45,228 40,222 40,216 Z" fill="#FF8A65" stroke="#1F2937" stroke-width="8" stroke-linejoin="round"/>
    <path d="M108,228 L108,184 Q108,170 122,170 L134,170 Q148,170 148,184 L148,228 Z" fill="#1F2937"/>
    <path d="M128,90 L142,124 L178,128 L150,152 L158,188 L128,170 L98,188 L106,152 L78,128 L114,124 Z" fill="#FFC857" stroke="#1F2937" stroke-width="8" stroke-linejoin="round"/>
  </svg>
)}
