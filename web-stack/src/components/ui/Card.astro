---
/**
 * Card — the standard cream card with hard ink-drop.
 * @prop tone "cream" | "sky" | "coral" | "mint" | "sun" | "ink"
 * @prop pop  Use the bigger 6px shadow.
 */
interface Props {
  tone?: "cream" | "sky" | "coral" | "mint" | "sun" | "ink";
  pop?: boolean;
  class?: string;
}
const { tone = "cream", pop = false, class: className = "" } = Astro.props;

const tones = {
  cream: "bg-brand-cream text-brand-ink",
  sky:   "bg-brand-sky   text-brand-ink",
  coral: "bg-brand-coral text-brand-ink",
  mint:  "bg-brand-mint  text-brand-ink",
  sun:   "bg-brand-sun   text-brand-ink",
  ink:   "bg-brand-ink   text-brand-cream",
};
---

<div
  class={`border-2 border-brand-ink rounded-[var(--radius-card)] p-6 ${tones[tone]} ${pop ? "shadow-[var(--shadow-pop)]" : "shadow-[var(--shadow-card)]"} ${className}`}
>
  <slot />
</div>
