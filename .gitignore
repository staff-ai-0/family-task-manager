# Environment files
.env
.env.*
.env.production
.env.local
!.env.example
!.env.template
!.env.gcp.example
!.env.onprem.example

# Credentials files
CREDENTIALS.md
service-keys.txt
secrets.json
*.secrets

# Keys & Certificates
*.key
*.pem
*.p12
*.pfx
keys/
vault-keys/
.vault-token

# =============================================================================
# Backups (Keep Local, Don't Commit)
# =============================================================================

*.backup
*.bak
*.sql
*.dump

