# =========================================================================
# GCP DEPLOYMENT — .env template (Family Task Manager)
# =========================================================================
# Copy to .env on the VM:
#   cp .env.gcp.example .env && nano .env
# Never commit .env. Only .env.gcp.example is checked in.
# =========================================================================

# ── Environment ───────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=familyapp
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=familyapp

# ── Application secrets ───────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days — mobile UX, no silent re-auth

# ── Public URLs (Cloudflare Tunnel — staging subdomain) ───────────────────
# Cutover to family.agent-ia.mx + api.family.agent-ia.mx once GCP is green.
PUBLIC_URL=https://gcp-family.agent-ia.mx
PUBLIC_API_URL=https://api-gcp-family.agent-ia.mx
BASE_URL=https://api-gcp-family.agent-ia.mx
ALLOWED_ORIGINS=https://gcp-family.agent-ia.mx,https://api-gcp-family.agent-ia.mx

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────
# Token from Cloudflare Zero Trust → Tunnels → create tunnel → docker connector
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_cloudflare_tunnel_token

# ── LiteLLM (on-prem proxy via Cloudflare) ────────────────────────────────
# Receipt scanner (Claude Vision) + auto-translate route through on-prem.
LITELLM_API_BASE=https://litellm.agent-ia.mx
LITELLM_API_KEY=sk-CHANGE_ME_onprem_master_key
LITELLM_MODEL=claude-haiku

# ── AI provider keys (only used when bypassing LiteLLM) ───────────────────
ANTHROPIC_API_KEY=

# ── Google OAuth ──────────────────────────────────────────────────────────
# Web client ID (server-side verification + Astro Sign-In button).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated list of additional native (iOS/Android) client IDs.
GOOGLE_CLIENT_IDS=
# PUBLIC_* is inlined into the client bundle at frontend build time.
PUBLIC_GOOGLE_CLIENT_ID=

# ── PayPal (subscriptions) ────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live
PAYPAL_WEBHOOK_ID=
PAYPAL_PLAN_ID_PLUS_MONTHLY=
PAYPAL_PLAN_ID_PLUS_ANNUAL=
PAYPAL_PLAN_ID_PRO_MONTHLY=
PAYPAL_PLAN_ID_PRO_ANNUAL=

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@family.agent-ia.mx
EMAIL_FROM_NAME=Family Task Manager

# ── SMTP (fallback) ───────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Vault (disabled on GCP) ───────────────────────────────────────────────
VAULT_ENABLED=false
VAULT_ADDR=
VAULT_TOKEN=
